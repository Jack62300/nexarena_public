{% set _route = app.request.get('_route') %}

{# ============================================ #}
{#  HEADER                                      #}
{# ============================================ #}
<header>
    <div id="sticky-header" class="tg-header__area transparent-header">
        <div class="container custom-container">
            <div class="row">
                <div class="col-12">
                    <div class="mobile-nav-toggler"><i class="fas fa-bars"></i></div>
                    <div class="tgmenu__wrap">
                        <nav class="tgmenu__nav">

                            {# ── Logo ── #}
                            <div class="logo nx-logo">
                                <a href="{{ path('app_home') }}">
                                    <img src="{{ asset('assets/img/logo/logo-h.svg') }}" alt="{{ setting('site_name', 'Nexarena') }}">
                                </a>
                            </div>

                            {# ── Navigation ── #}
                            <div class="tgmenu__navbar-wrap tgmenu__main-menu d-none d-xl-flex">
                                <ul class="navigation">
                                    <li class="{{ _route == 'app_home' ? 'active' : '' }}">
                                        <a href="{{ path('app_home') }}">Accueil</a>
                                    </li>
                                    <li class="{{ _route starts with 'articles_' ? 'active' : '' }}">
                                        <a href="{{ path('articles_list') }}">Actualites</a>
                                    </li>
                                    <li class="{{ _route starts with 'plugins_' ? 'active' : '' }}">
                                        <a href="{{ path('plugins_index') }}">Plugins</a>
                                    </li>
                                    <li class="{{ _route starts with 'recruitment_' ? 'active' : '' }}">
                                        <a href="{{ path('recruitment_index') }}">Recrutement</a>
                                    </li>
                                </ul>
                            </div>

                            {# ── ACTIONS ── #}
                            <div class="tgmenu__action d-none d-md-block">
                                <ul class="list-wrap">
                                    <li class="search">
                                        <a href="javascript:void(0)"><i class="flaticon-loupe"></i></a>
                                    </li>

                                    {% if app.user %}
                                        <li class="header-btn">
                                            <a href="{{ path('user_servers_new') }}" class="tg-border-btn">
                                                <svg preserveAspectRatio="none" viewBox="0 0 157 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M131.75 2L155.75 25L131.75 47L148.75 24L131.75 2Z" fill="currentColor"/>
                                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M25 1L1 24.5111L25 47L8 23.4889L25 1Z" fill="currentColor"/>
                                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M24.75 1L0.75 25L23.75 47H131.75L155.75 25L131.75 1H24.75Z" stroke="currentColor" stroke-width="1.5"/>
                                                </svg>
                                                <i class="fas fa-plus"></i> Ajouter
                                            </a>
                                        </li>

                                        {% include 'includes/_notifications.html.twig' %}

                                        <li class="nx-profile" id="nxProfileWrap">
                                            <a href="javascript:void(0)" class="nx-profile__toggle" id="nxProfileToggle">
                                                <span class="nx-profile__avatar">
                                                    {% if app.user.avatar starts with 'http' %}
                                                        <img src="{{ app.user.avatar }}" alt="">
                                                    {% elseif app.user.avatar %}
                                                        <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="">
                                                    {% else %}
                                                        <i class="fas fa-user"></i>
                                                    {% endif %}
                                                </span>
                                                <span class="nx-profile__name d-none d-lg-inline">{{ app.user.username }}</span>
                                                <i class="fas fa-angle-down nx-profile__arrow"></i>
                                            </a>
                                            <div class="nx-dropdown" id="nxProfileDropdown">
                                                <div class="nx-dropdown__header">
                                                    <span class="nx-dropdown__avatar">
                                                        {% if app.user.avatar starts with 'http' %}
                                                            <img src="{{ app.user.avatar }}" alt="">
                                                        {% elseif app.user.avatar %}
                                                            <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="">
                                                        {% else %}
                                                            <i class="fas fa-user"></i>
                                                        {% endif %}
                                                    </span>
                                                    <div>
                                                        <span class="nx-dropdown__name">{{ app.user.username }}</span>
                                                        <span class="nx-dropdown__role">
                                                            {% if is_granted('ROLE_FONDATEUR') %}Fondateur
                                                            {% elseif is_granted('ROLE_DEVELOPPEUR') %}Developpeur
                                                            {% elseif is_granted('ROLE_RESPONSABLE') %}Responsable
                                                            {% elseif is_granted('ROLE_MANAGER') %}Manager
                                                            {% elseif is_granted('ROLE_EDITEUR') %}Editeur
                                                            {% else %}Membre{% endif %}
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="nx-dropdown__divider"></div>
                                                <a href="{{ path('user_profile') }}" class="nx-dropdown__item">
                                                    <i class="fas fa-user-circle"></i> Mon profil
                                                </a>
                                                <a href="{{ path('user_servers_list') }}" class="nx-dropdown__item">
                                                    <i class="fas fa-server"></i> Mes serveurs
                                                </a>
                                                <a href="{{ path('user_recruitment_list') }}" class="nx-dropdown__item">
                                                    <i class="fas fa-bullhorn"></i> Mes recrutements
                                                </a>
                                                <a href="{{ path('applicant_list') }}" class="nx-dropdown__item">
                                                    <i class="fas fa-file-alt"></i> Mes candidatures
                                                </a>
                                                {% if is_granted('ROLE_EDITEUR') %}
                                                    <div class="nx-dropdown__divider"></div>
                                                    <a href="{{ path('admin_dashboard') }}" class="nx-dropdown__item nx-dropdown__item--admin">
                                                        <i class="fas fa-shield-alt"></i> Administration
                                                    </a>
                                                {% endif %}
                                                <div class="nx-dropdown__divider"></div>
                                                <a href="{{ path('app_logout') }}" class="nx-dropdown__item nx-dropdown__item--danger">
                                                    <i class="fas fa-sign-out-alt"></i> Deconnexion
                                                </a>
                                            </div>
                                        </li>

                                    {% else %}
                                        <li class="header-btn">
                                            <a href="{{ path('app_login') }}" class="tg-border-btn">
                                                <svg preserveAspectRatio="none" viewBox="0 0 157 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M131.75 2L155.75 25L131.75 47L148.75 24L131.75 2Z" fill="currentColor"/>
                                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M25 1L1 24.5111L25 47L8 23.4889L25 1Z" fill="currentColor"/>
                                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M24.75 1L0.75 25L23.75 47H131.75L155.75 25L131.75 1H24.75Z" stroke="currentColor" stroke-width="1.5"/>
                                                </svg>
                                                <i class="flaticon-edit"></i> Connexion
                                            </a>
                                        </li>
                                    {% endif %}

                                    <li class="side-toggle-icon">
                                        <span></span>
                                        <span></span>
                                        <span></span>
                                    </li>
                                </ul>
                            </div>

                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ============================================ #}
    {#  MOBILE MENU                                 #}
    {# ============================================ #}
    <div class="tgmobile__menu">
        <nav class="tgmobile__menu-box">
            <div class="close-btn"><i class="flaticon-swords-in-cross-arrangement"></i></div>
            <div class="nav-logo nx-logo nx-logo--mobile">
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('assets/img/logo/logo-h.svg') }}" alt="{{ setting('site_name', 'Nexarena') }}">
                </a>
            </div>
            <div class="tgmobile__search">
                <form action="#">
                    <input type="text" placeholder="Rechercher un serveur...">
                    <button><i class="flaticon-loupe"></i></button>
                </form>
            </div>
            <div class="tgmobile__menu-outer">
                {# Auto-populated by JS from .navigation #}
            </div>

            {# Mobile User Section #}
            <div class="nx-mobile-user">
                {% if app.user %}
                    <div class="nx-mobile-user__header">
                        <span class="nx-mobile-user__avatar">
                            {% if app.user.avatar starts with 'http' %}
                                <img src="{{ app.user.avatar }}" alt="">
                            {% elseif app.user.avatar %}
                                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="">
                            {% else %}
                                <i class="fas fa-user"></i>
                            {% endif %}
                        </span>
                        <div>
                            <span class="nx-mobile-user__name">{{ app.user.username }}</span>
                            <span class="nx-mobile-user__role">
                                {% if is_granted('ROLE_FONDATEUR') %}Fondateur
                                {% elseif is_granted('ROLE_DEVELOPPEUR') %}Developpeur
                                {% elseif is_granted('ROLE_RESPONSABLE') %}Responsable
                                {% elseif is_granted('ROLE_MANAGER') %}Manager
                                {% elseif is_granted('ROLE_EDITEUR') %}Editeur
                                {% else %}Membre{% endif %}
                            </span>
                        </div>
                    </div>
                    <div class="nx-mobile-user__links">
                        <a href="{{ path('user_servers_new') }}"><i class="fas fa-plus-circle"></i> Ajouter un serveur</a>
                        <a href="{{ path('user_servers_list') }}"><i class="fas fa-server"></i> Mes serveurs</a>
                        <a href="{{ path('user_recruitment_list') }}"><i class="fas fa-bullhorn"></i> Mes recrutements</a>
                        <a href="{{ path('applicant_list') }}"><i class="fas fa-file-alt"></i> Mes candidatures</a>
                        <a href="{{ path('user_profile') }}"><i class="fas fa-user-circle"></i> Mon profil</a>
                        {% if is_granted('ROLE_EDITEUR') %}
                            <a href="{{ path('admin_dashboard') }}" class="nx-mobile-user__admin"><i class="fas fa-shield-alt"></i> Administration</a>
                        {% endif %}
                        <a href="{{ path('app_logout') }}" class="nx-mobile-user__logout"><i class="fas fa-sign-out-alt"></i> Deconnexion</a>
                    </div>
                {% else %}
                    <div class="nx-mobile-user__links">
                        <a href="{{ path('app_login') }}" class="nx-mobile-user__cta"><i class="fas fa-sign-in-alt"></i> Connexion</a>
                        <a href="{{ path('app_register') }}"><i class="fas fa-user-plus"></i> Inscription</a>
                    </div>
                {% endif %}
            </div>

            <div class="social-links">
                <ul class="list-wrap">
                    <li><a href="{{ setting('social_discord', '#') }}"><i class="fab fa-discord"></i></a></li>
                    <li><a href="{{ setting('social_twitter', '#') }}"><i class="fab fa-twitter"></i></a></li>
                    <li><a href="{{ setting('social_instagram', '#') }}"><i class="fab fa-instagram"></i></a></li>
                    <li><a href="{{ setting('social_youtube', '#') }}"><i class="fab fa-youtube"></i></a></li>
                </ul>
            </div>
        </nav>
    </div>
    <div class="tgmobile__menu-backdrop"></div>

    {# ============================================ #}
    {#  SEARCH POPUP                                #}
    {# ============================================ #}
    <div class="search__popup-wrap">
        <div class="search__layer"></div>
        <div class="search__close">
            <span><i class="flaticon-swords-in-cross-arrangement"></i></span>
        </div>
        <div class="search__wrap text-center">
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <h2 class="title">... <span>Rechercher</span> ...</h2>
                        <div class="search__form">
                            <form action="#">
                                <input type="text" name="search" placeholder="Tapez vos mots-cles ici..." required>
                                <button class="search-btn"><i class="flaticon-loupe"></i></button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ============================================ #}
    {#  OFF-CANVAS SIDE PANEL                       #}
    {# ============================================ #}
    <div class="offCanvas__wrap">
        <div class="offCanvas__body">
            <div class="offCanvas__top">
                <div class="offCanvas__logo logo nx-logo nx-logo--offcanvas">
                    <a href="{{ path('app_home') }}">
                        <img src="{{ asset('assets/img/logo/logo-h.svg') }}" alt="{{ setting('site_name', 'Nexarena') }}">
                    </a>
                </div>
                <div class="offCanvas__toggle">
                    <i class="flaticon-swords-in-cross-arrangement"></i>
                </div>
            </div>
            <div class="offCanvas__content">
                <h2 class="title">Trouvez les meilleurs <span>serveurs de jeux</span></h2>
                <p class="nx-offcanvas-desc">{{ setting('site_description', 'La plateforme de reference pour trouver et voter pour les meilleurs serveurs de jeux.') }}</p>

                <div class="offCanvas__contact">
                    <h4 class="small-title">LIENS RAPIDES</h4>
                    <ul class="offCanvas__contact-list list-wrap nx-quick-links">
                        <li><a href="{{ path('app_home') }}"><i class="fas fa-home"></i> Accueil</a></li>
                        <li><a href="{{ path('articles_list') }}"><i class="fas fa-newspaper"></i> Actualites</a></li>
                        {% if app.user %}
                            <li><a href="{{ path('user_servers_new') }}"><i class="fas fa-plus-circle"></i> Ajouter un serveur</a></li>
                            <li><a href="{{ path('user_servers_list') }}"><i class="fas fa-server"></i> Mes serveurs</a></li>
                            <li><a href="{{ path('user_recruitment_list') }}"><i class="fas fa-bullhorn"></i> Mes recrutements</a></li>
                            <li><a href="{{ path('applicant_list') }}"><i class="fas fa-file-alt"></i> Mes candidatures</a></li>
                        {% else %}
                            <li><a href="{{ path('app_login') }}"><i class="fas fa-sign-in-alt"></i> Connexion</a></li>
                            <li><a href="{{ path('app_register') }}"><i class="fas fa-user-plus"></i> Inscription</a></li>
                        {% endif %}
                    </ul>
                </div>

                <div class="offCanvas__contact">
                    <h4 class="small-title">CONTACT</h4>
                    <ul class="offCanvas__contact-list list-wrap">
                        <li><a href="mailto:{{ setting('contact_email', 'contact@nexarena.fr') }}">{{ setting('contact_email', 'contact@nexarena.fr') }}</a></li>
                    </ul>
                </div>

                <ul class="offCanvas__social list-wrap">
                    <li><a href="{{ setting('social_discord', '#') }}"><i class="fab fa-discord"></i></a></li>
                    <li><a href="{{ setting('social_twitter', '#') }}"><i class="fab fa-twitter"></i></a></li>
                    <li><a href="{{ setting('social_instagram', '#') }}"><i class="fab fa-instagram"></i></a></li>
                    <li><a href="{{ setting('social_youtube', '#') }}"><i class="fab fa-youtube"></i></a></li>
                </ul>
            </div>
            <div class="offCanvas__copyright">
                <p>Copyright &copy; {{ "now"|date("Y") }} - <span>{{ setting('site_name', 'Nexarena') }}</span></p>
            </div>
        </div>
    </div>
    <div class="offCanvas__overlay"></div>

</header>

{# ============================================ #}
{#  NAVBAR CUSTOM CSS                           #}
{# ============================================ #}
<link rel="stylesheet" href="{{ asset('assets/css/components/header.css') }}">

{# ============================================ #}
{#  NAVBAR JS                                   #}
{# ============================================ #}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var wrap = document.getElementById('nxProfileWrap');
    var toggle = document.getElementById('nxProfileToggle');
    var dropdown = document.getElementById('nxProfileDropdown');

    if (toggle && dropdown && wrap) {
        toggle.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            dropdown.classList.toggle('open');
            wrap.classList.toggle('open');
        });

        document.addEventListener('click', function(e) {
            if (!wrap.contains(e.target)) {
                dropdown.classList.remove('open');
                wrap.classList.remove('open');
            }
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                dropdown.classList.remove('open');
                wrap.classList.remove('open');
            }
        });
    }
});
</script>
