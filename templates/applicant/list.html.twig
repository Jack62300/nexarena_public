{% extends 'base.html.twig' %}

{% block title %}Mes candidatures - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<style>
    /* ===== PAGE ===== */
    .mal-page {
        min-height: 100vh;
        position: relative;
        padding: 120px 0 100px;
    }
    .mal-page::before {
        content: '';
        position: fixed; inset: 0;
        background:
            radial-gradient(ellipse at 20% 0%, rgba(69,248,130,0.06) 0%, transparent 50%),
            radial-gradient(ellipse at 80% 100%, rgba(59,130,246,0.04) 0%, transparent 50%);
        pointer-events: none; z-index: 0;
    }
    .mal-scanline {
        position: fixed; top: 0; left: 0; right: 0; height: 100%;
        background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.008) 2px, rgba(255,255,255,0.008) 4px);
        pointer-events: none; z-index: 0;
    }

    /* ===== HEADER ===== */
    .mal-header {
        position: relative; z-index: 1;
        display: flex; align-items: center; gap: 20px;
        margin-bottom: 35px;
    }
    .mal-header__icon {
        width: 60px; height: 60px;
        border-radius: 16px;
        background: linear-gradient(135deg, rgba(69,248,130,0.12), rgba(69,248,130,0.02));
        border: 1px solid rgba(69,248,130,0.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 24px; color: #45f882;
        flex-shrink: 0;
    }
    .mal-header__text h1 {
        font-size: 28px; font-weight: 900;
        text-transform: uppercase; letter-spacing: 2px;
        margin-bottom: 4px;
    }
    .mal-header__text p {
        font-size: 14px; color: rgba(255,255,255,0.4);
    }

    /* ===== CARDS GRID ===== */
    .mal-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px;
        position: relative; z-index: 1;
    }
    @media (max-width: 767px) { .mal-grid { grid-template-columns: 1fr; } }

    .mal-card {
        background: rgba(15,25,35,0.7);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 16px;
        padding: 24px;
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        text-decoration: none !important; color: inherit !important;
        display: flex; flex-direction: column;
    }
    .mal-card::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 2px;
        transition: background 0.3s;
    }
    .mal-card--pending::before { background: linear-gradient(90deg, #ffc107, rgba(255,193,7,0.1)); }
    .mal-card--accepted::before { background: linear-gradient(90deg, #45f882, rgba(69,248,130,0.1)); }
    .mal-card--rejected::before { background: linear-gradient(90deg, #dc3545, rgba(220,53,69,0.1)); }

    .mal-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(0,0,0,0.3), 0 0 20px rgba(69,248,130,0.04);
        border-color: rgba(69,248,130,0.1);
    }

    .mal-card__top {
        display: flex; justify-content: space-between; align-items: flex-start;
        margin-bottom: 14px;
    }
    .mal-card__badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 12px; border-radius: 8px;
        font-size: 11px; font-weight: 800;
        text-transform: uppercase; letter-spacing: 0.8px;
    }
    .mal-card__badge--pending {
        background: rgba(255,193,7,0.1);
        color: #ffc107;
        border: 1px solid rgba(255,193,7,0.15);
    }
    .mal-card__badge--accepted {
        background: rgba(69,248,130,0.1);
        color: #45f882;
        border: 1px solid rgba(69,248,130,0.15);
    }
    .mal-card__badge--rejected {
        background: rgba(220,53,69,0.1);
        color: #dc3545;
        border: 1px solid rgba(220,53,69,0.15);
    }
    .mal-card__chat {
        width: 32px; height: 32px;
        border-radius: 8px;
        background: rgba(59,130,246,0.1);
        border: 1px solid rgba(59,130,246,0.15);
        display: flex; align-items: center; justify-content: center;
        color: #3b82f6; font-size: 13px;
    }

    .mal-card__title {
        font-size: 17px; font-weight: 800; color: #fff;
        margin-bottom: 8px; line-height: 1.3;
        transition: color 0.3s;
    }
    .mal-card:hover .mal-card__title { color: #45f882; }
    .mal-card__server {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 12px; color: rgba(255,255,255,0.35);
        margin-bottom: 16px; font-weight: 600;
    }
    .mal-card__server i { color: #45f882; font-size: 8px; }

    .mal-card__footer {
        display: flex; justify-content: space-between; align-items: center;
        padding-top: 14px;
        border-top: 1px solid rgba(255,255,255,0.04);
        margin-top: auto;
    }
    .mal-card__date {
        font-size: 12px; color: rgba(255,255,255,0.25);
    }
    .mal-card__date i { margin-right: 4px; }
    .mal-card__view {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 12px; font-weight: 700; color: #45f882;
        letter-spacing: 0.5px; text-transform: uppercase;
        transition: gap 0.3s;
    }
    .mal-card:hover .mal-card__view { gap: 10px; }

    /* ===== EMPTY ===== */
    .mal-empty {
        text-align: center;
        padding: 80px 20px;
        position: relative; z-index: 1;
    }
    .mal-empty__icon {
        width: 100px; height: 100px;
        border-radius: 50%;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.04);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 36px; color: rgba(255,255,255,0.08);
        margin-bottom: 20px;
    }
    .mal-empty p {
        color: rgba(255,255,255,0.3); font-size: 16px; margin-bottom: 20px;
    }
    .mal-empty__link {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 24px; border-radius: 12px;
        background: rgba(69,248,130,0.1);
        border: 1px solid rgba(69,248,130,0.2);
        color: #45f882; font-weight: 700; font-size: 14px;
        text-decoration: none; transition: all 0.3s;
    }
    .mal-empty__link:hover {
        background: rgba(69,248,130,0.2);
        transform: translateY(-2px);
        color: #45f882;
    }
</style>
{% endblock %}

{% block body %}
<div class="mal-page">
    <div class="mal-scanline"></div>

    <div class="container" style="max-width:1100px;">
        <div class="mal-header">
            <div class="mal-header__icon"><i class="fas fa-file-alt"></i></div>
            <div class="mal-header__text">
                <h1>Mes candidatures</h1>
                <p>{{ applications|length }} candidature{{ applications|length > 1 ? 's' : '' }} soumise{{ applications|length > 1 ? 's' : '' }}</p>
            </div>
        </div>

        {% if applications|length > 0 %}
            <div class="mal-grid">
                {% for app in applications %}
                    <a href="{{ path('applicant_show', {id: app.id}) }}" class="mal-card mal-card--{{ app.status }}">
                        <div class="mal-card__top">
                            {% if app.status == 'accepted' %}
                                <span class="mal-card__badge mal-card__badge--accepted"><i class="fas fa-check-circle"></i> Acceptee</span>
                            {% elseif app.status == 'rejected' %}
                                <span class="mal-card__badge mal-card__badge--rejected"><i class="fas fa-times-circle"></i> Refusee</span>
                            {% else %}
                                <span class="mal-card__badge mal-card__badge--pending"><i class="fas fa-hourglass-half"></i> En attente</span>
                            {% endif %}
                            {% if app.chatEnabled %}
                                <div class="mal-card__chat" title="Chat actif"><i class="fas fa-comments"></i></div>
                            {% endif %}
                        </div>
                        <h3 class="mal-card__title">{{ app.listing.title }}</h3>
                        <div class="mal-card__server">
                            <i class="fas fa-circle"></i> {{ app.listing.server.name }}
                        </div>
                        <div class="mal-card__footer">
                            <span class="mal-card__date"><i class="far fa-clock"></i> {{ app.createdAt|date('d/m/Y H:i') }}</span>
                            <span class="mal-card__view">Voir <i class="fas fa-arrow-right"></i></span>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="mal-empty">
                <div class="mal-empty__icon"><i class="fas fa-inbox"></i></div>
                <p>Vous n'avez pas encore postule a une offre.</p>
                <a href="{{ path('recruitment_index') }}" class="mal-empty__link">
                    <i class="fas fa-search"></i> Explorer les offres
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
