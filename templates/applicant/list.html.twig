{% extends 'base.html.twig' %}

{% block title %}Mes candidatures - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/applicant-list.css') }}">
{% endblock %}

{% block body %}
<div class="mal-page">
    <div class="mal-scanline"></div>

    <div class="container" style="max-width:1100px;">
        <div class="mal-header">
            <div class="mal-header__icon"><i class="fas fa-file-alt"></i></div>
            <div class="mal-header__text">
                <h1>Mes candidatures</h1>
                <p>{{ applications|length }} candidature{{ applications|length > 1 ? 's' : '' }} soumise{{ applications|length > 1 ? 's' : '' }}</p>
            </div>
        </div>

        {% if applications|length > 0 %}
            <div class="mal-grid">
                {% for app in applications %}
                    <a href="{{ path('applicant_show', {id: app.id}) }}" class="mal-card mal-card--{{ app.status }}">
                        <div class="mal-card__top">
                            {% if app.status == 'accepted' %}
                                <span class="mal-card__badge mal-card__badge--accepted"><i class="fas fa-check-circle"></i> Acceptee</span>
                            {% elseif app.status == 'rejected' %}
                                <span class="mal-card__badge mal-card__badge--rejected"><i class="fas fa-times-circle"></i> Refusee</span>
                            {% else %}
                                <span class="mal-card__badge mal-card__badge--pending"><i class="fas fa-hourglass-half"></i> En attente</span>
                            {% endif %}
                            {% if app.chatEnabled %}
                                <div class="mal-card__chat" title="Chat actif"><i class="fas fa-comments"></i></div>
                            {% endif %}
                        </div>
                        <h3 class="mal-card__title">{{ app.listing.title }}</h3>
                        <div class="mal-card__server">
                            <i class="fas fa-circle"></i> {{ app.listing.server.name }}
                        </div>
                        <div class="mal-card__footer">
                            <span class="mal-card__date"><i class="far fa-clock"></i> {{ app.createdAt|time_ago }}</span>
                            <span class="mal-card__view">Voir <i class="fas fa-arrow-right"></i></span>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="mal-empty">
                <div class="mal-empty__icon"><i class="fas fa-inbox"></i></div>
                <p>Vous n'avez pas encore postule a une offre.</p>
                <a href="{{ path('recruitment_index') }}" class="mal-empty__link">
                    <i class="fas fa-search"></i> Explorer les offres
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
