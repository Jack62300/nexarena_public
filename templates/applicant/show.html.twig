{% extends 'base.html.twig' %}

{% block title %}Ma candidature - {{ listing.title }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<style>
    /* ===== PAGE ===== */
    .mas-page {
        min-height: 100vh;
        position: relative;
        padding: 120px 0 100px;
    }
    .mas-page::before {
        content: '';
        position: fixed; inset: 0;
        background:
            radial-gradient(ellipse at 20% 0%, rgba(69,248,130,0.06) 0%, transparent 50%),
            radial-gradient(ellipse at 80% 100%, rgba(59,130,246,0.04) 0%, transparent 50%);
        pointer-events: none; z-index: 0;
    }
    .mas-scanline {
        position: fixed; top: 0; left: 0; right: 0; height: 100%;
        background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.008) 2px, rgba(255,255,255,0.008) 4px);
        pointer-events: none; z-index: 0;
    }

    .mas-back {
        display: inline-flex; align-items: center; gap: 8px;
        color: rgba(255,255,255,0.4); font-size: 13px; margin-bottom: 24px;
        text-decoration: none; transition: all 0.3s; font-weight: 600;
        position: relative; z-index: 1;
    }
    .mas-back:hover { color: #45f882; transform: translateX(-3px); }

    /* ===== STATUS HERO ===== */
    .mas-status-hero {
        position: relative; z-index: 1;
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 24px;
        padding: 32px;
    }
    .mas-status-hero::before {
        content: '';
        position: absolute; inset: 0;
        z-index: -1;
    }
    .mas-status-hero--pending::before { background: linear-gradient(135deg, rgba(255,193,7,0.06), rgba(15,25,35,0.8)); }
    .mas-status-hero--accepted::before { background: linear-gradient(135deg, rgba(69,248,130,0.06), rgba(15,25,35,0.8)); }
    .mas-status-hero--rejected::before { background: linear-gradient(135deg, rgba(220,53,69,0.06), rgba(15,25,35,0.8)); }
    .mas-status-hero {
        background: rgba(15,25,35,0.7);
        border: 1px solid rgba(255,255,255,0.04);
    }
    .mas-status-hero--pending { border-color: rgba(255,193,7,0.1); }
    .mas-status-hero--accepted { border-color: rgba(69,248,130,0.1); }
    .mas-status-hero--rejected { border-color: rgba(220,53,69,0.1); }

    .mas-sh__top {
        display: flex; align-items: center; gap: 16px;
        margin-bottom: 16px; flex-wrap: wrap;
    }
    .mas-sh__icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px;
    }
    .mas-sh__icon--pending { background: rgba(255,193,7,0.1); color: #ffc107; border: 1px solid rgba(255,193,7,0.15); }
    .mas-sh__icon--accepted { background: rgba(69,248,130,0.1); color: #45f882; border: 1px solid rgba(69,248,130,0.15); }
    .mas-sh__icon--rejected { background: rgba(220,53,69,0.1); color: #dc3545; border: 1px solid rgba(220,53,69,0.15); }

    .mas-sh__info h2 {
        font-size: 22px; font-weight: 900; text-transform: uppercase;
        letter-spacing: 1px; margin-bottom: 4px;
    }
    .mas-sh__info p {
        font-size: 13px; color: rgba(255,255,255,0.4);
    }
    .mas-sh__info a { color: #45f882; text-decoration: none; font-weight: 700; }
    .mas-sh__info a:hover { text-decoration: underline; }

    .mas-sh__badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 16px; border-radius: 10px;
        font-size: 13px; font-weight: 800;
        text-transform: uppercase; letter-spacing: 1px;
        margin-left: auto;
    }
    .mas-sh__badge--pending { background: rgba(255,193,7,0.12); color: #ffc107; }
    .mas-sh__badge--accepted { background: rgba(69,248,130,0.12); color: #45f882; }
    .mas-sh__badge--rejected { background: rgba(220,53,69,0.12); color: #dc3545; }

    .mas-sh__comment {
        margin-top: 16px; padding: 16px 20px;
        background: rgba(10,16,24,0.5);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 12px;
    }
    .mas-sh__comment-label {
        font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 1px;
        color: rgba(255,255,255,0.35);
        margin-bottom: 8px;
    }
    .mas-sh__comment-text {
        font-size: 14px; color: rgba(255,255,255,0.75);
        line-height: 1.6; white-space: pre-wrap;
    }

    /* ===== RESPONSES ===== */
    .mas-card {
        position: relative; z-index: 1;
        background: rgba(15,25,35,0.7);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 16px;
        padding: 28px;
        margin-bottom: 24px;
        overflow: hidden;
    }
    .mas-card::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 2px;
        background: linear-gradient(90deg, #45f882, rgba(69,248,130,0.05));
    }
    .mas-card__section {
        display: flex; align-items: center; gap: 10px;
        font-size: 14px; font-weight: 800; color: #45f882;
        text-transform: uppercase; letter-spacing: 1px;
        margin-bottom: 20px; padding-bottom: 14px;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .mas-card__section i { font-size: 16px; }

    .mas-resp {
        margin-bottom: 16px;
        padding: 18px;
        background: rgba(10,16,24,0.4);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 12px;
        transition: border-color 0.3s;
    }
    .mas-resp:hover { border-color: rgba(69,248,130,0.08); }
    .mas-resp:last-child { margin-bottom: 0; }
    .mas-resp__label {
        font-size: 11px; font-weight: 800;
        text-transform: uppercase; letter-spacing: 1px;
        color: rgba(255,255,255,0.35);
        margin-bottom: 8px;
    }
    .mas-resp__value {
        font-size: 14px; color: rgba(255,255,255,0.8);
        line-height: 1.6; white-space: pre-wrap;
    }

    /* ===== CHAT ===== */
    .mas-chat {
        position: relative; z-index: 1;
        background: rgba(15,25,35,0.7);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 24px;
    }
    .mas-chat::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 2px;
        background: linear-gradient(90deg, #3b82f6, rgba(59,130,246,0.05));
    }
    .mas-chat__header {
        padding: 18px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        display: flex; align-items: center; gap: 12px;
    }
    .mas-chat__header-icon {
        width: 36px; height: 36px;
        border-radius: 10px;
        background: rgba(59,130,246,0.1);
        border: 1px solid rgba(59,130,246,0.15);
        display: flex; align-items: center; justify-content: center;
        color: #3b82f6; font-size: 14px;
    }
    .mas-chat__header h3 {
        font-size: 14px; font-weight: 800; color: rgba(255,255,255,0.8);
        text-transform: uppercase; letter-spacing: 1px; margin: 0;
    }
    .mas-chat__messages {
        height: 380px;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }
    .mas-chat__messages::-webkit-scrollbar { width: 4px; }
    .mas-chat__messages::-webkit-scrollbar-track { background: transparent; }
    .mas-chat__messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 2px; }

    .mas-chat__msg {
        max-width: 78%;
        padding: 14px 18px;
        border-radius: 16px;
        font-size: 14px;
        line-height: 1.5;
        word-break: break-word;
        position: relative;
    }
    .mas-chat__msg--mine {
        align-self: flex-end;
        background: linear-gradient(135deg, rgba(69,248,130,0.12), rgba(69,248,130,0.06));
        border: 1px solid rgba(69,248,130,0.1);
        color: #e4e6eb;
        border-bottom-right-radius: 4px;
    }
    .mas-chat__msg--other {
        align-self: flex-start;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.04);
        color: #e4e6eb;
        border-bottom-left-radius: 4px;
    }
    .mas-chat__msg-meta {
        font-size: 11px;
        color: rgba(255,255,255,0.3);
        margin-top: 6px;
        display: flex; align-items: center; gap: 6px;
    }
    .mas-chat__msg-sender { font-weight: 700; color: rgba(255,255,255,0.5); }

    .mas-chat__input {
        display: flex; gap: 12px; padding: 18px 24px;
        border-top: 1px solid rgba(255,255,255,0.04);
        background: rgba(10,16,24,0.3);
    }
    .mas-chat__input input {
        flex: 1;
        background: rgba(10,16,24,0.6);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 12px;
        color: #fff;
        padding: 12px 18px;
        font-size: 14px;
        transition: border-color 0.3s;
    }
    .mas-chat__input input:focus {
        outline: none;
        border-color: rgba(59,130,246,0.4);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.06);
    }
    .mas-chat__input button {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 12px 22px;
        cursor: pointer;
        font-weight: 800;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s;
        white-space: nowrap;
    }
    .mas-chat__input button:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 20px rgba(59,130,246,0.3);
    }
    .mas-chat__input button:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

    .mas-chat__empty {
        text-align: center; padding: 50px 20px;
        color: rgba(255,255,255,0.2); font-size: 14px;
    }
    .mas-chat__empty i {
        font-size: 32px; display: block; margin-bottom: 12px;
        color: rgba(59,130,246,0.15);
    }
</style>
{% endblock %}

{% block body %}
<div class="mas-page">
    <div class="mas-scanline"></div>

    <div class="container" style="max-width:800px;">
        <a href="{{ path('applicant_list') }}" class="mas-back">
            <i class="fas fa-arrow-left"></i> Mes candidatures
        </a>

        {# ===== STATUS HERO ===== #}
        <div class="mas-status-hero mas-status-hero--{{ application.status }}">
            <div class="mas-sh__top">
                {% if application.status == 'accepted' %}
                    <div class="mas-sh__icon mas-sh__icon--accepted"><i class="fas fa-trophy"></i></div>
                {% elseif application.status == 'rejected' %}
                    <div class="mas-sh__icon mas-sh__icon--rejected"><i class="fas fa-times"></i></div>
                {% else %}
                    <div class="mas-sh__icon mas-sh__icon--pending"><i class="fas fa-hourglass-half"></i></div>
                {% endif %}

                <div class="mas-sh__info">
                    <h2>{{ listing.title }}</h2>
                    <p><a href="{{ path('server_show', {slug: listing.server.slug}) }}">{{ listing.server.name }}</a> &middot; Soumise le {{ application.createdAt|date('d/m/Y a H:i') }}</p>
                </div>

                {% if application.status == 'accepted' %}
                    <span class="mas-sh__badge mas-sh__badge--accepted"><i class="fas fa-check-circle"></i> Acceptee</span>
                {% elseif application.status == 'rejected' %}
                    <span class="mas-sh__badge mas-sh__badge--rejected"><i class="fas fa-times-circle"></i> Refusee</span>
                {% else %}
                    <span class="mas-sh__badge mas-sh__badge--pending"><i class="fas fa-clock"></i> En attente</span>
                {% endif %}
            </div>

            {% if application.statusComment %}
                <div class="mas-sh__comment">
                    <div class="mas-sh__comment-label"><i class="fas fa-comment"></i> Commentaire du gestionnaire</div>
                    <div class="mas-sh__comment-text">{{ application.statusComment }}</div>
                </div>
            {% endif %}
        </div>

        {# ===== CHAT ===== #}
        {% if application.chatEnabled %}
            <div class="mas-chat" id="chatPanel">
                <div class="mas-chat__header">
                    <div class="mas-chat__header-icon"><i class="fas fa-comments"></i></div>
                    <h3>Discussion</h3>
                </div>
                <div class="mas-chat__messages" id="chatMessages">
                    <div class="mas-chat__empty" id="chatEmpty">
                        <i class="fas fa-comment-dots"></i>
                        Aucun message pour le moment.
                    </div>
                </div>
                <div class="mas-chat__input">
                    <input type="text" id="chatInput" placeholder="Ecrivez votre message..." maxlength="2000" autocomplete="off">
                    <button onclick="sendMessage()" id="chatSendBtn"><i class="fas fa-paper-plane"></i> Envoyer</button>
                </div>
            </div>
        {% endif %}

        {# ===== RESPONSES ===== #}
        <div class="mas-card">
            <div class="mas-card__section"><i class="fas fa-clipboard-check"></i> Vos reponses</div>

            {% set formFields = listing.formFields %}
            {% for key, value in application.responses %}
                {% set fieldIndex = key %}
                {% set field = formFields[fieldIndex] is defined ? formFields[fieldIndex] : null %}
                <div class="mas-resp">
                    <div class="mas-resp__label">
                        {{ field ? field.label : ('Champ #' ~ key) }}
                    </div>
                    <div class="mas-resp__value">
                        {% if value is iterable %}
                            {{ value|join(', ') }}
                        {% else %}
                            {{ value ?: '-' }}
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

{% if application.chatEnabled %}
<script>
var currentUserId = {{ app.user.id }};
var lastMessageId = 0;
var chatUrl = '{{ path('api_applicant_chat_messages', {appId: application.id}) }}';
var sendUrl = '{{ path('api_applicant_chat_send', {appId: application.id}) }}';

function escapeHtml(text) {
    var d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
}

function renderMessage(msg) {
    var isMine = msg.senderId === currentUserId;
    return '<div class="mas-chat__msg ' + (isMine ? 'mas-chat__msg--mine' : 'mas-chat__msg--other') + '">' +
        '<div>' + escapeHtml(msg.content) + '</div>' +
        '<div class="mas-chat__msg-meta">' +
            '<span class="mas-chat__msg-sender">' + escapeHtml(msg.senderName) + '</span> &middot; ' + escapeHtml(msg.createdAt) +
        '</div>' +
    '</div>';
}

function loadMessages() {
    fetch(chatUrl + '?after=' + lastMessageId, { credentials: 'same-origin' })
        .then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function(messages) {
            if (Array.isArray(messages) && messages.length > 0) {
                var container = document.getElementById('chatMessages');
                var empty = document.getElementById('chatEmpty');
                if (empty) empty.remove();

                messages.forEach(function(msg) {
                    container.insertAdjacentHTML('beforeend', renderMessage(msg));
                    lastMessageId = msg.id;
                });
                container.scrollTop = container.scrollHeight;
            }
        })
        .catch(function(e) { console.error('Chat load error:', e); });
}

function sendMessage() {
    var input = document.getElementById('chatInput');
    var content = input.value.trim();
    if (!content) return;

    var btn = document.getElementById('chatSendBtn');
    btn.disabled = true;

    fetch(sendUrl, {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: content })
    })
    .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
    })
    .then(function(msg) {
        if (msg.id) {
            var container = document.getElementById('chatMessages');
            var empty = document.getElementById('chatEmpty');
            if (empty) empty.remove();

            container.insertAdjacentHTML('beforeend', renderMessage(msg));
            lastMessageId = msg.id;
            container.scrollTop = container.scrollHeight;
            input.value = '';
        }
        btn.disabled = false;
    })
    .catch(function(e) { console.error('Chat send error:', e); btn.disabled = false; });
}

document.getElementById('chatInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); sendMessage(); }
});

loadMessages();
setInterval(loadMessages, 3000);
</script>
{% endif %}
{% endblock %}
