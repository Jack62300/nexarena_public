{% extends 'base.html.twig' %}

{% block title %}{{ title }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block body %}

    {# ===== HEADER ===== #}
    <section class="nx-legal-header">
        <div class="container">
            <nav class="nx-legal-breadcrumb">
                <a href="{{ path('app_home') }}">Accueil</a>
                <i class="fas fa-chevron-right"></i>
                <span>{{ title }}</span>
            </nav>
            <h1 class="nx-legal-title">{{ title }}</h1>
        </div>
    </section>

    {# ===== CONTENT ===== #}
    <section class="nx-legal-body">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-8 col-lg-10">
                    <div class="nx-legal-content">
                        {% if content %}
                            {{ content|raw }}
                        {% else %}
                            <div class="nx-legal-empty">
                                <i class="fas fa-file-alt"></i>
                                <p>Cette page n'a pas encore ete redigee.</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/legal.css') }}">
{% endblock %}
