{% extends 'base.html.twig' %}

{% block title %}Boost — {{ server.name }} · {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/featured-booking.css') }}">
{% endblock %}

{% block body %}
<div class="fb-page">

    {# ===== HERO ===== #}
    <div class="fb-hero">
        <div class="fb-hero__glow"></div>
        <div class="container">
            <div class="fb-hero__inner">
                <div class="fb-hero__left">
                    <div class="fb-hero__badge"><i class="fas fa-crown"></i> Sélection premium</div>
                    <h1 class="fb-hero__title">{{ server.name }}</h1>
                    <p class="fb-hero__sub">Réservez une position en vitrine pour booster votre visibilité</p>
                </div>
                <div class="fb-hero__right">
                    <div class="fb-balance">
                        <div class="fb-balance__icon"><i class="fas fa-bolt"></i></div>
                        <div>
                            <div class="fb-balance__label">NexBoost du serveur</div>
                            <div class="fb-balance__val">{{ user_boost_balance }}</div>
                        </div>
                        <a href="{{ path('user_servers_manage', {id: server.id}) }}" class="fb-balance__add">
                            <i class="fas fa-plus"></i> Déposer
                        </a>
                    </div>
                    <a href="{{ path('user_servers_manage', {id: server.id}) }}" class="fb-back-btn">
                        <i class="fas fa-arrow-left"></i> Gestion du serveur
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container">

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="fb-alert fb-alert--{{ type }}">
                    <i class="fas fa-{{ type == 'success' ? 'check-circle' : 'exclamation-triangle' }}"></i>
                    <span>{{ message }}</span>
                    <button type="button" onclick="this.parentElement.remove()">&times;</button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="fb-layout">

            {# ===== LEFT — CONFIGURATION ===== #}
            <div class="fb-config">

                {# Scope tabs (only if game scope available) #}
                {% if has_game_scope %}
                <div class="fb-card">
                    <div class="fb-card__label"><i class="fas fa-bullseye"></i> Emplacement</div>
                    <div class="fb-scope-tabs">
                        <button type="button" class="fb-scope-tab fb-scope-tab--active" data-scope="homepage" onclick="selectScope('homepage', this)">
                            <i class="fas fa-home"></i> Page d'accueil
                        </button>
                        <button type="button" class="fb-scope-tab" data-scope="game" onclick="selectScope('game', this)">
                            <i class="fas fa-gamepad"></i> {{ server_gc_name }}
                        </button>
                    </div>
                </div>
                {% endif %}

                {# Position picker #}
                <div class="fb-card">
                    <div class="fb-card__label"><i class="fas fa-trophy"></i> Position</div>
                    <div class="fb-positions">
                        {% for pos in 1..5 %}
                        <button type="button" class="fb-pos{% if pos == 1 %} fb-pos--active{% endif %}" data-pos="{{ pos }}" onclick="selectPosition({{ pos }}, this)">
                            <div class="fb-pos__top">
                                {% if pos == 1 %}<i class="fas fa-crown fb-pos__crown"></i>{% endif %}
                                <span class="fb-pos__num">#{{ pos }}</span>
                            </div>
                            <div class="fb-pos__cost">
                                <span id="posCost{{ pos }}">{{ homepage_costs[pos] }}</span>
                                <i class="fas fa-bolt"></i>
                            </div>
                            <div class="fb-pos__unit">/ 12h</div>
                        </button>
                        {% endfor %}
                    </div>
                </div>

                {# Date strip (compact, 7 days at a time) #}
                <div class="fb-card">
                    <div class="fb-card__label-row">
                        <div class="fb-card__label"><i class="fas fa-calendar-day"></i> Date</div>
                        <span class="fb-strip-range" id="fbStripRange"></span>
                    </div>
                    <div class="fb-datepicker">
                        <button type="button" class="fb-datepicker__nav" onclick="navigateDays(-7)" id="navPrev"><i class="fas fa-chevron-left"></i></button>
                        <div class="fb-datepicker__strip" id="dayStrip"></div>
                        <button type="button" class="fb-datepicker__nav" onclick="navigateDays(7)"><i class="fas fa-chevron-right"></i></button>
                    </div>
                    <div class="fb-datepicker__legend">
                        <span><span class="fb-dot fb-dot--free"></span> Disponible</span>
                        <span><span class="fb-dot fb-dot--mine"></span> Mon serveur</span>
                        <span><span class="fb-dot fb-dot--taken"></span> Pris</span>
                        <span><span class="fb-dot fb-dot--past"></span> Passé</span>
                    </div>
                </div>

                {# Slot + Period — shown after date selected #}
                <div class="fb-card fb-options" id="fbOptions" style="display:none;">
                    <div class="fb-options__inner">
                        <div class="fb-options__group">
                            <div class="fb-card__label"><i class="fas fa-clock"></i> Créneau de départ</div>
                            <div class="fb-slot-btns" id="slotBtnsWrap">
                                <button type="button" class="fb-slot-btn fb-slot-btn--active" data-slot="00:00" onclick="selectSlot('00:00', this)">
                                    <i class="fas fa-moon"></i>
                                    <div><strong>Nuit</strong><span>00:00 – 12:00</span></div>
                                </button>
                                <button type="button" class="fb-slot-btn" data-slot="12:00" onclick="selectSlot('12:00', this)">
                                    <i class="fas fa-sun"></i>
                                    <div><strong>Jour</strong><span>12:00 – 00:00</span></div>
                                </button>
                            </div>
                        </div>
                        <div class="fb-options__group">
                            <div class="fb-card__label"><i class="fas fa-calendar-week"></i> Période</div>
                            <div class="fb-period-btns" id="periodBtnsWrap">
                                <button type="button" class="fb-period-btn fb-period-btn--active" data-slots="1" onclick="selectPeriod(1, this)">
                                    <strong>12h</strong><span>1 créneau</span>
                                </button>
                                <button type="button" class="fb-period-btn" data-slots="2" onclick="selectPeriod(2, this)">
                                    <strong>1 jour</strong><span>2 créneaux</span>
                                </button>
                                <button type="button" class="fb-period-btn" data-slots="6" onclick="selectPeriod(6, this)">
                                    <strong>3 jours</strong><span>6 créneaux</span>
                                </button>
                                <button type="button" class="fb-period-btn" data-slots="14" onclick="selectPeriod(14, this)">
                                    <strong>1 semaine</strong><span>14 créneaux</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            {# ===== RIGHT — SUMMARY ===== #}
            <div class="fb-summary-col">
                <div class="fb-summary" id="fbSummary">

                    <div class="fb-summary__placeholder" id="fbSummaryPlaceholder">
                        <div class="fb-summary__ph-icon"><i class="fas fa-calendar-check"></i></div>
                        <p>Choisissez une date<br>pour voir le récapitulatif</p>
                    </div>

                    <div class="fb-summary__content" id="fbSummaryContent" style="display:none;">
                        <div class="fb-summary__header">
                            <i class="fas fa-bolt"></i> Récapitulatif
                        </div>
                        <div class="fb-summary__rows" id="fbSummaryRows"></div>
                        <div class="fb-summary__cost" id="fbSummaryCost">
                            <i class="fas fa-bolt"></i> <span id="fbCostNum">0</span> NexBoost
                        </div>
                        <div class="fb-summary__balance" id="fbSummaryBalance"></div>
                        <form method="post" action="{{ path('featured_booking_book', {id: server.id}) }}" style="margin:0;">
                            <input type="hidden" name="_token" value="{{ csrf_token('featured_booking') }}">
                            <input type="hidden" name="scope" id="confirmScope" value="homepage">
                            <input type="hidden" name="position" id="confirmPosition" value="1">
                            <input type="hidden" name="startsAt" id="confirmStartsAt" value="">
                            <input type="hidden" name="slots_count" id="confirmSlotsCount" value="1">
                            <button type="submit" class="fb-summary__btn" id="confirmBtn">
                                <i class="fas fa-crown"></i> Réserver maintenant
                            </button>
                        </form>
                    </div>
                </div>

                <div class="fb-tip">
                    <i class="fas fa-lightbulb"></i>
                    <div>
                        <strong>Comment ça marche ?</strong><br>
                        Chaque créneau = 12h d'exposition. Plus la position est haute (#1 en tête), plus elle coûte de NexBoost mais plus votre serveur est visible.
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    var homepageCosts        = {{ homepage_costs|json_encode|raw }};
    var gameCosts            = {{ game_costs|json_encode|raw }};
    var homepageAvailability = {{ homepage_availability|json_encode|raw }};
    var serverId             = {{ server.id }};
    var serverGcName         = {{ server_gc_name|json_encode|raw }};
    var userBoostBalance     = {{ user_boost_balance }};

    var currentScope    = 'homepage';
    var currentPosition = 1;
    var currentCosts    = homepageCosts;
    var slotTaken       = {};
    var serverBookedSlots = [];
    var costPer12h      = homepageCosts[1] || 10;

    var today = new Date();
    today.setHours(0, 0, 0, 0);
    var stripOffset  = 0;
    var selectedDate = null;
    var selectedSlot = '00:00';
    var slotsCount   = 1;   // number of 12h slots to book

    var dayNames   = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];
    var monthNames = ['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];

    function pad2(n) { return n < 10 ? '0' + n : '' + n; }

    function buildSlotTakenFromAvailability(availability, pos) {
        var result = {};
        for (var key in availability) { result[key] = !!(availability[key] && availability[key][pos]); }
        return result;
    }

    slotTaken = buildSlotTakenFromAvailability(homepageAvailability, 1);

    // Compute range start/end dates based on selectedDate + selectedSlot + slotsCount
    function getRangeDates() {
        if (!selectedDate) return { start: null, end: null };
        var start = new Date(selectedDate + 'T' + selectedSlot + ':00');
        var endMs  = start.getTime() + slotsCount * 12 * 3600 * 1000;
        var end    = new Date(endMs - 1); // last ms of last slot
        return { start: start, end: end };
    }

    function dateToYMD(d) {
        return d.getFullYear() + '-' + pad2(d.getMonth()+1) + '-' + pad2(d.getDate());
    }

    // ---- DATE STRIP ----
    function renderStrip() {
        var strip = document.getElementById('dayStrip');
        strip.innerHTML = '';

        var startDate = new Date(today);
        startDate.setDate(today.getDate() + stripOffset);
        var endDate = new Date(startDate);
        endDate.setDate(startDate.getDate() + 6);

        var rangeEl = document.getElementById('fbStripRange');
        rangeEl.textContent = startDate.getDate() + ' ' + monthNames[startDate.getMonth()]
                            + ' – ' + endDate.getDate() + ' ' + monthNames[endDate.getMonth()];

        document.getElementById('navPrev').disabled = stripOffset <= 0;

        var range = getRangeDates();
        var rangeStartYMD = range.start ? dateToYMD(range.start) : null;
        var rangeEndYMD   = range.end   ? dateToYMD(range.end)   : null;

        for (var i = 0; i < 7; i++) {
            var d = new Date(startDate);
            d.setDate(startDate.getDate() + i);

            var dateStr = dateToYMD(d);
            var isPast  = d < today;

            var morningKey   = dateStr + ' 00:00';
            var afternoonKey = dateStr + ' 12:00';
            var morningTaken   = slotTaken[morningKey]   || false;
            var afternoonTaken = slotTaken[afternoonKey] || false;
            var morningMine    = serverBookedSlots.indexOf(morningKey)   !== -1;
            var afternoonMine  = serverBookedSlots.indexOf(afternoonKey) !== -1;

            var card = document.createElement('button');
            card.type = 'button';
            card.className = 'fb-day-card';

            if (isPast) {
                card.classList.add('fb-day-card--past');
                card.disabled = true;
            } else if (morningMine && afternoonMine) {
                card.classList.add('fb-day-card--mine');
                card.setAttribute('data-date', dateStr);
                card.addEventListener('click', function() { selectDateFn(this.getAttribute('data-date')); });
            } else if ((morningTaken || morningMine) && (afternoonTaken || afternoonMine)) {
                card.classList.add('fb-day-card--full');
                card.disabled = true;
            } else {
                card.classList.add('fb-day-card--available');
                card.setAttribute('data-date', dateStr);
                card.addEventListener('click', function() { selectDateFn(this.getAttribute('data-date')); });
            }

            // Range highlight
            if (rangeStartYMD && rangeEndYMD && dateStr >= rangeStartYMD && dateStr <= rangeEndYMD) {
                card.classList.remove('fb-day-card--available','fb-day-card--mine');
                if (dateStr === rangeStartYMD && dateStr === rangeEndYMD) {
                    card.classList.add('fb-day-card--selected');
                } else if (dateStr === rangeStartYMD) {
                    card.classList.add('fb-day-card--range-start');
                } else if (dateStr === rangeEndYMD) {
                    card.classList.add('fb-day-card--range-end');
                } else {
                    card.classList.add('fb-day-card--range-mid');
                }
            }

            card.innerHTML =
                '<div class="fb-day-card__dow">' + dayNames[d.getDay()] + '</div>' +
                '<div class="fb-day-card__num">' + d.getDate() + '</div>' +
                '<div class="fb-day-card__dots">' +
                    '<span class="fb-day-dot ' + getDotClass(morningTaken, morningMine, isPast) + '" title="00h-12h"></span>' +
                    '<span class="fb-day-dot ' + getDotClass(afternoonTaken, afternoonMine, isPast) + '" title="12h-00h"></span>' +
                '</div>';

            strip.appendChild(card);
        }
    }

    function getDotClass(taken, mine, past) {
        if (past) return 'fb-day-dot--past';
        if (mine) return 'fb-day-dot--mine';
        if (taken) return 'fb-day-dot--taken';
        return 'fb-day-dot--free';
    }

    window.navigateDays = function(dir) {
        var next = stripOffset + dir;
        if (next < 0) next = 0;
        stripOffset = next;
        renderStrip();
    };

    // ---- SCOPE & POSITION ----
    function updateCostDisplay() {
        currentCosts = currentScope === 'homepage' ? homepageCosts : gameCosts;
        for (var i = 1; i <= 5; i++) {
            var el = document.getElementById('posCost' + i);
            if (el) el.textContent = currentCosts[i] || '?';
        }
        costPer12h = currentCosts[currentPosition] || 1;
    }

    function loadAvailability() {
        var url = '/serveur/' + serverId + '/boost/availability?scope=' + currentScope + '&position=' + currentPosition;
        fetch(url)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                slotTaken         = data.slot_taken         || {};
                serverBookedSlots = data.server_booked_slots || [];
                costPer12h        = data.cost_per_12h        || 1;
                selectedDate = null;
                hideSummary();
                document.getElementById('fbOptions').style.display = 'none';
                renderStrip();
            })
            .catch(function() {});
    }

    window.selectScope = function(scope, btn) {
        currentScope = scope;
        document.querySelectorAll('.fb-scope-tab').forEach(function(el) { el.classList.remove('fb-scope-tab--active'); });
        btn.classList.add('fb-scope-tab--active');
        document.getElementById('confirmScope').value = scope;
        updateCostDisplay();
        loadAvailability();
    };

    window.selectPosition = function(pos, btn) {
        currentPosition = pos;
        document.querySelectorAll('.fb-pos').forEach(function(el) { el.classList.remove('fb-pos--active'); });
        btn.classList.add('fb-pos--active');
        document.getElementById('confirmPosition').value = pos;
        costPer12h = currentCosts[pos] || 1;

        if (currentScope === 'homepage') {
            slotTaken    = buildSlotTakenFromAvailability(homepageAvailability, pos);
            selectedDate = null;
            hideSummary();
            document.getElementById('fbOptions').style.display = 'none';
            renderStrip();
        } else {
            loadAvailability();
        }
    };

    // ---- DATE & SLOT SELECTION ----
    function selectDateFn(dateStr) {
        selectedDate = dateStr;
        renderStrip();
        updateSlotButtons();
        updatePeriodButtons();
        document.getElementById('fbOptions').style.display = '';
        updateSummary();
    }

    function updateSlotButtons() {
        if (!selectedDate) return;
        var morningKey   = selectedDate + ' 00:00';
        var afternoonKey = selectedDate + ' 12:00';
        var morningTaken   = slotTaken[morningKey]   || false;
        var afternoonTaken = slotTaken[afternoonKey] || false;
        var morningMine    = serverBookedSlots.indexOf(morningKey)   !== -1;
        var afternoonMine  = serverBookedSlots.indexOf(afternoonKey) !== -1;

        var btns = document.querySelectorAll('.fb-slot-btn');
        btns.forEach(function(btn) {
            var slot  = btn.getAttribute('data-slot');
            var taken = (slot === '00:00') ? morningTaken  : afternoonTaken;
            var mine  = (slot === '00:00') ? morningMine   : afternoonMine;
            btn.classList.remove('fb-slot-btn--active','fb-slot-btn--mine','fb-slot-btn--taken');
            btn.disabled = false;
            if (mine)        { btn.classList.add('fb-slot-btn--mine');  btn.disabled = true; }
            else if (taken)  { btn.classList.add('fb-slot-btn--taken'); btn.disabled = true; }
        });

        var morningOk   = !morningTaken   && !morningMine;
        var afternoonOk = !afternoonTaken && !afternoonMine;
        if (morningOk)        { selectedSlot = '00:00'; btns[0].classList.add('fb-slot-btn--active'); }
        else if (afternoonOk) { selectedSlot = '12:00'; btns[1].classList.add('fb-slot-btn--active'); }
    }

    function updatePeriodButtons() {
        // just re-render strip so range highlight updates; buttons already rendered in HTML
        renderStrip();
        updateSummary();
    }

    window.selectSlot = function(slot, btn) {
        if (btn.disabled) return;
        selectedSlot = slot;
        document.querySelectorAll('.fb-slot-btn:not(:disabled)').forEach(function(el) { el.classList.remove('fb-slot-btn--active'); });
        btn.classList.add('fb-slot-btn--active');
        renderStrip();
        updateSummary();
    };

    window.selectPeriod = function(n, btn) {
        slotsCount = n;
        document.querySelectorAll('.fb-period-btn').forEach(function(el) { el.classList.remove('fb-period-btn--active'); });
        btn.classList.add('fb-period-btn--active');
        document.getElementById('confirmSlotsCount').value = n;
        renderStrip();
        updateSummary();
    };

    // ---- SUMMARY ----
    function hideSummary() {
        document.getElementById('fbSummaryPlaceholder').style.display = '';
        document.getElementById('fbSummaryContent').style.display = 'none';
    }

    function formatDate(dateStr) {
        var p = dateStr.split('-');
        return p[2] + '/' + p[1] + '/' + p[0];
    }

    function updateSummary() {
        if (!selectedDate) return;

        var startKey = selectedDate + ' ' + selectedSlot;
        var taken    = slotTaken[startKey] || false;
        var mine     = serverBookedSlots.indexOf(startKey) !== -1;
        var canBook  = !taken && !mine;

        var totalCost  = slotsCount * costPer12h;
        var scopeLabel = currentScope === 'homepage' ? "Page d'accueil" : serverGcName;
        var slotLabel  = selectedSlot === '00:00' ? '00:00 – 12:00' : '12:00 – 00:00';

        // Compute end date/time
        var startDt = new Date(selectedDate + 'T' + selectedSlot + ':00');
        var endDt   = new Date(startDt.getTime() + slotsCount * 12 * 3600 * 1000);
        var endStr  = pad2(endDt.getDate()) + '/' + pad2(endDt.getMonth()+1) + '/' + endDt.getFullYear()
                    + ' ' + pad2(endDt.getHours()) + ':00';

        var periodLabel = slotsCount === 1  ? '12h (1 créneau)'
                        : slotsCount === 2  ? '1 jour (2 créneaux)'
                        : slotsCount === 6  ? '3 jours (6 créneaux)'
                        : slotsCount === 14 ? '1 semaine (14 créneaux)'
                        : (slotsCount * 12) + 'h (' + slotsCount + ' créneaux)';

        var rows = [
            { icon: 'fa-bullseye',        label: 'Emplacement', val: scopeLabel },
            { icon: 'fa-trophy',          label: 'Position',    val: '#' + currentPosition },
            { icon: 'fa-play-circle',     label: 'Début',       val: formatDate(selectedDate) + ' ' + selectedSlot },
            { icon: 'fa-stop-circle',     label: 'Fin',         val: endStr },
            { icon: 'fa-calendar-week',   label: 'Période',     val: periodLabel },
        ];

        var rowsHtml = rows.map(function(r) {
            return '<div class="fb-sum-row">'
                 + '<span class="fb-sum-row__label"><i class="fas ' + r.icon + '"></i> ' + r.label + '</span>'
                 + '<span class="fb-sum-row__val">' + r.val + '</span>'
                 + '</div>';
        }).join('');

        document.getElementById('fbSummaryRows').innerHTML = rowsHtml;
        document.getElementById('fbCostNum').textContent = totalCost;
        document.getElementById('fbSummaryCost').style.color = canBook ? '#ff6b35' : '#e74a3b';

        var balanceOk = userBoostBalance >= totalCost;
        var balEl = document.getElementById('fbSummaryBalance');
        if (!balanceOk) {
            balEl.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Solde insuffisant (' + userBoostBalance + ' NexBoost disponibles)';
            balEl.className = 'fb-summary__balance fb-summary__balance--warn';
        } else {
            balEl.innerHTML = '<i class="fas fa-check-circle"></i> Solde suffisant (' + userBoostBalance + ' NexBoost)';
            balEl.className = 'fb-summary__balance fb-summary__balance--ok';
        }

        var confirmBtn = document.getElementById('confirmBtn');
        confirmBtn.disabled = !canBook || !balanceOk;

        document.getElementById('confirmScope').value      = currentScope;
        document.getElementById('confirmPosition').value   = currentPosition;
        document.getElementById('confirmStartsAt').value   = selectedDate + ' ' + selectedSlot;
        document.getElementById('confirmSlotsCount').value = slotsCount;

        document.getElementById('fbSummaryPlaceholder').style.display = 'none';
        document.getElementById('fbSummaryContent').style.display     = '';
    }

    // ---- INIT ----
    updateCostDisplay();
    renderStrip();
})();
</script>
{% endblock %}
