{% block javascripts %}
{% set allPlans = defaultPlans|merge(customPlans) %}
{% if app.user and allPlans|length > 0 %}
{% if paypal_client_id %}
<script src="https://www{% if is_sandbox %}.sandbox{% endif %}.paypal.com/sdk/js?client-id={{ paypal_client_id }}&currency={{ paypal_currency }}&disable-funding=credit,card,paylater&enable-funding=sepa,giropay,mybank&debug=true"></script>
{% endif %}
<script nonce="{{ csp_nonce() }}">
(function() {
    var currentPlanId = null;
    var currentNexbitsPrice = 0;
    var currentServerId = null;
    var currentSourceBalance = {{ app.user ? app.user.tokenBalance : 0 }};
    var buttonsRendered = {};
    var buying = false;

    window.selectSource = function(type, el) {
        document.querySelectorAll('.pp-source-option').forEach(function(o) {
            o.classList.remove('pp-source-option--active');
        });

        if (type === 'personal') {
            document.querySelector('.pp-source-option[data-source="personal"]').classList.add('pp-source-option--active');
            currentServerId = null;
            currentSourceBalance = {{ app.user ? app.user.tokenBalance : 0 }};
        } else {
            el.classList.add('pp-source-option--active');
            currentServerId = parseInt(el.getAttribute('data-server-id'));
            currentSourceBalance = parseInt(el.getAttribute('data-server-balance'));
        }

        document.getElementById('ppActiveBalance').textContent = currentSourceBalance;
        updateNexbitsBtn();
    };

    function updateNexbitsBtn() {
        var btn = document.getElementById('ppNexbitsBtn');
        var errorEl = document.getElementById('ppNexbitsError');
        if (!btn) return;
        if (currentSourceBalance < currentNexbitsPrice) {
            btn.disabled = true;
            btn.classList.add('pp-modal__nexbits-btn--disabled');
            errorEl.textContent = 'Solde insuffisant. Il manque ' + (currentNexbitsPrice - currentSourceBalance) + ' NexBits.';
            errorEl.style.display = '';
        } else {
            btn.disabled = false;
            btn.classList.remove('pp-modal__nexbits-btn--disabled');
            errorEl.style.display = 'none';
        }
    }

    window.openPayment = function(btn) {
        var planId = btn.getAttribute('data-plan-id');
        var planName = btn.getAttribute('data-plan-name');
        var planPrice = parseFloat(btn.getAttribute('data-plan-price') || '0');
        var planCurrency = btn.getAttribute('data-plan-currency');
        var planTokens = btn.getAttribute('data-plan-tokens');
        var planBoost = btn.getAttribute('data-plan-boost');
        var nexbitsPrice = parseInt(btn.getAttribute('data-plan-nexbits-price') || '0');

        currentPlanId = parseInt(planId);
        currentNexbitsPrice = nexbitsPrice;

        var hasPaypal = planPrice > 0;
        var hasNexbits = nexbitsPrice > 0;
        var hasCrypto = {% if crypto_enabled %}planPrice > 0{% else %}false{% endif %};
        var hasStripe = {% if stripe_enabled %}planPrice > 0{% else %}false{% endif %};
        var hasBoth = hasPaypal && hasNexbits;

        document.getElementById('ppPlanName').textContent = planName;

        var details = [];
        if (parseInt(planTokens) > 0) details.push(planTokens + ' NexBits');
        if (parseInt(planBoost) > 0) details.push(planBoost + ' NexBoost');
        document.getElementById('ppPlanDetail').textContent = details.join(' + ');

        // Tabs: show if more than one payment method
        var tabsEl = document.getElementById('ppTabs');
        var methodCount = (hasPaypal ? 1 : 0) + (hasNexbits ? 1 : 0) + (hasCrypto ? 1 : 0) + (hasStripe ? 1 : 0);
        tabsEl.style.display = methodCount > 1 ? '' : 'none';

        // Show/hide tab buttons
        var nexbitsTabBtn = document.querySelector('.pp-modal__tab[data-tab="nexbits"]');
        if (nexbitsTabBtn) nexbitsTabBtn.style.display = hasNexbits ? '' : 'none';
        var cryptoTabBtn = document.querySelector('.pp-modal__tab[data-tab="crypto"]');
        if (cryptoTabBtn) cryptoTabBtn.style.display = hasCrypto ? '' : 'none';
        var stripeTabBtn = document.querySelector('.pp-modal__tab[data-tab="stripe"]');
        if (stripeTabBtn) stripeTabBtn.style.display = hasStripe ? '' : 'none';

        // Crypto tab content
        if (hasCrypto) {
            document.getElementById('ppCryptoPrice').innerHTML = planPrice.toFixed(2) + ' <span>' + planCurrency + '</span>';
            document.getElementById('ppCryptoBtnLabel').textContent = 'Payer ' + planPrice.toFixed(2) + ' ' + planCurrency + ' en Crypto';
            var cryptoErrorEl = document.getElementById('ppCryptoError');
            if (cryptoErrorEl) cryptoErrorEl.style.display = 'none';
            var cryptoBtn = document.getElementById('ppCryptoBtn');
            if (cryptoBtn) { cryptoBtn.disabled = false; }
        }

        // Stripe tab content
        if (hasStripe) {
            var stripePriceEl = document.getElementById('ppStripePrice');
            if (stripePriceEl) stripePriceEl.innerHTML = planPrice.toFixed(2) + ' <span>' + planCurrency + '</span>';
            var stripeBtnLabel = document.getElementById('ppStripeBtnLabel');
            if (stripeBtnLabel) stripeBtnLabel.textContent = 'Payer ' + planPrice.toFixed(2) + ' ' + planCurrency + ' par carte';
            var stripeErrorEl = document.getElementById('ppStripeError');
            if (stripeErrorEl) stripeErrorEl.style.display = 'none';
            var stripeBtn = document.getElementById('ppStripeBtn');
            if (stripeBtn) { stripeBtn.disabled = false; }
        }

        // PayPal tab content
        if (hasPaypal) {
            document.getElementById('ppPlanPrice').innerHTML = planPrice.toFixed(2) + ' <span>' + planCurrency + '</span>';
        }

        // NexBits tab content
        if (hasNexbits) {
            document.getElementById('ppNexbitsPrice').innerHTML = nexbitsPrice + ' <span>NexBits</span>';
            document.getElementById('ppNexbitsBtnLabel').textContent = 'Payer ' + nexbitsPrice + ' NexBits';

            // Reset source to personal on each modal open
            currentServerId = null;
            currentSourceBalance = {{ app.user ? app.user.tokenBalance : 0 }};
            document.querySelectorAll('.pp-source-option').forEach(function(o) {
                o.classList.remove('pp-source-option--active');
            });
            var personalOpt = document.querySelector('.pp-source-option[data-source="personal"]');
            if (personalOpt) personalOpt.classList.add('pp-source-option--active');
            var balEl = document.getElementById('ppActiveBalance');
            if (balEl) balEl.textContent = currentSourceBalance;

            updateNexbitsBtn();
        }

        // Show the right tab first: PayPal > NexBits > Crypto > Stripe
        if (hasPaypal) {
            switchPayTab('paypal');
        } else if (hasNexbits) {
            switchPayTab('nexbits');
        } else if (hasCrypto) {
            switchPayTab('crypto');
        } else if (hasStripe) {
            switchPayTab('stripe');
        }

        // Show/hide tab contents for single-method plans
        document.getElementById('ppTabPaypal').style.display = hasPaypal ? '' : 'none';
        document.getElementById('ppTabNexbits').style.display = (!hasPaypal && hasNexbits) ? '' : 'none';
        var cryptoTabContent = document.getElementById('ppTabCrypto');
        if (cryptoTabContent) {
            cryptoTabContent.style.display = (!hasPaypal && !hasNexbits && hasCrypto) ? '' : 'none';
        }
        var stripeTabContent = document.getElementById('ppTabStripe');
        if (stripeTabContent) {
            stripeTabContent.style.display = (!hasPaypal && !hasNexbits && !hasCrypto && hasStripe) ? '' : 'none';
        }

        document.getElementById('ppOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';

        // Render PayPal button if needed and not already done
        if (hasPaypal && !buttonsRendered[planId] && typeof paypal !== 'undefined') {
            var container = document.getElementById('ppButtonContainer');
            container.innerHTML = '';
            paypal.Buttons({
                fundingSource: paypal.FUNDING.PAYPAL,
                style: {
                    layout: 'horizontal',
                    color: 'black',
                    shape: 'rect',
                    label: 'pay',
                    height: 50,
                    tagline: false
                },
                createOrder: function(data, actions) {
                    return fetch('{{ path("premium_create_order") }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        credentials: 'same-origin',
                        body: JSON.stringify({ planId: currentPlanId })
                    })
                    .then(function(res) {
                        if (!res.ok) {
                            return res.text().then(function(text) {
                                console.error('createOrder HTTP ' + res.status, text.substring(0, 300));
                                throw new Error('Erreur serveur (' + res.status + ')');
                            });
                        }
                        return res.json();
                    })
                    .then(function(json) {
                        if (json.error) throw new Error(json.error);
                        return json.orderId;
                    });
                },
                onApprove: function(data, actions) {
                    console.log('[PayPal] onApprove called, orderID:', data.orderID);
                    return fetch('{{ path("premium_capture_order") }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        credentials: 'same-origin',
                        body: JSON.stringify({ orderId: data.orderID, planId: currentPlanId })
                    })
                    .then(function(res) {
                        console.log('[PayPal] captureOrder response status:', res.status);
                        if (!res.ok) {
                            return res.text().then(function(text) {
                                console.error('[PayPal] captureOrder HTTP ' + res.status, text.substring(0, 300));
                                throw new Error('Erreur serveur (' + res.status + ')');
                            });
                        }
                        return res.json();
                    })
                    .then(function(json) {
                        console.log('[PayPal] captureOrder response:', json);
                        if (json.error) {
                            alert('Erreur: ' + json.error);
                        } else if (json.pending) {
                            console.log('[PayPal] Payment pending (bank transfer)...');
                            window.location.href = '{{ path("premium_success") }}?pending=1';
                        } else {
                            console.log('[PayPal] Redirecting to success page...');
                            window.location.href = '{{ path("premium_success") }}';
                        }
                    })
                    .catch(function(err) {
                        console.error('[PayPal] onApprove error:', err);
                        alert('Erreur lors de la capture du paiement: ' + err.message);
                        throw err;
                    });
                },
                onCancel: function() {
                    closePayment();
                },
                onError: function(err) {
                    console.error('PayPal error:', err);
                    alert('Une erreur est survenue avec PayPal. Veuillez reessayer.');
                    closePayment();
                }
            }).render('#ppButtonContainer');

            buttonsRendered[planId] = true;
        }
    };

    window.switchPayTab = function(tab) {
        document.querySelectorAll('.pp-modal__tab').forEach(function(t) {
            t.classList.toggle('pp-modal__tab--active', t.getAttribute('data-tab') === tab);
        });
        document.getElementById('ppTabPaypal').style.display = tab === 'paypal' ? '' : 'none';
        document.getElementById('ppTabNexbits').style.display = tab === 'nexbits' ? '' : 'none';
        var cryptoContent = document.getElementById('ppTabCrypto');
        if (cryptoContent) cryptoContent.style.display = tab === 'crypto' ? '' : 'none';
        var stripeContent = document.getElementById('ppTabStripe');
        if (stripeContent) stripeContent.style.display = tab === 'stripe' ? '' : 'none';
    };

    window.payCrypto = function() {
        var btn = document.getElementById('ppCryptoBtn');
        var errorEl = document.getElementById('ppCryptoError');
        if (btn.disabled) return;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Preparation...';
        if (errorEl) errorEl.style.display = 'none';

        fetch('{{ path("premium_create_crypto_order") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin',
            body: JSON.stringify({ planId: currentPlanId })
        })
        .then(function(res) { return res.json(); })
        .then(function(json) {
            if (json.error) {
                if (errorEl) { errorEl.textContent = json.error; errorEl.style.display = ''; }
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-arrow-right"></i> <span id="ppCryptoBtnLabel">Payer avec Crypto.com</span>';
            } else {
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Redirection...';
                window.location.href = json.paymentUrl;
            }
        })
        .catch(function() {
            if (errorEl) { errorEl.textContent = 'Une erreur est survenue. Veuillez reessayer.'; errorEl.style.display = ''; }
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-arrow-right"></i> <span>Payer avec Crypto.com</span>';
        });
    };

    window.payStripe = function() {
        var btn = document.getElementById('ppStripeBtn');
        var errorEl = document.getElementById('ppStripeError');
        if (!btn || btn.disabled) return;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Preparation...';
        if (errorEl) errorEl.style.display = 'none';

        fetch('{{ path("premium_stripe_checkout") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin',
            body: JSON.stringify({ planId: currentPlanId })
        })
        .then(function(res) { return res.json(); })
        .then(function(json) {
            if (json.error) {
                if (errorEl) { errorEl.textContent = json.error; errorEl.style.display = ''; }
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-credit-card"></i> <span id="ppStripeBtnLabel">Payer avec Stripe</span>';
            } else {
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Redirection vers Stripe...';
                window.location.href = json.sessionUrl;
            }
        })
        .catch(function() {
            if (errorEl) { errorEl.textContent = 'Une erreur est survenue. Veuillez reessayer.'; errorEl.style.display = ''; }
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-credit-card"></i> <span>Payer avec Stripe</span>';
        });
    };

    window.buyWithNexbits = function() {
        if (buying) return;
        buying = true;

        var btn = document.getElementById('ppNexbitsBtn');
        var errorEl = document.getElementById('ppNexbitsError');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Traitement...';
        errorEl.style.display = 'none';

        var payload = { planId: currentPlanId };
        if (currentServerId !== null) {
            payload.serverId = currentServerId;
        }

        fetch('{{ path("premium_buy_nexbits") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function(res) { return res.json(); })
        .then(function(json) {
            if (json.error) {
                errorEl.textContent = json.error;
                errorEl.style.display = '';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-coins"></i> <span id="ppNexbitsBtnLabel">Payer ' + currentNexbitsPrice + ' NexBits</span>';
            } else {
                window.location.href = '{{ path("premium_success") }}';
            }
        })
        .catch(function() {
            errorEl.textContent = 'Une erreur est survenue. Veuillez reessayer.';
            errorEl.style.display = '';
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-coins"></i> <span id="ppNexbitsBtnLabel">Payer ' + currentNexbitsPrice + ' NexBits</span>';
        })
        .finally(function() {
            buying = false;
        });
    };

    window.closePayment = function() {
        document.getElementById('ppOverlay').classList.remove('active');
        document.body.style.overflow = '';
    };

    // ESC key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closePayment();
    });
})();
</script>
{% endif %}

<script nonce="{{ csp_nonce() }}">
window.switchTab = function(id) {
    document.querySelectorAll('.nx-tab-btn').forEach(function(b) {
        b.classList.toggle('active', b.getAttribute('data-tab') === id);
    });
    document.querySelectorAll('.nx-tab-panel').forEach(function(p) {
        p.classList.remove('active');
    });
    var panel = document.getElementById('tab-' + id);
    if (panel) panel.classList.add('active');
};
// Default tab on load
switchTab('all');
</script>
{% endblock %}
