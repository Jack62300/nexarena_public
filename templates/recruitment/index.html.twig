{% extends 'base.html.twig' %}

{% block title %}Recrutement - {{ setting('site_name', 'Nexarena') }}{% endblock %}
{% block meta_description %}Trouvez les meilleures offres de recrutement pour les serveurs de jeux sur {{ setting('site_name', 'Nexarena') }}.{% endblock %}

{% block stylesheets %}
<style>
    /* ===== PAGE BG ===== */
    .rci-page {
        min-height: 100vh;
        position: relative;
        overflow: hidden;
    }
    .rci-page::before {
        content: '';
        position: fixed; inset: 0;
        background:
            radial-gradient(ellipse at 20% 0%, rgba(69,248,130,0.07) 0%, transparent 50%),
            radial-gradient(ellipse at 80% 100%, rgba(59,130,246,0.05) 0%, transparent 50%);
        pointer-events: none;
        z-index: 0;
    }

    /* ===== HERO ===== */
    .rci-hero {
        padding: 130px 0 0;
        position: relative;
        z-index: 1;
        text-align: center;
    }
    .rci-hero__icon {
        width: 80px; height: 80px;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(69,248,130,0.15), rgba(69,248,130,0.03));
        border: 1px solid rgba(69,248,130,0.2);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 32px; color: #45f882;
        margin-bottom: 24px;
        position: relative;
        animation: rci-float 3s ease-in-out infinite;
    }
    .rci-hero__icon::after {
        content: '';
        position: absolute;
        inset: -6px;
        border-radius: 24px;
        border: 1px solid rgba(69,248,130,0.08);
        animation: rci-pulse-ring 2s ease-out infinite;
    }
    @keyframes rci-float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
    }
    @keyframes rci-pulse-ring {
        0% { transform: scale(1); opacity: 1; }
        100% { transform: scale(1.3); opacity: 0; }
    }
    .rci-hero__title {
        font-size: 44px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 14px;
        background: linear-gradient(135deg, #fff, rgba(255,255,255,0.7));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .rci-hero__sub {
        color: rgba(255,255,255,0.45);
        font-size: 17px;
        margin-bottom: 28px;
        max-width: 500px;
        margin-left: auto; margin-right: auto;
        line-height: 1.6;
    }
    .rci-hero__stats {
        display: inline-flex; gap: 6px; align-items: center;
        padding: 8px 22px;
        background: rgba(69,248,130,0.06);
        border: 1px solid rgba(69,248,130,0.12);
        border-radius: 30px;
        font-size: 14px;
        color: #45f882;
        font-weight: 700;
        letter-spacing: 0.5px;
    }
    .rci-hero__stats i { font-size: 12px; }

    /* ===== FILTERS ===== */
    .rci-filters {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
        padding: 40px 15px 30px;
        position: relative;
        z-index: 1;
    }
    .rci-fbtn {
        padding: 9px 20px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.02);
        color: rgba(255,255,255,0.45);
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }
    .rci-fbtn::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(69,248,130,0.1), transparent);
        opacity: 0;
        transition: opacity 0.3s;
    }
    .rci-fbtn:hover {
        border-color: rgba(69,248,130,0.25);
        color: #45f882;
        transform: translateY(-1px);
    }
    .rci-fbtn:hover::before { opacity: 1; }
    .rci-fbtn--active {
        background: rgba(69,248,130,0.1);
        border-color: rgba(69,248,130,0.3);
        color: #45f882;
        box-shadow: 0 0 20px rgba(69,248,130,0.08);
    }
    .rci-fbtn--active::before { opacity: 1; }

    /* ===== GRID ===== */
    .rci-grid-wrap {
        position: relative;
        z-index: 1;
        padding: 0 0 100px;
    }
    .rci-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    @media (max-width: 1199px) { .rci-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 767px) { .rci-grid { grid-template-columns: 1fr; } }

    /* ===== CARD ===== */
    .rci-card {
        background: rgba(15,25,35,0.7);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        text-decoration: none !important;
        color: inherit !important;
        position: relative;
    }
    .rci-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 16px;
        padding: 1px;
        background: linear-gradient(135deg, rgba(69,248,130,0.15), transparent 60%);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.4s;
        pointer-events: none;
    }
    .rci-card:hover {
        transform: translateY(-6px);
        box-shadow:
            0 20px 50px rgba(0,0,0,0.4),
            0 0 30px rgba(69,248,130,0.06);
        border-color: rgba(69,248,130,0.1);
    }
    .rci-card:hover::before { opacity: 1; }

    .rci-card__visual {
        height: 180px;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, rgba(69,248,130,0.04), rgba(10,16,24,0.9));
    }
    .rci-card__visual img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .rci-card:hover .rci-card__visual img { transform: scale(1.08); }
    .rci-card__visual-ph {
        width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center;
        font-size: 48px; color: rgba(69,248,130,0.08);
    }
    .rci-card__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 40%, rgba(10,16,24,0.95) 100%);
    }
    .rci-card__tags {
        position: absolute;
        top: 14px; left: 14px;
        display: flex; gap: 8px;
    }
    .rci-card__tag {
        padding: 5px 12px;
        border-radius: 8px;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        backdrop-filter: blur(12px);
    }
    .rci-card__tag--cat {
        background: rgba(69,248,130,0.15);
        color: #45f882;
        border: 1px solid rgba(69,248,130,0.2);
    }
    .rci-card__tag--lock {
        background: rgba(59,130,246,0.15);
        color: #3b82f6;
        border: 1px solid rgba(59,130,246,0.2);
    }

    .rci-card__body {
        padding: 22px 22px 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    .rci-card__server {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 12px; color: rgba(255,255,255,0.4);
        margin-bottom: 10px;
        font-weight: 600;
        letter-spacing: 0.3px;
    }
    .rci-card__server i {
        color: #45f882;
        font-size: 10px;
    }
    .rci-card__title {
        font-size: 18px; font-weight: 800; color: #fff;
        margin-bottom: 10px;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        line-height: 1.3;
        transition: color 0.3s;
    }
    .rci-card:hover .rci-card__title { color: #45f882; }
    .rci-card__desc {
        font-size: 13px; color: rgba(255,255,255,0.3); line-height: 1.6;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        margin-bottom: 18px; flex: 1;
    }
    .rci-card__footer {
        display: flex; justify-content: space-between; align-items: center;
        padding-top: 16px;
        border-top: 1px solid rgba(255,255,255,0.04);
    }
    .rci-card__date {
        font-size: 12px; color: rgba(255,255,255,0.25);
    }
    .rci-card__date i { margin-right: 4px; }
    .rci-card__cta {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 8px 18px; border-radius: 10px;
        font-size: 12px; font-weight: 800;
        text-transform: uppercase; letter-spacing: 1px;
        background: linear-gradient(135deg, rgba(69,248,130,0.15), rgba(69,248,130,0.05));
        color: #45f882;
        border: 1px solid rgba(69,248,130,0.2);
        transition: all 0.3s;
    }
    .rci-card:hover .rci-card__cta {
        background: linear-gradient(135deg, #45f882, #2bc866);
        color: #0a1018;
        border-color: #45f882;
        box-shadow: 0 4px 20px rgba(69,248,130,0.3);
    }

    /* ===== EMPTY ===== */
    .rci-empty {
        text-align: center;
        padding: 80px 20px;
        position: relative;
        z-index: 1;
    }
    .rci-empty__icon {
        width: 100px; height: 100px;
        border-radius: 50%;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.04);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 36px; color: rgba(255,255,255,0.08);
        margin-bottom: 20px;
    }
    .rci-empty p {
        color: rgba(255,255,255,0.3);
        font-size: 16px;
    }

    /* ===== SCANLINE FX ===== */
    .rci-scanline {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 100%;
        background: repeating-linear-gradient(
            0deg,
            transparent,
            transparent 2px,
            rgba(255,255,255,0.008) 2px,
            rgba(255,255,255,0.008) 4px
        );
        pointer-events: none;
        z-index: 0;
    }
</style>
{% endblock %}

{% block body %}
<div class="rci-page">
    <div class="rci-scanline"></div>

    {# ===== HERO ===== #}
    <section class="rci-hero">
        <div class="container">
            <div class="rci-hero__icon">
                <i class="fas fa-users-cog"></i>
            </div>
            <h1 class="rci-hero__title">Recrutement</h1>
            <p class="rci-hero__sub">Rejoignez les meilleures equipes de jeu. Trouvez l'offre qui correspond a vos talents.</p>
            <span class="rci-hero__stats">
                <i class="fas fa-fire"></i>
                {{ listings|length }} offre{{ listings|length > 1 ? 's' : '' }} active{{ listings|length > 1 ? 's' : '' }}
            </span>
        </div>
    </section>

    {# ===== FILTERS ===== #}
    <div class="container">
        <div class="rci-filters">
            <a href="{{ path('recruitment_index') }}" class="rci-fbtn {{ currentCategory is null ? 'rci-fbtn--active' : '' }}">
                <i class="fas fa-th"></i> Toutes
            </a>
            {% for cat in categories %}
                <a href="{{ path('recruitment_index', {category: cat.id}) }}" class="rci-fbtn {{ currentCategory == cat.id ? 'rci-fbtn--active' : '' }}">
                    {% if cat.icon %}<i class="{{ cat.icon }}"></i>{% endif %} {{ cat.name }}
                </a>
            {% endfor %}
        </div>
    </div>

    {# ===== LISTINGS ===== #}
    <section class="rci-grid-wrap">
        <div class="container">
            {% if listings|length > 0 %}
                <div class="rci-grid">
                    {% for listing in listings %}
                        <a href="{{ path('recruitment_show', {slug: listing.slug}) }}" class="rci-card">
                            <div class="rci-card__visual">
                                {% if listing.image1 %}
                                    <img src="{{ asset('uploads/recruitment/' ~ listing.image1) }}" alt="{{ listing.title }}" loading="lazy">
                                {% else %}
                                    <div class="rci-card__visual-ph"><i class="fas fa-bullhorn"></i></div>
                                {% endif %}
                                <div class="rci-card__overlay"></div>
                                <div class="rci-card__tags">
                                    <span class="rci-card__tag rci-card__tag--cat">
                                        {{ listing.server.category.name }}
                                    </span>
                                    {% if listing.requiresLogin %}
                                        <span class="rci-card__tag rci-card__tag--lock"><i class="fas fa-lock"></i></span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="rci-card__body">
                                <div class="rci-card__server">
                                    <i class="fas fa-circle"></i> {{ listing.server.name }}
                                    {% if listing.server.gameCategory %}
                                        &middot; {{ listing.server.gameCategory.name }}
                                    {% endif %}
                                </div>
                                <h3 class="rci-card__title">{{ listing.title }}</h3>
                                <div class="rci-card__desc">{{ listing.description|striptags }}</div>
                                <div class="rci-card__footer">
                                    <span class="rci-card__date"><i class="far fa-clock"></i> {{ listing.createdAt|date('d/m/Y') }}</span>
                                    <span class="rci-card__cta"><i class="fas fa-arrow-right"></i> Postuler</span>
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="rci-empty">
                    <div class="rci-empty__icon"><i class="fas fa-satellite-dish"></i></div>
                    <p>Aucune offre de recrutement disponible pour le moment.</p>
                </div>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
