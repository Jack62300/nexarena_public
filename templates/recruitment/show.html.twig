{% extends 'base.html.twig' %}

{% block title %}{{ listing.title }} - Recrutement - {{ setting('site_name', 'Nexarena') }}{% endblock %}
{% block meta_description %}{{ listing.description|striptags|slice(0, 160) }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/recruitment-show.css') }}">
{% endblock %}

{% block body %}
<div class="rcs-page">
    <div class="rcs-scanline"></div>

    {# ===== HERO ===== #}
    <section class="rcs-hero">
        <div class="container">
            <a href="{{ path('recruitment_index') }}" class="rcs-back">
                <i class="fas fa-arrow-left"></i> Retour aux offres
            </a>

            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="rcs-alert rcs-alert--{{ type == 'error' ? 'error' : 'success' }}">
                        <i class="fas fa-{{ type == 'error' ? 'exclamation-triangle' : 'check-circle' }}"></i> {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {# Banner #}
            <div class="rcs-hero__banner">
                {% if listing.image1 %}
                    <img src="{{ asset('uploads/recruitment/' ~ listing.image1) }}" alt="{{ listing.title }}">
                {% else %}
                    <div class="rcs-hero__banner-ph"><i class="fas fa-gamepad"></i></div>
                {% endif %}
                <div class="rcs-hero__banner-overlay"></div>
                <div class="rcs-hero__banner-content">
                    <a href="{{ path('server_show', {slug: listing.server.slug}) }}" class="rcs-server-chip">
                        <i class="fas fa-server"></i> {{ listing.server.name }}
                        {% if listing.server.category %}
                            <span style="opacity:0.4;">|</span> {{ listing.server.category.name }}
                        {% endif %}
                    </a>
                    <h1 class="rcs-title">{{ listing.title }}</h1>
                    <div class="rcs-meta">
                        <span class="rcs-meta__item"><i class="fas fa-user"></i> {{ listing.author.username }}</span>
                        <span class="rcs-meta__item"><i class="far fa-calendar"></i> {{ listing.createdAt|time_ago('d/m/Y') }}</span>
                        <span class="rcs-meta__item"><i class="fas fa-clipboard-list"></i> {{ listing.formFields|length }} question{{ listing.formFields|length > 1 ? 's' : '' }}</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ===== CONTENT ===== #}
    <section>
        <div class="container">
            <div class="rcs-layout">
                {# LEFT #}
                <div class="rcs-main">
                    {% if listing.image2 %}
                        <div class="rcs-images">
                            <img src="{{ asset('uploads/recruitment/' ~ listing.image2) }}" alt="{{ listing.title }}">
                        </div>
                    {% endif %}

                    <div class="rcs-desc">
                        {{ listing.description|raw }}
                    </div>
                </div>

                {# RIGHT #}
                <div class="rcs-sidebar">
                    <div class="rcs-form-card">
                        <div class="rcs-form-head">
                            <div class="rcs-form-head__icon"><i class="fas fa-paper-plane"></i></div>
                            <h2 class="rcs-form-head__title">Postuler</h2>
                        </div>
                        <p class="rcs-form-sub">Remplissez le formulaire pour soumettre votre candidature.</p>

                        {% if listing.requiresLogin and not app.user %}
                            <div class="rcs-lock-msg">
                                <div class="rcs-lock-msg__icon"><i class="fas fa-lock"></i></div>
                                <p>Cette annonce est reservee aux membres.<br>Connectez-vous pour postuler.</p>
                                <a href="{{ path('app_login') }}" class="rcs-lock-msg__btn">
                                    <i class="fas fa-sign-in-alt"></i> Se connecter
                                </a>
                            </div>
                        {% else %}
                        <form method="post" action="{{ path('recruitment_apply', {slug: listing.slug}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('recruitment_apply_' ~ listing.id) }}">

                            <div class="rcs-fg">
                                <label class="rcs-fl">Votre nom / pseudo <span class="req">*</span></label>
                                <input type="text" name="applicant_name" class="rcs-fi" required maxlength="255"
                                       placeholder="Ex: Steve"
                                       value="{{ app.user ? app.user.username : '' }}">
                            </div>
                            <div class="rcs-fg">
                                <label class="rcs-fl">Votre email <span class="req">*</span></label>
                                <input type="email" name="applicant_email" class="rcs-fi" required maxlength="255"
                                       placeholder="votre@email.com"
                                       value="{{ app.user ? app.user.email : '' }}">
                            </div>

                            <div class="rcs-f-divider"></div>

                            {% for index, field in listing.formFields %}
                                <div class="rcs-fg">
                                    <label class="rcs-fl">
                                        {{ field.label }}
                                        {% if field.required|default(false) %}<span class="req">*</span>{% endif %}
                                    </label>

                                    {% if field.type == 'text' %}
                                        <input type="text" name="field_{{ index }}" class="rcs-fi"
                                               placeholder="{{ field.placeholder|default('') }}"
                                               {{ field.required|default(false) ? 'required' : '' }}>
                                    {% elseif field.type == 'email' %}
                                        <input type="email" name="field_{{ index }}" class="rcs-fi"
                                               placeholder="{{ field.placeholder|default('') }}"
                                               {{ field.required|default(false) ? 'required' : '' }}>
                                    {% elseif field.type == 'number' %}
                                        <input type="number" name="field_{{ index }}" class="rcs-fi"
                                               placeholder="{{ field.placeholder|default('') }}"
                                               {{ field.required|default(false) ? 'required' : '' }}>
                                    {% elseif field.type == 'textarea' %}
                                        <textarea name="field_{{ index }}" class="rcs-fi rcs-fi--ta"
                                                  placeholder="{{ field.placeholder|default('') }}"
                                                  {{ field.required|default(false) ? 'required' : '' }}></textarea>
                                    {% elseif field.type == 'select' %}
                                        <select name="field_{{ index }}" class="rcs-fi rcs-fi--sel"
                                                {{ field.required|default(false) ? 'required' : '' }}>
                                            <option value="">{{ field.placeholder|default('Choisir...') }}</option>
                                            {% for option in field.options|default([]) %}
                                                <option value="{{ option }}">{{ option }}</option>
                                            {% endfor %}
                                        </select>
                                    {% elseif field.type == 'radio' %}
                                        <div class="rcs-f-radio">
                                            {% for option in field.options|default([]) %}
                                                <label>
                                                    <input type="radio" name="field_{{ index }}" value="{{ option }}"
                                                           {{ field.required|default(false) ? 'required' : '' }}>
                                                    {{ option }}
                                                </label>
                                            {% endfor %}
                                        </div>
                                    {% elseif field.type == 'checkbox' %}
                                        <div class="rcs-f-check">
                                            <label>
                                                <input type="checkbox" name="field_{{ index }}" value="1">
                                                {{ field.placeholder|default(field.label) }}
                                            </label>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endfor %}

                            <button type="submit" class="rcs-submit">
                                <i class="fas fa-paper-plane"></i> Envoyer ma candidature
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}
