{% extends 'base.html.twig' %}

{% block title %}Mes promotions live - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block body %}
<div class="container py-5" style="max-width:900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-weight:700;color:#fff;margin:0;"><i class="fas fa-broadcast-tower" style="color:#45f882;margin-right:8px;"></i> Mes promotions live</h2>
        {% if live_promo_enabled %}
            <a href="{{ path('app_promotions_new') }}" class="btn btn-sm" style="background:#45f882;color:#000;font-weight:600;border-radius:8px;padding:8px 18px;">
                <i class="fas fa-plus"></i> Nouvelle promotion
            </a>
        {% endif %}
    </div>

    {% if not live_promo_enabled %}
        <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:40px;text-align:center;">
            <i class="fas fa-broadcast-tower" style="font-size:32px;color:rgba(255,255,255,0.2);margin-bottom:12px;"></i>
            <p style="color:rgba(255,255,255,0.5);margin:0;">Les promotions live ne sont pas activees.</p>
        </div>
    {% elseif promotions is empty %}
        <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:40px;text-align:center;">
            <i class="fas fa-video" style="font-size:32px;color:rgba(255,255,255,0.2);margin-bottom:12px;"></i>
            <p style="color:rgba(255,255,255,0.5);margin:0;">Vous n'avez pas encore de promotion live.</p>
        </div>
    {% else %}
        <div style="display:flex;flex-direction:column;gap:12px;">
            {% for promo in promotions %}
            <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:20px;display:flex;align-items:center;gap:16px;">
                <div style="width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;
                    {% if promo.platform == 'twitch' %}background:rgba(145,70,255,0.15);color:#9146FF;{% else %}background:rgba(255,0,0,0.12);color:#FF0000;{% endif %}">
                    <i class="fab fa-{{ promo.platform }}"></i>
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="font-weight:600;color:#fff;">{{ promo.channelName }}</div>
                    <div style="font-size:12px;color:rgba(255,255,255,0.5);">
                        {{ promo.startDate|date('d/m/Y') }} - {{ promo.endDate|date('d/m/Y') }}
                        {% if promo.server %} &bull; {{ promo.server.name }}{% endif %}
                    </div>
                </div>
                <div style="text-align:right;">
                    {% if promo.isCurrentlyActive %}
                        <span style="display:inline-block;padding:4px 12px;border-radius:12px;font-size:11px;font-weight:600;background:rgba(69,248,130,0.1);color:#45f882;">Actif</span>
                    {% elseif promo.endDate < date() %}
                        <span style="display:inline-block;padding:4px 12px;border-radius:12px;font-size:11px;font-weight:600;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.4);">Termine</span>
                    {% else %}
                        <span style="display:inline-block;padding:4px 12px;border-radius:12px;font-size:11px;font-weight:600;background:rgba(255,193,7,0.1);color:#ffc107;">A venir</span>
                    {% endif %}
                    <div style="font-size:11px;color:rgba(255,255,255,0.4);margin-top:4px;">{{ promo.cost }} NexBits</div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
