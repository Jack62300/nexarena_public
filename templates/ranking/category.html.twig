{% extends 'base.html.twig' %}

{% set _year = 'now'|date('Y') %}
{% set _base_url = setting('seo_site_url', app.request.schemeAndHttpHost) %}

{% block title %}Top Serveur {{ category.name }} {{ _year }} - Classement | {{ setting('site_name', 'Nexarena') }}{% endblock %}
{% block meta_description %}Top serveur {{ category.name }} {{ _year }} : decouvrez les {{ totalServers }} meilleurs serveurs {{ category.name }} classes par votes. {{ gameCategories|length }} categories disponibles sur {{ setting('site_name', 'Nexarena') }}.{% endblock %}

{% block og_image %}
    {% if category.image %}
    <meta property="og:image" content="{{ app.request.schemeAndHttpHost ~ asset('uploads/categories/' ~ category.image) }}">
    <meta property="og:image:alt" content="Top Serveur {{ category.name }}">
    {% elseif setting('seo_og_image') %}
    <meta property="og:image" content="{{ app.request.schemeAndHttpHost ~ '/' ~ setting('seo_og_image') }}">
    {% endif %}
{% endblock %}

{% block json_ld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ ('Top Serveur ' ~ category.name ~ ' ' ~ _year)|json_encode|raw }},
  "description": {{ ('Classement des meilleurs serveurs ' ~ category.name ~ '. ' ~ totalServers ~ ' serveurs, ' ~ gameCategories|length ~ ' categories.')|json_encode|raw }},
  "url": {{ (_base_url ~ path('ranking_category', {slug: category.slug}))|json_encode|raw }},
  "inLanguage": "fr-FR",
  "isPartOf": {"@id": {{ (_base_url ~ '/#website')|json_encode|raw }}},
  "numberOfItems": {{ totalServers }},
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Accueil","item":{{ _base_url|json_encode|raw }}},
      {"@type":"ListItem","position":2,"name":{{ ('Top Serveur ' ~ category.name)|json_encode|raw }},"item":{{ (_base_url ~ path('ranking_category', {slug: category.slug}))|json_encode|raw }}}
    ]
  }
  {% if gameCategories|length > 0 %},
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {% for gc in gameCategories %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": {{ ('Top Serveur ' ~ gc.name)|json_encode|raw }},
        "url": {{ (_base_url ~ path('ranking_game_category', {slug: gc.slug}))|json_encode|raw }}
      }{{ not loop.last ? ',' : '' }}
      {% endfor %}
    ]
  }
  {% endif %}
}
</script>
{% endblock %}

{% block body %}

    {# ===== PAGE HEADER ===== #}
    <section class="nx-rk-header">
        <div class="container">
            <nav aria-label="breadcrumb" class="nx-rk-breadcrumb">
                <ol>
                    <li><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li><i class="fas fa-chevron-right"></i></li>
                    <li class="active">{{ category.name }}</li>
                </ol>
            </nav>

            <div class="nx-rk-header__content">
                <div class="nx-rk-header__left">
                    <div class="nx-rk-header__icon">
                        {% if category.image %}
                            <img src="{{ asset('uploads/categories/' ~ category.image) }}" alt="{{ category.name }}">
                        {% else %}
                            <i class="{{ category.icon ?? 'fas fa-gamepad' }}"></i>
                        {% endif %}
                    </div>
                    <div>
                        <h1 class="nx-rk-header__title">Top Serveur {{ category.name }}</h1>
                        {% if category.description %}
                            <p class="nx-rk-header__desc">{{ category.description }}</p>
                        {% endif %}
                    </div>
                </div>
                <div class="nx-rk-header__right" style="display:flex;gap:12px;">
                    <div class="nx-rk-header__stat">
                        <span class="nx-rk-header__stat-value">{{ totalServers }}</span>
                        <span class="nx-rk-header__stat-label">serveur{{ totalServers > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="nx-rk-header__stat">
                        <span class="nx-rk-header__stat-value">{{ gameCategories|length }}</span>
                        <span class="nx-rk-header__stat-label">sous-cat.</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ===== SUBCATEGORIES GRID ===== #}
    <section class="nx-cat-grid-section">
        <div class="container">
            {% if gameCategories|length > 0 %}
                <div class="nx-cat-grid">
                    {% for gc in gameCategories %}
                        {% set count = serverCounts[gc.id] ?? 0 %}
                        <a href="{{ path('ranking_game_category', {slug: gc.slug}) }}" class="nx-cat-card wow fadeInUp" data-wow-delay="{{ (loop.index0 * 0.06)|round(2) }}s" title="Top serveur {{ gc.name }}">
                            <div class="nx-cat-card__img">
                                <img src="{{ asset(gc_image(gc, category)) }}" alt="Top serveur {{ gc.name }}" loading="lazy">
                                {% if gc.icon %}
                                    <div class="nx-cat-card__icon-badge">
                                        <img src="{{ asset('uploads/categories/' ~ gc.icon) }}" alt="">
                                    </div>
                                {% endif %}
                            </div>
                            <div class="nx-cat-card__body">
                                <h3 class="nx-cat-card__name">{{ gc.name }}</h3>
                                <span class="nx-cat-card__count">
                                    <i class="fas fa-server"></i> {{ count }} serveur{{ count > 1 ? 's' : '' }}
                                </span>
                            </div>
                            <div class="nx-cat-card__arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                            <div class="nx-cat-card__glow"></div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="nx-rk-empty">
                    <div class="nx-rk-empty__icon">
                        <i class="{{ category.icon ?? 'fas fa-gamepad' }}"></i>
                    </div>
                    <h3 class="nx-rk-empty__title">Aucune sous-categorie</h3>
                    <p class="nx-rk-empty__text">Cette categorie ne contient pas encore de sous-categories.</p>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/ranking.css') }}">
<style>
.nx-rk-header__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 12px;
    padding: 6px;
}
</style>
{% endblock %}
