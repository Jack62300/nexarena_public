    cursor: pointer;
}
.nx-pg-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(69,248,130,0.06), transparent);
    opacity: 0;
    transition: opacity 0.3s;
}
.nx-pg-btn:hover {
