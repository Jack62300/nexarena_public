{% extends 'base.html.twig' %}

{% block title %}Mes favoris - {{ setting('site_name', 'Nexarena') }}{% endblock %}
{% block robots %}<meta name="robots" content="noindex, nofollow">{% endblock %}

{% block stylesheets %}
<style>
.fav-page { padding: 0 0 80px; background: #0a1018; }

.fav-header {
    padding: 130px 0 30px;
}
.fav-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
}
.fav-header__left {
    display: flex;
    align-items: center;
    gap: 16px;
}
.fav-header__icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(239,68,68,0.12), rgba(239,68,68,0.03));
    border: 1px solid rgba(239,68,68,0.15);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.fav-header__icon i { font-size: 20px; color: #ef4444; }
.fav-header__title {
    font-size: 28px; font-weight: 800; color: #fff; margin: 0;
    font-family: var(--tg-heading-font-family);
}
.fav-header__count {
    font-size: 13px; color: rgba(255,255,255,0.4); margin-top: 2px;
}
.fav-header__count strong { color: #ef4444; }

/* List */
.fav-list { display: flex; flex-direction: column; gap: 6px; }

.fav-item {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #0e151c;
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 10px;
    padding: 12px 16px;
    transition: all .25s;
}
.fav-item:hover {
    border-color: rgba(69,248,130,0.12);
    background: #111a22;
}

.fav-item__pos {
    width: 32px; flex-shrink: 0;
    font-size: 13px; font-weight: 700;
    color: rgba(255,255,255,0.25);
    text-align: center;
    font-family: var(--tg-heading-font-family);
}

.fav-item__thumb {
    width: 40px; height: 40px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    display: block;
}
.fav-item__thumb img { width: 100%; height: 100%; object-fit: cover; }
.fav-item__thumb-ph {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, rgba(69,248,130,0.08), rgba(69,248,130,0.02));
    border: 1px solid rgba(69,248,130,0.1);
    display: flex; align-items: center; justify-content: center;
    border-radius: 8px;
}
.fav-item__thumb-ph i { font-size: 14px; color: rgba(69,248,130,0.4); }

.fav-item__info { flex: 1; min-width: 0; }
.fav-item__name {
    font-size: 14px; font-weight: 700; color: #fff; margin: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.fav-item__name a { color: #fff; transition: color .2s; text-decoration: none; }
.fav-item__name a:hover { color: #45f882; }
.fav-item__meta {
    display: flex; align-items: center; gap: 12px;
    font-size: 11px; color: rgba(255,255,255,0.3); margin-top: 2px;
}
.fav-item__meta i { font-size: 9px; margin-right: 3px; }
.fav-item__meta-sep { color: rgba(255,255,255,0.1); }

.fav-item__votes {
    display: flex; align-items: center; gap: 5px;
    flex-shrink: 0; padding: 0 10px;
}
.fav-item__votes i { font-size: 11px; color: #45f882; opacity: .6; }
.fav-item__votes-count {
    font-size: 15px; font-weight: 800; color: #fff;
    font-family: var(--tg-heading-font-family);
}

.fav-item__rating {
    display: flex; align-items: center; gap: 3px;
    flex-shrink: 0;
    font-size: 12px; font-weight: 600; color: #fbbf24;
}
.fav-item__rating i { font-size: 10px; }

.fav-item__actions {
    display: flex; align-items: center; gap: 6px;
    flex-shrink: 0;
}
.fav-item__btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 5px; padding: 7px 14px;
    border-radius: 6px; font-size: 12px; font-weight: 600;
    text-decoration: none; transition: all .2s;
    border: none; cursor: pointer;
}
.fav-item__btn--view {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.6);
}
.fav-item__btn--view:hover {
    background: #45f882; border-color: #45f882; color: #0e151c;
}
.fav-item__btn--remove {
    background: rgba(239,68,68,0.06);
    border: 1px solid rgba(239,68,68,0.12);
    color: rgba(239,68,68,0.6);
    padding: 7px 9px;
}
.fav-item__btn--remove:hover {
    background: rgba(239,68,68,0.15);
    border-color: rgba(239,68,68,0.3);
    color: #ef4444;
}

/* Empty */
.fav-empty {
    text-align: center; padding: 80px 20px;
    background: rgba(255,255,255,0.02);
    border: 1px dashed rgba(255,255,255,0.06);
    border-radius: 16px;
}

@media (max-width: 767px) {
    .fav-header { padding: 110px 0 24px; }
    .fav-header__title { font-size: 22px; }
    .fav-item { padding: 10px 12px; gap: 10px; }
    .fav-item__thumb { width: 34px; height: 34px; }
    .fav-item__pos { width: 24px; font-size: 11px; }
    .fav-item__meta { display: none; }
    .fav-item__rating { display: none; }
    .fav-item__btn--view span { display: none; }
    .fav-item__btn--view { padding: 7px 9px; }
}
</style>
{% endblock %}

{% block body %}

    <section class="fav-page">

        <div class="container">
            <div class="fav-header">
                <div class="fav-header__inner">
                    <div class="fav-header__left">
                        <div class="fav-header__icon"><i class="fas fa-heart"></i></div>
                        <div>
                            <h1 class="fav-header__title">Mes favoris</h1>
                            <div class="fav-header__count"><strong>{{ total }}</strong> serveur{{ total > 1 ? 's' : '' }} en favoris</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container">
            {% if favorites|length > 0 %}
                <div class="fav-list">
                    {% for fav in favorites %}
                        {% set server = fav.server %}
                        <div class="fav-item">
                            <div class="fav-item__pos">{{ (page - 1) * 20 + loop.index }}</div>

                            <a href="{{ path('server_show', {slug: server.slug}) }}" class="fav-item__thumb">
                                {% if server.presentationImage %}
                                    <img src="{{ asset('uploads/servers/presentations/' ~ server.presentationImage) }}" alt="{{ server.name }}">
                                {% else %}
                                    <div class="fav-item__thumb-ph"><i class="fas fa-server"></i></div>
                                {% endif %}
                            </a>

                            <div class="fav-item__info">
                                <h4 class="fav-item__name">
                                    <a href="{{ path('server_show', {slug: server.slug}) }}">{{ server.name }}</a>
                                </h4>
                                <div class="fav-item__meta">
                                    {% if server.gameCategory %}
                                        <span><i class="fas fa-gamepad"></i>{{ server.gameCategory.name }}</span>
                                    {% elseif server.category %}
                                        <span><i class="{{ server.category.icon ?? 'fas fa-folder' }}"></i>{{ server.category.name }}</span>
                                    {% endif %}
                                    <span class="fav-item__meta-sep">·</span>
                                    <span><i class="fas fa-clock"></i>{{ fav.createdAt|time_ago }}</span>
                                </div>
                            </div>

                            {% if server.averageRating %}
                                <div class="fav-item__rating">
                                    <i class="fas fa-star"></i> {{ server.averageRating|number_format(1) }}
                                </div>
                            {% endif %}

                            <div class="fav-item__votes">
                                <i class="fas fa-fire"></i>
                                <span class="fav-item__votes-count">{{ server.monthlyVotes }}</span>
                            </div>

                            <div class="fav-item__actions">
                                <a href="{{ path('server_show', {slug: server.slug}) }}" class="fav-item__btn fav-item__btn--view">
                                    <span>Voir</span> <i class="fas fa-arrow-right"></i>
                                </a>
                                <form method="post" action="{{ path('app_server_favorite_toggle', {slug: server.slug}) }}" style="margin:0;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('favorite_' ~ server.id) }}">
                                    <button type="submit" class="fav-item__btn fav-item__btn--remove" title="Retirer des favoris">
                                        <i class="fas fa-heart-broken"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {# Pagination #}
                {% if pages > 1 %}
                    <div class="nx-rk-pagination">
                        {% if page > 1 %}
                            <a href="{{ path('app_favorites', {page: page - 1}) }}" class="nx-pg-arrow"><i class="fas fa-chevron-left"></i></a>
                        {% endif %}
                        {% for p in 1..pages %}
                            {% if p == page %}
                                <span class="nx-pg-btn nx-pg-active">{{ p }}</span>
                            {% elseif p <= 2 or p >= pages - 1 or (p >= page - 2 and p <= page + 2) %}
                                <a href="{{ path('app_favorites', {page: p}) }}" class="nx-pg-btn">{{ p }}</a>
                            {% elseif p == 3 or p == pages - 2 %}
                                <span class="nx-pg-dots">...</span>
                            {% endif %}
                        {% endfor %}
                        {% if page < pages %}
                            <a href="{{ path('app_favorites', {page: page + 1}) }}" class="nx-pg-arrow"><i class="fas fa-chevron-right"></i></a>
                        {% endif %}
                    </div>
                {% endif %}

            {% else %}
                <div class="fav-empty">
                    <div style="font-size:48px;margin-bottom:16px;color:rgba(255,255,255,0.1);"><i class="fas fa-heart"></i></div>
                    <div style="color:rgba(255,255,255,0.4);font-size:18px;font-weight:700;margin-bottom:8px;">Aucun favori</div>
                    <p style="color:rgba(255,255,255,0.25);font-size:14px;margin:0;">Parcourez les serveurs et ajoutez vos preferes en cliquant sur le coeur.</p>
                </div>
            {% endif %}
        </div>

    </section>

{% endblock %}
