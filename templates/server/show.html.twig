{% block javascripts %}
<script>
(function() {
    /* === TABS === */
    var tabs = document.querySelectorAll('.sv-nav__link');
    tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
            tabs.forEach(function(t) { t.classList.remove('active'); });
            tab.classList.add('active');
            document.querySelectorAll('.sv-pane').forEach(function(p) { p.classList.remove('active'); });
            var pane = document.getElementById('pane-' + tab.getAttribute('data-tab'));
            if (pane) pane.classList.add('active');
        });
    });

    /* Auto-switch to avis tab if #comments in URL */
    if (window.location.hash === '#comments') {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        document.querySelectorAll('.sv-pane').forEach(function(p) { p.classList.remove('active'); });
        var avisTab = document.querySelector('.sv-nav__link[data-tab="avis"]');
        var avisPane = document.getElementById('pane-avis');
        if (avisTab) avisTab.classList.add('active');
        if (avisPane) avisPane.classList.add('active');
    }

    /* === VOTE === */
    var cooldownSeconds = 0;
    var timerInterval = null;
    var slug = '{{ server.slug }}';

    function updateTimerDisplay() {
        var h = Math.floor(cooldownSeconds / 3600);
        var m = Math.floor((cooldownSeconds % 3600) / 60);
        var s = cooldownSeconds % 60;
        var text = '';
        if (h > 0) text += h + 'h ';
        text += (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s);
        document.getElementById('cooldownText').textContent = text;
    }

    function setVoteDisabled(disabled) {
        var btns = document.querySelectorAll('#voteBtnDiscord, #voteBtnSteam, #voteBtnDiscordMobile, #voteBtnSteamMobile');
        btns.forEach(function(btn) {
            if (disabled) {
                btn.classList.add('sv-vote__btn--disabled');
            } else {
                btn.classList.remove('sv-vote__btn--disabled');
            }
        });
    }

    function startTimer(seconds) {
        cooldownSeconds = seconds;
        if (cooldownSeconds <= 0) { stopTimer(); return; }
        setVoteDisabled(true);
        document.getElementById('voteTimer').style.display = 'block';
        updateTimerDisplay();
        if (timerInterval) clearInterval(timerInterval);
        timerInterval = setInterval(function() {
            cooldownSeconds--;
            if (cooldownSeconds <= 0) stopTimer();
            else updateTimerDisplay();
        }, 1000);
    }

    function stopTimer() {
        cooldownSeconds = 0;
        if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
        setVoteDisabled(false);
        document.getElementById('voteTimer').style.display = 'none';
    }

    function syncCounters(monthly, total) {
        document.getElementById('monthlyVotes').textContent = monthly;
        document.getElementById('totalVotes').textContent = total + ' au total';
        var mob = document.getElementById('monthlyVotesMobile');
        if (mob) mob.textContent = monthly;
    }

    function checkStatus() {
        fetch('/serveur/' + slug + '/vote-status')
        .then(function(r) { return r.json(); })
        .then(function(d) {
            syncCounters(d.monthly_votes, d.total_votes);
            if (!d.can_vote && d.cooldown > 0) startTimer(d.cooldown);
            else if (d.can_vote) setVoteDisabled(false);
        });
    }

    window.copyIp = function() {
        var ip = document.getElementById('serverIp') || document.getElementById('serverIpSidebar');
        if (!ip) return;
        navigator.clipboard.writeText(ip.textContent).then(function() {
            document.querySelectorAll('.sv-connect__copy').forEach(function(b) {
                b.innerHTML = '<i class="fas fa-check"></i>';
                setTimeout(function() { b.innerHTML = '<i class="fas fa-copy"></i>'; }, 2000);
            });
        });
    };

    /* === FLAG MODAL === */
    var flagTokens = {
        {% if app.user and app.user.id == server.owner.id %}
            {% for comment in comments %}
                {% if not comment.isFlagged %}
                    {{ comment.id }}: '{{ csrf_token('flag_comment_' ~ comment.id) }}',
                {% endif %}
            {% endfor %}
        {% endif %}
    };

    window.openFlagModal = function(commentId) {
        var modal = document.getElementById('flagModal');
        var form = document.getElementById('flagForm');
        var tokenInput = document.getElementById('flagToken');
        if (!modal || !form) return;
        form.action = '/serveur/' + slug + '/comment/' + commentId + '/flag';
        tokenInput.value = flagTokens[commentId] || '';
        modal.classList.add('active');
    };

    window.closeFlagModal = function() {
        var modal = document.getElementById('flagModal');
        if (modal) modal.classList.remove('active');
    };

    /* Close modal on background click */
    var flagModal = document.getElementById('flagModal');
    if (flagModal) {
        flagModal.addEventListener('click', function(e) {
            if (e.target === flagModal) closeFlagModal();
        });
    }

    checkStatus();

    /* === SERVER STATUS (hero badge) === */
    var statusBadge = document.getElementById('statusBadge');
    var serverId = {{ server.id }};
    var hasQueryType = {{ (server.ip and server.port) ? 'true' : 'false' }};

    function loadServerStatus() {
        fetch('/api/server-status/' + serverId)
        .then(function(r) { return r.json(); })
        .then(function(d) {
            // Update hero badge
            if (statusBadge) {
                if (d.online === true) {
                    statusBadge.className = 'sv-tag sv-tag--status online';
                    statusBadge.innerHTML = '<span class="sv-status-dot"></span> ' + d.players + '/' + d.maxPlayers + ' En ligne';
                } else {
                    statusBadge.className = 'sv-tag sv-tag--status offline';
                    statusBadge.innerHTML = '<span class="sv-status-dot"></span> Hors ligne';
                }
            }

            // Update player count badge in tab
            var badge = document.getElementById('playerCountBadge');
            if (badge) {
                badge.textContent = d.online ? d.players : '0';
            }

            // Render server status pane
            var container = document.getElementById('serverStatusContent');
            if (!container) return;

            if (!d.online) {
                container.innerHTML = '<div class="sv-status-offline"><i class="fas fa-power-off"></i><div style="font-size:16px;font-weight:600;color:#e74a3b;margin-bottom:6px;">Serveur hors ligne</div><div>Le serveur ne repond pas actuellement.</div></div>';
                return;
            }

            var html = '';

            // Header with player count
            html += '<div class="sv-status-header">';
            html += '<div><div class="sv-status-header__count">' + d.players + '/' + d.maxPlayers + '</div>';
            html += '<div class="sv-status-header__label">joueurs connectes</div></div>';
            if (d.map) {
                html += '<div class="sv-status-header__map"><i class="fas fa-map-marked-alt"></i>' + escapeHtml(d.map) + '</div>';
            }
            html += '</div>';

            if (d.playerList && d.playerList.length > 0) {
                // Search bar
                html += '<input type="text" class="sv-player-search" id="playerSearch" placeholder="Rechercher un joueur..." oninput="filterPlayers()">';

                // Player table
                html += '<div style="background:rgba(var(--sv-bg-card-rgb),0.5);border:1px solid rgb(var(--sv-border-rgb));border-radius:14px;overflow:hidden;">';
                html += '<table class="sv-player-table">';
                html += '<thead><tr><th>ID</th><th>Nom</th>';
                if (d.playerList[0] && d.playerList[0].ping !== null) {
                    html += '<th>Ping</th>';
                }
                html += '</tr></thead><tbody id="playerTableBody">';

                d.playerList.forEach(function(p) {
                    html += '<tr class="sv-player-row" data-name="' + escapeHtml(p.name).toLowerCase() + '">';
                    html += '<td>' + p.id + '</td>';
                    html += '<td class="sv-player-name">' + escapeHtml(p.name) + '</td>';
                    if (p.ping !== null) {
                        var pingClass = 'sv-player-ping--good';
                        if (p.ping > 100) pingClass = 'sv-player-ping--bad';
                        else if (p.ping > 60) pingClass = 'sv-player-ping--medium';
                        html += '<td class="sv-player-ping ' + pingClass + '">' + p.ping + ' ms</td>';
                    }
                    html += '</tr>';
                });

                html += '</tbody></table></div>';
            } else if (d.players > 0) {
                html += '<div class="sv-status-empty"><i class="fas fa-users"></i><div>' + d.players + ' joueur(s) connecte(s)</div><div style="font-size:12px;margin-top:6px;">La liste detaillee n\'est pas disponible pour ce type de serveur.</div></div>';
            } else {
                html += '<div class="sv-status-empty"><i class="fas fa-ghost"></i><div>Aucun joueur connecte</div></div>';
            }

            container.innerHTML = html;
        })
        .catch(function() {
            if (statusBadge) statusBadge.style.display = 'none';
            var container = document.getElementById('serverStatusContent');
            if (container) {
                container.innerHTML = '<div class="sv-status-offline"><i class="fas fa-exclamation-triangle"></i><div>Impossible de recuperer le statut du serveur.</div></div>';
            }
        });
    }

    function escapeHtml(text) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
    }

    window.filterPlayers = function() {
        var search = document.getElementById('playerSearch');
        if (!search) return;
        var val = search.value.toLowerCase();
        var rows = document.querySelectorAll('.sv-player-row');
        rows.forEach(function(row) {
            row.style.display = row.getAttribute('data-name').indexOf(val) !== -1 ? '' : 'none';
        });
    };

    if (hasQueryType) {
        loadServerStatus();
        // Refresh every 60 seconds
        setInterval(loadServerStatus, 60000);
    } else if (statusBadge) {
        // Fallback: simple online/offline check via existing endpoint
        fetch('/serveur/' + slug + '/status')
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.online === true) {
                statusBadge.className = 'sv-tag sv-tag--status online';
                statusBadge.innerHTML = '<span class="sv-status-dot"></span> En ligne';
            } else if (d.online === false) {
                statusBadge.className = 'sv-tag sv-tag--status offline';
                statusBadge.innerHTML = '<span class="sv-status-dot"></span> Hors ligne';
            } else {
                statusBadge.style.display = 'none';
            }
        })
        .catch(function() {
            statusBadge.style.display = 'none';
        });
    }
})();
</script>
{% if server.twitchChannel %}
<script>
/* === Twitch Integration === */
(function() {
    var serverId = {{ server.id }};
    var hasTwitchLive = {{ has_twitch_live ? 'true' : 'false' }};

    function formatNumber(n) {
        if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
        if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
        return n.toString();
    }

    function formatDuration(dur) {
        // dur = "1h23m45s" or "23m45s"
        var match = dur.match(/(?:(\d+)h)?(?:(\d+)m)?(?:(\d+)s)?/);
        if (!match) return dur;
        var h = match[1] || '0';
        var m = match[2] || '0';
        return h !== '0' ? h + 'h' + m.padStart(2, '0') : m + 'min';
    }

    function timeAgo(dateStr) {
        var d = new Date(dateStr);
        var now = new Date();
        var diff = Math.floor((now - d) / 1000);
        if (diff < 3600) return Math.floor(diff / 60) + ' min';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h';
        return Math.floor(diff / 86400) + 'j';
    }

    fetch('/api/twitch-info/' + serverId)
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.error) return;

        var ch = data.channel;
        var isLive = data.is_live;
        var followers = data.followers;

        // Update sidebar widget
        var nameEl = document.getElementById('twitchWidgetName');
        if (nameEl) nameEl.textContent = ch.display_name;

        var statusEl = document.getElementById('twitchWidgetStatus');
        if (statusEl) {
            if (isLive) {
                statusEl.innerHTML = '<span class="sv-twitch-widget__dot sv-twitch-widget__dot--live"></span> En direct';
                statusEl.classList.add('sv-twitch-widget__status--live');
            }
        }

        var avatarEl = document.getElementById('twitchWidgetAvatar');
        if (avatarEl && ch.profile_image_url) {
            avatarEl.innerHTML = '<img src="' + ch.profile_image_url + '" alt="' + ch.display_name + '">';
        }

        var followersEl = document.getElementById('twitchWidgetFollowers');
        if (followersEl) followersEl.textContent = formatNumber(followers);

        if (isLive && data.stream) {
            var viewersContainer = document.getElementById('twitchWidgetViewersContainer');
            if (viewersContainer) viewersContainer.style.display = '';
            var viewersStat = document.getElementById('twitchWidgetViewersStat');
            if (viewersStat) viewersStat.textContent = formatNumber(data.stream.viewer_count);
        }

        // Update stream tab bar
        var bar = document.getElementById('twitchBar');
        if (bar) {
            var barHtml = '<div class="sv-twitch-bar__inner">';
            barHtml += '<div class="sv-twitch-bar__left">';
            if (ch.profile_image_url) {
                barHtml += '<img src="' + ch.profile_image_url + '" alt="" class="sv-twitch-bar__avatar">';
            }
            barHtml += '<div class="sv-twitch-bar__info">';
            barHtml += '<div class="sv-twitch-bar__name">' + ch.display_name + '</div>';
            barHtml += '<div class="sv-twitch-bar__meta">' + formatNumber(followers) + ' followers</div>';
            barHtml += '</div></div>';
            barHtml += '<div class="sv-twitch-bar__right">';
            if (isLive) {
                barHtml += '<span class="sv-twitch-bar__live"><span class="sv-twitch-bar__live-dot"></span> EN DIRECT</span>';
                barHtml += '<span class="sv-twitch-bar__viewers"><i class="fas fa-eye"></i> ' + formatNumber(data.stream.viewer_count) + '</span>';
                barHtml += '<span class="sv-twitch-bar__game"><i class="fas fa-gamepad"></i> ' + (data.stream.game_name || '') + '</span>';
            } else {
                barHtml += '<span class="sv-twitch-bar__offline-badge">Hors ligne</span>';
            }
            barHtml += '</div></div>';
            bar.innerHTML = barHtml;
        }

        // Stream tab: update nav badge
        var streamTab = document.querySelector('.sv-nav__link[data-tab="stream"]');
        if (streamTab && isLive) {
            streamTab.innerHTML = '<span class="sv-twitch-bar__live-dot" style="display:inline-block;margin-right:5px;"></span> Stream';
        }

        if (hasTwitchLive) {
            var liveSection = document.getElementById('twitchLiveSection');
            var offlineSection = document.getElementById('twitchOfflineSection');
            var vodsSection = document.getElementById('twitchVodsSection');

            if (isLive) {
                if (liveSection) {
                    liveSection.style.display = 'block';
                    var titleEl = document.getElementById('twitchStreamTitle');
                    if (titleEl) titleEl.textContent = data.stream.title;
                    var countEl = document.getElementById('twitchViewerCount');
                    if (countEl) countEl.textContent = formatNumber(data.stream.viewer_count);
                }
            } else {
                if (offlineSection) offlineSection.style.display = 'block';
            }

            // VODs
            if (data.vods && data.vods.length > 0 && vodsSection) {
                vodsSection.style.display = 'block';
                var grid = document.getElementById('twitchVodsGrid');
                if (grid) {
                    var vodsHtml = '';
                    data.vods.forEach(function(vod) {
                        var thumb = vod.thumbnail_url || '';
                        if (thumb === '') thumb = 'https://static-cdn.jtvnw.net/ttv-static/404_preview-320x180.jpg';
                        vodsHtml += '<a href="' + vod.url + '" target="_blank" rel="noopener" class="sv-twitch-vod">';
                        vodsHtml += '<div class="sv-twitch-vod__thumb"><img src="' + thumb + '" alt="">';
                        vodsHtml += '<span class="sv-twitch-vod__duration">' + formatDuration(vod.duration) + '</span></div>';
                        vodsHtml += '<div class="sv-twitch-vod__info">';
                        vodsHtml += '<div class="sv-twitch-vod__title">' + vod.title + '</div>';
                        vodsHtml += '<div class="sv-twitch-vod__meta">';
                        vodsHtml += '<span><i class="fas fa-eye"></i> ' + formatNumber(vod.view_count) + '</span>';
                        vodsHtml += '<span>il y a ' + timeAgo(vod.created_at) + '</span>';
                        vodsHtml += '</div></div></a>';
                    });
                    grid.innerHTML = vodsHtml;
                }
            }
        }
    })
    .catch(function() {
        var bar = document.getElementById('twitchBar');
        if (bar) bar.innerHTML = '<div class="sv-twitch-bar__inner sv-twitch-bar__error"><i class="fab fa-twitch" style="color:#9146ff;margin-right:8px;"></i> Informations Twitch indisponibles</div>';
    });
})();
</script>
{% endif %}

<script>
/* === Browser Fingerprint === */
(function() {
    function computeFingerprint() {
        var components = [];
        components.push(navigator.userAgent || '');
        components.push(navigator.language || '');
        components.push(screen.width + 'x' + screen.height + 'x' + screen.colorDepth);
        components.push(new Date().getTimezoneOffset().toString());
        components.push(navigator.hardwareConcurrency || '');
        components.push(navigator.platform || '');

        // Canvas fingerprint
        try {
            var canvas = document.createElement('canvas');
            canvas.width = 200;
            canvas.height = 50;
            var ctx = canvas.getContext('2d');
            ctx.textBaseline = 'top';
            ctx.font = '14px Arial';
            ctx.fillStyle = '#f60';
            ctx.fillRect(125, 1, 62, 20);
            ctx.fillStyle = '#069';
            ctx.fillText('Nexarena fp', 2, 15);
            ctx.fillStyle = 'rgba(102, 204, 0, 0.7)';
            ctx.fillText('Nexarena fp', 4, 17);
            components.push(canvas.toDataURL());
        } catch (e) {
            components.push('canvas_error');
        }

        // WebGL
        try {
            var gl = document.createElement('canvas').getContext('webgl');
            if (gl) {
                var debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
                if (debugInfo) {
                    components.push(gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL));
                }
            }
        } catch (e) {
            components.push('webgl_error');
        }

        var raw = components.join('|||');

        // SHA-256 hash
        return crypto.subtle.digest('SHA-256', new TextEncoder().encode(raw)).then(function(hash) {
            var bytes = new Uint8Array(hash);
            var hex = '';
            for (var i = 0; i < bytes.length; i++) {
                hex += bytes[i].toString(16).padStart(2, '0');
            }
            return hex;
        });
    }

    computeFingerprint().then(function(fp) {
        // Populate hidden fp inputs in vote forms
        ['fpDiscord','fpSteam','fpDiscordMobile','fpSteamMobile'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.value = fp;
        });
    }).catch(function() {
        // Fingerprint unavailable, vote without it
    });
})();

