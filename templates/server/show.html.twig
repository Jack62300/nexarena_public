                            <div class="sv-twitch-widget__body" id="twitchWidgetBody">
                                <div class="sv-twitch-widget__avatar" id="twitchWidgetAvatar"></div>
                                <div class="sv-twitch-widget__stats">
                                    <div class="sv-twitch-widget__stat">
                                        <div class="sv-twitch-widget__stat-value" id="twitchWidgetFollowers">--</div>
                                        <div class="sv-twitch-widget__stat-label">Followers</div>
                                    </div>
                                    <div class="sv-twitch-widget__stat" id="twitchWidgetViewersContainer" style="display:none;">
                                        <div class="sv-twitch-widget__stat-value" id="twitchWidgetViewersStat">0</div>
                                        <div class="sv-twitch-widget__stat-label">Spectateurs</div>
                                    </div>
                                </div>
                            </div>
                            <a href="https://twitch.tv/{{ server.twitchChannel }}" target="_blank" rel="noopener" class="sv-twitch-widget__link">
                                <i class="fab fa-twitch"></i> Voir la chaine
                            </a>
                        </div>
                    {% endif %}

                    {# Connection quick #}
                    {% if server.ip %}
                        <div class="sv-connect">
                            <div class="sv-connect__title">Rejoindre</div>
                            <div class="sv-connect__ip">
                                <code id="serverIpSidebar">{{ server.ip }}{% if server.port %}:{{ server.port }}{% endif %}</code>
                                <button type="button" class="sv-connect__copy" onclick="copyIp()" title="Copier">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    {% endif %}

                    {# Similar servers #}
                    {% if similarServers|length > 0 %}
                        <div class="sv-similar">
                            <div class="sv-similar__title">Serveurs similaires</div>
