{% if app.user %}
window.updateDonatePreview = function() {
    var nexbits = parseInt(document.getElementById('donateNexbits').value) || 0;
    var nexboost = parseInt(document.getElementById('donateNexboost').value) || 0;
    var btn = document.getElementById('donateTriggerBtn');
    if (btn) {
        btn.disabled = (nexbits <= 0 && nexboost <= 0);
    }
};

window.openDonateModal = function() {
    var nexbits = parseInt(document.getElementById('donateNexbits').value) || 0;
    var nexboost = parseInt(document.getElementById('donateNexboost').value) || 0;
    if (nexbits <= 0 && nexboost <= 0) return;

    var summary = document.getElementById('donateModalSummary');
    summary.innerHTML = '';
    if (nexbits > 0) {
        var li = document.createElement('li');
        li.innerHTML = '<strong>' + nexbits + '</strong> NexBits';
        summary.appendChild(li);
    }
    if (nexboost > 0) {
        var li2 = document.createElement('li');
        li2.innerHTML = '<strong>' + nexboost + '</strong> NexBoost';
        summary.appendChild(li2);
    }

    var modal = new bootstrap.Modal(document.getElementById('donateModal'));
    modal.show();
};

window.submitDonateForm = function() {
    var modalEl = document.getElementById('donateModal');
    var bsModal = bootstrap.Modal.getInstance(modalEl);
    if (bsModal) bsModal.hide();
    document.getElementById('donateForm').submit();
};
{% endif %}
</script>
{% endblock %}
