{% extends 'base.html.twig' %}

{% block title %}{{ server.name }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}
{% block meta_description %}{{ server.shortDescription }}{% endblock %}

{% block stylesheets %}
{% set theme = server_theme(server.pageTemplate) %}
{% set theme_bg = theme_image(server.pageTemplate, 'bg') %}
{% set theme_decor_l = theme_image(server.pageTemplate, 'decor-left') %}
{% set theme_decor_r = theme_image(server.pageTemplate, 'decor-right') %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/server-show.css') }}">
<style>
    :root {
        --sv-accent: {{ theme.primary }};
        --sv-accent-dark: {{ theme.secondary }};
        --sv-accent-rgb: {{ theme.rgb }};
        --sv-bg-body: {{ theme.bg_body }};
        --sv-bg-card-rgb: {{ theme.bg_card_rgb }};
        --sv-border-rgb: {{ theme.border_rgb }};
        --sv-hero-from: {{ theme.hero_from }};
        --sv-hero-to: {{ theme.hero_to }};
        --sv-glow: {{ theme.glow }};
    }
    .sv-page-bg__overlay {
        opacity: {{ theme.overlay_opacity }};
    }
</style>
<style>
.sv-donate-widget {
    background: rgba(var(--sv-bg-card-rgb), 0.85);
    border: 1px solid rgba(var(--sv-border-rgb), 0.25);
    border-radius: 14px;
    padding: 18px;
    margin-bottom: 16px;
}
.sv-donate-widget--guest p {
    font-size: 13px;
    color: #8892a4;
    margin: 8px 0 0;
    text-align: center;
}
.sv-donate-widget--guest a {
    color: var(--sv-accent);
    text-decoration: none;
}
.sv-donate-widget__header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 14px;
    color: var(--sv-accent);
    margin-bottom: 14px;
    letter-spacing: .5px;
}
.sv-donate-widget__fields {
    display: flex;
    flex-direction: column;
    gap: 12px;
}
.sv-donate-widget__field label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: #b0b8cc;
    margin-bottom: 4px;
}
.sv-donate-widget__input {
    width: 100%;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(var(--sv-border-rgb), 0.35);
    border-radius: 8px;
    padding: 8px 12px;
    color: #e0e6ff;
    font-size: 14px;
    outline: none;
    transition: border-color .2s;
}
.sv-donate-widget__input:focus {
    border-color: var(--sv-accent);
}
.sv-donate-widget__balance {
    display: block;
    font-size: 11px;
    color: #6b7280;
    margin-top: 3px;
}
.sv-donate-widget__warning {
    background: rgba(255,100,0,0.1);
    border: 1px solid rgba(255,100,0,0.3);
    border-radius: 8px;
    padding: 9px 12px;
    margin-top: 14px;
    font-size: 12px;
    color: #f4a14a;
}
.sv-donate-widget__btn {
    width: 100%;
    margin-top: 14px;
    background: var(--sv-accent);
    color: #000;
    font-weight: 700;
    font-size: 14px;
    border: none;
    border-radius: 9px;
    padding: 10px;
    cursor: pointer;
    transition: opacity .2s, transform .15s;
}
.sv-donate-widget__btn:hover:not(:disabled) {
    opacity: .88;
    transform: translateY(-1px);
}
.sv-donate-widget__btn:disabled {
    opacity: .35;
    cursor: not-allowed;
}
</style>
{% endblock %}

{% block body %}
{% set theme = server_theme(server.pageTemplate) %}
{% set theme_bg = theme_image(server.pageTemplate, 'bg') %}
{% set theme_decor_l = theme_image(server.pageTemplate, 'decor-left') %}
{% set theme_decor_r = theme_image(server.pageTemplate, 'decor-right') %}

{# ===== THEME BACKGROUND ===== #}
<div class="sv-page-bg">
    {% if theme_bg %}
        <div class="sv-page-bg__img" style="background-image: url('{{ asset(theme_bg) }}')"></div>
    {% endif %}
    <div class="sv-page-bg__overlay"></div>
    <div class="sv-page-bg__vignette"></div>
</div>

{# ===== DECORATIVE ELEMENTS ===== #}
{% if theme_decor_l %}
    <img src="{{ asset(theme_decor_l) }}" alt="" class="sv-decor sv-decor--left">
{% endif %}
{% if theme_decor_r %}
    <img src="{{ asset(theme_decor_r) }}" alt="" class="sv-decor sv-decor--right">
{% endif %}

{# ===== HERO SECTION ===== #}
<section class="sv-hero">
    <div class="sv-hero__bg">
        <div class="sv-hero__bg-glow"></div>
        <div class="sv-hero__bg-glow-left"></div>
    </div>
    <div class="container sv-hero__inner">

        {% if server.banner %}
            <img src="{{ asset('uploads/servers/banners/' ~ server.banner) }}" alt="{{ server.name }}" class="sv-hero__banner">
        {% endif %}

        <div class="sv-hero__header">
            <div class="sv-hero__icon">
                {% if server.category and server.category.icon %}
                    <i class="{{ server.category.icon }}"></i>
                {% else %}
                    <i class="fas fa-server"></i>
                {% endif %}
            </div>

            <div class="sv-hero__info">
                <h1 class="sv-hero__name">{{ server.name }}</h1>
                <div class="sv-hero__tags">
                    {% if server.category %}
                        <span class="sv-tag sv-tag--cat"><i class="fas fa-folder"></i> {{ server.category.name }}</span>
                    {% endif %}
                    {% if server.gameCategory %}
                        <span class="sv-tag sv-tag--game"><i class="fas fa-gamepad"></i> {{ server.gameCategory.name }}</span>
                    {% endif %}
                    {% if server.serverType %}
                        <span class="sv-tag sv-tag--type"><i class="fas fa-tag"></i> {{ server.serverType.name }}</span>
                    {% endif %}
                    {% if server.slots > 0 %}
                        <span class="sv-tag sv-tag--slots"><i class="fas fa-users"></i> {{ server.slots }} slots</span>
                    {% endif %}
                    <span class="sv-tag sv-tag--access">
                        <i class="fas {{ server.isPrivate ? 'fa-lock' : 'fa-lock-open' }}"></i>
                        {{ server.isPrivate ? 'Prive' : 'Public' }}
                    </span>
                    {% if server.statusCheckEnabled and server.ip and server.port %}
                        <span class="sv-tag sv-tag--status" id="statusBadge">
                            <span class="sv-status-dot"></span> Verification...
                        </span>
                    {% endif %}
                    {% for tag in server.tags %}
                        <span class="sv-tag sv-tag--custom" {% if tag.color %}style="background:{{ tag.color }}20;color:{{ tag.color }};border-color:{{ tag.color }}40;"{% endif %}>
                            <i class="fas fa-hashtag"></i> {{ tag.name }}
                        </span>
                    {% endfor %}
                </div>
                {% if server.shortDescription %}
                    <p class="sv-hero__short">{{ server.shortDescription }}</p>
                {% endif %}
                <div class="sv-hero__dates">
                    <span><i class="fas fa-calendar-plus"></i> Créé {{ server.createdAt|time_ago }}</span>
                    {% if server.updatedAt and server.updatedAt != server.createdAt %}
                        <span><i class="fas fa-pencil-alt"></i> Modifié {{ server.updatedAt|time_ago }}</span>
                    {% endif %}
                </div>
            </div>

        </div>
    </div>
</section>

{# ===== NAV TABS ===== #}
<div class="sv-nav">
    <div class="container">
        <div class="sv-nav__inner">
            <a class="sv-nav__link active" data-tab="description">Description</a>
            <a class="sv-nav__link" data-tab="avis">
                Avis <span class="sv-nav__badge">{{ commentCount }}</span>
            </a>
            {% if server.ip and server.port %}
                <a class="sv-nav__link" data-tab="serveur">
                    Serveur <span class="sv-nav__badge" id="playerCountBadge">...</span>
                </a>
            {% endif %}
            {% if server.twitchChannel %}
                <a class="sv-nav__link" data-tab="stream">Stream</a>
            {% endif %}
            {% if server.ip or server.website or server.discordUrl %}
                <a class="sv-nav__link" data-tab="infos">Infos</a>
            {% endif %}
        </div>
    </div>
</div>

{# ===== CONTENT ===== #}
<section class="sv-content">
    <div class="container">
        <div class="row g-4">

            {# ===== MAIN COL ===== #}
            <div class="col-lg-8">

                {# Tab: Description #}
                <div class="sv-pane active" id="pane-description">
                    {% if server.fullDescription %}
                        <div class="sv-desc">
                            {{ server.fullDescription|raw }}
                        </div>
                    {% else %}
                        <div class="sv-desc" style="color:#5a5c69;">
                            <p>Aucune description detaillee pour le moment.</p>
                        </div>
                    {% endif %}

                    {% if server.presentationImage %}
                        <div class="sv-presentation">
                            <img src="{{ asset('uploads/servers/presentations/' ~ server.presentationImage) }}" alt="{{ server.name }}">
                        </div>
                    {% endif %}
                </div>

                {# Tab: Avis (Comments) #}
                <div class="sv-pane" id="pane-avis">
                    <div class="sv-comments" id="comments">

                        {# Comment form or login prompt #}
                        {% if app.user %}
                            <form method="post" action="{{ path('server_comment_post', {slug: server.slug}) }}" class="sv-comment-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('comment_' ~ server.id) }}">
                                {% set av = user_avatar(app.user) %}
                                {% if av %}
                                    <img src="{{ av starts with 'http' ? av : asset(av) }}" alt="{{ app.user.username }}" class="sv-comment-form__avatar">
                                {% else %}
                                    <div class="sv-comment-form__avatar-placeholder">
                                        {{ app.user.username|slice(0, 1)|upper }}
                                    </div>
                                {% endif %}
                                <div class="sv-comment-form__body">
                                    <textarea name="content" class="sv-comment-form__textarea" placeholder="Partagez votre avis sur ce serveur..." required minlength="3" maxlength="2000"></textarea>
                                    <div class="sv-comment-form__actions">
                                        <button type="submit" class="sv-comment-form__btn">
                                            <i class="fas fa-paper-plane"></i>&nbsp; Publier
                                        </button>
                                    </div>
                                </div>
                            </form>
                        {% else %}
                            <div class="sv-comment-login">
                                <div class="sv-comment-login__text">
                                    <i class="fas fa-comment-dots" style="font-size:20px;margin-bottom:8px;display:block;color:#3d4250;"></i>
                                    Connectez-vous pour donner votre avis sur ce serveur.
                                </div>
                                <a href="{{ path('app_login') }}" class="sv-comment-login__link">
                                    <i class="fas fa-sign-in-alt"></i>&nbsp; Se connecter
                                </a>
                            </div>
                        {% endif %}

                        {# Comments list #}
                        {% if comments|length > 0 %}
                            {% for comment in comments %}
                                <div class="sv-comment">
                                    {% set av = user_avatar(comment.author) %}
                                    {% if av %}
                                        <img src="{{ av starts with 'http' ? av : asset(av) }}" alt="{{ comment.author.username }}" class="sv-comment__avatar">
                                    {% else %}
                                        <div class="sv-comment__avatar-placeholder">
                                            {{ comment.author.username|slice(0, 1)|upper }}
                                        </div>
                                    {% endif %}
                                    <div class="sv-comment__body">
                                        <div class="sv-comment__header">
                                            <span class="sv-comment__author">{{ comment.author.username }}</span>
                                            <span class="sv-comment__date">{{ comment.createdAt|time_ago }}</span>
                                            {% if comment.isFlagged %}
                                                <span class="sv-comment__flagged-badge"><i class="fas fa-flag"></i> Signale</span>
                                            {% endif %}
                                        </div>
                                        <div class="sv-comment__content">{{ comment.content|e|nl2br }}</div>
                                        {% if app.user and app.user.id == server.owner.id and not comment.isFlagged %}
                                            <div class="sv-comment__actions">
                                                <button type="button" class="sv-comment__flag-btn" onclick="openFlagModal({{ comment.id }})">
                                                    <i class="fas fa-flag"></i> Signaler
                                                </button>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="sv-comment-empty">
                                <div class="sv-comment-empty__icon"><i class="fas fa-comments"></i></div>
                                <div class="sv-comment-empty__text">Soyez le premier a donner votre avis !</div>
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Tab: Serveur (live status + players) #}
                {% if server.ip and server.port %}
                    <div class="sv-pane" id="pane-serveur">
                        <div id="serverStatusContent">
                            <div class="sv-status-loading">
                                <i class="fas fa-circle-notch"></i>
                                Chargement du statut du serveur...
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Tab: Stream (Twitch) #}
                {% if server.twitchChannel %}
                    <div class="sv-pane" id="pane-stream">
                        {# Twitch channel info bar - loaded via JS #}
                        <div class="sv-twitch-bar" id="twitchBar">
                            <div class="sv-twitch-bar__loading">
                                <i class="fas fa-circle-notch fa-spin"></i> Chargement des informations Twitch...
                            </div>
                        </div>

                        {% if has_twitch_live %}
                            {# Premium: Live embed + chat #}
                            <div class="sv-twitch-live" id="twitchLiveSection" style="display:none;">
                                <div class="sv-twitch-live__header">
                                    <div class="sv-twitch-live__badge">
                                        <span class="sv-twitch-live__dot"></span> EN DIRECT
                                    </div>
                                    <span class="sv-twitch-live__title" id="twitchStreamTitle"></span>
                                    <span class="sv-twitch-live__viewers" id="twitchViewers">
                                        <i class="fas fa-eye"></i> <span id="twitchViewerCount">0</span>
                                    </span>
                                </div>
                                <div class="sv-twitch-live__player">
                                    <iframe
                                        id="twitchPlayerFrame"
                                        src="https://player.twitch.tv/?channel={{ server.twitchChannel }}&parent={{ app.request.host }}&muted=true"
                                        allowfullscreen>
                                    </iframe>
                                </div>
                            </div>

                            {# Offline message #}
                            <div class="sv-twitch-offline" id="twitchOfflineSection" style="display:none;">
                                <div class="sv-twitch-offline__icon"><i class="fab fa-twitch"></i></div>
                                <div class="sv-twitch-offline__text">La chaine n'est pas en direct actuellement.</div>
                                <div class="sv-twitch-offline__sub">Les rediffusions sont disponibles ci-dessous.</div>
                            </div>

                            {# VODs #}
                            <div class="sv-twitch-vods" id="twitchVodsSection" style="display:none;">
                                <h4 class="sv-twitch-vods__title">
                                    <i class="fas fa-video"></i> Rediffusions recentes
                                </h4>
                                <div class="sv-twitch-vods__grid" id="twitchVodsGrid"></div>
                            </div>
                        {% else %}
                            {# Not subscribed: teaser #}
                            <div class="sv-twitch-teaser" id="twitchTeaser">
                                <div class="sv-twitch-teaser__content">
                                    <i class="fab fa-twitch sv-twitch-teaser__icon"></i>
                                    <h4 class="sv-twitch-teaser__title">Direct & Rediffusions</h4>
                                    <p class="sv-twitch-teaser__text">
                                        Le direct Twitch et les rediffusions ne sont pas disponibles pour ce serveur.
                                    </p>
                                    <a href="https://twitch.tv/{{ server.twitchChannel }}" target="_blank" rel="noopener" class="sv-twitch-teaser__link">
                                        <i class="fab fa-twitch"></i> Regarder sur Twitch
                                    </a>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}

                {# Tab: Infos #}
                <div class="sv-pane" id="pane-infos">
                    <div class="row g-4">
                        {% if server.ip %}
                            <div class="col-md-6">
                                <div class="sv-connect">
                                    <div class="sv-connect__title">Adresse du serveur</div>
                                    <div class="sv-connect__ip">
                                        <code id="serverIp">{{ server.ip }}{% if server.port %}:{{ server.port }}{% endif %}</code>
                                        <button type="button" class="sv-connect__copy" onclick="copyIp()" title="Copier">
                                            <i class="fas fa-copy"></i>
                                        </button>
                                    </div>
                                    {% if server.connectUrl %}
                                        <a href="{{ server.connectUrl }}" target="_blank" rel="noopener" class="sv-connect__url">
                                            <i class="fas fa-external-link-alt"></i> Rejoindre le serveur
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}
                        <div class="col-md-6">
                            <div class="sv-connect">
                                <div class="sv-connect__title">Informations</div>
                                <div style="font-size:13px;color:#8b949e;">
                                    {% if server.category %}
                                        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgb(var(--sv-border-rgb));">
                                            <span>Categorie</span>
                                            <span style="color:#fff;">{{ server.category.name }}</span>
                                        </div>
                                    {% endif %}
                                    {% if server.gameCategory %}
                                        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgb(var(--sv-border-rgb));">
                                            <span>Jeu</span>
                                            <span style="color:#fff;">{{ server.gameCategory.name }}</span>
                                        </div>
                                    {% endif %}
                                    {% if server.serverType %}
                                        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgb(var(--sv-border-rgb));">
                                            <span>Type</span>
                                            <span style="color:#fff;">{{ server.serverType.name }}</span>
                                        </div>
                                    {% endif %}
                                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgb(var(--sv-border-rgb));">
                                        <span>Slots</span>
                                        <span style="color:#fff;">{{ server.slots > 0 ? server.slots : 'Illimite' }}</span>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;padding:8px 0;">
                                        <span>Acces</span>
                                        <span style="color:#fff;">{{ server.isPrivate ? 'Prive' : 'Public' }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# ===== SIDEBAR ===== #}
            <div class="col-lg-4">
                <div class="sv-sidebar">

                    {# Vote widget #}
                    <div class="sv-vote-widget" id="voteCard">
                        <div class="sv-vote__label">Votes ce mois</div>
                        <div class="sv-vote__count" id="monthlyVotes">{{ server.monthlyVotes }}</div>
                        <div class="sv-vote__total" id="totalVotes">{{ server.totalVotes }} au total</div>
                        <form method="post" action="{{ path('vote_prepare', {slug: server.slug}) }}" id="voteFormDiscord">
                            <input type="hidden" name="provider" value="discord">
                            <input type="hidden" name="fp" id="fpDiscord" value="">
                            <input type="hidden" name="_token" value="{{ csrf_token('vote_prepare_' ~ server.slug) }}">
                            <button type="submit" class="sv-vote__btn sv-vote__btn--discord" id="voteBtnDiscord">
                                <i class="fab fa-discord"></i> <span>Voter via Discord</span>
                            </button>
                        </form>
                        <div class="sv-vote__sep">ou</div>
                        <form method="post" action="{{ path('vote_prepare', {slug: server.slug}) }}" id="voteFormSteam">
                            <input type="hidden" name="provider" value="steam">
                            <input type="hidden" name="fp" id="fpSteam" value="">
                            <input type="hidden" name="_token" value="{{ csrf_token('vote_prepare_' ~ server.slug) }}">
                            <button type="submit" class="sv-vote__btn sv-vote__btn--steam" id="voteBtnSteam">
                                <i class="fab fa-steam"></i> <span>Voter via Steam</span>
                            </button>
                        </form>
                        <div class="sv-vote__timer" id="voteTimer">
                            <i class="fas fa-clock"></i> <span id="cooldownText">--:--</span>
                        </div>
                        <div class="sv-vote__msg" id="voteMessage"></div>
                    </div>

                    {# Donation widget #}
                    {% if app.user %}
                        <div class="sv-donate-widget">
                            <div class="sv-donate-widget__header">
                                <i class="fas fa-hand-holding-heart"></i>
                                <span>Soutenir ce serveur</span>
                            </div>
                            <form method="post" action="{{ path('server_donate', {slug: server.slug}) }}" id="donateForm">
                                <input type="hidden" name="_token" value="{{ csrf_token('donate_' ~ server.id) }}">
                                <div class="sv-donate-widget__fields">
                                    <div class="sv-donate-widget__field">
                                        <label for="donateNexbits">
                                            <i class="fas fa-coins" style="color:#f6c23e;"></i> NexBits
                                        </label>
                                        <input type="number" id="donateNexbits" name="nexbits" min="0" max="{{ app.user.tokenBalance }}" value="0" class="sv-donate-widget__input" oninput="updateDonatePreview()">
                                        <span class="sv-donate-widget__balance">Solde : {{ app.user.tokenBalance }} NexBits</span>
                                    </div>
                                    <div class="sv-donate-widget__field">
                                        <label for="donateNexboost">
                                            <i class="fas fa-rocket" style="color:#45f882;"></i> NexBoost
                                        </label>
                                        <input type="number" id="donateNexboost" name="nexboost" min="0" max="{{ app.user.boostTokenBalance }}" value="0" class="sv-donate-widget__input" oninput="updateDonatePreview()">
                                        <span class="sv-donate-widget__balance">Solde : {{ app.user.boostTokenBalance }} NexBoost</span>
                                    </div>
                                </div>
                                <div class="sv-donate-widget__warning">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    Ce don est <strong>definitif</strong> et <strong>non-remboursable</strong>.
                                </div>
                                <button type="button" class="sv-donate-widget__btn" onclick="openDonateModal()" id="donateTriggerBtn" disabled>
                                    <i class="fas fa-hand-holding-heart"></i> Faire un don
                                </button>
                            </form>
                        </div>
                    {% else %}
                        <div class="sv-donate-widget sv-donate-widget--guest">
                            <div class="sv-donate-widget__header">
                                <i class="fas fa-hand-holding-heart"></i>
                                <span>Soutenir ce serveur</span>
                            </div>
                            <p class="sv-donate-widget__guest-msg">
                                <a href="{{ path('app_login') }}">Connectez-vous</a> pour faire un don de NexBits ou NexBoost a ce serveur.
                            </p>
                        </div>
                    {% endif %}

                    {# Social icons #}
                    {% set hasSocials = server.website or server.discordUrl or server.twitterUrl or server.youtubeUrl or server.instagramUrl or server.twitchChannel %}
                    {% if hasSocials %}
                        <div class="sv-socials">
                            {% if server.website %}
                                <a href="{{ server.website }}" target="_blank" rel="noopener" class="sv-social sv-social--website" title="Site web">
                                    <i class="fas fa-globe"></i>
                                </a>
                            {% endif %}
                            {% if server.discordUrl %}
                                <a href="{{ server.discordUrl }}" target="_blank" rel="noopener" class="sv-social sv-social--discord" title="Discord">
                                    <i class="fab fa-discord"></i>
                                </a>
                            {% endif %}
                            {% if server.twitterUrl %}
                                <a href="{{ server.twitterUrl }}" target="_blank" rel="noopener" class="sv-social sv-social--twitter" title="Twitter / X">
                                    <i class="fab fa-twitter"></i>
                                </a>
                            {% endif %}
                            {% if server.youtubeUrl %}
                                <a href="{{ server.youtubeUrl }}" target="_blank" rel="noopener" class="sv-social sv-social--youtube" title="YouTube">
                                    <i class="fab fa-youtube"></i>
                                </a>
                            {% endif %}
                            {% if server.instagramUrl %}
