{% extends 'base.html.twig' %}

{% block title %}Recherche{% if query %} : {{ query }}{% endif %} - {{ setting('site_name', 'Nexarena') }}{% endblock %}
{% block meta_description %}Recherchez parmi les serveurs de jeux sur {{ setting('site_name', 'Nexarena') }}.{% endblock %}

{% block body %}

    {# breadcrumb-area #}
    <section class="breadcrumb-area" data-background="{{ asset('assets/img/bg/breadcrumb_bg01.jpg') }}">
        <div class="container">
            <div class="breadcrumb__wrapper">
                <div class="row">
                    <div class="col-xl-6 col-lg-7">
                        <div class="breadcrumb__content">
                            <h2 class="title">Recherche</h2>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Recherche</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="nx-rk-list" style="padding-top:40px;padding-bottom:60px;">
        <div class="container">

            {# Search bar #}
            <form action="{{ path('app_search') }}" method="GET" class="nx-search-form" style="margin-bottom:32px;">
                <div style="display:flex;gap:12px;max-width:600px;margin:0 auto;">
                    <input type="text" name="q" value="{{ query }}" placeholder="Rechercher un serveur..."
                           autofocus minlength="2" required
                           style="flex:1;background:#0d1b2d;border:1px solid #1e3048;border-radius:10px;padding:12px 18px;color:#fff;font-size:15px;outline:none;transition:border-color .2s;"
                           onfocus="this.style.borderColor='#45f882'" onblur="this.style.borderColor='#1e3048'">
                    <button type="submit" style="background:#45f882;color:#050d18;border:none;border-radius:10px;padding:12px 24px;font-weight:700;font-size:15px;cursor:pointer;display:flex;align-items:center;gap:8px;">
                        <i class="fas fa-search"></i> Rechercher
                    </button>
                </div>
            </form>

            {% if query %}
                <div style="text-align:center;margin-bottom:24px;color:rgba(255,255,255,0.5);font-size:14px;">
                    {{ total }} resultat{{ total > 1 ? 's' : '' }} pour <strong style="color:#45f882;">"{{ query }}"</strong>
                </div>
            {% endif %}

            {% if servers|length > 0 %}
                {# Table header - desktop only #}
                <div class="nx-rk-table-head d-none d-lg-flex">
                    <span class="nx-rk-table-head__pos">#</span>
                    <span class="nx-rk-table-head__server">Serveur</span>
                    <span class="nx-rk-table-head__votes">Votes</span>
                    <span class="nx-rk-table-head__action"></span>
                </div>

                <div class="nx-rk-rows">
                    {% for server in servers %}
                        <div class="nx-rk-row wow fadeInUp" data-wow-delay="{{ (loop.index0 * 0.05)|round(2) }}s">
                            <div class="nx-rk-row__pos">
                                <span class="nx-rk-pos">{{ (page - 1) * 20 + loop.index }}</span>
                            </div>
                            <div class="nx-rk-row__server">
                                <a href="{{ path('server_show', {slug: server.slug}) }}" class="nx-rk-row__thumb">
                                    {% if server.presentationImage %}
                                        <img src="{{ asset('uploads/servers/presentations/' ~ server.presentationImage) }}" alt="{{ server.name }}">
                                    {% else %}
                                        <div class="nx-rk-row__thumb-placeholder">
                                            <i class="fas fa-server"></i>
                                        </div>
                                    {% endif %}
                                </a>
                                <div class="nx-rk-row__info">
                                    <div class="nx-rk-row__name-row">
                                        <h4 class="nx-rk-row__name">
                                            <a href="{{ path('server_show', {slug: server.slug}) }}">{{ server.name }}</a>
                                        </h4>
                                    </div>
                                    {% if server.shortDescription %}
                                        <p class="nx-rk-row__desc">{{ server.shortDescription }}</p>
                                    {% endif %}
                                    <div class="nx-rk-row__tags">
                                        {% if server.gameCategory %}
                                            <span class="nx-rk-tag"><i class="fas fa-gamepad"></i> {{ server.gameCategory.name }}</span>
                                        {% elseif server.category %}
                                            <span class="nx-rk-tag"><i class="{{ server.category.icon ?? 'fas fa-folder' }}"></i> {{ server.category.name }}</span>
                                        {% endif %}
                                        {% if server.averageRating %}
                                            <span class="nx-rk-tag" style="color:#fbbf24;">
                                                <i class="fas fa-star"></i> {{ server.averageRating|number_format(1) }}
                                            </span>
                                        {% endif %}
                                        {% for tag in server.tags %}
                                            <span class="nx-rk-tag nx-rk-tag--custom" {% if tag.color %}style="background:{{ tag.color }}15;color:{{ tag.color }};border:1px solid {{ tag.color }}30;"{% endif %}>
                                                <i class="fas fa-hashtag" {% if tag.color %}style="color:{{ tag.color }} !important;opacity:1 !important;"{% endif %}></i> {{ tag.name }}
                                            </span>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                            <div class="nx-rk-row__votes">
                                <div class="nx-rk-row__votes-main">
                                    <i class="fas fa-fire"></i>
                                    <span class="nx-rk-row__votes-count">{{ server.monthlyVotes }}</span>
                                </div>
                                <span class="nx-rk-row__votes-label">votes ce mois</span>
                            </div>
                            <div class="nx-rk-row__action d-none d-lg-block">
                                <a href="{{ path('server_show', {slug: server.slug}) }}" class="nx-rk-btn">
                                    Voir <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {# Pagination #}
                {% if pages > 1 %}
                    <div class="nx-rk-pagination">
                        {% if page > 1 %}
                            <a href="{{ path('app_search', {q: query, page: page - 1}) }}" class="nx-pg-arrow"><i class="fas fa-chevron-left"></i></a>
                        {% endif %}
                        {% for p in 1..pages %}
                            {% if p == page %}
                                <span class="nx-pg-btn nx-pg-active">{{ p }}</span>
                            {% elseif p <= 2 or p >= pages - 1 or (p >= page - 2 and p <= page + 2) %}
                                <a href="{{ path('app_search', {q: query, page: p}) }}" class="nx-pg-btn">{{ p }}</a>
                            {% elseif p == 3 or p == pages - 2 %}
                                <span class="nx-pg-dots">...</span>
                            {% endif %}
                        {% endfor %}
                        {% if page < pages %}
                            <a href="{{ path('app_search', {q: query, page: page + 1}) }}" class="nx-pg-arrow"><i class="fas fa-chevron-right"></i></a>
                        {% endif %}
                    </div>
                {% endif %}

            {% elseif query %}
                <div class="nx-rk-empty" style="padding:80px 0;text-align:center;">
                    <div style="font-size:48px;margin-bottom:16px;color:rgba(255,255,255,0.15);"><i class="fas fa-search"></i></div>
                    <div style="color:rgba(255,255,255,0.5);font-size:16px;">Aucun serveur trouve pour <strong>"{{ query }}"</strong></div>
                    <p style="color:rgba(255,255,255,0.3);font-size:14px;margin-top:8px;">Essayez avec d'autres mots-cles ou parcourez les categories.</p>
                </div>
            {% else %}
                <div class="nx-rk-empty" style="padding:80px 0;text-align:center;">
                    <div style="font-size:48px;margin-bottom:16px;color:rgba(255,255,255,0.15);"><i class="fas fa-search"></i></div>
                    <div style="color:rgba(255,255,255,0.5);font-size:16px;">Tapez un nom de serveur pour lancer la recherche</div>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}
