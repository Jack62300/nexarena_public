{% extends 'base.html.twig' %}

{% block title %}Recherche{% if query %} : {{ query }}{% endif %} - {{ setting('site_name', 'Nexarena') }}{% endblock %}
{% block meta_description %}{% if query %}Resultats de recherche pour "{{ query }}" sur {{ setting('site_name', 'Nexarena') }}. Trouvez les meilleurs serveurs de jeux.{% else %}Recherchez parmi les serveurs de jeux sur {{ setting('site_name', 'Nexarena') }}.{% endif %}{% endblock %}
{% block robots %}<meta name="robots" content="noindex, follow">{% endblock %}

{% block stylesheets %}
<style>
.sr-page { padding: 0 0 80px; background: #0a1018; }

.sr-header { padding: 130px 0 30px; }
.sr-header__inner {
    display: flex; align-items: center; gap: 16px;
}
.sr-header__icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: linear-gradient(135deg, rgba(69,248,130,0.12), rgba(69,248,130,0.03));
    border: 1px solid rgba(69,248,130,0.15);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.sr-header__icon i { font-size: 20px; color: #45f882; }
.sr-header__title {
    font-size: 28px; font-weight: 800; color: #fff; margin: 0;
    font-family: var(--tg-heading-font-family);
}

/* Search bar */
.sr-bar {
    display: flex; gap: 10px;
    max-width: 640px; margin: 0 auto 28px;
}
.sr-bar__input {
    flex: 1; background: #0e151c;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px; padding: 11px 18px;
    color: #fff; font-size: 15px; outline: none;
    transition: border-color .2s;
}
.sr-bar__input:focus { border-color: #45f882; }
.sr-bar__input::placeholder { color: rgba(255,255,255,0.2); }
.sr-bar__btn {
    background: #45f882; color: #050d18; border: none;
    border-radius: 10px; padding: 11px 22px;
    font-weight: 700; font-size: 14px; cursor: pointer;
    display: flex; align-items: center; gap: 7px;
    transition: background .2s;
}
.sr-bar__btn:hover { background: #3de074; }

/* Result count */
.sr-count {
    text-align: center; margin-bottom: 20px;
    font-size: 13px; color: rgba(255,255,255,0.4);
}
.sr-count strong { color: #45f882; }

/* List */
.sr-list { display: flex; flex-direction: column; gap: 6px; }

.sr-item {
    display: flex; align-items: center; gap: 14px;
    background: #0e151c;
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 10px; padding: 12px 16px;
    transition: all .25s;
}
.sr-item:hover {
    border-color: rgba(69,248,130,0.12);
    background: #111a22;
}

.sr-item__pos {
    width: 32px; flex-shrink: 0;
    font-size: 13px; font-weight: 700;
    color: rgba(255,255,255,0.25);
    text-align: center;
    font-family: var(--tg-heading-font-family);
}

.sr-item__thumb {
    width: 40px; height: 40px;
    border-radius: 8px; overflow: hidden;
    flex-shrink: 0; display: block;
}
.sr-item__thumb img { width: 100%; height: 100%; object-fit: cover; }
.sr-item__thumb-ph {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, rgba(69,248,130,0.08), rgba(69,248,130,0.02));
    border: 1px solid rgba(69,248,130,0.1);
    display: flex; align-items: center; justify-content: center;
    border-radius: 8px;
}
.sr-item__thumb-ph i { font-size: 14px; color: rgba(69,248,130,0.4); }

.sr-item__info { flex: 1; min-width: 0; }
.sr-item__name {
    font-size: 14px; font-weight: 700; color: #fff; margin: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.sr-item__name a { color: #fff; transition: color .2s; text-decoration: none; }
.sr-item__name a:hover { color: #45f882; }
.sr-item__meta {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; color: rgba(255,255,255,0.3); margin-top: 2px;
}
.sr-item__meta i { font-size: 9px; margin-right: 3px; }
.sr-item__meta-sep { color: rgba(255,255,255,0.1); }

.sr-item__tags {
    display: flex; align-items: center; gap: 4px;
    flex-shrink: 0;
}
.sr-item__tag {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 10px; font-weight: 600;
    padding: 2px 8px; border-radius: 5px;
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.4);
}
.sr-item__tag i { font-size: 8px; }

.sr-item__rating {
    display: flex; align-items: center; gap: 3px;
    flex-shrink: 0;
    font-size: 12px; font-weight: 600; color: #fbbf24;
}
.sr-item__rating i { font-size: 10px; }

.sr-item__votes {
    display: flex; align-items: center; gap: 5px;
    flex-shrink: 0; padding: 0 10px;
}
.sr-item__votes i { font-size: 11px; color: #45f882; opacity: .6; }
.sr-item__votes-count {
    font-size: 15px; font-weight: 800; color: #fff;
    font-family: var(--tg-heading-font-family);
}

.sr-item__btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 5px; padding: 7px 14px;
    border-radius: 6px; font-size: 12px; font-weight: 600;
    text-decoration: none; transition: all .2s;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.6);
    flex-shrink: 0;
}
.sr-item__btn:hover {
    background: #45f882; border-color: #45f882; color: #0e151c;
}

/* Empty */
.sr-empty {
    text-align: center; padding: 80px 20px;
    background: rgba(255,255,255,0.02);
    border: 1px dashed rgba(255,255,255,0.06);
    border-radius: 16px;
}

@media (max-width: 767px) {
    .sr-header { padding: 110px 0 24px; }
    .sr-header__title { font-size: 22px; }
    .sr-bar { flex-direction: column; }
    .sr-item { padding: 10px 12px; gap: 10px; }
    .sr-item__thumb { width: 34px; height: 34px; }
    .sr-item__pos { width: 24px; font-size: 11px; }
    .sr-item__meta { display: none; }
    .sr-item__tags { display: none; }
    .sr-item__rating { display: none; }
    .sr-item__btn span { display: none; }
    .sr-item__btn { padding: 7px 9px; }
}
</style>
{% endblock %}

{% block body %}

    <section class="sr-page">

        <div class="container">
            <div class="sr-header">
                <div class="sr-header__inner">
                    <div class="sr-header__icon"><i class="fas fa-search"></i></div>
                    <h1 class="sr-header__title">Recherche</h1>
                </div>
            </div>
        </div>

        <div class="container">

            {# Search bar #}
            <form action="{{ path('app_search') }}" method="GET" class="sr-bar">
                <input type="text" name="q" value="{{ query }}" placeholder="Rechercher un serveur..."
                       autofocus minlength="2" required class="sr-bar__input">
                <button type="submit" class="sr-bar__btn">
                    <i class="fas fa-search"></i> Rechercher
                </button>
            </form>

            {% if query %}
                <div class="sr-count">
                    {{ total }} resultat{{ total > 1 ? 's' : '' }} pour <strong>"{{ query }}"</strong>
                </div>
            {% endif %}

            {% if servers|length > 0 %}
                <div class="sr-list">
                    {% for server in servers %}
                        <div class="sr-item">
                            <div class="sr-item__pos">{{ (page - 1) * 20 + loop.index }}</div>

                            <a href="{{ path('server_show', {slug: server.slug}) }}" class="sr-item__thumb">
                                {% if server.presentationImage %}
                                    <img src="{{ asset('uploads/servers/presentations/' ~ server.presentationImage) }}" alt="{{ server.name }}">
                                {% else %}
                                    <div class="sr-item__thumb-ph"><i class="fas fa-server"></i></div>
                                {% endif %}
                            </a>

                            <div class="sr-item__info">
                                <h4 class="sr-item__name">
                                    <a href="{{ path('server_show', {slug: server.slug}) }}">{{ server.name }}</a>
                                </h4>
                                <div class="sr-item__meta">
                                    {% if server.gameCategory %}
                                        <span><i class="fas fa-gamepad"></i>{{ server.gameCategory.name }}</span>
                                    {% elseif server.category %}
                                        <span><i class="{{ server.category.icon ?? 'fas fa-folder' }}"></i>{{ server.category.name }}</span>
                                    {% endif %}
                                    {% if server.shortDescription %}
                                        <span class="sr-item__meta-sep">·</span>
                                        <span style="max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block;vertical-align:bottom;">{{ server.shortDescription }}</span>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="sr-item__tags d-none d-lg-flex">
                                {% for tag in server.tags|slice(0, 3) %}
                                    <span class="sr-item__tag" {% if tag.color %}style="background:{{ tag.color }}12;color:{{ tag.color }};border:1px solid {{ tag.color }}25;"{% endif %}>
                                        <i class="fas fa-hashtag" {% if tag.color %}style="color:{{ tag.color }} !important;"{% endif %}></i>{{ tag.name }}
                                    </span>
                                {% endfor %}
                            </div>

                            {% if server.averageRating %}
                                <div class="sr-item__rating d-none d-md-flex">
                                    <i class="fas fa-star"></i> {{ server.averageRating|number_format(1) }}
                                </div>
                            {% endif %}

                            <div class="sr-item__votes">
                                <i class="fas fa-fire"></i>
                                <span class="sr-item__votes-count">{{ server.monthlyVotes }}</span>
                            </div>

                            <a href="{{ path('server_show', {slug: server.slug}) }}" class="sr-item__btn">
                                <span>Voir</span> <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    {% endfor %}
                </div>

                {# Pagination #}
                {% if pages > 1 %}
                    <div class="nx-rk-pagination">
                        {% if page > 1 %}
                            <a href="{{ path('app_search', {q: query, page: page - 1}) }}" class="nx-pg-arrow"><i class="fas fa-chevron-left"></i></a>
                        {% endif %}
                        {% for p in 1..pages %}
                            {% if p == page %}
                                <span class="nx-pg-btn nx-pg-active">{{ p }}</span>
                            {% elseif p <= 2 or p >= pages - 1 or (p >= page - 2 and p <= page + 2) %}
                                <a href="{{ path('app_search', {q: query, page: p}) }}" class="nx-pg-btn">{{ p }}</a>
                            {% elseif p == 3 or p == pages - 2 %}
                                <span class="nx-pg-dots">...</span>
                            {% endif %}
                        {% endfor %}
                        {% if page < pages %}
                            <a href="{{ path('app_search', {q: query, page: page + 1}) }}" class="nx-pg-arrow"><i class="fas fa-chevron-right"></i></a>
                        {% endif %}
                    </div>
                {% endif %}

            {% elseif query %}
                <div class="sr-empty">
                    <div style="font-size:48px;margin-bottom:16px;color:rgba(255,255,255,0.1);"><i class="fas fa-search"></i></div>
                    <div style="color:rgba(255,255,255,0.4);font-size:18px;font-weight:700;margin-bottom:8px;">Aucun resultat</div>
                    <p style="color:rgba(255,255,255,0.25);font-size:14px;margin:0;">Aucun serveur trouve pour <strong>"{{ query }}"</strong>. Essayez d'autres mots-cles.</p>
                </div>
            {% else %}
                <div class="sr-empty">
                    <div style="font-size:48px;margin-bottom:16px;color:rgba(255,255,255,0.1);"><i class="fas fa-search"></i></div>
                    <div style="color:rgba(255,255,255,0.4);font-size:16px;">Tapez un nom de serveur pour lancer la recherche</div>
                </div>
            {% endif %}

        </div>

    </section>

{% endblock %}
