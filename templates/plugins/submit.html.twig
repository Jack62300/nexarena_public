{% extends 'base.html.twig' %}

{% block title %}Soumettre un plugin — {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block body %}

    <section class="breadcrumb-area" data-background="{{ asset('assets/img/bg/breadcrumb_bg01.jpg') }}">
        <div class="container">
            <div class="breadcrumb__wrapper">
                <div class="row">
                    <div class="col-xl-6 col-lg-7">
                        <div class="breadcrumb__content">
                            <h2 class="title">Soumettre un plugin</h2>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                    <li class="breadcrumb-item"><a href="{{ path('plugins_index') }}">Plugins</a></li>
                                    <li class="breadcrumb-item active">Soumettre</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="signup__area team-bg section-pt-120 section-pb-120" data-background="{{ asset('assets/img/bg/team_bg.jpg') }}">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-7 col-lg-9">
                    <div class="singUp-wrap">
                        <h2 class="title"><i class="fas fa-puzzle-piece me-2"></i>Soumettre un plugin</h2>
                        <p>Vous avez développé un plugin d'intégration pour Nexarena ? Soumettez-le pour validation par notre équipe.</p>

                        {# Récompense tokens #}
                        {% set rewardAmount = setting('plugin_submission_reward', '200')|number_format(0, '.', ' ') %}
                        {% if setting('plugin_submission_reward', '200')|number_format > 0 %}
                        <div style="background:rgba(69,248,130,0.1);border:1px solid rgba(69,248,130,0.35);border-radius:10px;padding:16px 20px;margin-bottom:16px;text-align:center;">
                            <div style="font-size:1.5rem;font-weight:800;color:#45f882;">
                                <i class="fas fa-coins me-2"></i>{{ setting('plugin_submission_reward', '200') }} NexBits
                            </div>
                            <div style="font-size:.9rem;color:#ccc;margin-top:4px;">
                                crédités sur votre compte lors de l'approbation de votre plugin
                            </div>
                        </div>
                        {% endif %}

                        {# Propriété notice #}
                        <div style="background:rgba(246,194,62,0.07);border:1px solid rgba(246,194,62,0.2);border-radius:10px;padding:16px 20px;margin-bottom:24px;">
                            <p style="margin:0;font-size:.9rem;color:#ccc;">
                                <i class="fas fa-exclamation-triangle me-2" style="color:#f6c23e;"></i>
                                <strong style="color:#fff;">Important :</strong> Tout plugin soumis devient la propriété de <strong>{{ setting('site_name', 'Nexarena') }}</strong>.
                                Votre nom de créateur sera crédité sur la page des plugins.
                            </p>
                        </div>

                        {% for message in app.flashes('success') %}
                            <div class="alert alert-success">{{ message }}</div>
                        {% endfor %}

                        {% if errors is defined and errors|length > 0 %}
                            <div class="alert alert-danger">
                                <ul class="mb-0">
                                    {% for error in errors %}
                                        <li>{{ error }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}

                        <form method="post" enctype="multipart/form-data" class="account__form">
                            <input type="hidden" name="_token" value="{{ csrf_token('plugin_submit') }}">

                            <div class="form-grp">
                                <label>Nom du plugin <span style="color:#e74c3c;">*</span></label>
                                <input type="text" name="plugin_name" class="form-control" placeholder="ex: NexVote FiveM" maxlength="100" required
                                       value="{{ app.request.request.get('plugin_name', '') }}">
                            </div>

                            <div class="form-grp">
                                <label>Votre nom / pseudo de créateur <span style="color:#e74c3c;">*</span></label>
                                <input type="text" name="creator_name" class="form-control" placeholder="ex: DevStudio, John_Dev, ..." maxlength="100" required
                                       value="{{ app.request.request.get('creator_name', '') }}">
                                <small style="color:#888;">Ce nom sera affiché publiquement sur la page des plugins.</small>
                            </div>

                            <div class="form-grp">
                                <label>Jeu / plateforme concerné(e) <span style="color:#e74c3c;">*</span></label>
                                <input type="text" name="game_description" class="form-control" placeholder="ex: FiveM ESX, Minecraft Spigot, Discord Bot..." maxlength="150" required
                                       value="{{ app.request.request.get('game_description', '') }}">
                            </div>

                            <div class="form-grp">
                                <label>Description courte <span style="color:#e74c3c;">*</span></label>
                                <textarea name="description" class="form-control" rows="4" maxlength="500" required
                                          placeholder="Décrivez brièvement votre plugin et ce qu'il fait (500 caractères max.)...">{{ app.request.request.get('description', '') }}</textarea>
                                <small style="color:#888;">Max. 500 caractères.</small>
                            </div>

                            <div class="form-grp">
                                <label>Archive du plugin <span style="color:#e74c3c;">*</span> <small style="color:#888;">(ZIP ou RAR, 50 Mo max.)</small></label>
                                <input type="file" name="archive_file" class="form-control" accept=".zip,.rar" required>
                                <small style="color:#888;">Incluez votre code source, README et instructions d'installation.</small>
                            </div>

                            <div class="form-grp" style="margin-top:20px;">
                                <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;">
                                    <input type="checkbox" name="accept_terms" value="1" style="width:18px;height:18px;margin-top:2px;accent-color:#45f882;" required>
                                    <span style="font-size:.9rem;color:#ccc;">
                                        Je comprends et j'accepte que ce plugin devienne la propriété de
                                        <strong>{{ setting('site_name', 'Nexarena') }}</strong>.
                                        Mon nom de créateur sera crédité sur la page des plugins.
                                    </span>
                                </label>
                            </div>

                            <button type="submit" class="btn btn-two arrow-btn mt-3">
                                <i class="fas fa-paper-plane me-2"></i>Soumettre le plugin
                            </button>
                        </form>

                        <div class="account__switch mt-4">
                            <p><a href="{{ path('plugins_index') }}"><i class="fas fa-arrow-left me-1"></i>Retour aux plugins</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
