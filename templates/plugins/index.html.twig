{% extends 'base.html.twig' %}

{% block title %}Plugins - {{ setting('site_name', 'Nexarena') }}{% endblock %}
{% block meta_description %}Integrez le systeme de vote Nexarena sur votre serveur avec nos plugins gratuits.{% endblock %}

{% block body %}

    {# ===== HERO / HEADER ===== #}
    <section class="nx-pl-header">
        <div class="container">
            <nav aria-label="breadcrumb" class="nx-pl-breadcrumb">
                <ol>
                    <li><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li><i class="fas fa-chevron-right"></i></li>
                    <li class="active">Plugins</li>
                </ol>
            </nav>

            <div class="nx-pl-header__content">
                <div class="nx-pl-header__icon">
                    <i class="fas fa-puzzle-piece"></i>
                </div>
                <div>
                    <h1 class="nx-pl-header__title">Plugins</h1>
                    <p class="nx-pl-header__desc">Integrez le systeme de vote Nexarena sur votre serveur de jeu</p>
                </div>
            </div>
        </div>
    </section>

    {# ===== CATEGORY TABS ===== #}
    <section class="nx-pl-content">
        <div class="container">
            <div class="nx-pl-tabs">
                <button class="nx-pl-tab active" data-filter="all">
                    <i class="fas fa-th-large"></i> Tous
                    <span class="nx-pl-tab__count">{{ plugins|length }}</span>
                </button>
                <button class="nx-pl-tab" data-filter="game">
                    <i class="fas fa-gamepad"></i> Serveurs de Jeux
                    <span class="nx-pl-tab__count">{{ grouped.game|length }}</span>
                </button>
                <button class="nx-pl-tab" data-filter="vocal">
                    <i class="fas fa-headset"></i> Vocal
                    <span class="nx-pl-tab__count">{{ grouped.vocal|length }}</span>
                </button>
                <button class="nx-pl-tab" data-filter="hosting">
                    <i class="fas fa-cloud"></i> Hebergement
                    <span class="nx-pl-tab__count">{{ grouped.hosting|length }}</span>
                </button>
            </div>

            {# ===== PLUGIN GRID ===== #}
            {% if plugins|length > 0 %}
                <div class="nx-pl-grid">
                    {% for plugin in plugins %}
                        <div class="nx-pl-card wow fadeInUp" data-category="{{ plugin.category }}" data-wow-delay="{{ (loop.index0 * 0.05)|round(2) }}s">
                            <div class="nx-pl-card__header">
                                <div class="nx-pl-card__icon">
                                    {% if plugin.iconFileName %}
                                        <img src="{{ asset('uploads/plugins/icons/' ~ plugin.iconFileName) }}" alt="{{ plugin.name }}">
                                    {% else %}
                                        {% set platformIcons = {
                                            'minecraft': 'fas fa-cube',
                                            'fivem': 'fas fa-car',
                                            'gmod': 'fas fa-wrench',
                                            'discord': 'fab fa-discord',
                                            'teamspeak': 'fas fa-headset',
                                            'rust': 'fas fa-shield-alt',
                                            'ark': 'fas fa-dragon',
                                            'csgo': 'fas fa-crosshairs',
                                            'unturned': 'fas fa-skull-crossbones'
                                        } %}
                                        <i class="{{ platformIcons[plugin.platform] ?? 'fas fa-puzzle-piece' }}"></i>
                                    {% endif %}
                                </div>
                                <div class="nx-pl-card__badges">
                                    {% set platformLabels = {
                                        'minecraft': 'Minecraft',
                                        'fivem': 'FiveM',
                                        'gmod': "Garry's Mod",
                                        'discord': 'Discord',
                                        'teamspeak': 'TeamSpeak',
                                        'rust': 'Rust',
                                        'ark': 'ARK',
                                        'csgo': 'CS2',
                                        'unturned': 'Unturned'
                                    } %}
                                    <span class="nx-pl-badge nx-pl-badge--platform">
                                        {{ platformLabels[plugin.platform] ?? plugin.platform }}
                                    </span>
                                    <span class="nx-pl-badge nx-pl-badge--version">v{{ plugin.version }}</span>
                                </div>
                            </div>
                            <div class="nx-pl-card__body">
                                <h3 class="nx-pl-card__name">{{ plugin.name }}</h3>
                                <p class="nx-pl-card__desc">{{ plugin.description }}</p>
                            </div>
                            <div class="nx-pl-card__footer">
                                <div class="nx-pl-card__stats">
                                    <span class="nx-pl-card__downloads">
                                        <i class="fas fa-download"></i> {{ plugin.downloadCount }}
                                    </span>
                                    {% if plugin.virusTotalStatus == 'clean' %}
                                        <span class="nx-pl-card__vt nx-pl-card__vt--clean">
                                            <i class="fas fa-shield-alt"></i> Verifie
                                        </span>
                                    {% endif %}
                                </div>
                                {% if plugin.fileName %}
                                    <a href="{{ path('plugins_download', {slug: plugin.slug}) }}" class="nx-pl-card__btn">
                                        <i class="fas fa-download"></i> Telecharger
                                    </a>
                                {% else %}
                                    <span class="nx-pl-card__btn nx-pl-card__btn--disabled">
                                        <i class="fas fa-clock"></i> Bientot
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="nx-pl-empty">
                    <div class="nx-pl-empty__icon">
                        <i class="fas fa-puzzle-piece"></i>
                    </div>
                    <h3 class="nx-pl-empty__title">Aucun plugin disponible</h3>
                    <p class="nx-pl-empty__text">Les plugins seront bientot disponibles. Revenez vite !</p>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}

{% block stylesheets %}
<style>
/* ================================================
   PLUGINS PAGE - Nexarena
   ================================================ */

/* ── Header ── */
.nx-pl-header {
    padding: 140px 0 40px;
    background: linear-gradient(180deg, rgba(10,16,24,0.95) 0%, rgba(15,25,35,0.98) 100%);
    border-bottom: 1px solid rgba(69,248,130,0.08);
}

.nx-pl-breadcrumb ol {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0;
    margin: 0 0 25px;
}
.nx-pl-breadcrumb li {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
}
.nx-pl-breadcrumb li a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
}
.nx-pl-breadcrumb li a:hover { color: #45f882; }
.nx-pl-breadcrumb li.active { color: #45f882; font-weight: 600; }
.nx-pl-breadcrumb li i { font-size: 8px; }

.nx-pl-header__content {
    display: flex;
    align-items: center;
    gap: 20px;
}

.nx-pl-header__icon {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(69,248,130,0.15), rgba(69,248,130,0.05));
    border: 1px solid rgba(69,248,130,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: #45f882;
    flex-shrink: 0;
}

.nx-pl-header__title {
    font-size: 32px;
    font-weight: 700;
    color: #fff;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.nx-pl-header__desc {
    font-size: 15px;
    color: rgba(255,255,255,0.5);
    margin: 5px 0 0;
}

/* ── Content ── */
.nx-pl-content {
    padding: 40px 0 80px;
}

/* ── Tabs ── */
.nx-pl-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 35px;
    flex-wrap: wrap;
}

.nx-pl-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    color: rgba(255,255,255,0.5);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.nx-pl-tab:hover {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.8);
}

.nx-pl-tab.active {
    background: rgba(69,248,130,0.08);
    border-color: rgba(69,248,130,0.25);
    color: #45f882;
}

.nx-pl-tab__count {
    background: rgba(255,255,255,0.08);
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 11px;
}

.nx-pl-tab.active .nx-pl-tab__count {
    background: rgba(69,248,130,0.15);
}

/* ── Grid ── */
.nx-pl-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}

@media (max-width: 991px) {
    .nx-pl-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 575px) {
    .nx-pl-grid { grid-template-columns: 1fr; }
}

/* ── Card ── */
.nx-pl-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
}

.nx-pl-card:hover {
    border-color: rgba(69,248,130,0.2);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3), 0 0 20px rgba(69,248,130,0.05);
}

.nx-pl-card__header {
    padding: 20px 20px 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}

.nx-pl-card__icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(69,248,130,0.12), rgba(69,248,130,0.03));
    border: 1px solid rgba(69,248,130,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    color: #45f882;
    overflow: hidden;
    flex-shrink: 0;
}

.nx-pl-card__icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.nx-pl-card__badges {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.nx-pl-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.nx-pl-badge--platform {
    background: rgba(69,248,130,0.1);
    color: #45f882;
    border: 1px solid rgba(69,248,130,0.2);
}

.nx-pl-badge--version {
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.08);
}

.nx-pl-card__body {
    padding: 18px 20px;
    flex: 1;
}

.nx-pl-card__name {
    font-size: 17px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 8px;
}

.nx-pl-card__desc {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.nx-pl-card__footer {
    padding: 15px 20px;
    border-top: 1px solid rgba(255,255,255,0.04);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.nx-pl-card__stats {
    display: flex;
    align-items: center;
    gap: 12px;
}

.nx-pl-card__downloads {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
}
.nx-pl-card__downloads i { margin-right: 3px; }

.nx-pl-card__vt {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 600;
}
.nx-pl-card__vt--clean {
    background: rgba(28,200,138,0.1);
    color: #1cc88a;
}

.nx-pl-card__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: linear-gradient(135deg, #45f882, #2bc866);
    color: #0a1018;
    font-size: 12px;
    font-weight: 700;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.2s;
}
.nx-pl-card__btn:hover {
    color: #0a1018;
    transform: translateY(-1px);
    box-shadow: 0 4px 15px rgba(69,248,130,0.3);
}

.nx-pl-card__btn--disabled {
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.3);
    cursor: not-allowed;
}
.nx-pl-card__btn--disabled:hover {
    color: rgba(255,255,255,0.3);
    transform: none;
    box-shadow: none;
}

/* ── Empty State ── */
.nx-pl-empty {
    text-align: center;
    padding: 80px 20px;
}
.nx-pl-empty__icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    color: rgba(255,255,255,0.15);
    margin-bottom: 20px;
}
.nx-pl-empty__title {
    font-size: 20px;
    color: rgba(255,255,255,0.6);
    margin: 0 0 10px;
}
.nx-pl-empty__text {
    font-size: 14px;
    color: rgba(255,255,255,0.35);
}
</style>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var tabs = document.querySelectorAll('.nx-pl-tab');
    var cards = document.querySelectorAll('.nx-pl-card');

    tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
            tabs.forEach(function(t) { t.classList.remove('active'); });
            tab.classList.add('active');

            var filter = tab.getAttribute('data-filter');

            cards.forEach(function(card) {
                if (filter === 'all' || card.getAttribute('data-category') === filter) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    });
});
</script>
{% endblock %}
