{% extends 'base.html.twig' %}

{% set _base_url = setting('seo_site_url', app.request.schemeAndHttpHost) %}
{% set _art_desc = article.content|striptags|slice(0, 155)|trim ~ '...' %}
{% set _art_url = url('articles_show', {slug: article.slug}) %}
{% set _word_count = article.content|striptags|split(' ')|length %}
{% set _read_time = (_word_count / 200)|round(0, 'ceil') %}

{% block title %}{{ article.title }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}
{% block meta_description %}{{ _art_desc }}{% endblock %}
{% block og_type %}article{% endblock %}

{% block og_image %}
    {% if article.image %}
    <meta property="og:image" content="{{ app.request.schemeAndHttpHost ~ asset('uploads/articles/' ~ article.image) }}">
    <meta property="og:image:alt" content="{{ article.title }}">
    {% elseif setting('seo_og_image') %}
    <meta property="og:image" content="{{ app.request.schemeAndHttpHost ~ '/' ~ setting('seo_og_image') }}">
    {% endif %}
{% endblock %}

{% block twitter_image %}
    {% if article.image %}
    <meta name="twitter:image" content="{{ app.request.schemeAndHttpHost ~ asset('uploads/articles/' ~ article.image) }}">
    {% endif %}
{% endblock %}

{% block json_ld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title|json_encode|raw }},
  "description": {{ _art_desc|json_encode|raw }},
  "url": {{ (_base_url ~ path('articles_show', {slug: article.slug}))|json_encode|raw }},
  "inLanguage": "fr-FR",
  "datePublished": {{ article.createdAt|date('c')|json_encode|raw }},
  "dateModified": {{ (article.updatedAt ?? article.createdAt)|date('c')|json_encode|raw }},
  "publisher": {
    "@id": {{ (_base_url ~ '/#organization')|json_encode|raw }}
  },
  "isPartOf": {"@id": {{ (_base_url ~ '/#website')|json_encode|raw }}}
  {% if article.image %},
  "image": {{ (app.request.schemeAndHttpHost ~ asset('uploads/articles/' ~ article.image))|json_encode|raw }}
  {% endif %},
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Accueil","item":{{ _base_url|json_encode|raw }}},
      {"@type":"ListItem","position":2,"name":"Actualites","item":{{ (_base_url ~ path('articles_list'))|json_encode|raw }}},
      {"@type":"ListItem","position":3,"name":{{ article.title|json_encode|raw }},"item":{{ (_base_url ~ path('articles_show', {slug: article.slug}))|json_encode|raw }}}
    ]
  }
}
</script>
{% endblock %}

{% block body %}

    {# ===== BREADCRUMB AREA ===== #}
    <section class="bd-breadcrumb" {% if article.image %}style="--bd-bg: url('{{ asset('uploads/articles/' ~ article.image) }}')"{% endif %}>
        <div class="bd-breadcrumb__bg"></div>
        <div class="bd-breadcrumb__overlay"></div>
        <div class="container">
            <div class="bd-breadcrumb__content">
                <h2 class="bd-breadcrumb__title">Actualites</h2>
                <nav class="bd-breadcrumb__nav">
                    <a href="{{ path('app_home') }}">Accueil</a>
                    <span class="bd-breadcrumb__sep"><i class="fas fa-angle-right"></i></span>
                    <a href="{{ path('articles_list') }}">Actualites</a>
                    <span class="bd-breadcrumb__sep"><i class="fas fa-angle-right"></i></span>
                    <span class="bd-breadcrumb__current">{{ article.title|length > 40 ? article.title|slice(0, 40) ~ '...' : article.title }}</span>
                </nav>
            </div>
        </div>
    </section>

    {# ===== BLOG DETAILS ===== #}
    <section class="bd-area">
        <div class="container">
            <div class="row">

                {# ── Main Content ── #}
                <div class="col-xl-8 col-lg-7">
                    <div class="bd-post">

                        {# Featured Image #}
                        {% if article.image %}
                        <div class="bd-post__thumb">
                            <img src="{{ asset('uploads/articles/' ~ article.image) }}" alt="{{ article.title }}">
                        </div>
                        {% endif %}

                        {# Meta #}
                        <div class="bd-post__meta">
                            <span class="bd-post__meta-item">
                                <i class="far fa-calendar-alt"></i> {{ article.createdAt|date('d M Y') }}
                            </span>
                            <span class="bd-post__meta-item">
                                <i class="far fa-clock"></i> {{ _read_time }} min de lecture
                            </span>
                            {% if article.updatedAt %}
                            <span class="bd-post__meta-item">
                                <i class="fas fa-pen-fancy"></i> Mis a jour le {{ article.updatedAt|date('d/m/Y') }}
                            </span>
                            {% endif %}
                        </div>

                        {# Title #}
                        <h1 class="bd-post__title">{{ article.title }}</h1>

                        {# Body #}
                        <div class="bd-post__body ql-snow">
                            <div class="ql-editor">
                                {{ article.content|raw }}
                            </div>
                        </div>

                        {# Bottom: Share #}
                        <div class="bd-post__bottom">
                            <div class="bd-post__share">
                                <h5 class="bd-post__share-label">Partager <i class="fas fa-share-alt"></i></h5>
                                <div class="bd-post__share-links">
                                    <a href="https://twitter.com/intent/tweet?url={{ _art_url|url_encode }}&text={{ article.title|url_encode }}" target="_blank" rel="noopener" title="X / Twitter"><i class="fab fa-x-twitter"></i></a>
                                    <a href="https://www.facebook.com/sharer/sharer.php?u={{ _art_url|url_encode }}" target="_blank" rel="noopener" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                                    <a href="https://www.reddit.com/submit?url={{ _art_url|url_encode }}&title={{ article.title|url_encode }}" target="_blank" rel="noopener" title="Reddit"><i class="fab fa-reddit-alien"></i></a>
                                    <a href="https://api.whatsapp.com/send?text={{ (article.title ~ ' ' ~ _art_url)|url_encode }}" target="_blank" rel="noopener" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>
                                </div>
                            </div>
                        </div>

                    </div>

                    {# ── Related Articles ── #}
                    {% if relatedArticles|length > 0 %}
                    <div class="bd-related">
                        <h4 class="bd-related__title"><span>Articles</span> similaires</h4>
                        <div class="row">
                            {% for related in relatedArticles %}
                            <div class="col-md-4 col-sm-6 mb-4">
                                <a href="{{ path('articles_show', {slug: related.slug}) }}" class="bd-related-card">
                                    <div class="bd-related-card__img">
                                        {% if related.image %}
                                        <img src="{{ asset('uploads/articles/' ~ related.image) }}" alt="{{ related.title }}" loading="lazy">
                                        {% else %}
                                        <div class="bd-related-card__placeholder"><i class="fas fa-newspaper"></i></div>
                                        {% endif %}
                                    </div>
                                    <div class="bd-related-card__info">
                                        <span class="bd-related-card__date"><i class="far fa-calendar-alt"></i> {{ related.createdAt|date('d/m/Y') }}</span>
                                        <h5 class="bd-related-card__name">{{ related.title }}</h5>
                                    </div>
                                </a>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>

                {# ── Sidebar ── #}
                <div class="col-xl-4 col-lg-5">
                    <aside class="bd-sidebar">

                        {# Recent Posts #}
                        <div class="bd-widget">
                            <h4 class="bd-widget__title">Articles recents</h4>
                            <div class="bd-widget__posts">
                                {% for recent in recentArticles %}
                                <a href="{{ path('articles_show', {slug: recent.slug}) }}" class="bd-rc-post {{ recent.id == article.id ? 'bd-rc-post--active' : '' }}">
                                    <div class="bd-rc-post__thumb">
                                        {% if recent.image %}
                                        <img src="{{ asset('uploads/articles/' ~ recent.image) }}" alt="{{ recent.title }}" loading="lazy">
                                        {% else %}
                                        <div class="bd-rc-post__placeholder"><i class="fas fa-newspaper"></i></div>
                                        {% endif %}
                                    </div>
                                    <div class="bd-rc-post__info">
                                        <h6 class="bd-rc-post__name">{{ recent.title }}</h6>
                                        <span class="bd-rc-post__date"><i class="far fa-calendar-alt"></i> {{ recent.createdAt|date('d M Y') }}</span>
                                    </div>
                                </a>
                                {% endfor %}
                            </div>
                        </div>

                        {# Newsletter / CTA #}
                        <div class="bd-widget bd-widget--cta">
                            <div class="bd-cta">
                                <div class="bd-cta__icon"><i class="fas fa-plus-circle"></i></div>
                                <h4 class="bd-cta__title">Ajouter votre serveur</h4>
                                <p class="bd-cta__desc">Rejoignez le classement et gagnez en visibilite aupres de milliers de joueurs.</p>
                                {% if app.user %}
                                <a href="{{ path('user_servers_new') }}" class="bd-cta__btn">Ajouter un serveur</a>
                                {% else %}
                                <a href="{{ path('app_register') }}" class="bd-cta__btn">Creer un compte</a>
                                {% endif %}
                            </div>
                        </div>

                        {# Back to list #}
                        <div class="bd-widget">
                            <a href="{{ path('articles_list') }}" class="bd-back-link">
                                <i class="fas fa-arrow-left"></i> Toutes les actualites
                            </a>
                        </div>

                    </aside>
                </div>

            </div>
        </div>
    </section>

{% endblock %}

{% block stylesheets %}
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('assets/css/pages/articles-show.css') }}?v=4">
{% endblock %}
