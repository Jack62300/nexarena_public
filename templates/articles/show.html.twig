{% extends 'base.html.twig' %}

{% block title %}{{ article.title }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block body %}

    {# ===== HEADER ===== #}
    <section class="nx-art-header">
        <div class="container">
            <nav class="nx-art-breadcrumb">
                <a href="{{ path('app_home') }}">Accueil</a>
                <i class="fas fa-chevron-right"></i>
                <a href="{{ path('articles_list') }}">Actualites</a>
                <i class="fas fa-chevron-right"></i>
                <span>{{ article.title|length > 50 ? article.title|slice(0, 50) ~ '...' : article.title }}</span>
            </nav>
        </div>
    </section>

    {# ===== ARTICLE ===== #}
    <section class="nx-art-content">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-8 col-lg-10">

                    {# Meta #}
                    <div class="nx-art-meta">
                        <span class="nx-art-meta__item">
                            <i class="far fa-calendar-alt"></i> {{ article.createdAt|date('d M Y') }}
                        </span>
                        {% if article.updatedAt %}
                            <span class="nx-art-meta__item">
                                <i class="fas fa-sync-alt"></i> Mis a jour le {{ article.updatedAt|date('d/m/Y') }}
                            </span>
                        {% endif %}
                    </div>

                    {# Title #}
                    <h1 class="nx-art-title">{{ article.title }}</h1>

                    {# Featured Image #}
                    {% if article.image %}
                        <div class="nx-art-hero">
                            <img src="{{ asset('uploads/articles/' ~ article.image) }}" alt="{{ article.title }}">
                        </div>
                    {% endif %}

                    {# Body #}
                    <div class="nx-art-body">
                        {{ article.content|raw }}
                    </div>

                    {# Footer #}
                    <div class="nx-art-footer">
                        <a href="{{ path('articles_list') }}" class="nx-art-back">
                            <i class="fas fa-arrow-left"></i>
                            Retour aux actualites
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </section>

{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/articles-show.css') }}">
{% endblock %}
