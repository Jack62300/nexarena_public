{% extends 'base.html.twig' %}

{% block title %}Actualites - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block body %}

    {# ===== HEADER ===== #}
    <section class="nx-news-header">
        <div class="container">
            <div class="nx-news-header__inner">
                <div class="nx-news-header__left">
                    <nav class="nx-news-breadcrumb">
                        <a href="{{ path('app_home') }}">Accueil</a>
                        <i class="fas fa-chevron-right"></i>
                        <span>Actualites</span>
                    </nav>
                    <h1 class="nx-news-header__title">Actualites</h1>
                    <p class="nx-news-header__sub">Toutes les dernieres nouvelles de la communaute</p>
                </div>
                {% if totalArticles > 0 %}
                    <div class="nx-news-header__right">
                        <span class="nx-news-count">{{ totalArticles }} article{{ totalArticles > 1 ? 's' : '' }}</span>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    {# ===== GRID ===== #}
    <section class="nx-news-grid">
        <div class="container">
            {% if articles|length > 0 %}
                <div class="row g-4">
                    {% for article in articles %}
                        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6">
                            <a href="{{ path('articles_show', {slug: article.slug}) }}" class="nx-card wow fadeInUp" data-wow-delay="{{ (loop.index0 % 4 * 0.08) }}s">
                                <div class="nx-card__img">
                                    {% if article.image %}
                                        <img src="{{ asset('uploads/articles/' ~ article.image) }}" alt="{{ article.title }}">
                                    {% else %}
                                        <div class="nx-card__placeholder">
                                            <i class="fas fa-newspaper"></i>
                                        </div>
                                    {% endif %}
                                    <div class="nx-card__date">
                                        <span class="nx-card__day">{{ article.createdAt|date('d') }}</span>
                                        <span class="nx-card__month">{{ article.createdAt|date('M') }}</span>
                                    </div>
                                </div>
                                <div class="nx-card__body">
                                    <h3 class="nx-card__title">{{ article.title }}</h3>
                                    <p class="nx-card__excerpt">{{ article.content|striptags|slice(0, 100) }}{% if article.content|striptags|length > 100 %}...{% endif %}</p>
                                    <span class="nx-card__read">
                                        Lire <i class="fas fa-arrow-right"></i>
                                    </span>
                                </div>
                            </a>
                        </div>
                    {% endfor %}
                </div>

                {# ===== PAGINATION ===== #}
                {% if totalPages > 1 %}
                    <nav class="nx-pagination">
                        {% if currentPage > 1 %}
                            <a href="{{ path('articles_list', {page: currentPage - 1}) }}" class="nx-pagination__btn nx-pagination__prev">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        {% endif %}

                        {% set startPage = max(1, currentPage - 2) %}
                        {% set endPage = min(totalPages, startPage + 4) %}
                        {% set startPage = max(1, endPage - 4) %}

                        {% if startPage > 1 %}
                            <a href="{{ path('articles_list', {page: 1}) }}" class="nx-pagination__num">1</a>
                            {% if startPage > 2 %}
                                <span class="nx-pagination__dots">...</span>
                            {% endif %}
                        {% endif %}

                        {% for p in startPage..endPage %}
                            <a href="{{ path('articles_list', {page: p}) }}" class="nx-pagination__num {{ p == currentPage ? 'is-active' : '' }}">{{ p }}</a>
                        {% endfor %}

                        {% if endPage < totalPages %}
                            {% if endPage < totalPages - 1 %}
                                <span class="nx-pagination__dots">...</span>
                            {% endif %}
                            <a href="{{ path('articles_list', {page: totalPages}) }}" class="nx-pagination__num">{{ totalPages }}</a>
                        {% endif %}

                        {% if currentPage < totalPages %}
                            <a href="{{ path('articles_list', {page: currentPage + 1}) }}" class="nx-pagination__btn nx-pagination__next">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        {% endif %}
                    </nav>
                {% endif %}

            {% else %}
                <div class="nx-news-empty">
                    <div class="nx-news-empty__icon">
                        <i class="fas fa-newspaper"></i>
                    </div>
                    <h3>Aucune actualite pour le moment</h3>
                    <p>Revenez bientot pour les dernieres nouvelles !</p>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}

{% block stylesheets %}
<style>
/* ================================================
   ACTUALITES - Nexarena
   ================================================ */

/* ─── Header ─── */
.nx-news-header {
    padding: 140px 0 0;
}
.nx-news-header__inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
}
.nx-news-breadcrumb {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    margin-bottom: 16px;
}
.nx-news-breadcrumb a {
    color: rgba(255,255,255,0.4);
    transition: color 0.2s;
}
.nx-news-breadcrumb a:hover {
    color: var(--tg-theme-primary);
}
.nx-news-breadcrumb i {
    font-size: 8px;
    color: rgba(255,255,255,0.15);
}
.nx-news-header__title {
    font-size: 32px;
    font-weight: 800;
    color: #fff;
    margin: 0 0 6px;
    font-family: var(--tg-heading-font-family);
    text-transform: uppercase;
    letter-spacing: 1px;
}
.nx-news-header__sub {
    font-size: 14px;
    color: rgba(255,255,255,0.35);
    margin: 0;
}
.nx-news-count {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.04);
    padding: 6px 14px;
    border-radius: 6px;
    white-space: nowrap;
}

/* ─── Grid ─── */
.nx-news-grid {
    padding: 40px 0 100px;
}

/* ─── Card ─── */
.nx-card {
    display: flex;
    flex-direction: column;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    height: 100%;
    text-decoration: none !important;
}
.nx-card:hover {
    border-color: rgba(69,248,130,0.2);
    transform: translateY(-4px);
    background: rgba(255,255,255,0.035);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
}

/* Card Image */
.nx-card__img {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: rgba(0,0,0,0.3);
}
.nx-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}
.nx-card:hover .nx-card__img img {
    transform: scale(1.05);
}
.nx-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(69,248,130,0.05) 0%, rgba(0,0,0,0.2) 100%);
}
.nx-card__placeholder i {
    font-size: 32px;
    color: rgba(255,255,255,0.08);
}

/* Date Badge */
.nx-card__date {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(8px);
    border-radius: 8px;
    padding: 6px 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    min-width: 44px;
}
.nx-card__day {
    font-size: 18px;
    font-weight: 800;
    color: #fff;
    font-family: var(--tg-heading-font-family);
}
.nx-card__month {
    font-size: 10px;
    font-weight: 700;
    color: var(--tg-theme-primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 2px;
}

/* Card Body */
.nx-card__body {
    padding: 18px 18px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
}
.nx-card__title {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 10px;
    line-height: 1.4;
    font-family: var(--tg-heading-font-family);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.2s;
}
.nx-card:hover .nx-card__title {
    color: var(--tg-theme-primary);
}
.nx-card__excerpt {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.nx-card__read {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 700;
    color: var(--tg-theme-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 14px;
    opacity: 0;
    transform: translateX(-6px);
    transition: all 0.3s ease;
}
.nx-card:hover .nx-card__read {
    opacity: 1;
    transform: translateX(0);
}
.nx-card__read i {
    font-size: 10px;
    transition: transform 0.2s;
}
.nx-card:hover .nx-card__read i {
    transform: translateX(3px);
}

/* ─── Pagination ─── */
.nx-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 50px;
}
.nx-pagination__num,
.nx-pagination__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    transition: all 0.2s ease;
    text-decoration: none !important;
    font-family: var(--tg-heading-font-family);
}
.nx-pagination__num:hover,
.nx-pagination__btn:hover {
    color: #fff;
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.1);
}
.nx-pagination__num.is-active {
    color: #000;
    background: var(--tg-theme-primary);
    border-color: var(--tg-theme-primary);
    font-weight: 800;
}
.nx-pagination__dots {
    color: rgba(255,255,255,0.2);
    font-size: 14px;
    padding: 0 4px;
}
.nx-pagination__btn i {
    font-size: 12px;
}

/* ─── Empty State ─── */
.nx-news-empty {
    text-align: center;
    padding: 80px 20px;
}
.nx-news-empty__icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255,255,255,0.03);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
}
.nx-news-empty__icon i {
    font-size: 32px;
    color: rgba(255,255,255,0.08);
}
.nx-news-empty h3 {
    font-size: 20px;
    color: rgba(255,255,255,0.35);
    margin: 0 0 8px;
}
.nx-news-empty p {
    color: rgba(255,255,255,0.2);
    font-size: 14px;
    margin: 0;
}

/* ─── Responsive ─── */
@media (max-width: 1199.98px) {
    .nx-card__title { font-size: 14px; }
    .nx-card__body { padding: 16px 16px 18px; }
}
@media (max-width: 991.98px) {
    .nx-news-header { padding: 120px 0 0; }
    .nx-news-header__title { font-size: 26px; }
}
@media (max-width: 767.98px) {
    .nx-news-header__inner {
        flex-direction: column;
        align-items: flex-start;
    }
}
@media (max-width: 575.98px) {
    .nx-news-header__title { font-size: 22px; }
    .nx-card__read {
        opacity: 1;
        transform: translateX(0);
    }
}
</style>
{% endblock %}
