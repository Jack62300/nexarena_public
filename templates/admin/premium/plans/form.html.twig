{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ plan ? 'Modifier' : 'Nouveau plan premium' }}{% endblock %}
{% block title %}Nexarena Admin - {{ plan ? 'Modifier' : 'Nouveau' }} plan{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus { outline: none; border-color: var(--accent); }
    textarea.form-control-admin { resize: vertical; }
    .form-check-admin { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .form-check-admin input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent); }
    .icon-preview { width: 64px; height: 64px; object-fit: contain; border-radius: 8px; border: 1px solid var(--border-color); margin-bottom: 8px; }
    .info-box { background: rgba(69,248,130,0.07); border: 1px solid rgba(69,248,130,0.2); border-radius: 8px; padding: 12px 16px; font-size: 13px; color: var(--text-secondary); margin-bottom: 15px; }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ plan ? 'Modifier le plan' : 'Nouveau plan premium' }}</h3>
                <a href="{{ path('admin_premium_plans_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                    <div class="form-group">
                        <label for="{{ form.name.vars.id }}">Nom du plan</label>
                        {{ form_widget(form.name, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.description.vars.id }}">Description</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control-admin', 'rows': 4}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="info-box">
                        <i class="fas fa-info-circle"></i>
                        Vous devez renseigner au moins un prix (PayPal ou NexBits).
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="{{ form.price.vars.id }}">Prix PayPal</label>
                                {{ form_widget(form.price, {'attr': {'class': 'form-control-admin', 'placeholder': '0.00'}}) }}
                                {{ form_errors(form.price) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="{{ form.currency.vars.id }}">Devise</label>
                                {{ form_widget(form.currency, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.currency) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="{{ form.nexbitsPrice.vars.id }}">Prix NexBits</label>
                                {{ form_widget(form.nexbitsPrice, {'attr': {'class': 'form-control-admin', 'placeholder': '0'}}) }}
                                {{ form_errors(form.nexbitsPrice) }}
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.tokensGiven.vars.id }}">NexBits offerts</label>
                                {{ form_widget(form.tokensGiven, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.tokensGiven) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.boostTokensGiven.vars.id }}">NexBoost offerts</label>
                                {{ form_widget(form.boostTokensGiven, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.boostTokensGiven) }}
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="{{ form.planType.vars.id }}">Type de plan</label>
                        {{ form_widget(form.planType, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.planType) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.iconFile.vars.id }}">Icône</label>
                        {% if plan and plan.iconFileName %}
                            <img src="{{ asset('uploads/plans/' ~ plan.iconFileName) }}" alt="" class="icon-preview">
                        {% endif %}
                        {{ form_widget(form.iconFile, {'attr': {'style': 'color:var(--text-secondary);'}}) }}
                        {{ form_errors(form.iconFile) }}
                        <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">PNG, JPG, GIF, SVG ou WebP - 2 Mo max</div>
                    </div>

                    <div class="form-group">
                        <label for="{{ form.position.vars.id }}">Position</label>
                        {{ form_widget(form.position, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.position) }}
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            {{ form_widget(form.isActive) }}
                            Plan actif
                        </label>
                        {{ form_errors(form.isActive) }}
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ plan ? 'Enregistrer' : 'Créer' }}
                        </button>
                        <a href="{{ path('admin_premium_plans_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
