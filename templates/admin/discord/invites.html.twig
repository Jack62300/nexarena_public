{% extends 'admin/base.html.twig' %}

{% block page_title %}Invitations Discord{% endblock %}
{% block title %}Nexarena Admin - Invitations Discord{% endblock %}

{% block admin_css %}
    .dc-rank {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        font-weight: 700;
        font-size: 13px;
    }
    .dc-rank--gold {
        background: rgba(255,215,0,0.15);
        color: #ffd700;
        border: 1px solid rgba(255,215,0,0.3);
    }
    .dc-rank--silver {
        background: rgba(192,192,192,0.15);
        color: #c0c0c0;
        border: 1px solid rgba(192,192,192,0.3);
    }
    .dc-rank--bronze {
        background: rgba(205,127,50,0.15);
        color: #cd7f32;
        border: 1px solid rgba(205,127,50,0.3);
    }
{% endblock %}

{% block admin_body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 style="margin:0;font-weight:600;"><i class="fas fa-user-plus" style="color:var(--accent);margin-right:6px;"></i> Invitations Discord</h4>
    <a href="{{ path('admin_discord_index') }}" class="btn-admin btn-admin--outline btn-admin--sm"><i class="fas fa-arrow-left"></i> Retour</a>
</div>

{# Leaderboard #}
<div class="admin-table mb-4">
    <div class="admin-table__header">
        <h3><i class="fas fa-trophy" style="color:#ffd700;margin-right:8px;font-size:13px;"></i> Classement des inviteurs</h3>
    </div>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Utilisateur</th>
                <th>Invitations</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in leaderboard %}
            <tr>
                <td>
                    {% if loop.index == 1 %}
                        <span class="dc-rank dc-rank--gold">1</span>
                    {% elseif loop.index == 2 %}
                        <span class="dc-rank dc-rank--silver">2</span>
                    {% elseif loop.index == 3 %}
                        <span class="dc-rank dc-rank--bronze">3</span>
                    {% else %}
                        <span style="font-weight:600;color:var(--text-secondary);padding-left:6px;">{{ loop.index }}</span>
                    {% endif %}
                </td>
                <td>
                    <div class="dash-user">
                        <div class="dash-user__avatar dash-user__avatar--placeholder" style="background:#5865f2;">
                            {{ entry.inviterUsername|slice(0, 1)|upper }}
                        </div>
                        <div>
                            <div class="dash-user__name">{{ entry.inviterUsername }}</div>
                        </div>
                    </div>
                </td>
                <td>
                    <span style="font-weight:700;color:var(--accent);font-size:15px;">{{ entry.inviteCount }}</span>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="3" style="text-align:center;padding:30px;color:var(--text-secondary);font-size:13px;">Aucune invitation enregistree.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# Recent invites #}
<div class="admin-table">
    <div class="admin-table__header">
        <h3><i class="fas fa-clock" style="color:var(--text-secondary);margin-right:8px;font-size:13px;"></i> Invitations recentes</h3>
    </div>
    <table>
        <thead>
            <tr>
                <th>Inviteur</th>
                <th>Invite</th>
                <th>Code</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            {% for invite in recent %}
            <tr>
                <td>
                    <div class="dash-user">
                        <div class="dash-user__avatar dash-user__avatar--placeholder" style="background:#5865f2;">
                            {{ invite.inviterUsername|slice(0, 1)|upper }}
                        </div>
                        <div>
                            <div class="dash-user__name">{{ invite.inviterUsername }}</div>
                        </div>
                    </div>
                </td>
                <td>
                    <div class="dash-user">
                        <div class="dash-user__avatar dash-user__avatar--placeholder" style="background:#36b9cc;">
                            {{ invite.invitedUsername|slice(0, 1)|upper }}
                        </div>
                        <div>
                            <div class="dash-user__name">{{ invite.invitedUsername }}</div>
                        </div>
                    </div>
                </td>
                <td style="font-family:monospace;font-size:12px;color:var(--text-secondary);">{{ invite.inviteCode }}</td>
                <td style="color:var(--text-secondary);font-size:12px;">{{ invite.joinedAt|date('d/m/Y H:i') }}</td>
            </tr>
            {% else %}
            <tr><td colspan="4" style="text-align:center;padding:30px;color:var(--text-secondary);font-size:13px;">Aucune invitation recente.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
<link rel="stylesheet" href="{{ asset('assets/css/admin/dashboard.css') }}">
<link rel="stylesheet" href="{{ asset('assets/css/admin/discord.css') }}">
{% endblock %}
