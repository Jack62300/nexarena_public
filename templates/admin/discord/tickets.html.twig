{% extends 'admin/base.html.twig' %}

{% block page_title %}Tickets Discord{% endblock %}
{% block title %}Nexarena Admin - Tickets Discord{% endblock %}

{% block admin_body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 style="margin:0;font-weight:600;"><i class="fas fa-ticket-alt" style="color:var(--accent);margin-right:6px;"></i> Tickets support</h4>
    <a href="{{ path('admin_discord_index') }}" class="btn-admin btn-admin--outline btn-admin--sm"><i class="fas fa-arrow-left"></i> Retour</a>
</div>

{# Tabs #}
<div class="dc-tabs">
    <a href="{{ path('admin_discord_tickets') }}" class="dc-tab {{ current_status is null ? 'dc-tab--active' : '' }}">
        Tous ({{ open_count + closed_count }})
    </a>
    <a href="{{ path('admin_discord_tickets', {status: 'open'}) }}" class="dc-tab {{ current_status == 'open' ? 'dc-tab--active' : '' }}">
        <i class="fas fa-envelope-open"></i> Ouverts ({{ open_count }})
    </a>
    <a href="{{ path('admin_discord_tickets', {status: 'closed'}) }}" class="dc-tab {{ current_status == 'closed' ? 'dc-tab--active' : '' }}">
        <i class="fas fa-lock"></i> Fermes ({{ closed_count }})
    </a>
</div>

{# Table #}
<div class="admin-table">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Utilisateur</th>
                <th>Categorie</th>
                <th>Sujet</th>
                <th>Msgs</th>
                <th>Statut</th>
                <th>Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for ticket in tickets %}
            <tr>
                <td style="font-weight:600;">{{ ticket.id }}</td>
                <td>
                    <div class="dash-user">
                        <div class="dash-user__avatar dash-user__avatar--placeholder" style="background:#5865f2;">
                            {{ ticket.discordUsername|slice(0, 1)|upper }}
                        </div>
                        <div>
                            <div class="dash-user__name">{{ ticket.discordUsername }}</div>
                            {% if ticket.siteUser %}
                                <div class="dash-user__email">Site: {{ ticket.siteUser.username }}</div>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td><span class="dc-ticket-cat">{{ category_labels[ticket.category] ?? ticket.category }}</span></td>
                <td><span class="dash-user__name">{{ ticket.subject|length > 40 ? ticket.subject[:40] ~ '...' : ticket.subject }}</span></td>
                <td>{{ ticket.messages|length }}</td>
                <td><span class="dc-ticket-status dc-ticket-status--{{ ticket.status }}">{{ ticket.status == 'open' ? 'Ouvert' : 'Ferme' }}</span></td>
                <td style="color:var(--text-secondary);font-size:12px;">{{ ticket.createdAt|time_ago }}</td>
                <td>
                    <a href="{{ path('admin_discord_ticket_show', {id: ticket.id}) }}" class="btn-admin btn-admin--outline btn-admin--sm"><i class="fas fa-eye"></i></a>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text-secondary);font-size:13px;">Aucun ticket{{ current_status == 'open' ? ' ouvert' : (current_status == 'closed' ? ' ferme' : '') }}.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
<link rel="stylesheet" href="{{ asset('assets/css/admin/dashboard.css') }}">
<link rel="stylesheet" href="{{ asset('assets/css/admin/discord.css') }}">
{% endblock %}
