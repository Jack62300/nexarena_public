{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ command ? 'Modifier la commande' : 'Nouvelle commande' }}{% endblock %}
{% block title %}Nexarena Admin - {{ command ? 'Modifier' : 'Nouvelle' }} commande Discord{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus {
        outline: none;
        border-color: var(--accent);
    }
    textarea.form-control-admin {
        min-height: 100px;
        resize: vertical;
    }
    .form-check-admin {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .form-check-admin input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
    .form-row { display: flex; gap: 20px; }
    .form-row .form-group { flex: 1; }
    .form-section-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 16px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 8px;
    }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ command ? 'Modifier la commande' : 'Nouvelle commande' }}</h3>
                <a href="{{ path('admin_discord_commands') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                {{ form_start(form) }}

                    {# Base fields #}
                    <div class="form-section-title">
                        <i class="fas fa-terminal" style="color:var(--accent);font-size:12px;"></i> Informations de base
                    </div>

                    <div class="form-group">
                        <label for="{{ form.name.vars.id }}">Nom de la commande</label>
                        {{ form_widget(form.name, {'attr': {'class': 'form-control-admin', 'pattern': '[a-z0-9\\-_]+', 'maxlength': 32, 'style': 'font-family:monospace;'}}) }}
                        {{ form_errors(form.name) }}
                        <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">Minuscules, chiffres, tirets et underscores uniquement. Sera utilisé comme /nom.</div>
                    </div>

                    <div class="form-group">
                        <label for="{{ form.description.vars.id }}">Description</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control-admin', 'placeholder': 'Description affichée dans Discord', 'maxlength': 100}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.response.vars.id }}">Réponse texte</label>
                        {{ form_widget(form.response, {'attr': {'class': 'form-control-admin', 'placeholder': 'Texte de la réponse...'}}) }}
                        {{ form_errors(form.response) }}
                    </div>

                    {# Embed fields #}
                    <div class="form-section-title" style="margin-top:30px;">
                        <i class="fas fa-window-maximize" style="color:#7289da;font-size:12px;"></i> Embed (optionnel)
                    </div>

                    <div class="form-group">
                        <label for="{{ form.embedTitle.vars.id }}">Titre de l'embed</label>
                        {{ form_widget(form.embedTitle, {'attr': {'class': 'form-control-admin', 'placeholder': "Titre de l'embed Discord", 'maxlength': 256}}) }}
                        {{ form_errors(form.embedTitle) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.embedDescription.vars.id }}">Description de l'embed</label>
                        {{ form_widget(form.embedDescription, {'attr': {'class': 'form-control-admin', 'placeholder': "Contenu de l'embed..."}}) }}
                        {{ form_errors(form.embedDescription) }}
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="{{ form.embedColor.vars.id }}">Couleur de l'embed</label>
                            {{ form_widget(form.embedColor, {'attr': {'type': 'color', 'style': 'width:60px;height:40px;border:1px solid var(--border-color);border-radius:6px;background:var(--bg-darker);cursor:pointer;'}}) }}
                            {{ form_errors(form.embedColor) }}
                        </div>
                        <div class="form-group">
                            <label for="{{ form.embedImage.vars.id }}">Image de l'embed (URL)</label>
                            {{ form_widget(form.embedImage, {'attr': {'class': 'form-control-admin', 'placeholder': 'https://example.com/image.png'}}) }}
                            {{ form_errors(form.embedImage) }}
                        </div>
                    </div>

                    {# Settings #}
                    <div class="form-section-title" style="margin-top:30px;">
                        <i class="fas fa-cog" style="color:var(--text-secondary);font-size:12px;"></i> Paramètres
                    </div>

                    <div class="form-group">
                        <label for="{{ form.requiredRole.vars.id }}">Rôle requis (ID Discord)</label>
                        {{ form_widget(form.requiredRole, {'attr': {'class': 'form-control-admin', 'placeholder': 'Laisser vide pour aucune restriction', 'style': 'font-family:monospace;'}}) }}
                        {{ form_errors(form.requiredRole) }}
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            {{ form_widget(form.isActive) }}
                            Commande active
                        </label>
                        {{ form_errors(form.isActive) }}
                    </div>

                    {# Note #}
                    <div style="padding:12px 16px;font-size:12px;color:var(--text-secondary);background:rgba(246,194,62,0.06);border:1px solid rgba(246,194,62,0.15);border-radius:6px;display:flex;align-items:center;gap:10px;margin-bottom:20px;">
                        <i class="fas fa-exclamation-triangle" style="color:#f6c23e;"></i>
                        Noms réservés : <code style="background:var(--bg-darker);padding:1px 5px;border-radius:3px;font-size:11px;">setup</code>,
                        <code style="background:var(--bg-darker);padding:1px 5px;border-radius:3px;font-size:11px;">warn</code>,
                        <code style="background:var(--bg-darker);padding:1px 5px;border-radius:3px;font-size:11px;">mute</code>,
                        <code style="background:var(--bg-darker);padding:1px 5px;border-radius:3px;font-size:11px;">kick</code>,
                        <code style="background:var(--bg-darker);padding:1px 5px;border-radius:3px;font-size:11px;">ban</code>,
                        <code style="background:var(--bg-darker);padding:1px 5px;border-radius:3px;font-size:11px;">warnings</code>,
                        <code style="background:var(--bg-darker);padding:1px 5px;border-radius:3px;font-size:11px;">role</code>
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ command ? 'Enregistrer' : 'Créer' }}
                        </button>
                        <a href="{{ path('admin_discord_commands') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
