{% extends 'admin/base.html.twig' %}

{% block page_title %}Ticket #{{ ticket.id }}{% endblock %}
{% block title %}Nexarena Admin - Ticket #{{ ticket.id }}{% endblock %}

{% block admin_body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 style="margin:0;font-weight:600;">
        <i class="fas fa-ticket-alt" style="color:var(--accent);margin-right:6px;"></i>
        Ticket #{{ ticket.id }} &mdash; {{ ticket.subject }}
    </h4>
    <a href="{{ path('admin_discord_tickets') }}" class="btn-admin btn-admin--outline btn-admin--sm"><i class="fas fa-arrow-left"></i> Retour</a>
</div>

{# Info grid #}
<div class="dc-info-grid">
    <div class="dc-info-item">
        <div class="dc-info-item__label">Utilisateur Discord</div>
        <div class="dc-info-item__value">{{ ticket.discordUsername }}</div>
    </div>
    <div class="dc-info-item">
        <div class="dc-info-item__label">Utilisateur site</div>
        <div class="dc-info-item__value">{{ ticket.siteUser ? ticket.siteUser.username : 'Non lie' }}</div>
    </div>
    <div class="dc-info-item">
        <div class="dc-info-item__label">Categorie</div>
        <div class="dc-info-item__value"><span class="dc-ticket-cat">{{ category_labels[ticket.category] ?? ticket.category }}</span></div>
    </div>
    <div class="dc-info-item">
        <div class="dc-info-item__label">Statut</div>
        <div class="dc-info-item__value"><span class="dc-ticket-status dc-ticket-status--{{ ticket.status }}">{{ ticket.status == 'open' ? 'Ouvert' : 'Ferme' }}</span></div>
    </div>
    <div class="dc-info-item">
        <div class="dc-info-item__label">Ouvert le</div>
        <div class="dc-info-item__value">{{ ticket.createdAt|time_ago }}</div>
    </div>
    {% if ticket.closedAt %}
    <div class="dc-info-item">
        <div class="dc-info-item__label">Ferme le</div>
        <div class="dc-info-item__value">{{ ticket.closedAt|time_ago }} par {{ ticket.closedBy }}</div>
    </div>
    {% endif %}
</div>

{# Description #}
{% if ticket.description %}
<div class="admin-table mb-3">
    <div class="admin-table__header">
        <h3><i class="fas fa-align-left" style="margin-right:8px;font-size:13px;"></i> Description initiale</h3>
    </div>
    <div style="padding:18px 22px;">
        <div style="color:var(--text-primary);font-size:13px;white-space:pre-wrap;line-height:1.6;opacity:0.85;">{{ ticket.description }}</div>
    </div>
</div>
{% endif %}

{# Conversation #}
<div class="admin-table">
    <div class="admin-table__header">
        <h3><i class="fas fa-comments" style="margin-right:8px;font-size:13px;"></i> Conversation</h3>
        <span style="font-size:12px;color:var(--text-secondary);">{{ ticket.messages|length }} message(s)</span>
    </div>
    <div style="padding:16px 22px;">
        <div class="dc-chat">
            {% for msg in ticket.messages %}
            <div class="dc-msg {{ msg.authorIsStaff ? 'dc-msg--staff' : '' }}">
                <div class="dc-msg__avatar">{{ msg.authorUsername|slice(0, 1)|upper }}</div>
                <div class="dc-msg__body">
                    <div class="dc-msg__head">
                        <span class="dc-msg__author">{{ msg.authorUsername }}</span>
                        {% if msg.authorIsStaff %}<span class="dc-msg__badge">Staff</span>{% endif %}
                        <span class="dc-msg__time">{{ msg.createdAt|time_ago('d/m/Y H:i:s') }}</span>
                    </div>
                    <div class="dc-msg__text">{{ msg.content }}</div>
                </div>
            </div>
            {% else %}
            <div style="text-align:center;color:var(--text-secondary);padding:30px;font-size:13px;">Aucun message.</div>
            {% endfor %}
        </div>
    </div>
</div>
<link rel="stylesheet" href="{{ asset('assets/css/admin/dashboard.css') }}">
<link rel="stylesheet" href="{{ asset('assets/css/admin/discord.css') }}">
{% endblock %}
