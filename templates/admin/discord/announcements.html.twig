{% extends 'admin/base.html.twig' %}

{% block page_title %}Annonces Discord{% endblock %}
{% block title %}Nexarena Admin - Annonces Discord{% endblock %}

{% block admin_body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 style="margin:0;font-weight:600;"><i class="fas fa-bullhorn" style="color:var(--accent);margin-right:6px;"></i> Annonces Discord</h4>
    <div style="display:flex;gap:8px;">
        <a href="{{ path('admin_discord_announcement_new') }}" class="btn-admin btn-admin--primary btn-admin--sm"><i class="fas fa-plus"></i> Nouvelle annonce</a>
        <a href="{{ path('admin_discord_index') }}" class="btn-admin btn-admin--outline btn-admin--sm"><i class="fas fa-arrow-left"></i> Retour</a>
    </div>
</div>

{# Table #}
<div class="admin-table">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Titre</th>
                <th>Type</th>
                <th>Canal ID</th>
                <th>Programmee</th>
                <th>Envoyee</th>
                <th>Par</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for ann in announcements %}
            <tr>
                <td style="font-weight:600;">{{ ann.id }}</td>
                <td style="color:var(--text-primary);font-size:13px;font-weight:500;">{{ ann.title|length > 50 ? ann.title[:50] ~ '...' : ann.title }}</td>
                <td>
                    {% if ann.type == 'patchnote' %}
                        <span class="dc-ticket-status" style="background:rgba(88,101,242,0.12);color:#7289da;">Patchnote</span>
                    {% else %}
                        <span class="dc-ticket-status" style="background:rgba(69,248,130,0.1);color:var(--accent);">Annonce</span>
                    {% endif %}
                </td>
                <td style="font-family:monospace;font-size:12px;color:var(--text-secondary);">{{ ann.channelId }}</td>
                <td style="color:var(--text-secondary);font-size:12px;">{{ ann.scheduledAt ? ann.scheduledAt|time_ago : 'Immediat' }}</td>
                <td>
                    {% if ann.sentAt %}
                        <span style="color:var(--accent);font-size:12px;">{{ ann.sentAt|time_ago }}</span>
                    {% else %}
                        <span style="color:var(--text-secondary);font-size:12px;">Non</span>
                    {% endif %}
                </td>
                <td style="color:var(--text-secondary);font-size:13px;">{{ ann.createdBy.username }}</td>
                <td>
                    <div style="display:flex;gap:6px;">
                        {% if not ann.sentAt %}
                        <form action="{{ path('admin_discord_announcement_send', {id: ann.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Envoyer cette annonce maintenant ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('ann_send_' ~ ann.id) }}">
                            <button type="submit" class="btn-admin btn-admin--outline btn-admin--sm" style="border-color:var(--accent);color:var(--accent);" title="Envoyer maintenant">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </form>
                        {% endif %}
                        <form action="{{ path('admin_discord_announcement_delete', {id: ann.id}) }}" method="post" style="display:inline;" onsubmit="return confirm('Supprimer cette annonce ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('ann_delete_' ~ ann.id) }}">
                            <button type="submit" class="btn-admin btn-admin--outline btn-admin--sm" style="border-color:var(--danger);color:var(--danger);" title="Supprimer">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text-secondary);font-size:13px;">Aucune annonce.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
<link rel="stylesheet" href="{{ asset('assets/css/admin/dashboard.css') }}">
<link rel="stylesheet" href="{{ asset('assets/css/admin/discord.css') }}">
{% endblock %}
