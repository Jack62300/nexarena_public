{% extends 'admin/base.html.twig' %}

{% block page_title %}Badges{% endblock %}
{% block title %}Nexarena Admin - Badges{% endblock %}

{% block admin_body %}
    <div class="admin-table">
        <div class="admin-table__header">
            <h3>Badges</h3>
            <a href="{{ path('admin_badges_new') }}" class="btn-admin btn-admin--primary">
                <i class="fas fa-plus"></i> Ajouter
            </a>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Icone</th>
                    <th>Nom</th>
                    <th>Couleur</th>
                    <th>Critere</th>
                    <th>Seuil</th>
                    <th>Attribue</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for badge in badges %}
                    <tr>
                        <td>
                            {% if badge.iconFileName %}
                                <img src="{{ asset('uploads/badges/' ~ badge.iconFileName) }}" alt="{{ badge.name }}" style="width:32px;height:32px;object-fit:contain;border-radius:6px;">
                            {% else %}
                                <i class="fas fa-award" style="font-size:20px;color:{{ badge.color ?? '#8b949e' }};"></i>
                            {% endif %}
                        </td>
                        <td><strong>{{ badge.name }}</strong></td>
                        <td>
                            {% if badge.color %}
                                <span style="display:inline-block;width:24px;height:24px;border-radius:6px;background:{{ badge.color }};border:1px solid rgba(255,255,255,0.1);"></span>
                            {% else %}
                                <span style="color:var(--text-secondary);font-size:12px;">—</span>
                            {% endif %}
                        </td>
                        <td style="color:var(--text-secondary);font-size:12px;">
                            {% if badge.criteria %}
                                {{ badge.criteria.type|default('—') }}
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td style="color:var(--text-secondary);">
                            {{ badge.criteria.threshold|default('—') }}
                        </td>
                        <td style="color:var(--text-secondary);">
                            {{ badge.userBadges|length }}
                        </td>
                        <td>
                            {% if badge.isActive %}
                                <span class="status-dot status-dot--active"></span>Actif
                            {% else %}
                                <span class="status-dot status-dot--inactive"></span>Inactif
                            {% endif %}
                        </td>
                        <td>
                            <div style="display:flex;gap:8px;">
                                <a href="{{ path('admin_badges_edit', {id: badge.id}) }}" class="btn-admin btn-admin--outline btn-admin--sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                {% if is_granted('ROLE_MANAGER') %}
                                    <form method="post" action="{{ path('admin_badges_delete', {id: badge.id}) }}" onsubmit="return confirm('Supprimer ce badge ?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ badge.id) }}">
                                        <button type="submit" class="btn-admin btn-admin--sm" style="background:var(--danger);color:#fff;border:none;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" style="text-align:center;color:var(--text-secondary);padding:30px;">
                            Aucun badge pour le moment.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
