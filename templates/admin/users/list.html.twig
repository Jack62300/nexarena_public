{% extends 'admin/base.html.twig' %}

{% block page_title %}Utilisateurs{% endblock %}
{% block title %}Nexarena Admin - Utilisateurs{% endblock %}

{% block admin_body %}
    <div class="admin-table">
        <div class="admin-table__header">
            <h3>Liste des utilisateurs</h3>
            <span style="color:var(--text-secondary);font-size:13px;">{{ users|length }} utilisateur(s)</span>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Utilisateur</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Inscription</th>
                    <th>Methode</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr {% if user.isCurrentlyBanned() %}style="opacity:.7;"{% endif %}>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                {% set av = user_avatar(user) %}
                                {% if av %}
                                    <img src="{{ av starts with 'http' ? av : asset(av) }}" alt="" style="width:30px;height:30px;border-radius:50%;object-fit:cover;">
                                {% else %}
                                    <div style="width:30px;height:30px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;">
                                        {{ user.username|slice(0, 1)|upper }}
                                    </div>
                                {% endif %}
                                <div>
                                    {{ user.username }}
                                    {% if user.isCurrentlyBanned() %}
                                        <span style="display:inline-block;margin-left:6px;padding:2px 7px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(255,71,87,.15);color:#ff4757;border:1px solid rgba(255,71,87,.3);"
                                              title="{{ user.banReason }}{% if user.banExpiresAt %} — expire le {{ user.banExpiresAt|date('d/m/Y H:i') }}{% endif %}">
                                            <i class="fas fa-ban" style="font-size:9px;"></i> BANNI{% if user.banExpiresAt %} temp.{% endif %}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td style="color:var(--text-secondary);">{{ user.email }}</td>
                        <td>{{ role_badge(user.roles)|raw }}</td>
                        <td style="color:var(--text-secondary);">{{ user.createdAt|time_ago }}</td>
                        <td>
                            {% if user.googleId %}
                                <i class="fab fa-google" style="color:#ea4335;" title="Google"></i>
                            {% endif %}
                            {% if user.discordId %}
                                <i class="fab fa-discord" style="color:#5865f2;" title="Discord"></i>
                            {% endif %}
                            {% if user.twitchId %}
                                <i class="fab fa-twitch" style="color:#9146ff;" title="Twitch"></i>
                            {% endif %}
                            {% if user.steamId %}
                                <i class="fab fa-steam" style="color:#c7d5e0;" title="Steam"></i>
                            {% endif %}
                            {% if user.password %}
                                <i class="fas fa-envelope" style="color:var(--text-secondary);" title="Email/Password"></i>
                            {% endif %}
                        </td>
                        <td>
                            <div style="display:flex;gap:8px;">
                                {% if is_granted('ROLE_RESPONSABLE') %}
                                    <a href="{{ path('admin_users_edit', {id: user.id}) }}" class="btn-admin btn-admin--outline btn-admin--sm" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                {% endif %}

                                {% if is_granted('ROLE_MANAGER') and user != app.user %}
                                    {% if user.isCurrentlyBanned() %}
                                        <form method="post" action="{{ path('admin_users_unban', {id: user.id}) }}" style="display:inline;" onsubmit="return confirm('Lever le ban de {{ user.username }} ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('user_unban_' ~ user.id) }}">
                                            <button type="submit" class="btn-admin btn-admin--sm" style="background:rgba(69,248,130,.15);color:#45f882;border:1px solid rgba(69,248,130,.3);" title="Lever le ban">
                                                <i class="fas fa-unlock"></i>
                                            </button>
                                        </form>
                                    {% else %}
                                        <button type="button"
                                                class="btn-admin btn-admin--sm js-ban-btn"
                                                style="background:rgba(255,71,87,.12);color:#ff4757;border:1px solid rgba(255,71,87,.25);"
                                                title="Bannir"
                                                data-user-id="{{ user.id }}"
                                                data-username="{{ user.username }}">
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    {% endif %}
                                {% endif %}

                                {% if is_granted('ROLE_RESPONSABLE') and user != app.user %}
                                    <button type="button"
                                            class="btn-admin btn-admin--sm js-delete-btn"
                                            style="background:rgba(231,76,60,.15);color:#e74c3c;border:1px solid rgba(231,76,60,.3);"
                                            title="Supprimer le compte"
                                            data-user-id="{{ user.id }}"
                                            data-username="{{ user.username }}"
                                            data-servers="{{ user.servers|length }}"
                                            data-token="{{ csrf_token('user_delete_' ~ user.id) }}">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align:center;color:var(--text-secondary);padding:30px;">
                            Aucun utilisateur inscrit.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# ── Delete modal ── #}
    <div id="deleteModal" style="display:none;position:fixed;inset:0;z-index:1001;align-items:center;justify-content:center;">
        <div style="position:absolute;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px);" id="deleteModalBackdrop"></div>
        <div style="position:relative;background:var(--bg-card);border:1px solid rgba(231,76,60,.35);border-radius:16px;padding:32px;width:100%;max-width:460px;margin:16px;">
            <div style="text-align:center;margin-bottom:20px;">
                <div style="width:60px;height:60px;border-radius:50%;background:rgba(231,76,60,.15);border:2px solid rgba(231,76,60,.4);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:24px;color:#e74c3c;">
                    <i class="fas fa-user-times"></i>
                </div>
                <h3 style="margin:0 0 6px;font-size:18px;color:#e74c3c;">Supprimer le compte</h3>
                <p id="deleteModalSubtitle" style="color:var(--text-secondary);font-size:14px;margin:0;"></p>
            </div>

            <div style="background:rgba(231,76,60,.07);border:1px solid rgba(231,76,60,.2);border-radius:10px;padding:14px 16px;margin-bottom:20px;font-size:13px;color:var(--text-secondary);">
                <div style="font-weight:700;color:#e74c3c;margin-bottom:8px;"><i class="fas fa-exclamation-triangle"></i> Cette action est irréversible. Seront supprimés :</div>
                <ul style="margin:0;padding-left:18px;line-height:2;">
                    <li>Tous ses <strong id="del-servers" style="color:#e6edf3;"></strong> serveur(s) et leurs données (votes, classement…)</li>
                    <li>Ses annonces de recrutement</li>
                    <li>Ses commentaires</li>
                    <li>Ses tokens et transactions</li>
                    <li>Tout le reste lié à ce compte</li>
                </ul>
            </div>

            <form id="deleteForm" method="post">
                <input type="hidden" name="_token" id="deleteCsrfToken">
                <div style="display:flex;gap:10px;">
                    <button type="button" id="deleteModalCancel" style="flex:1;padding:12px;background:transparent;border:1px solid var(--border);border-radius:10px;color:var(--text-secondary);font-size:14px;font-weight:600;cursor:pointer;">
                        Annuler
                    </button>
                    <button type="submit" style="flex:1;padding:12px;background:#e74c3c;border:none;border-radius:10px;color:#fff;font-size:14px;font-weight:700;cursor:pointer;">
                        <i class="fas fa-trash"></i> Supprimer définitivement
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# ── Ban modal ── #}
    <div id="banModal" style="display:none;position:fixed;inset:0;z-index:1000;align-items:center;justify-content:center;">
        <div style="position:absolute;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);" id="banModalBackdrop"></div>
        <div style="position:relative;background:var(--bg-card);border:1px solid var(--border);border-radius:16px;padding:32px;width:100%;max-width:460px;margin:16px;">
            <h3 style="margin:0 0 4px;font-size:18px;">Bannir l'utilisateur</h3>
            <p id="banModalSubtitle" style="color:var(--text-secondary);font-size:14px;margin:0 0 24px;"></p>

            <form id="banForm" method="post">
                <input type="hidden" name="_token" id="banCsrfToken">

                <div style="margin-bottom:18px;">
                    <label style="display:block;font-size:13px;font-weight:500;margin-bottom:10px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.4px;">Type de ban</label>
                    <div style="display:flex;gap:10px;">
                        <label style="flex:1;cursor:pointer;">
                            <input type="radio" name="type" value="permanent" checked onchange="toggleDuration(this)" style="display:none;">
                            <div class="ban-type-card ban-type-card--active" data-value="permanent" style="border:2px solid var(--accent);border-radius:10px;padding:12px;text-align:center;font-size:14px;font-weight:600;">
                                <i class="fas fa-infinity" style="display:block;font-size:20px;margin-bottom:4px;color:var(--accent);"></i>
                                Permanent
                            </div>
                        </label>
                        <label style="flex:1;cursor:pointer;">
                            <input type="radio" name="type" value="temporary" onchange="toggleDuration(this)" style="display:none;">
                            <div class="ban-type-card" data-value="temporary" style="border:2px solid var(--border);border-radius:10px;padding:12px;text-align:center;font-size:14px;font-weight:600;color:var(--text-secondary);">
                                <i class="fas fa-clock" style="display:block;font-size:20px;margin-bottom:4px;"></i>
                                Temporaire
                            </div>
                        </label>
                    </div>
                </div>

                <div id="durationGroup" style="display:none;margin-bottom:18px;">
                    <label style="display:block;font-size:13px;font-weight:500;margin-bottom:8px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.4px;">Durée</label>
                    <div style="display:flex;gap:8px;">
                        <input type="number" name="duration" min="1" max="365" value="7" style="flex:1;background:var(--bg-card-hover,rgba(255,255,255,.04));border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text-primary);font-size:15px;outline:none;">
                        <select name="duration_unit" style="flex:1;background:var(--bg-card-hover,rgba(255,255,255,.04));border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text-primary);font-size:14px;outline:none;">
                            <option value="hours">Heure(s)</option>
                            <option value="days" selected>Jour(s)</option>
                        </select>
                    </div>
                </div>

                <div style="margin-bottom:24px;">
                    <label style="display:block;font-size:13px;font-weight:500;margin-bottom:8px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.4px;">Raison <span style="font-weight:400;text-transform:none;">(optionnel)</span></label>
                    <textarea name="reason" rows="3" maxlength="500" placeholder="Ex : spam, triche, comportement toxique…" style="width:100%;background:var(--bg-card-hover,rgba(255,255,255,.04));border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text-primary);font-size:14px;resize:vertical;outline:none;"></textarea>
                </div>

                <div style="display:flex;gap:10px;">
                    <button type="button" id="banModalCancel" style="flex:1;padding:12px;background:transparent;border:1px solid var(--border);border-radius:10px;color:var(--text-secondary);font-size:14px;font-weight:600;cursor:pointer;">
                        Annuler
                    </button>
                    <button type="submit" style="flex:1;padding:12px;background:#ff4757;border:none;border-radius:10px;color:#fff;font-size:14px;font-weight:700;cursor:pointer;">
                        <i class="fas fa-ban"></i> Confirmer le ban
                    </button>
                </div>
            </form>
        </div>
    </div>

{% endblock %}

{% block admin_js %}
    <script nonce="{{ csp_nonce() }}">
    {# ── Delete modal ── #}
    (function () {
        var deleteModal    = document.getElementById('deleteModal');
        var deleteForm     = document.getElementById('deleteForm');
        var deleteSubtitle = document.getElementById('deleteModalSubtitle');
        var deleteCsrf     = document.getElementById('deleteCsrfToken');
        var delServers     = document.getElementById('del-servers');

        var deleteUrls = {
            {% for user in users %}
                {% if is_granted('ROLE_RESPONSABLE') and user != app.user %}
                    '{{ user.id }}': '{{ path('admin_users_delete', {id: user.id}) }}',
                {% endif %}
            {% endfor %}
        };

        document.querySelectorAll('.js-delete-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var userId   = btn.dataset.userId;
                var username = btn.dataset.username;
                var servers  = btn.dataset.servers;
                var token    = btn.dataset.token;

                deleteSubtitle.textContent = 'Compte : ' + username;
                delServers.textContent = servers;
                deleteForm.action = deleteUrls[userId];
                deleteCsrf.value  = token;
                deleteModal.style.display = 'flex';
            });
        });

        document.getElementById('deleteModalCancel').addEventListener('click', function () {
            deleteModal.style.display = 'none';
        });
        document.getElementById('deleteModalBackdrop').addEventListener('click', function () {
            deleteModal.style.display = 'none';
        });
    }());

    {# ── Ban modal ── #}
    (function () {
        var csrfTokens = {
            {% for user in users %}
                {% if is_granted('ROLE_MANAGER') and user != app.user and not user.isCurrentlyBanned() %}
                    '{{ user.id }}': '{{ csrf_token('user_ban_' ~ user.id) }}',
                {% endif %}
            {% endfor %}
        };
        var banUrls = {
            {% for user in users %}
                {% if is_granted('ROLE_MANAGER') and user != app.user and not user.isCurrentlyBanned() %}
                    '{{ user.id }}': '{{ path('admin_users_ban', {id: user.id}) }}',
                {% endif %}
            {% endfor %}
        };

        var modal = document.getElementById('banModal');

        document.querySelectorAll('.js-ban-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var userId = btn.dataset.userId;
                var username = btn.dataset.username;
                document.getElementById('banModalSubtitle').textContent = 'Utilisateur : ' + username;
                document.getElementById('banForm').action = banUrls[userId];
                document.getElementById('banCsrfToken').value = csrfTokens[userId];
                // Reset form
                document.querySelector('input[name="type"][value="permanent"]').checked = true;
                document.getElementById('durationGroup').style.display = 'none';
                document.querySelectorAll('.ban-type-card').forEach(function (c) {
                    c.style.border = '2px solid var(--border)';
                    c.style.color = 'var(--text-secondary)';
                });
                document.querySelector('.ban-type-card[data-value="permanent"]').style.border = '2px solid var(--accent)';
                document.querySelector('.ban-type-card[data-value="permanent"]').style.color = 'inherit';
                modal.style.display = 'flex';
            });
        });

        document.getElementById('banModalCancel').addEventListener('click', closeModal);
        document.getElementById('banModalBackdrop').addEventListener('click', closeModal);

        function closeModal() {
            modal.style.display = 'none';
        }
    }());

    function toggleDuration(radio) {
        var group = document.getElementById('durationGroup');
        group.style.display = radio.value === 'temporary' ? 'block' : 'none';
        document.querySelectorAll('.ban-type-card').forEach(function (c) {
            var active = c.dataset.value === radio.value;
            c.style.border = active ? '2px solid var(--accent)' : '2px solid var(--border)';
            c.style.color = active ? 'inherit' : 'var(--text-secondary)';
        });
    }
    </script>
{% endblock %}
