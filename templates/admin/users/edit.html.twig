{% extends 'admin/base.html.twig' %}

{% block page_title %}Modifier l'utilisateur{% endblock %}
{% block title %}Nexarena Admin - Modifier utilisateur{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus {
        outline: none;
        border-color: var(--accent);
    }
    .form-control-admin:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .role-checkbox {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        margin-bottom: 8px;
        cursor: pointer;
    }
    .role-checkbox:hover { border-color: var(--accent); }
    .role-checkbox input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
    .user-info {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 20px;
        background: var(--bg-darker);
        border-radius: 8px;
        margin-bottom: 25px;
    }
    .user-info__avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
    }
    .user-info__avatar-placeholder {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: 700;
    }
{% endblock %}

{% block admin_body %}
    <div>
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>Modifier l'utilisateur</h3>
                <a href="{{ path('admin_users_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                <div class="user-info">
                    {% set av = user_avatar(user) %}
                    {% if av %}
                        <img src="{{ av starts with 'http' ? av : asset(av) }}" alt="" class="user-info__avatar">
                    {% else %}
                        <div class="user-info__avatar-placeholder">
                            {{ user.username|slice(0, 1)|upper }}
                        </div>
                    {% endif %}
                    <div>
                        <div style="font-weight:600;font-size:16px;">{{ user.username }}</div>
                        <div style="color:var(--text-secondary);font-size:13px;">{{ user.email }}</div>
                        <div style="color:var(--text-secondary);font-size:12px;margin-top:4px;">
                            Inscrit le {{ user.createdAt|date('d/m/Y a H:i') }}
                        </div>
                    </div>
                </div>

                {# === Solde NexBits / NexBoost === #}
                <div style="display:flex;gap:16px;margin-bottom:25px;">
                    <div style="flex:1;padding:16px;background:rgba(255,215,0,0.06);border:1px solid rgba(255,215,0,0.15);border-radius:8px;display:flex;align-items:center;gap:12px;">
                        <i class="fas fa-coins" style="color:#ffd700;font-size:22px;"></i>
                        <div>
                            <div style="font-size:12px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.5px;">NexBits</div>
                            <div style="font-size:22px;font-weight:700;color:#ffd700;">{{ user.tokenBalance }}</div>
                        </div>
                    </div>
                    <div style="flex:1;padding:16px;background:rgba(255,107,53,0.06);border:1px solid rgba(255,107,53,0.15);border-radius:8px;display:flex;align-items:center;gap:12px;">
                        <i class="fas fa-bolt" style="color:#ff6b35;font-size:22px;"></i>
                        <div>
                            <div style="font-size:12px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.5px;">NexBoost</div>
                            <div style="font-size:22px;font-weight:700;color:#ff6b35;">{{ user.boostTokenBalance }}</div>
                        </div>
                    </div>
                </div>

                {# === Credit / Debit NexBits & NexBoost === #}
                <div style="background:var(--bg-darker);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:25px;">
                    <h4 style="font-size:14px;font-weight:700;color:var(--text-primary);margin-bottom:16px;">
                        <i class="fas fa-gift" style="color:#36b9cc;"></i> Crediter / Debiter
                    </h4>
                    <form method="post" action="{{ path('admin_users_credit', {id: user.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('user_credit_' ~ user.id) }}">
                        <div style="display:flex;gap:12px;margin-bottom:12px;">
                            <div style="flex:1;">
                                <label style="display:block;margin-bottom:4px;font-size:12px;font-weight:600;color:var(--text-secondary);">
                                    <i class="fas fa-coins" style="color:#ffd700;"></i> NexBits
                                </label>
                                <input type="number" name="nexbits" class="form-control-admin" value="0" step="1" placeholder="Ex: 100 ou -50">
                            </div>
                            <div style="flex:1;">
                                <label style="display:block;margin-bottom:4px;font-size:12px;font-weight:600;color:var(--text-secondary);">
                                    <i class="fas fa-bolt" style="color:#ff6b35;"></i> NexBoost
                                </label>
                                <input type="number" name="nexboost" class="form-control-admin" value="0" step="1" placeholder="Ex: 5 ou -2">
                            </div>
                        </div>
                        <div style="margin-bottom:12px;">
                            <label style="display:block;margin-bottom:4px;font-size:12px;font-weight:600;color:var(--text-secondary);">Raison (optionnel)</label>
                            <input type="text" name="credit_reason" class="form-control-admin" placeholder="Ex: Compensation, bonus evenement..." maxlength="200">
                        </div>
                        <div style="font-size:11px;color:var(--text-secondary);margin-bottom:12px;">
                            <i class="fas fa-info-circle"></i> Entrez un nombre negatif pour debiter. Le solde ne descendra pas en dessous de 0.
                        </div>
                        <button type="submit" class="btn-admin btn-admin--primary" style="background:#36b9cc;border-color:#36b9cc;">
                            <i class="fas fa-gift"></i> Appliquer
                        </button>
                    </form>
                </div>

                <form method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('user_edit') }}">

                    <div class="form-group">
                        <label for="username">Nom d'utilisateur</label>
                        <input type="text" id="username" name="username" class="form-control-admin" value="{{ user.username }}" required>
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" class="form-control-admin" value="{{ user.email }}" disabled>
                    </div>

                    <div class="form-group">
                        <label>Roles</label>
                        {% for role in assignable_roles %}
                            {% if role.technicalName != 'ROLE_USER' %}
                                <label class="role-checkbox">
                                    <input type="checkbox" name="roles[]" value="{{ role.technicalName }}" {{ role.technicalName in user.roles ? 'checked' : '' }}>
                                    <span class="role-badge" style="background:{{ role.color }}22;color:{{ role.color }};border:1px solid {{ role.color }}44;">
                                        {{ role.name }}
                                    </span>
                                    {% if role.description %}
                                        <span style="color:var(--text-secondary);font-size:12px;">{{ role.description }}</span>
                                    {% endif %}
                                </label>
                            {% endif %}
                        {% endfor %}
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> Enregistrer
                        </button>
                        <a href="{{ path('admin_users_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
