{% extends 'admin/base.html.twig' %}

{% block page_title %}Modifier l'utilisateur{% endblock %}
{% block title %}Nexarena Admin - Modifier utilisateur{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus {
        outline: none;
        border-color: var(--accent);
    }
    .form-control-admin:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .role-checkbox {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        margin-bottom: 8px;
        cursor: pointer;
    }
    .role-checkbox:hover { border-color: var(--accent); }
    .role-checkbox input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
    .user-info {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 20px;
        background: var(--bg-darker);
        border-radius: 8px;
        margin-bottom: 25px;
    }
    .user-info__avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
    }
    .user-info__avatar-placeholder {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: 700;
    }
{% endblock %}

{% block admin_body %}
    <div>
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>Modifier l'utilisateur</h3>
                <a href="{{ path('admin_users_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                <div class="user-info">
                    {% set av = user_avatar(user) %}
                    {% if av %}
                        <img src="{{ av starts with 'http' ? av : asset(av) }}" alt="" class="user-info__avatar">
                    {% else %}
                        <div class="user-info__avatar-placeholder">
                            {{ user.username|slice(0, 1)|upper }}
                        </div>
                    {% endif %}
                    <div>
                        <div style="font-weight:600;font-size:16px;">{{ user.username }}</div>
                        <div style="color:var(--text-secondary);font-size:13px;">{{ user.email }}</div>
                        <div style="color:var(--text-secondary);font-size:12px;margin-top:4px;">
                            Inscrit le {{ user.createdAt|time_ago }}
                        </div>
                    </div>
                </div>

                {# === Solde NexBits / NexBoost === #}
                <div style="display:flex;gap:16px;margin-bottom:25px;">
                    <div style="flex:1;padding:16px;background:rgba(255,215,0,0.06);border:1px solid rgba(255,215,0,0.15);border-radius:8px;display:flex;align-items:center;gap:12px;">
                        <i class="fas fa-coins" style="color:#ffd700;font-size:22px;"></i>
                        <div>
                            <div style="font-size:12px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.5px;">NexBits</div>
                            <div style="font-size:22px;font-weight:700;color:#ffd700;">{{ user.tokenBalance }}</div>
                        </div>
                    </div>
                    <div style="flex:1;padding:16px;background:rgba(255,107,53,0.06);border:1px solid rgba(255,107,53,0.15);border-radius:8px;display:flex;align-items:center;gap:12px;">
                        <i class="fas fa-bolt" style="color:#ff6b35;font-size:22px;"></i>
                        <div>
                            <div style="font-size:12px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.5px;">NexBoost</div>
                            <div style="font-size:22px;font-weight:700;color:#ff6b35;">{{ user.boostTokenBalance }}</div>
                        </div>
                    </div>
                </div>

                {# === Credit / Debit NexBits & NexBoost === #}
                <div style="background:var(--bg-darker);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:25px;">
                    <h4 style="font-size:14px;font-weight:700;color:var(--text-primary);margin-bottom:16px;">
                        <i class="fas fa-gift" style="color:#36b9cc;"></i> Crediter / Debiter
                    </h4>
                    <form method="post" action="{{ path('admin_users_credit', {id: user.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('user_credit_' ~ user.id) }}">
                        <div style="display:flex;gap:12px;margin-bottom:12px;">
                            <div style="flex:1;">
                                <label style="display:block;margin-bottom:4px;font-size:12px;font-weight:600;color:var(--text-secondary);">
                                    <i class="fas fa-coins" style="color:#ffd700;"></i> NexBits
                                </label>
                                <input type="number" name="nexbits" class="form-control-admin" value="0" step="1" placeholder="Ex: 100 ou -50">
                            </div>
                            <div style="flex:1;">
                                <label style="display:block;margin-bottom:4px;font-size:12px;font-weight:600;color:var(--text-secondary);">
                                    <i class="fas fa-bolt" style="color:#ff6b35;"></i> NexBoost
                                </label>
                                <input type="number" name="nexboost" class="form-control-admin" value="0" step="1" placeholder="Ex: 5 ou -2">
                            </div>
                        </div>
                        <div style="margin-bottom:12px;">
                            <label style="display:block;margin-bottom:4px;font-size:12px;font-weight:600;color:var(--text-secondary);">Raison (optionnel)</label>
                            <input type="text" name="credit_reason" class="form-control-admin" placeholder="Ex: Compensation, bonus evenement..." maxlength="200">
                        </div>
                        <div style="font-size:11px;color:var(--text-secondary);margin-bottom:12px;">
                            <i class="fas fa-info-circle"></i> Entrez un nombre negatif pour debiter. Le solde ne descendra pas en dessous de 0.
                        </div>
                        <button type="submit" class="btn-admin btn-admin--primary" style="background:#36b9cc;border-color:#36b9cc;">
                            <i class="fas fa-gift"></i> Appliquer
                        </button>
                    </form>
                </div>

                <form method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('user_edit') }}">

                    <div class="form-group">
                        <label for="username">Nom d'utilisateur</label>
                        <input type="text" id="username" name="username" class="form-control-admin" value="{{ user.username }}" required>
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" class="form-control-admin" value="{{ user.email }}" disabled>
                    </div>

                    <div class="form-group">
                        <label>Roles</label>
                        {% for role in assignable_roles %}
                            {% if role.technicalName != 'ROLE_USER' %}
                                <label class="role-checkbox">
                                    <input type="checkbox" name="roles[]" value="{{ role.technicalName }}" {{ role.technicalName in user.roles ? 'checked' : '' }}>
                                    <span class="role-badge" style="background:{{ role.color }}22;color:{{ role.color }};border:1px solid {{ role.color }}44;">
                                        {{ role.name }}
                                    </span>
                                    {% if role.description %}
                                        <span style="color:var(--text-secondary);font-size:12px;">{{ role.description }}</span>
                                    {% endif %}
                                </label>
                            {% endif %}
                        {% endfor %}
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> Enregistrer
                        </button>
                        <a href="{{ path('admin_users_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>
                </form>

                {% if is_granted('ROLE_RESPONSABLE') and user != app.user %}
                {# ── Zone de suppression ── #}
                <div style="margin-top:32px;border-top:1px solid rgba(231,76,60,.25);padding-top:24px;">
                    <h4 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#e74c3c;margin-bottom:8px;">
                        <i class="fas fa-exclamation-triangle"></i> Zone dangereuse
                    </h4>
                    <p style="font-size:13px;color:var(--text-secondary);margin-bottom:14px;">
                        Supprime définitivement ce compte et toutes ses données associées (serveurs, recrutements, commentaires, tokens…).
                    </p>
                    <button type="button" id="editDeleteBtn" class="btn-admin"
                            style="background:rgba(231,76,60,.12);color:#e74c3c;border:1px solid rgba(231,76,60,.35);"
                            data-user-id="{{ user.id }}"
                            data-username="{{ user.username }}"
                            data-servers="{{ user.servers|length }}"
                            data-token="{{ csrf_token('user_delete_' ~ user.id) }}"
                            data-url="{{ path('admin_users_delete', {id: user.id}) }}">
                        <i class="fas fa-user-times"></i> Supprimer ce compte
                    </button>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    {% if is_granted('ROLE_RESPONSABLE') and user != app.user %}
    {# ── Delete confirmation modal ── #}
    <div id="editDeleteModal" style="display:none;position:fixed;inset:0;z-index:1001;align-items:center;justify-content:center;">
        <div style="position:absolute;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px);" id="editDeleteBackdrop"></div>
        <div style="position:relative;background:var(--bg-card);border:1px solid rgba(231,76,60,.35);border-radius:16px;padding:32px;width:100%;max-width:460px;margin:16px;">
            <div style="text-align:center;margin-bottom:20px;">
                <div style="width:60px;height:60px;border-radius:50%;background:rgba(231,76,60,.15);border:2px solid rgba(231,76,60,.4);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:24px;color:#e74c3c;">
                    <i class="fas fa-user-times"></i>
                </div>
                <h3 style="margin:0 0 6px;font-size:18px;color:#e74c3c;">Supprimer le compte</h3>
                <p style="color:var(--text-secondary);font-size:14px;margin:0;">{{ user.username }}</p>
            </div>
            <div style="background:rgba(231,76,60,.07);border:1px solid rgba(231,76,60,.2);border-radius:10px;padding:14px 16px;margin-bottom:20px;font-size:13px;color:var(--text-secondary);">
                <div style="font-weight:700;color:#e74c3c;margin-bottom:8px;"><i class="fas fa-exclamation-triangle"></i> Cette action est irréversible. Seront supprimés :</div>
                <ul style="margin:0;padding-left:18px;line-height:2;">
                    <li>Ses <strong style="color:#e6edf3;">{{ user.servers|length }} serveur(s)</strong> et leurs données</li>
                    <li>Ses annonces de recrutement</li>
                    <li>Ses commentaires</li>
                    <li>Ses tokens et transactions</li>
                </ul>
            </div>
            <form method="post" action="{{ path('admin_users_delete', {id: user.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('user_delete_' ~ user.id) }}">
                <div style="display:flex;gap:10px;">
                    <button type="button" id="editDeleteCancel" style="flex:1;padding:12px;background:transparent;border:1px solid var(--border);border-radius:10px;color:var(--text-secondary);font-size:14px;font-weight:600;cursor:pointer;">
                        Annuler
                    </button>
                    <button type="submit" style="flex:1;padding:12px;background:#e74c3c;border:none;border-radius:10px;color:#fff;font-size:14px;font-weight:700;cursor:pointer;">
                        <i class="fas fa-trash"></i> Supprimer définitivement
                    </button>
                </div>
            </form>
        </div>
    </div>
    {% endif %}
{% endblock %}

{% block admin_js %}
{% if is_granted('ROLE_RESPONSABLE') and user != app.user %}
<script nonce="{{ csp_nonce() }}">
(function () {
    var modal   = document.getElementById('editDeleteModal');
    var btn     = document.getElementById('editDeleteBtn');
    var cancel  = document.getElementById('editDeleteCancel');
    var backdrop = document.getElementById('editDeleteBackdrop');
    if (!btn) return;
    btn.addEventListener('click', function () {
        modal.style.display = 'flex';
    });
    cancel.addEventListener('click', function () { modal.style.display = 'none'; });
    backdrop.addEventListener('click', function () { modal.style.display = 'none'; });
}());
</script>
{% endif %}
{% endblock %}
