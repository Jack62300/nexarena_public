{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ partner ? 'Modifier' : 'Ajouter un partenaire' }}{% endblock %}
{% block title %}Nexarena Admin - {{ partner ? 'Modifier' : 'Nouveau' }} partenaire{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus { outline: none; border-color: var(--accent); }
    .form-check-admin { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .form-check-admin input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent); }
    .logo-preview { max-width: 120px; max-height: 80px; border-radius: 6px; margin-top: 10px; object-fit: contain; }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ partner ? 'Modifier le partenaire' : 'Ajouter un partenaire' }}</h3>
                <a href="{{ path('admin_partners_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                    <div class="form-group">
                        <label for="{{ form.name.vars.id }}">Nom</label>
                        {{ form_widget(form.name, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.url.vars.id }}">URL</label>
                        {{ form_widget(form.url, {'attr': {'class': 'form-control-admin', 'placeholder': 'https://'}}) }}
                        {{ form_errors(form.url) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.type.vars.id }}">Type</label>
                        {{ form_widget(form.type, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.type) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.logoFile.vars.id }}">Logo</label>
                        {% if partner and partner.logoFileName %}
                            <div style="margin-bottom:8px;">
                                <img src="{{ asset('uploads/partners/' ~ partner.logoFileName) }}" alt="" class="logo-preview">
                            </div>
                        {% endif %}
                        {{ form_widget(form.logoFile, {'attr': {'style': 'color:var(--text-secondary);'}}) }}
                        {{ form_errors(form.logoFile) }}
                        <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">PNG, JPG, GIF, SVG ou WebP - 2 Mo max</div>
                    </div>

                    <div class="form-group">
                        <label for="{{ form.position.vars.id }}">Position</label>
                        {{ form_widget(form.position, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.position) }}
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            {{ form_widget(form.isActive) }}
                            Actif
                        </label>
                        {{ form_errors(form.isActive) }}
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ partner ? 'Enregistrer' : 'Créer' }}
                        </button>
                        <a href="{{ path('admin_partners_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
