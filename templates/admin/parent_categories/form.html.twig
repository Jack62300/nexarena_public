{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ category ? 'Modifier la categorie' : 'Nouvelle categorie' }}{% endblock %}
{% block title %}Nexarena Admin - {{ category ? 'Modifier' : 'Nouvelle' }} categorie{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus {
        outline: none;
        border-color: var(--accent);
    }
    textarea.form-control-admin { min-height: 120px; resize: vertical; }
    .form-check-admin {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .form-check-admin input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
    .image-preview {
        max-width: 200px;
        max-height: 150px;
        border-radius: 6px;
        margin-top: 10px;
        object-fit: cover;
    }
    .icon-preview-box {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 8px;
        padding: 8px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
    }
    .icon-preview-box i { font-size: 24px; color: var(--accent); }
    .icon-preview-box span { font-size: 12px; color: var(--text-secondary); }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ category ? 'Modifier la categorie' : 'Creer une categorie' }}</h3>
                <a href="{{ path('admin_parent_categories_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                <form method="post" enctype="multipart/form-data">
                    <input type="hidden" name="_token" value="{{ csrf_token('parent_category_form') }}">

                    <div class="form-group">
                        <label for="name">Nom</label>
                        <input type="text" id="name" name="name" class="form-control-admin" value="{{ category ? category.name : '' }}" required>
                    </div>

                    <div class="form-group">
                        <label for="icon">Icone FontAwesome</label>
                        <input type="text" id="icon" name="icon" class="form-control-admin"
                               value="{{ category ? category.icon : '' }}"
                               placeholder="fas fa-server"
                               oninput="document.getElementById('icon-preview').className = this.value">
                        <div class="icon-preview-box">
                            <i id="icon-preview" class="{{ category and category.icon ? category.icon : 'fas fa-server' }}"></i>
                            <span>Apercu</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="description">Description</label>
                        <textarea id="description" name="description" class="form-control-admin">{{ category ? category.description : '' }}</textarea>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="image">Image</label>
                                <input type="file" id="image" name="image" class="form-control-admin" accept="image/*">
                                {% if category and category.image %}
                                    <img src="{{ asset('uploads/categories/' ~ category.image) }}" alt="" class="image-preview">
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="position">Position (ordre d'affichage)</label>
                                <input type="number" id="position" name="position" class="form-control-admin" value="{{ category ? category.position : 0 }}" min="0">
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="query_type">Protocole de requete serveur</label>
                        <select id="query_type" name="query_type" class="form-control-admin">
                            <option value="">Aucun (pas de query)</option>
                            <option value="cfx" {{ category and category.queryType == 'cfx' ? 'selected' : '' }}>FiveM / RedM (CFX)</option>
                            <option value="source" {{ category and category.queryType == 'source' ? 'selected' : '' }}>Source Engine (Rust, CS2, GMod, ARK, DayZ...)</option>
                            <option value="minecraft" {{ category and category.queryType == 'minecraft' ? 'selected' : '' }}>Minecraft</option>
                        </select>
                        <div style="font-size:12px;color:var(--text-secondary);margin-top:6px;">
                            Permet de recuperer les joueurs connectes et le statut des serveurs de cette categorie.
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            <input type="checkbox" name="is_active" value="1" {{ (category is null or category.isActive) ? 'checked' : '' }}>
                            Categorie active
                        </label>
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ category ? 'Enregistrer' : 'Creer' }}
                        </button>
                        <a href="{{ path('admin_parent_categories_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
