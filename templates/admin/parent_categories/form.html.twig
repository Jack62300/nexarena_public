{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ category ? 'Modifier la catégorie' : 'Nouvelle catégorie' }}{% endblock %}
{% block title %}Nexarena Admin - {{ category ? 'Modifier' : 'Nouvelle' }} catégorie{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus {
        outline: none;
        border-color: var(--accent);
    }
    textarea.form-control-admin { min-height: 120px; resize: vertical; }
    .form-check-admin {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .form-check-admin input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
    .image-preview {
        max-width: 200px;
        max-height: 150px;
        border-radius: 6px;
        margin-top: 10px;
        object-fit: cover;
    }
    .icon-preview-box {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 8px;
        padding: 8px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
    }
    .icon-preview-box i { font-size: 24px; color: var(--accent); }
    .icon-preview-box span { font-size: 12px; color: var(--text-secondary); }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ category ? 'Modifier la catégorie' : 'Créer une catégorie' }}</h3>
                <a href="{{ path('admin_parent_categories_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                    <div class="form-group">
                        <label for="{{ form.name.vars.id }}">Nom</label>
                        {{ form_widget(form.name, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.icon.vars.id }}">Icône FontAwesome</label>
                        {{ form_widget(form.icon, {'attr': {'class': 'form-control-admin', 'placeholder': 'fas fa-server', 'oninput': "document.getElementById('icon-preview').className = this.value"}}) }}
                        {{ form_errors(form.icon) }}
                        <div class="icon-preview-box">
                            <i id="icon-preview" class="{{ category and category.icon ? category.icon : 'fas fa-server' }}"></i>
                            <span>Aperçu</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="{{ form.description.vars.id }}">Description</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.imageFile.vars.id }}">Image</label>
                                {{ form_widget(form.imageFile, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.imageFile) }}
                                {% if category and category.image %}
                                    <img src="{{ asset('uploads/categories/' ~ category.image) }}" alt="" class="image-preview">
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.position.vars.id }}">Position (ordre d'affichage)</label>
                                {{ form_widget(form.position, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.position) }}
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="{{ form.queryType.vars.id }}">Protocole de requête serveur</label>
                        {{ form_widget(form.queryType, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.queryType) }}
                        <div style="font-size:12px;color:var(--text-secondary);margin-top:6px;">
                            Permet de récupérer les joueurs connectés et le statut des serveurs de cette catégorie.
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            {{ form_widget(form.isActive) }}
                            Catégorie active
                        </label>
                        {{ form_errors(form.isActive) }}
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ category ? 'Enregistrer' : 'Créer' }}
                        </button>
                        <a href="{{ path('admin_parent_categories_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
