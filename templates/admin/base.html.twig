<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Nexarena Admin{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ asset('assets/img/logo/new_logo_hd.png') }}">
    <link rel="apple-touch-icon" href="{{ asset('assets/img/logo/new_logo_hd.png') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/fontawesome-all.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/admin/base.css') }}">
    <style>{% block admin_css %}{% endblock %}</style>
</head>
<body>

    {# ===== SIDEBAR ===== #}
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="admin-sidebar__logo">
            <a href="{{ path('app_home') }}">
                <img src="{{ asset('assets/img/logo/new_logo_hd.png') }}" alt="{{ setting('site_name', 'Nexarena') }}">
            </a>
            <span>Administration</span>
        </div>

        {% set _r = app.current_route %}

        <nav class="admin-sidebar__nav">

            {# ── Principal ── #}
            <a href="{{ path('admin_dashboard') }}" class="admin-sidebar__link admin-sidebar__link--solo {{ _r == 'admin_dashboard' ? 'active' : '' }}">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>

            {# ── Contenu ── #}
            {% set contentActive = _r starts with 'admin_articles_' or _r starts with 'admin_parent_categories_' or _r starts with 'admin_categories_' or _r starts with 'admin_server_types_' or _r starts with 'admin_tags_' or _r starts with 'admin_servers_' or _r starts with 'admin_comments_' or _r starts with 'admin_plugins_' or _r starts with 'admin_plugin_submissions_' or _r starts with 'admin_partners_' or _r starts with 'admin_recruitment_' %}
            <div class="admin-sidebar__group admin-sidebar__group--green {{ contentActive ? 'open' : '' }}">
                <button class="admin-sidebar__section" type="button">
                    <span><i class="fas fa-th-large"></i> Contenu</span>
                    <i class="fas fa-chevron-right admin-sidebar__arrow"></i>
                </button>
                <div class="admin-sidebar__items">
                    <a href="{{ path('admin_articles_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_articles_' ? 'active' : '' }}">
                        <i class="fas fa-newspaper"></i> Articles
                    </a>
                    <a href="{{ path('admin_parent_categories_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_parent_categories_' ? 'active' : '' }}">
                        <i class="fas fa-layer-group"></i> Categories
                    </a>
                    <a href="{{ path('admin_categories_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_categories_' ? 'active' : '' }}">
                        <i class="fas fa-gamepad"></i> Sous-categories
                    </a>
                    <a href="{{ path('admin_server_types_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_server_types_' ? 'active' : '' }}">
                        <i class="fas fa-tags"></i> Types de serveur
                    </a>
                    <a href="{{ path('admin_tags_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_tags_' ? 'active' : '' }}">
                        <i class="fas fa-hashtag"></i> Tags
                    </a>
                    <a href="{{ path('admin_servers_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_servers_' ? 'active' : '' }}">
                        <i class="fas fa-server"></i> Serveurs
                    </a>
                    <a href="{{ path('admin_comments_flagged') }}" class="admin-sidebar__link {{ _r starts with 'admin_comments_' ? 'active' : '' }}">
                        <i class="fas fa-comments"></i> Commentaires
                        {% set flaggedCount = flagged_comments_count() %}
                        {% if flaggedCount > 0 %}
                            <span class="badge bg-danger">{{ flaggedCount }}</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('admin_plugins_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_plugins_' and not (_r starts with 'admin_plugin_submissions_') ? 'active' : '' }}">
                        <i class="fas fa-puzzle-piece"></i> Plugins
                    </a>
                    <a href="{{ path('admin_plugin_submissions_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_plugin_submissions_' ? 'active' : '' }}">
                        <i class="fas fa-inbox"></i> Soumissions plugins
                        {% set pendingSubs = pending_plugin_submissions_count() %}
                        {% if pendingSubs > 0 %}
                            <span class="badge bg-warning text-dark">{{ pendingSubs }}</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('admin_partners_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_partners_' ? 'active' : '' }}">
                        <i class="fas fa-handshake"></i> Partenaires
                    </a>
                    <a href="{{ path('admin_recruitment_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_recruitment_' ? 'active' : '' }}">
                        <i class="fas fa-bullhorn"></i> Recrutement
                        {% set pendingRecruitments = pending_recruitments_count() %}
                        {% if pendingRecruitments > 0 %}
                            <span class="badge bg-warning text-dark">{{ pendingRecruitments }}</span>
                        {% endif %}
                    </a>
                </div>
            </div>

            {# ── Paiement ── #}
            {% set paymentActive = _r starts with 'admin_premium_plans_' or _r starts with 'admin_transactions_' %}
            <div class="admin-sidebar__group admin-sidebar__group--gold {{ paymentActive ? 'open' : '' }}">
                <button class="admin-sidebar__section" type="button">
                    <span><i class="fas fa-crown"></i> Paiement</span>
                    <i class="fas fa-chevron-right admin-sidebar__arrow"></i>
                </button>
                <div class="admin-sidebar__items">
                    <a href="{{ path('admin_premium_plans_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_premium_plans_' ? 'active' : '' }}">
                        <i class="fas fa-gem"></i> Plans Premium
                    </a>
                    <a href="{{ path('admin_transactions_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_transactions_' ? 'active' : '' }}">
                        <i class="fas fa-receipt"></i> Transactions
                    </a>
                </div>
            </div>

            {# ── Utilisateurs ── #}
            {% set usersActive = _r starts with 'admin_users_' or _r starts with 'admin_votes_' or _r starts with 'admin_achievements_' or _r starts with 'admin_blacklist_' or _r starts with 'admin_ip_bans_' %}
            <div class="admin-sidebar__group admin-sidebar__group--cyan {{ usersActive ? 'open' : '' }}">
                <button class="admin-sidebar__section" type="button">
                    <span><i class="fas fa-users"></i> Utilisateurs</span>
                    <i class="fas fa-chevron-right admin-sidebar__arrow"></i>
                </button>
                <div class="admin-sidebar__items">
                    <a href="{{ path('admin_users_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_users_' ? 'active' : '' }}">
                        <i class="fas fa-user-cog"></i> Utilisateurs
                    </a>
                    <a href="{{ path('admin_votes_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_votes_' ? 'active' : '' }}">
                        <i class="fas fa-vote-yea"></i> Votes
                    </a>
                    <a href="{{ path('admin_achievements_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_achievements_' ? 'active' : '' }}">
                        <i class="fas fa-trophy"></i> Succès
                    </a>
                    <a href="{{ path('admin_blacklist_index') }}" class="admin-sidebar__link {{ _r starts with 'admin_blacklist_' ? 'active' : '' }}">
                        <i class="fas fa-ban"></i> Listes noires
                    </a>
                    <a href="{{ path('admin_users_bans') }}" class="admin-sidebar__link {{ _r == 'admin_users_bans' ? 'active' : '' }}">
                        <i class="fas fa-ban"></i> Bans Utilisateurs
                        {% set activeBansCount = banned_users_count() %}
                        {% if activeBansCount > 0 %}
                            <span class="badge bg-danger">{{ activeBansCount }}</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('admin_ip_bans_index') }}" class="admin-sidebar__link {{ _r starts with 'admin_ip_bans_' ? 'active' : '' }}">
                        <i class="fas fa-network-wired"></i> Bans IP
                        {% set ipBansCount = active_ip_bans_count() %}
                        {% if ipBansCount > 0 %}
                            <span class="badge bg-danger">{{ ipBansCount }}</span>
                        {% endif %}
                    </a>
                </div>
            </div>

            {# ── Configuration ── #}
            {% if is_granted('ROLE_RESPONSABLE') %}
            {% set configActive = _r starts with 'admin_settings_' or _r starts with 'admin_roles_' or _r starts with 'admin_themes_' or _r starts with 'admin_security_access_' %}
            <div class="admin-sidebar__group admin-sidebar__group--purple {{ configActive ? 'open' : '' }}">
                <button class="admin-sidebar__section" type="button">
                    <span><i class="fas fa-cog"></i> Configuration</span>
                    <i class="fas fa-chevron-right admin-sidebar__arrow"></i>
                </button>
                <div class="admin-sidebar__items">
                    <a href="{{ path('admin_settings_index') }}" class="admin-sidebar__link {{ _r starts with 'admin_settings_' ? 'active' : '' }}">
                        <i class="fas fa-sliders-h"></i> Parametres
                    </a>
                    <a href="{{ path('admin_roles_index') }}" class="admin-sidebar__link {{ _r starts with 'admin_roles_' ? 'active' : '' }}">
                        <i class="fas fa-shield-alt"></i> Roles & Permissions
                    </a>
                    <a href="{{ path('admin_themes_index') }}" class="admin-sidebar__link {{ _r starts with 'admin_themes_' ? 'active' : '' }}">
                        <i class="fas fa-palette"></i> Themes
                    </a>
                    <a href="{{ path('admin_security_access_index') }}" class="admin-sidebar__link {{ _r starts with 'admin_security_access_' ? 'active' : '' }}">
                        <i class="fas fa-shield-alt"></i> Securite & Acces
                    </a>
                </div>
            </div>
            {% endif %}

            {# ── Discord ── #}
            {% set discordActive = _r starts with 'admin_discord_' %}
            <div class="admin-sidebar__group admin-sidebar__group--blurple {{ discordActive ? 'open' : '' }}">
                <button class="admin-sidebar__section" type="button">
                    <span><i class="fab fa-discord"></i> Discord</span>
                    <i class="fas fa-chevron-right admin-sidebar__arrow"></i>
                </button>
                <div class="admin-sidebar__items">
                    <a href="{{ path('admin_discord_index') }}" class="admin-sidebar__link {{ _r == 'admin_discord_index' ? 'active' : '' }}">
                        <i class="fas fa-chart-bar"></i> Dashboard
                    </a>
                    <a href="{{ path('admin_discord_moderation') }}" class="admin-sidebar__link {{ _r == 'admin_discord_moderation' or _r == 'admin_discord_moderation_add' or _r == 'admin_discord_moderation_delete' ? 'active' : '' }}">
                        <i class="fas fa-ban"></i> Moderation
                    </a>
                    <a href="{{ path('admin_discord_moderation_log') }}" class="admin-sidebar__link {{ _r == 'admin_discord_moderation_log' ? 'active' : '' }}">
                        <i class="fas fa-scroll"></i> Journal Bot
                        {% set modlogCount = discord_modlog_today_count() %}
                        {% if modlogCount > 0 %}
                            <span class="badge bg-info">{{ modlogCount }}</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('admin_discord_sanctions') }}" class="admin-sidebar__link {{ _r starts with 'admin_discord_sanction' ? 'active' : '' }}">
                        <i class="fas fa-gavel"></i> Sanctions
                        {% set activeSanctions = discord_active_sanctions_count() %}
                        {% if activeSanctions > 0 %}
                            <span class="badge bg-warning text-dark">{{ activeSanctions }}</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('admin_discord_tickets') }}" class="admin-sidebar__link {{ _r starts with 'admin_discord_ticket' ? 'active' : '' }}">
                        <i class="fas fa-ticket-alt"></i> Tickets
                        {% set openTickets = discord_open_tickets_count() %}
                        {% if openTickets > 0 %}
                            <span class="badge bg-success">{{ openTickets }}</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('admin_discord_reaction_roles') }}" class="admin-sidebar__link {{ _r starts with 'admin_discord_reaction_role' ? 'active' : '' }}">
                        <i class="fas fa-smile"></i> Reaction Roles
                    </a>
                    <a href="{{ path('admin_discord_commands') }}" class="admin-sidebar__link {{ _r starts with 'admin_discord_command' ? 'active' : '' }}">
                        <i class="fas fa-terminal"></i> Commandes
                    </a>
                    <a href="{{ path('admin_discord_announcements') }}" class="admin-sidebar__link {{ _r starts with 'admin_discord_announcement' ? 'active' : '' }}">
                        <i class="fas fa-bullhorn"></i> Annonces
                    </a>
                    <a href="{{ path('admin_discord_invites') }}" class="admin-sidebar__link {{ _r starts with 'admin_discord_invite' ? 'active' : '' }}">
                        <i class="fas fa-user-plus"></i> Invitations
                    </a>
                </div>
            </div>

            {# ── Technique ── #}
            {% if is_granted('ROLE_DEVELOPPEUR') %}
            {% set techActive = _r starts with 'admin_webhooks_' or _r starts with 'admin_logs_' or _r starts with 'admin_server_admin_' or _r starts with 'admin_linux_users_' %}
            <div class="admin-sidebar__group admin-sidebar__group--red {{ techActive ? 'open' : '' }}">
                <button class="admin-sidebar__section" type="button">
                    <span><i class="fas fa-code"></i> Technique</span>
                    <i class="fas fa-chevron-right admin-sidebar__arrow"></i>
                </button>
                <div class="admin-sidebar__items">
                    <a href="{{ path('admin_webhooks_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_webhooks_' ? 'active' : '' }}">
                        <i class="fas fa-plug"></i> Webhooks
                    </a>
                    <a href="{{ path('admin_logs_list') }}" class="admin-sidebar__link {{ _r starts with 'admin_logs_' ? 'active' : '' }}">
                        <i class="fas fa-terminal"></i> Logs
                    </a>
                    <a href="{{ path('admin_server_admin_index') }}" class="admin-sidebar__link {{ _r starts with 'admin_server_admin_' ? 'active' : '' }}">
                        <i class="fas fa-server"></i> Serveur Ubuntu
                    </a>
                    <a href="{{ path('admin_linux_users_index') }}" class="admin-sidebar__link {{ _r starts with 'admin_linux_users_' ? 'active' : '' }}">
                        <i class="fas fa-users-cog"></i> Utilisateurs Linux
                    </a>
                </div>
            </div>
            {% endif %}

        </nav>

        <div class="admin-sidebar__footer">
            <a href="{{ path('app_home') }}"><i class="fas fa-arrow-left"></i> Retour au site</a>
        </div>
    </aside>

    {# ===== HEADER ===== #}
    <header class="admin-header">
        <div class="admin-header__left">
            <button class="admin-header__toggle" onclick="document.getElementById('adminSidebar').classList.toggle('open')">
                <i class="fas fa-bars"></i>
            </button>
            <span class="admin-header__title">{% block page_title %}Dashboard{% endblock %}</span>
        </div>
        <div class="admin-header__right">
            <a href="{{ path('app_home') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                <i class="fas fa-external-link-alt"></i> Voir le site
            </a>
            <div class="admin-header__user">
                {% set av = user_avatar(app.user) %}
                {% if av %}
                    <img src="{{ av starts with 'http' ? av : asset(av) }}" alt="{{ app.user.username }}">
                {% else %}
                    <div class="admin-header__user-avatar-placeholder">
                        {{ app.user.username|slice(0, 1)|upper }}
                    </div>
                {% endif %}
                <span>{{ app.user.username }}</span>
            </div>
            <a href="{{ path('app_logout') }}" class="btn-admin btn-admin--outline btn-admin--sm" title="Deconnexion">
                <i class="fas fa-sign-out-alt"></i>
            </a>
        </div>
    </header>

    {# ===== MAIN ===== #}
    <main class="admin-main">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block admin_body %}{% endblock %}
    </main>

    <script src="{{ asset('assets/js/vendor/jquery-3.6.0.min.js') }}"></script>
    <script src="{{ asset('assets/js/bootstrap.min.js') }}"></script>
    <script nonce="{{ csp_nonce() }}">
    document.querySelectorAll('.admin-sidebar__section').forEach(function(btn){
        btn.addEventListener('click', function(){
            var group = btn.closest('.admin-sidebar__group');
            if(!group) return;
            group.classList.toggle('open');
        });
    });
    </script>
    {% block admin_js %}{% endblock %}
</body>
</html>
