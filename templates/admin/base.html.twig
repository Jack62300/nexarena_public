<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Nexarena Admin{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ asset('assets/img/logo/favicon.png') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/fontawesome-all.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/admin/base.css') }}">
    <style>{% block admin_css %}{% endblock %}</style>
</head>
<body>

    {# ===== SIDEBAR ===== #}
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="admin-sidebar__logo">
            <a href="{{ path('app_home') }}">
                <img src="{{ asset('assets/img/logo/new_logoh.png') }}" alt="{{ setting('site_name', 'Nexarena') }}">
            </a>
            <span>Administration</span>
        </div>

        <nav class="admin-sidebar__nav">
            <div class="admin-sidebar__section">Principal</div>
            <a href="{{ path('admin_dashboard') }}" class="admin-sidebar__link {{ app.request.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>

            <div class="admin-sidebar__section">Contenu</div>
            <a href="{{ path('admin_articles_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_articles_' ? 'active' : '' }}">
                <i class="fas fa-newspaper"></i> Articles
            </a>
            <a href="{{ path('admin_parent_categories_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_parent_categories_' ? 'active' : '' }}">
                <i class="fas fa-layer-group"></i> Categories
            </a>
            <a href="{{ path('admin_categories_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_categories_' ? 'active' : '' }}">
                <i class="fas fa-gamepad"></i> Sous-categories
            </a>
            <a href="{{ path('admin_server_types_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_server_types_' ? 'active' : '' }}">
                <i class="fas fa-tags"></i> Types de serveur
            </a>
            <a href="{{ path('admin_servers_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_servers_' ? 'active' : '' }}">
                <i class="fas fa-server"></i> Serveurs
            </a>
            <a href="{{ path('admin_comments_flagged') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_comments_' ? 'active' : '' }}">
                <i class="fas fa-comments"></i> Commentaires
                {% set flaggedCount = flagged_comments_count() %}
                {% if flaggedCount > 0 %}
                    <span class="badge bg-danger">{{ flaggedCount }}</span>
                {% endif %}
            </a>
            <a href="{{ path('admin_plugins_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_plugins_' ? 'active' : '' }}">
                <i class="fas fa-puzzle-piece"></i> Plugins
            </a>
            <a href="{{ path('admin_partners_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_partners_' ? 'active' : '' }}">
                <i class="fas fa-handshake"></i> Partenaires
            </a>
            <a href="{{ path('admin_recruitment_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_recruitment_' ? 'active' : '' }}">
                <i class="fas fa-bullhorn"></i> Recrutement
                {% set pendingRecruitments = pending_recruitments_count() %}
                {% if pendingRecruitments > 0 %}
                    <span class="badge bg-warning text-dark">{{ pendingRecruitments }}</span>
                {% endif %}
            </a>
            <a href="{{ path('admin_featured_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_featured_' ? 'active' : '' }}">
                <i class="fas fa-star"></i> Mise en avant
            </a>

            <div class="admin-sidebar__section">Utilisateurs</div>
            <a href="{{ path('admin_users_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_users_' ? 'active' : '' }}">
                <i class="fas fa-users"></i> Utilisateurs
            </a>
            <a href="{{ path('admin_votes_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_votes_' ? 'active' : '' }}">
                <i class="fas fa-vote-yea"></i> Votes
            </a>

            {% if is_granted('ROLE_RESPONSABLE') %}
            <div class="admin-sidebar__section">Configuration</div>
            <a href="{{ path('admin_settings_index') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_settings_' ? 'active' : '' }}">
                <i class="fas fa-cog"></i> Parametres
            </a>
            <a href="{{ path('admin_roles_index') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_roles_' ? 'active' : '' }}">
                <i class="fas fa-shield-alt"></i> Roles & Permissions
            </a>
            <a href="{{ path('admin_themes_index') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_themes_' ? 'active' : '' }}">
                <i class="fas fa-palette"></i> Themes
            </a>
            {% endif %}

            {% if is_granted('ROLE_DEVELOPPEUR') %}
            <div class="admin-sidebar__section">Technique</div>
            <a href="{{ path('admin_webhooks_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_webhooks_' ? 'active' : '' }}">
                <i class="fas fa-plug"></i> Webhooks
            </a>
            <a href="{{ path('admin_logs_list') }}" class="admin-sidebar__link {{ app.request.get('_route') starts with 'admin_logs_' ? 'active' : '' }}">
                <i class="fas fa-terminal"></i> Logs
            </a>
            {% endif %}
        </nav>

        <div class="admin-sidebar__footer">
            <a href="{{ path('app_home') }}"><i class="fas fa-arrow-left"></i> Retour au site</a>
        </div>
    </aside>

    {# ===== HEADER ===== #}
    <header class="admin-header">
        <div class="admin-header__left">
            <button class="admin-header__toggle" onclick="document.getElementById('adminSidebar').classList.toggle('open')">
                <i class="fas fa-bars"></i>
            </button>
            <span class="admin-header__title">{% block page_title %}Dashboard{% endblock %}</span>
        </div>
        <div class="admin-header__right">
            <a href="{{ path('app_home') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                <i class="fas fa-external-link-alt"></i> Voir le site
            </a>
            <div class="admin-header__user">
                {% set av = user_avatar(app.user) %}
                {% if av %}
                    <img src="{{ av starts with 'http' ? av : asset(av) }}" alt="{{ app.user.username }}">
                {% else %}
                    <div class="admin-header__user-avatar-placeholder">
                        {{ app.user.username|slice(0, 1)|upper }}
                    </div>
                {% endif %}
                <span>{{ app.user.username }}</span>
            </div>
            <a href="{{ path('app_logout') }}" class="btn-admin btn-admin--outline btn-admin--sm" title="Deconnexion">
                <i class="fas fa-sign-out-alt"></i>
            </a>
        </div>
    </header>

    {# ===== MAIN ===== #}
    <main class="admin-main">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block admin_body %}{% endblock %}
    </main>

    <script src="{{ asset('assets/js/vendor/jquery-3.6.0.min.js') }}"></script>
    <script src="{{ asset('assets/js/bootstrap.min.js') }}"></script>
    {% block admin_js %}{% endblock %}
</body>
</html>
