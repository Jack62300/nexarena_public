{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ category ? 'Modifier la sous-catégorie' : 'Nouvelle sous-catégorie' }}{% endblock %}
{% block title %}Nexarena Admin - {{ category ? 'Modifier' : 'Nouvelle' }} sous-catégorie{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus { outline: none; border-color: var(--accent); }
    textarea.form-control-admin { min-height: 120px; resize: vertical; }
    .form-check-admin {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .form-check-admin input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
    .image-preview {
        max-width: 200px;
        max-height: 150px;
        border-radius: 6px;
        margin-top: 10px;
        object-fit: cover;
    }
    .icon-preview {
        width: 64px;
        height: 64px;
        border-radius: 8px;
        margin-top: 10px;
        object-fit: contain;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        padding: 4px;
    }
    .upload-hint {
        font-size: 11px;
        color: var(--text-secondary);
        margin-top: 5px;
    }
    .upload-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
    }
    .upload-badge--green { background: rgba(69,248,130,0.1); color: #45f882; border: 1px solid rgba(69,248,130,0.2); }
    .upload-badge--blue  { background: rgba(79,195,247,0.1); color: #4fc3f7; border: 1px solid rgba(79,195,247,0.2); }
    .color-row { display: flex; align-items: center; gap: 12px; }
    .color-swatch {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        flex-shrink: 0;
    }
    .field-builder-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 12px;
        margin-top: 12px;
    }
    .field-card {
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 14px;
        transition: border-color 0.2s;
    }
    .field-card.active { border-color: var(--accent); }
    .field-card__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }
    .field-card__label {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-primary);
    }
    .field-card__key {
        font-size: 10px;
        color: var(--text-secondary);
        font-family: monospace;
        margin-top: 2px;
    }
    .field-card__icon {
        font-size: 18px;
        color: var(--accent);
        margin-bottom: 8px;
    }
    .field-toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 6px;
    }
    .field-toggle-row:first-of-type { margin-top: 0; }
    .toggle-switch {
        position: relative;
        width: 34px;
        height: 18px;
        flex-shrink: 0;
    }
    .toggle-switch input { opacity: 0; width: 0; height: 0; }
    .toggle-slider {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.1);
        border-radius: 18px;
        cursor: pointer;
        transition: background 0.2s;
    }
    .toggle-slider:before {
        content: '';
        position: absolute;
        width: 12px;
        height: 12px;
        left: 3px;
        top: 3px;
        background: #fff;
        border-radius: 50%;
        transition: transform 0.2s;
    }
    .toggle-switch input:checked + .toggle-slider { background: var(--accent); }
    .toggle-switch input:checked + .toggle-slider:before { transform: translateX(16px); }
    .toggle-switch input:disabled + .toggle-slider { opacity: 0.4; cursor: not-allowed; }
    .field-builder-hint {
        font-size: 12px;
        color: var(--text-secondary);
        margin-top: 8px;
    }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ category ? 'Modifier la sous-catégorie' : 'Créer une sous-catégorie' }}</h3>
                <a href="{{ path('admin_categories_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                    <div class="form-group">
                        <label for="{{ form.category.vars.id }}">Catégorie parente</label>
                        {{ form_widget(form.category, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.category) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.name.vars.id }}">Nom</label>
                        {{ form_widget(form.name, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.description.vars.id }}">Description</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.color.vars.id }}">Couleur</label>
                                <div class="color-row">
                                    <input type="color" id="colorPicker" value="{{ category and category.color ? category.color : '#45f882' }}" style="width:60px;height:40px;border:1px solid var(--border-color);border-radius:6px;background:var(--bg-darker);cursor:pointer;">
                                    {{ form_widget(form.color, {'attr': {'id': 'colorHex', 'class': 'form-control-admin', 'placeholder': '#45f882', 'style': 'flex:1;'}}) }}
                                </div>
                                {{ form_errors(form.color) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.position.vars.id }}">Position</label>
                                {{ form_widget(form.position, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.position) }}
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.imageFile.vars.id }}">
                                    Image — page d'accueil (top 10)
                                </label>
                                <div class="upload-badge upload-badge--green">
                                    <i class="fas fa-home"></i> Pop-cats homepage
                                </div>
                                {{ form_widget(form.imageFile, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.imageFile) }}
                                <div class="upload-hint">Format portrait recommandé (3:4) — JPEG, PNG, WebP, SVG — max 5 Mo</div>
                                {% if category and category.image %}
                                    <img src="{{ asset('uploads/categories/' ~ category.image) }}" alt="" class="image-preview">
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.iconFile.vars.id }}">
                                    Icône — page de classement
                                </label>
                                <div class="upload-badge upload-badge--blue">
                                    <i class="fas fa-trophy"></i> Page ranking
                                </div>
                                {{ form_widget(form.iconFile, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.iconFile) }}
                                <div class="upload-hint">Format carré recommandé (logo) — JPEG, PNG, WebP, SVG — max 2 Mo</div>
                                {% if category and category.icon %}
                                    <img src="{{ asset('uploads/categories/' ~ category.icon) }}" alt="" class="icon-preview">
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            {{ form_widget(form.isActive) }}
                            Catégorie active
                        </label>
                        {{ form_errors(form.isActive) }}
                    </div>

                    {# === CHAMPS DE CONNEXION === #}
                    <div class="form-group" style="margin-top:24px;">
                        <label style="font-size:14px;font-weight:700;color:var(--text-primary);margin-bottom:4px;">
                            <i class="fas fa-plug" style="margin-right:6px;color:var(--accent);"></i>
                            Champs de connexion
                        </label>
                        <div class="field-builder-hint">
                            Définissez quels champs de connexion sont affichés lors de la création/édition d'un serveur
                            dans cette sous-catégorie. Si aucun champ n'est activé, tous les champs sont affichés
                            (rétrocompatibilité).
                        </div>
                        <input type="hidden" id="server_form_fields_json" name="server_form_fields_json" value="">

                        <div class="field-builder-grid" id="fieldBuilderGrid">
                            {# Cards rendered by JS #}
                        </div>
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ category ? 'Enregistrer' : 'Créer' }}
                        </button>
                        <a href="{{ path('admin_categories_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}

{% block admin_js %}
<script nonce="{{ csp_nonce() }}">
(function() {
    // Color picker sync
    var colorPicker = document.getElementById('colorPicker');
    var colorHex = document.getElementById('colorHex');
    if (colorPicker && colorHex) {
        colorPicker.addEventListener('input', function() { colorHex.value = colorPicker.value; });
        colorHex.addEventListener('input', function() {
            if (/^#[0-9a-fA-F]{6}$/.test(colorHex.value)) colorPicker.value = colorHex.value;
        });
    }

    // ── Field Builder ──
    var FIELD_DEFS = [
        { key: 'ip',          label: 'Adresse IP / Hostname', icon: 'fas fa-server' },
        { key: 'port',        label: 'Port',                  icon: 'fas fa-ethernet' },
        { key: 'connect_url', label: 'URL de connexion',      icon: 'fas fa-link' },
        { key: 'website',     label: 'Site web',              icon: 'fas fa-globe' },
        { key: 'discord_url', label: 'Lien Discord',          icon: 'fab fa-discord' },
    ];

    // Load existing config from entity
    var existingRaw = {{ (category and category.serverFormFields is not null) ? category.serverFormFields|json_encode|raw : '[]' }};
    // Build a map: key -> {shown, required}
    var state = {};
    FIELD_DEFS.forEach(function(fd) {
        state[fd.key] = { shown: false, required: false };
    });
    if (existingRaw && existingRaw.length > 0) {
        existingRaw.forEach(function(fc) {
            if (state[fc.key] !== undefined) {
                state[fc.key].shown = true;
                state[fc.key].required = !!fc.required;
            }
        });
    }

    var grid = document.getElementById('fieldBuilderGrid');
    var hiddenInput = document.getElementById('server_form_fields_json');

    function serialize() {
        var result = [];
        FIELD_DEFS.forEach(function(fd) {
            if (state[fd.key].shown) {
                result.push({ key: fd.key, required: state[fd.key].required });
            }
        });
        hiddenInput.value = JSON.stringify(result);
    }

    function renderCards() {
        grid.innerHTML = '';
        FIELD_DEFS.forEach(function(fd) {
            var s = state[fd.key];
            var card = document.createElement('div');
            card.className = 'field-card' + (s.shown ? ' active' : '');

            card.innerHTML =
                '<div class="field-card__icon"><i class="' + fd.icon + '"></i></div>' +
                '<div class="field-card__header">' +
                    '<div>' +
                        '<div class="field-card__label">' + fd.label + '</div>' +
                        '<div class="field-card__key">' + fd.key + '</div>' +
                    '</div>' +
                '</div>' +
                '<div class="field-toggle-row">' +
                    '<span>Afficher</span>' +
                    '<label class="toggle-switch">' +
                        '<input type="checkbox" class="js-shown" data-key="' + fd.key + '"' + (s.shown ? ' checked' : '') + '>' +
                        '<span class="toggle-slider"></span>' +
                    '</label>' +
                '</div>' +
                '<div class="field-toggle-row">' +
                    '<span>Obligatoire</span>' +
                    '<label class="toggle-switch">' +
                        '<input type="checkbox" class="js-required" data-key="' + fd.key + '"' +
                            (s.required ? ' checked' : '') + (!s.shown ? ' disabled' : '') + '>' +
                        '<span class="toggle-slider"></span>' +
                    '</label>' +
                '</div>';

            card.querySelector('.js-shown').addEventListener('change', function() {
                state[fd.key].shown = this.checked;
                if (!this.checked) state[fd.key].required = false;
                renderCards();
                serialize();
            });
            card.querySelector('.js-required').addEventListener('change', function() {
                state[fd.key].required = this.checked;
                serialize();
            });

            grid.appendChild(card);
        });
    }

    renderCards();
    serialize();
})();
</script>
{% endblock %}
