{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ category ? 'Modifier la sous-catégorie' : 'Nouvelle sous-catégorie' }}{% endblock %}
{% block title %}Nexarena Admin - {{ category ? 'Modifier' : 'Nouvelle' }} sous-catégorie{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus { outline: none; border-color: var(--accent); }
    textarea.form-control-admin { min-height: 120px; resize: vertical; }
    .form-check-admin {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .form-check-admin input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
    .image-preview {
        max-width: 200px;
        max-height: 150px;
        border-radius: 6px;
        margin-top: 10px;
        object-fit: cover;
    }
    .icon-preview {
        width: 64px;
        height: 64px;
        border-radius: 8px;
        margin-top: 10px;
        object-fit: contain;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        padding: 4px;
    }
    .upload-hint {
        font-size: 11px;
        color: var(--text-secondary);
        margin-top: 5px;
    }
    .upload-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
    }
    .upload-badge--green { background: rgba(69,248,130,0.1); color: #45f882; border: 1px solid rgba(69,248,130,0.2); }
    .upload-badge--blue  { background: rgba(79,195,247,0.1); color: #4fc3f7; border: 1px solid rgba(79,195,247,0.2); }
    .color-row { display: flex; align-items: center; gap: 12px; }
    .color-swatch {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        flex-shrink: 0;
    }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ category ? 'Modifier la sous-catégorie' : 'Créer une sous-catégorie' }}</h3>
                <a href="{{ path('admin_categories_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                    <div class="form-group">
                        <label for="{{ form.category.vars.id }}">Catégorie parente</label>
                        {{ form_widget(form.category, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.category) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.name.vars.id }}">Nom</label>
                        {{ form_widget(form.name, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.description.vars.id }}">Description</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.color.vars.id }}">Couleur</label>
                                <div class="color-row">
                                    <input type="color" id="colorPicker" value="{{ category and category.color ? category.color : '#45f882' }}" style="width:60px;height:40px;border:1px solid var(--border-color);border-radius:6px;background:var(--bg-darker);cursor:pointer;">
                                    {{ form_widget(form.color, {'attr': {'id': 'colorHex', 'class': 'form-control-admin', 'placeholder': '#45f882', 'style': 'flex:1;'}}) }}
                                </div>
                                {{ form_errors(form.color) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.position.vars.id }}">Position</label>
                                {{ form_widget(form.position, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.position) }}
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.imageFile.vars.id }}">
                                    Image — page d'accueil (top 10)
                                </label>
                                <div class="upload-badge upload-badge--green">
                                    <i class="fas fa-home"></i> Pop-cats homepage
                                </div>
                                {{ form_widget(form.imageFile, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.imageFile) }}
                                <div class="upload-hint">Format portrait recommandé (3:4) — JPEG, PNG, WebP, SVG — max 5 Mo</div>
                                {% if category and category.image %}
                                    <img src="{{ asset('uploads/categories/' ~ category.image) }}" alt="" class="image-preview">
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.iconFile.vars.id }}">
                                    Icône — page de classement
                                </label>
                                <div class="upload-badge upload-badge--blue">
                                    <i class="fas fa-trophy"></i> Page ranking
                                </div>
                                {{ form_widget(form.iconFile, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.iconFile) }}
                                <div class="upload-hint">Format carré recommandé (logo) — JPEG, PNG, WebP, SVG — max 2 Mo</div>
                                {% if category and category.icon %}
                                    <img src="{{ asset('uploads/categories/' ~ category.icon) }}" alt="" class="icon-preview">
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            {{ form_widget(form.isActive) }}
                            Catégorie active
                        </label>
                        {{ form_errors(form.isActive) }}
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ category ? 'Enregistrer' : 'Créer' }}
                        </button>
                        <a href="{{ path('admin_categories_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}

{% block admin_js %}
<script>
(function() {
    var colorPicker = document.getElementById('colorPicker');
    var colorHex = document.getElementById('colorHex');
    if (!colorPicker || !colorHex) return;

    colorPicker.addEventListener('input', function() {
        colorHex.value = colorPicker.value;
    });
    colorHex.addEventListener('input', function() {
        if (/^#[0-9a-fA-F]{6}$/.test(colorHex.value)) {
            colorPicker.value = colorHex.value;
        }
    });
})();
</script>
{% endblock %}
