{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ category ? 'Modifier la sous-categorie' : 'Nouvelle sous-categorie' }}{% endblock %}
{% block title %}Nexarena Admin - {{ category ? 'Modifier' : 'Nouvelle' }} sous-categorie{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus {
        outline: none;
        border-color: var(--accent);
    }
    select.form-control-admin {
        appearance: auto;
    }
    textarea.form-control-admin { min-height: 120px; resize: vertical; }
    .form-check-admin {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .form-check-admin input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
    .image-preview {
        max-width: 200px;
        max-height: 150px;
        border-radius: 6px;
        margin-top: 10px;
        object-fit: cover;
    }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ category ? 'Modifier la sous-categorie' : 'Creer une sous-categorie' }}</h3>
                <a href="{{ path('admin_categories_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                <form method="post" enctype="multipart/form-data">
                    <input type="hidden" name="_token" value="{{ csrf_token('category_form') }}">

                    <div class="form-group">
                        <label for="category_id">Categorie parente</label>
                        <select id="category_id" name="category_id" class="form-control-admin">
                            <option value="">-- Aucune --</option>
                            {% for parent in parentCategories %}
                                <option value="{{ parent.id }}"
                                    {{ (category and category.category and category.category.id == parent.id) ? 'selected' : '' }}>
                                    {{ parent.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="name">Nom</label>
                        <input type="text" id="name" name="name" class="form-control-admin" value="{{ category ? category.name : '' }}" required>
                    </div>

                    <div class="form-group">
                        <label for="description">Description</label>
                        <textarea id="description" name="description" class="form-control-admin">{{ category ? category.description : '' }}</textarea>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="image">Image</label>
                                <input type="file" id="image" name="image" class="form-control-admin" accept="image/*">
                                {% if category and category.image %}
                                    <img src="{{ asset('uploads/categories/' ~ category.image) }}" alt="" class="image-preview">
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="color">Couleur</label>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <input type="color" id="color" name="color" value="{{ category and category.color ? category.color : '#45f882' }}" style="width:50px;height:38px;padding:2px;background:var(--bg-darker);border:1px solid var(--border-color);border-radius:6px;cursor:pointer;">
                                    <input type="text" id="colorHex" class="form-control-admin" value="{{ category and category.color ? category.color : '' }}" placeholder="#45f882" maxlength="7" style="flex:1;">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="position">Position (ordre d'affichage)</label>
                                <input type="number" id="position" name="position" class="form-control-admin" value="{{ category ? category.position : 0 }}" min="0">
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            <input type="checkbox" name="is_active" value="1" {{ (category is null or category.isActive) ? 'checked' : '' }}>
                            Sous-categorie active
                        </label>
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ category ? 'Enregistrer' : 'Creer' }}
                        </button>
                        <a href="{{ path('admin_categories_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% block admin_js %}
<script>
(function(){
    const picker = document.getElementById('color');
    const hex = document.getElementById('colorHex');
    picker.addEventListener('input', function(){ hex.value = this.value; });
    hex.addEventListener('input', function(){ if (/^#[0-9a-fA-F]{6}$/.test(this.value)) picker.value = this.value; });
})();
</script>
{% endblock %}
