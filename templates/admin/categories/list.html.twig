{% extends 'admin/base.html.twig' %}

{% block page_title %}Sous-categories{% endblock %}
{% block title %}Nexarena Admin - Sous-categories{% endblock %}

{% block admin_body %}
    <div class="admin-table">
        <div class="admin-table__header">
            <h3>Sous-categories (Jeux)</h3>
            <a href="{{ path('admin_categories_new') }}" class="btn-admin btn-admin--primary">
                <i class="fas fa-plus"></i> Nouvelle sous-categorie
            </a>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Nom</th>
                    <th>Categorie parente</th>
                    <th>Position</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for category in categories %}
                    <tr>
                        <td>
                            {% if category.image %}
                                <img src="{{ asset('uploads/categories/' ~ category.image) }}" alt="" style="width:60px;height:40px;object-fit:cover;border-radius:4px;">
                            {% else %}
                                <div style="width:60px;height:40px;border-radius:4px;background:var(--bg-darker);display:flex;align-items:center;justify-content:center;">
                                    <i class="fas fa-gamepad" style="color:var(--text-secondary);"></i>
                                </div>
                            {% endif %}
                        </td>
                        <td>{{ category.name }}</td>
                        <td>
                            {% if category.category %}
                                <span style="color:var(--accent);">
                                    {% if category.category.icon %}<i class="{{ category.category.icon }}"></i> {% endif %}{{ category.category.name }}
                                </span>
                            {% else %}
                                <span style="color:var(--text-secondary);font-style:italic;">Aucune</span>
                            {% endif %}
                        </td>
                        <td style="color:var(--text-secondary);">{{ category.position }}</td>
                        <td>
                            {% if category.isActive %}
                                <span class="status-dot status-dot--active"></span>Active
                            {% else %}
                                <span class="status-dot status-dot--inactive"></span>Inactive
                            {% endif %}
                        </td>
                        <td>
                            <div style="display:flex;gap:8px;">
                                <a href="{{ path('admin_categories_edit', {id: category.id}) }}" class="btn-admin btn-admin--outline btn-admin--sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                {% if is_granted('ROLE_MANAGER') %}
                                    <form method="post" action="{{ path('admin_categories_delete', {id: category.id}) }}" onsubmit="return confirm('Supprimer cette sous-categorie ?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ category.id) }}">
                                        <button type="submit" class="btn-admin btn-admin--sm" style="background:var(--danger);color:#fff;border:none;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align:center;color:var(--text-secondary);padding:30px;">
                            Aucune sous-categorie pour le moment.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
