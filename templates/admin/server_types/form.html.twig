{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ serverType ? 'Modifier le type' : 'Nouveau type de serveur' }}{% endblock %}
{% block title %}Nexarena Admin - {{ serverType ? 'Modifier' : 'Nouveau' }} type de serveur{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus { outline: none; border-color: var(--accent); }
    .form-check-admin {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .form-check-admin input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ serverType ? 'Modifier le type' : 'Créer un type de serveur' }}</h3>
                <a href="{{ path('admin_server_types_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                {{ form_start(form) }}

                    <div class="form-group">
                        <label for="{{ form.category.vars.id }}">Catégorie parente</label>
                        {{ form_widget(form.category, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.category) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.name.vars.id }}">Nom du type</label>
                        {{ form_widget(form.name, {'attr': {'class': 'form-control-admin', 'placeholder': 'PvP, RP, Creative...'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.position.vars.id }}">Position (ordre d'affichage)</label>
                        {{ form_widget(form.position, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.position) }}
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            {{ form_widget(form.isActive) }}
                            Type actif
                        </label>
                        {{ form_errors(form.isActive) }}
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ serverType ? 'Enregistrer' : 'Créer' }}
                        </button>
                        <a href="{{ path('admin_server_types_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
