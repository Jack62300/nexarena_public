{% extends 'admin/base.html.twig' %}

{% block page_title %}Types de serveur{% endblock %}
{% block title %}Nexarena Admin - Types de serveur{% endblock %}

{% block admin_body %}
    <div class="admin-table">
        <div class="admin-table__header">
            <h3>Types de serveur</h3>
            <a href="{{ path('admin_server_types_new') }}" class="btn-admin btn-admin--primary">
                <i class="fas fa-plus"></i> Nouveau type
            </a>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Categorie</th>
                    <th>Position</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for st in serverTypes %}
                    <tr>
                        <td><strong>{{ st.name }}</strong></td>
                        <td>
                            {% if st.category %}
                                {% if st.category.icon %}
                                    <i class="{{ st.category.icon }}" style="margin-right:5px;color:var(--accent);"></i>
                                {% endif %}
                                {{ st.category.name }}
                            {% else %}
                                <span style="color:var(--text-secondary);">—</span>
                            {% endif %}
                        </td>
                        <td style="color:var(--text-secondary);">{{ st.position }}</td>
                        <td>
                            {% if st.isActive %}
                                <span class="status-dot status-dot--active"></span>Actif
                            {% else %}
                                <span class="status-dot status-dot--inactive"></span>Inactif
                            {% endif %}
                        </td>
                        <td>
                            <div style="display:flex;gap:8px;">
                                <a href="{{ path('admin_server_types_edit', {id: st.id}) }}" class="btn-admin btn-admin--outline btn-admin--sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                {% if is_granted('ROLE_MANAGER') %}
                                    <form method="post" action="{{ path('admin_server_types_delete', {id: st.id}) }}" onsubmit="return confirm('Supprimer ce type de serveur ?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ st.id) }}">
                                        <button type="submit" class="btn-admin btn-admin--sm" style="background:var(--danger);color:#fff;border:none;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" style="text-align:center;color:var(--text-secondary);padding:30px;">
                            Aucun type de serveur pour le moment.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
