{% extends 'admin/base.html.twig' %}

{% block page_title %}Dashboard{% endblock %}
{% block title %}Nexarena Admin - Dashboard{% endblock %}

{% block admin_body %}

    {# ===== KPI CARDS ===== #}
    <div class="row g-3 mb-4">
        {% for key, stat in stats %}
            <div class="col-xl-2 col-lg-4 col-md-6">
                <div class="kpi-card">
                    <div class="kpi-card__icon" style="background:{{ stat.color }}22;color:{{ stat.color }};">
                        <i class="{{ stat.icon }}"></i>
                    </div>
                    <div class="kpi-card__data">
                        <div class="kpi-card__value">{{ stat.value }}</div>
                        <div class="kpi-card__label">{{ stat.label }}</div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {# ===== REVENUE CHART + CATEGORY DOUGHNUT ===== #}
    <div class="row g-3 mb-4">
        <div class="col-xl-8">
            <div class="dash-card">
                <div class="dash-card__head">
                    <h4><i class="fas fa-chart-area"></i> Revenus PayPal (12 mois)</h4>
                </div>
                <div class="dash-card__body dash-card__body--chart">
                    <canvas id="chartRevenue"></canvas>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="dash-card">
                <div class="dash-card__head">
                    <h4><i class="fas fa-chart-pie"></i> Serveurs par categorie</h4>
                </div>
                <div class="dash-card__body dash-card__body--chart">
                    <canvas id="chartCategory"></canvas>
                </div>
            </div>
        </div>
    </div>

    {# ===== INSCRIPTIONS + VOTES CHARTS ===== #}
    <div class="row g-3 mb-4">
        <div class="col-xl-6">
            <div class="dash-card">
                <div class="dash-card__head">
                    <h4><i class="fas fa-chart-line"></i> Inscriptions (12 mois)</h4>
                </div>
                <div class="dash-card__body dash-card__body--chart-sm">
                    <canvas id="chartUsers"></canvas>
                </div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="dash-card">
                <div class="dash-card__head">
                    <h4><i class="fas fa-chart-bar"></i> Votes (12 mois)</h4>
                </div>
                <div class="dash-card__body dash-card__body--chart-sm">
                    <canvas id="chartVotes"></canvas>
                </div>
            </div>
        </div>
    </div>

    {# ===== DERNIERS ARTICLES ===== #}
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="dash-card">
                <div class="dash-card__head">
                    <h4><i class="fas fa-newspaper"></i> Derniers articles</h4>
                    <a href="{{ path('admin_articles_list') }}" class="dash-card__link">Voir tout <i class="fas fa-arrow-right"></i></a>
                </div>
                <div class="dash-card__body dash-card__body--flush">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Image</th>
                                <th>Titre</th>
                                <th>Statut</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for article in recent_articles %}
                                <tr>
                                    <td>
                                        {% if article.image %}
                                            <img src="{{ asset('uploads/articles/' ~ article.image) }}" alt="" style="width:48px;height:32px;object-fit:cover;border-radius:4px;">
                                        {% else %}
                                            <div style="width:48px;height:32px;border-radius:4px;background:rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:center;">
                                                <i class="fas fa-image" style="color:var(--text-secondary);font-size:11px;"></i>
                                            </div>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="dash-user__name">{{ article.title }}</span>
                                    </td>
                                    <td>
                                        {% if article.isPublished %}
                                            <span class="dash-badge dash-badge--success">Publie</span>
                                        {% else %}
                                            <span class="dash-badge dash-badge--muted">Brouillon</span>
                                        {% endif %}
                                    </td>
                                    <td class="dash-table__muted">{{ article.createdAt|time_ago }}</td>
                                    <td>
                                        <a href="{{ path('admin_articles_edit', {id: article.id}) }}" class="dash-card__link" style="font-size:13px;">
                                            <i class="fas fa-edit"></i> Modifier
                                        </a>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="5" class="dash-table__empty">Aucun article pour le moment.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    {# ===== RECENT USERS + RECENT TRANSACTIONS ===== #}
    <div class="row g-3">
        <div class="col-xl-7">
            <div class="dash-card">
                <div class="dash-card__head">
                    <h4><i class="fas fa-users"></i> Derniers inscrits</h4>
                    <a href="{{ path('admin_users_list') }}" class="dash-card__link">Voir tout <i class="fas fa-arrow-right"></i></a>
                </div>
                <div class="dash-card__body dash-card__body--flush">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Utilisateur</th>
                                <th>Role</th>
                                <th>Date</th>
                                <th>Via</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in recent_users %}
                                <tr>
                                    <td>
                                        <div class="dash-user">
                                            {% set av = user_avatar(user) %}
                                            {% if av %}
                                                <img src="{{ av starts with 'http' ? av : asset(av) }}" alt="" class="dash-user__avatar">
                                            {% else %}
                                                <div class="dash-user__avatar dash-user__avatar--placeholder">{{ user.username|slice(0, 1)|upper }}</div>
                                            {% endif %}
                                            <div>
                                                <div class="dash-user__name">{{ user.username }}</div>
                                                <div class="dash-user__email">{{ user.email }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>{{ role_badge(user.roles)|raw }}</td>
                                    <td class="dash-table__muted">{{ user.createdAt|time_ago('d/m/Y') }}</td>
                                    <td>
                                        {% if user.googleId %}<i class="fab fa-google" style="color:#ea4335;" title="Google"></i> {% endif %}
                                        {% if user.discordId %}<i class="fab fa-discord" style="color:#5865f2;" title="Discord"></i> {% endif %}
                                        {% if user.twitchId %}<i class="fab fa-twitch" style="color:#9146ff;" title="Twitch"></i> {% endif %}
                                        {% if user.steamId %}<i class="fab fa-steam" style="color:#c7d5e0;" title="Steam"></i> {% endif %}
                                        {% if not user.googleId and not user.discordId and not user.twitchId and not user.steamId %}<i class="fas fa-envelope" style="color:var(--text-secondary);" title="Email"></i>{% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="4" class="dash-table__empty">Aucun utilisateur.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="dash-card">
                <div class="dash-card__head">
                    <h4><i class="fab fa-paypal"></i> Dernieres ventes</h4>
                    <a href="{{ path('admin_transactions_list') }}" class="dash-card__link">Voir tout <i class="fas fa-arrow-right"></i></a>
                </div>
                <div class="dash-card__body dash-card__body--flush">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Utilisateur</th>
                                <th>Plan</th>
                                <th>Montant</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for tx in recent_transactions %}
                                <tr>
                                    <td>
                                        <div class="dash-user">
                                            {% set av = user_avatar(tx.user) %}
                                            {% if av %}
                                                <img src="{{ av starts with 'http' ? av : asset(av) }}" alt="" class="dash-user__avatar">
                                            {% else %}
                                                <div class="dash-user__avatar dash-user__avatar--placeholder">{{ tx.user.username|slice(0, 1)|upper }}</div>
                                            {% endif %}
                                            <span class="dash-user__name">{{ tx.user.username }}</span>
                                        </div>
                                    </td>
                                    <td class="dash-table__muted">{{ tx.plan ? tx.plan.name : '-' }}</td>
                                    <td><span class="dash-amount">{{ tx.amount }} {{ tx.currency }}</span></td>
                                    <td class="dash-table__muted">{{ tx.createdAt|time_ago('d/m H:i') }}</td>
                                </tr>
                            {% else %}
                                <tr><td colspan="4" class="dash-table__empty">Aucune transaction.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <link rel="stylesheet" href="{{ asset('assets/css/admin/dashboard.css') }}">

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var ts = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#8a8d93';
        var gc = 'rgba(255,255,255,0.04)';
        var baseOpts = function(showLegend) {
            return {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: !!showLegend, position: 'bottom', labels: { color: ts, padding: 10, font: { size: 11 }, usePointStyle: true, pointStyle: 'circle' } } },
                scales: {
                    x: { ticks: { color: ts, font: { size: 10 }, maxRotation: 0 }, grid: { color: gc } },
                    y: { beginAtZero: true, ticks: { color: ts, font: { size: 10 }, precision: 0 }, grid: { color: gc } }
                }
            };
        };

        {# ===== REVENUE AREA ===== #}
        var revData = {{ chart_revenue_by_month|json_encode|raw }};
        new Chart(document.getElementById('chartRevenue'), {
            type: 'line',
            data: {
                labels: revData.map(function(r) { return r.month; }),
                datasets: [{
                    label: 'Revenus (€)',
                    data: revData.map(function(r) { return r.total; }),
                    borderColor: '#f6c23e',
                    backgroundColor: 'rgba(246,194,62,0.08)',
                    fill: true,
                    tension: 0.35,
                    pointBackgroundColor: '#f6c23e',
                    pointRadius: 4,
                    pointHoverRadius: 7,
                    borderWidth: 2.5
                }]
            },
            options: baseOpts(false)
        });

        {# ===== CATEGORY DOUGHNUT ===== #}
        var catColors = ['#45f882','#4e73df','#e74a3b','#f6c23e','#1cc88a','#36b9cc','#fd7e14','#6f42c1','#e83e8c','#20c997','#17a2b8','#6610f2'];
        new Chart(document.getElementById('chartCategory'), {
            type: 'doughnut',
            data: {
                labels: {{ chart_servers_by_category|map(i => i.name)|json_encode|raw }},
                datasets: [{
                    data: {{ chart_servers_by_category|map(i => i.count)|json_encode|raw }},
                    backgroundColor: catColors.slice(0, {{ chart_servers_by_category|length }}),
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom', labels: { color: ts, padding: 10, font: { size: 11 }, usePointStyle: true, pointStyle: 'circle' } }
                }
            }
        });

        {# ===== USERS LINE ===== #}
        new Chart(document.getElementById('chartUsers'), {
            type: 'line',
            data: {
                labels: {{ chart_users_by_month|map(i => i.month)|json_encode|raw }},
                datasets: [{
                    label: 'Inscriptions',
                    data: {{ chart_users_by_month|map(i => i.count)|json_encode|raw }},
                    borderColor: '#45f882',
                    backgroundColor: 'rgba(69,248,130,0.08)',
                    fill: true,
                    tension: 0.35,
                    pointBackgroundColor: '#45f882',
                    pointRadius: 3,
                    pointHoverRadius: 6,
                    borderWidth: 2
                }]
            },
            options: baseOpts(false)
        });

        {# ===== VOTES BAR ===== #}
        new Chart(document.getElementById('chartVotes'), {
            type: 'bar',
            data: {
                labels: {{ chart_votes_by_month|map(i => i.month)|json_encode|raw }},
                datasets: [{
                    label: 'Votes',
                    data: {{ chart_votes_by_month|map(i => i.count)|json_encode|raw }},
                    backgroundColor: 'rgba(69,248,130,0.5)',
                    hoverBackgroundColor: 'rgba(69,248,130,0.8)',
                    borderRadius: 4,
                    borderSkipped: false
                }]
            },
            options: baseOpts(false)
        });
    });
    </script>

{% endblock %}
