{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ plugin ? 'Modifier le plugin' : 'Nouveau plugin' }}{% endblock %}
{% block title %}Nexarena Admin - {{ plugin ? 'Modifier' : 'Nouveau' }} plugin{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus { outline: none; border-color: var(--accent); }
    textarea.form-control-admin { resize: vertical; }
    .form-check-admin { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .form-check-admin input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent); }
    .icon-preview { width: 64px; height: 64px; object-fit: contain; border-radius: 8px; border: 1px solid var(--border-color); margin-bottom: 8px; }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ plugin ? 'Modifier le plugin' : 'Nouveau plugin' }}</h3>
                <a href="{{ path('admin_plugins_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                    <div class="form-group">
                        <label for="{{ form.name.vars.id }}">Nom</label>
                        {{ form_widget(form.name, {'attr': {'class': 'form-control-admin'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.platform.vars.id }}">Plateforme</label>
                                {{ form_widget(form.platform, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.platform) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="{{ form.category.vars.id }}">Catégorie</label>
                                {{ form_widget(form.category, {'attr': {'class': 'form-control-admin'}}) }}
                                {{ form_errors(form.category) }}
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="{{ form.version.vars.id }}">Version</label>
                        {{ form_widget(form.version, {'attr': {'class': 'form-control-admin', 'placeholder': '1.0.0'}}) }}
                        {{ form_errors(form.version) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.description.vars.id }}">Description courte</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control-admin', 'rows': 3}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.longDescription.vars.id }}">Description longue</label>
                        {{ form_widget(form.longDescription, {'attr': {'class': 'form-control-admin', 'rows': 6}}) }}
                        {{ form_errors(form.longDescription) }}
                    </div>

                    <div class="form-group">
                        <label for="{{ form.zipFile.vars.id }}">Fichier ZIP</label>
                        {% if plugin and plugin.fileName %}
                            <div style="font-size:12px;color:var(--text-secondary);margin-bottom:6px;">
                                <i class="fas fa-file-archive"></i> Fichier actuel : {{ plugin.fileName }}
                                {% if plugin.fileSize %}
                                    ({{ (plugin.fileSize / 1024 / 1024)|number_format(2) }} Mo)
                                {% endif %}
                            </div>
                        {% endif %}
                        {{ form_widget(form.zipFile, {'attr': {'style': 'color:var(--text-secondary);'}}) }}
                        {{ form_errors(form.zipFile) }}
                        <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">Fichier ZIP uniquement - 50 Mo max</div>
                    </div>

                    <div class="form-group">
                        <label for="{{ form.iconFile.vars.id }}">Icône</label>
                        {% if plugin and plugin.iconFileName %}
                            <img src="{{ asset('uploads/plugins/icons/' ~ plugin.iconFileName) }}" alt="" class="icon-preview">
                        {% endif %}
                        {{ form_widget(form.iconFile, {'attr': {'style': 'color:var(--text-secondary);'}}) }}
                        {{ form_errors(form.iconFile) }}
                        <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">PNG, JPG, GIF ou WebP - 2 Mo max</div>
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            {{ form_widget(form.isActive) }}
                            Plugin actif
                        </label>
                        {{ form_errors(form.isActive) }}
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ plugin ? 'Enregistrer' : 'Créer' }}
                        </button>
                        <a href="{{ path('admin_plugins_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
