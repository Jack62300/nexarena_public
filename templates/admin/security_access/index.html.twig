{% extends 'admin/base.html.twig' %}

{% block title %}Sécurité & Accès Géographique — Admin{% endblock %}
{% block page_title %}Sécurité & Accès Géographique{% endblock %}

{% block admin_css %}
/* ── Cartes ── */
.sa-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 16px;
}
.sa-card__header {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border-color);
    background: rgba(255,255,255,.02);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: .5px;
}
.sa-card__header i { font-size: 14px; }
.sa-card__body { padding: 20px; }

/* ── Toggles ── */
.sa-toggle-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(30,48,72,.5);
}
.sa-toggle-row:last-child { border-bottom: none; padding-bottom: 0; }
.sa-toggle-row:first-child { padding-top: 0; }
.sa-toggle {
    position: relative;
    display: inline-block;
    width: 46px;
    height: 24px;
    flex-shrink: 0;
    margin-top: 2px;
}
.sa-toggle input { display: none; }
.sa-toggle__rail {
    position: absolute;
    inset: 0;
    background: var(--border-color);
    border-radius: 24px;
    cursor: pointer;
    transition: background .25s;
}
.sa-toggle__rail:before {
    content: '';
    position: absolute;
    width: 16px;
    height: 16px;
    background: var(--text-secondary);
    border-radius: 50%;
    top: 4px;
    left: 4px;
    transition: transform .25s, background .25s;
}
.sa-toggle input:checked ~ .sa-toggle__rail { background: var(--accent); }
.sa-toggle input:checked ~ .sa-toggle__rail:before {
    transform: translateX(22px);
    background: #0a1018;
}
.sa-toggle-label { font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 3px; }
.sa-toggle-desc { font-size: 12px; color: var(--text-secondary); line-height: 1.5; }

/* ── Inputs / Textarea ── */
.sa-input {
    width: 100%;
    background: var(--bg-darker);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 13px;
    padding: 9px 14px;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    font-family: 'Courier New', monospace;
    resize: vertical;
}
.sa-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(69,248,130,.1);
}
.sa-input::placeholder { color: var(--text-secondary); opacity: .6; }
.sa-hint { font-size: 11px; color: var(--text-secondary); margin-top: 8px; line-height: 1.5; }
.sa-hint code {
    background: rgba(255,255,255,.08);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 11px;
    color: var(--accent);
}

/* ── Diagnostic ── */
.sa-diag-group { display: flex; gap: 8px; margin-bottom: 10px; }
.sa-diag-input {
    flex: 1;
    background: var(--bg-darker);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 13px;
    padding: 8px 12px;
    font-family: 'Courier New', monospace;
    outline: none;
    transition: border-color .2s;
}
.sa-diag-input:focus { border-color: var(--info); }
.sa-diag-btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: none;
    background: var(--info);
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .2s;
    white-space: nowrap;
}
.sa-diag-btn:hover { opacity: .85; }
.sa-diag-result {
    background: var(--bg-darker);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 12px 14px;
    font-family: 'Courier New', monospace;
    font-size: 12px;
    white-space: pre-wrap;
    max-height: 260px;
    overflow-y: auto;
    color: #6fffb0;
    display: none;
}
.sa-diag-result.error { color: #ff7675; }

/* ── Onglets régions ── */
.sa-region-tabs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }
.sa-tab {
    padding: 4px 12px;
    border-radius: 20px;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all .18s;
}
.sa-tab:hover { border-color: var(--accent); color: var(--accent); }
.sa-tab.active { background: var(--accent); border-color: var(--accent); color: #0a1018; font-weight: 700; }

/* ── Recherche pays ── */
.sa-search {
    width: 100%;
    background: var(--bg-darker);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 13px;
    padding: 8px 12px;
    outline: none;
    margin-bottom: 10px;
    transition: border-color .2s;
}
.sa-search:focus { border-color: var(--accent); }
.sa-search::placeholder { color: var(--text-secondary); opacity: .6; }

/* ── Boutons sélection ── */
.sa-sel-btns { display: flex; gap: 8px; margin-bottom: 14px; }
.sa-sel-btn {
    padding: 5px 12px;
    border-radius: 6px;
    border: 1px solid;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all .18s;
    background: transparent;
}
.sa-sel-btn--green { border-color: var(--success); color: var(--success); }
.sa-sel-btn--green:hover { background: rgba(28,200,138,.15); }
.sa-sel-btn--red { border-color: var(--danger); color: var(--danger); }
.sa-sel-btn--red:hover { background: rgba(231,74,59,.15); }

/* ── Grille pays ── */
.sa-country-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(138px, 1fr));
    gap: 5px;
    max-height: 500px;
    overflow-y: auto;
    padding-right: 2px;
}
.sa-country-grid::-webkit-scrollbar { width: 4px; }
.sa-country-grid::-webkit-scrollbar-track { background: transparent; }
.sa-country-grid::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 4px; }

.sa-country {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 8px;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    color: var(--text-secondary);
    background: rgba(255,255,255,.02);
    transition: all .15s;
    user-select: none;
    overflow: hidden;
}
.sa-country:hover { background: rgba(255,255,255,.06); color: var(--text-primary); }
.sa-country.selected {
    background: rgba(69,248,130,.12);
    border-color: var(--accent);
    color: var(--accent);
}
.sa-country input { display: none; }
.sa-country__flag { font-size: 1.05rem; flex-shrink: 0; line-height: 1; }
.sa-country__name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ── Compteur ── */
.sa-count-badge {
    background: rgba(69,248,130,.15);
    color: var(--accent);
    border: 1px solid rgba(69,248,130,.3);
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    padding: 2px 10px;
}

/* ── Barre sticky save ── */
.sa-save-bar {
    position: sticky;
    bottom: 0;
    background: var(--bg-dark);
    border-top: 1px solid var(--border-color);
    padding: 14px 0 6px;
    margin-top: 8px;
    z-index: 10;
}
.sa-save-btn {
    padding: 10px 28px;
    border-radius: 8px;
    border: none;
    background: var(--accent);
    color: #0a1018;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity .2s, transform .15s;
}
.sa-save-btn:hover { opacity: .88; transform: translateY(-1px); }

/* ── Badge alerte clé manquante ── */
.sa-warn-badge {
    background: rgba(246,194,62,.12);
    color: var(--warning);
    border: 1px solid rgba(246,194,62,.3);
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 10px;
}

/* ── Status bar ── */
.sa-status-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 14px 20px;
    background: rgba(255,255,255,.02);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    margin-bottom: 24px;
    align-items: center;
}
.sa-status-indicator {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 20px;
    border: 1px solid transparent;
}
.sa-status-indicator--ok {
    background: rgba(28,200,138,.1);
    border-color: rgba(28,200,138,.25);
    color: var(--success);
}
.sa-status-indicator--warn {
    background: rgba(246,194,62,.1);
    border-color: rgba(246,194,62,.25);
    color: var(--warning);
}
.sa-status-indicator--off {
    background: rgba(255,255,255,.04);
    border-color: var(--border-color);
    color: var(--text-secondary);
}
.sa-status-indicator--danger {
    background: rgba(231,74,59,.1);
    border-color: rgba(231,74,59,.25);
    color: var(--danger);
}
.sa-status-separator {
    flex: 1;
}
.sa-status-actions {
    display: flex;
    gap: 8px;
    align-items: center;
}
.sa-status-btn {
    padding: 6px 14px;
    border-radius: 7px;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all .18s;
    white-space: nowrap;
}
.sa-status-btn:hover { border-color: var(--accent); color: var(--accent); }
.sa-status-btn--danger { border-color: rgba(231,74,59,.4); color: var(--danger); }
.sa-status-btn--danger:hover { background: rgba(231,74,59,.1); }

/* ── Résultat "Mon IP" ── */
.sa-monip-result {
    margin-top: 14px;
    padding: 14px;
    border-radius: 8px;
    background: var(--bg-darker);
    border: 1px solid var(--border-color);
    font-size: 12px;
    display: none;
}
.sa-monip-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
}
.sa-monip-row:last-child { border-bottom: none; }
.sa-monip-key { color: var(--text-secondary); }
.sa-monip-val { font-weight: 600; font-family: 'Courier New', monospace; }
.sa-monip-val--ok { color: var(--success); }
.sa-monip-val--warn { color: var(--warning); }
.sa-monip-val--danger { color: var(--danger); }
.sa-monip-verdict {
    margin-top: 10px;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
    text-align: center;
}
.sa-monip-verdict--blocked { background: rgba(231,74,59,.15); color: var(--danger); border: 1px solid rgba(231,74,59,.3); }
.sa-monip-verdict--pass { background: rgba(28,200,138,.12); color: var(--success); border: 1px solid rgba(28,200,138,.25); }
{% endblock %}

{% block admin_body %}

{# ── En-tête ── #}
<div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;">
    <div style="width:48px;height:48px;border-radius:12px;background:rgba(69,248,130,.1);border:1px solid rgba(69,248,130,.2);display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--accent);flex-shrink:0;">
        <i class="fas fa-shield-alt"></i>
    </div>
    <div>
        <div style="font-size:22px;font-weight:700;color:var(--text-primary);">Sécurité & Accès Géographique</div>
        <div style="font-size:13px;color:var(--text-secondary);">Contrôlez les VPN/proxy, les pays autorisés et les IPs de confiance.</div>
    </div>
</div>

{# ── Barre de statut système ── #}
{% set apiOk = current.ipqs_api_key is not empty %}
{% set anyActive = current.vpn_block_enabled or current.country_block_enabled %}
<div class="sa-status-bar">

    {# Clé API #}
    {% if apiOk %}
        <div class="sa-status-indicator sa-status-indicator--ok">
            <i class="fas fa-check-circle"></i> Clé IPQS configurée
        </div>
    {% else %}
        <div class="sa-status-indicator sa-status-indicator--danger">
            <i class="fas fa-times-circle"></i> Clé IPQS manquante
        </div>
    {% endif %}

    {# VPN block #}
    {% if current.vpn_block_enabled %}
        <div class="sa-status-indicator {{ apiOk ? 'sa-status-indicator--ok' : 'sa-status-indicator--warn' }}">
            <i class="fas fa-{{ apiOk ? 'shield-alt' : 'exclamation-triangle' }}"></i>
            Blocage VPN {{ apiOk ? 'actif' : 'activé (sans clé = inactif)' }}
        </div>
    {% else %}
        <div class="sa-status-indicator sa-status-indicator--off">
            <i class="fas fa-minus-circle"></i> Blocage VPN désactivé
        </div>
    {% endif %}

    {# Country block #}
    {% if current.country_block_enabled %}
        <div class="sa-status-indicator {{ apiOk ? 'sa-status-indicator--ok' : 'sa-status-indicator--warn' }}">
            <i class="fas fa-{{ apiOk ? 'globe' : 'exclamation-triangle' }}"></i>
            Filtrage pays {{ apiOk ? 'actif' : 'activé (sans clé = inactif)' }}
        </div>
    {% else %}
        <div class="sa-status-indicator sa-status-indicator--off">
            <i class="fas fa-minus-circle"></i> Filtrage pays désactivé
        </div>
    {% endif %}

    <div class="sa-status-separator"></div>

    {# Actions #}
    <div class="sa-status-actions">
        <button type="button" id="monIpBtn" class="sa-status-btn">
            <i class="fas fa-crosshairs"></i> Tester mon IP
        </button>

        <form method="post" action="{{ path('admin_security_access_cache_flush') }}" style="display:inline;" id="cacheFlushForm">
            <input type="hidden" name="_token" value="{{ csrf_token('security_cache_flush') }}">
            <button type="submit" class="sa-status-btn sa-status-btn--danger"
                    onclick="return confirm('Vider le cache IPQS ? Toutes les IPs seront re-vérifiées à leur prochain accès.')">
                <i class="fas fa-trash-alt"></i> Vider cache IPQS
            </button>
        </form>
    </div>
</div>

{# Alerte si clé manquante et au moins une règle active #}
{% if not apiOk and anyActive %}
<div class="alert alert-warning d-flex align-items-center gap-3 mb-4" style="border-radius:10px;background:rgba(246,194,62,.12);border:1px solid rgba(246,194,62,.3);color:var(--warning);padding:14px 18px;font-size:13px;">
    <i class="fas fa-exclamation-triangle fa-lg flex-shrink-0"></i>
    <div>
        <strong>Le blocage VPN/pays ne fonctionne pas.</strong>
        La clé API IPQualityScore n'est pas configurée → tous les visiteurs passent (fail-open).
        <br>Ajoutez votre clé dans
        <a href="{{ path('admin_settings_index') }}#api_keys" class="fw-bold" style="color:var(--warning);text-decoration:underline;">
            Paramètres → Clés API → IPQualityScore API Key
        </a>.
        Le plan gratuit IPQS offre 200 vérifications/mois.
    </div>
</div>
{% endif %}

{# Résultat "Mon IP" #}
<div id="monIpResult" class="sa-monip-result"></div>

<form method="post" action="{{ path('admin_security_access_index') }}" id="securityForm">
    <input type="hidden" name="_token" value="{{ csrf_token('security_access_save') }}">
    <input type="hidden" name="allowed_countries" id="allowedCountriesInput" value="{{ selected_codes|join(',') }}">

    <div class="row g-4">

        {# ═══ COLONNE GAUCHE ═══ #}
        <div class="col-lg-5">

            {# Règles de blocage #}
            <div class="sa-card">
                <div class="sa-card__header">
                    <span><i class="fas fa-ban" style="color:var(--danger);"></i> Règles de blocage</span>
                </div>
                <div class="sa-card__body">

                    <div class="sa-toggle-row">
                        <label class="sa-toggle">
                            <input type="checkbox" name="setting_admin_vpn_block_enabled"
                                   {% if current.admin_vpn_block_enabled %}checked{% endif %}>
                            <span class="sa-toggle__rail"></span>
                        </label>
                        <div>
                            <div class="sa-toggle-label">Bloquer les VPN/proxy sur l'espace admin</div>
                            <div class="sa-toggle-desc">Protège le panneau d'administration contre les accès via VPN ou proxy.</div>
                        </div>
                    </div>

                    <div class="sa-toggle-row">
                        <label class="sa-toggle">
                            <input type="checkbox" name="setting_vpn_block_enabled"
                                   {% if current.vpn_block_enabled %}checked{% endif %}>
                            <span class="sa-toggle__rail"></span>
                        </label>
                        <div>
                            <div class="sa-toggle-label">Bloquer les VPN/proxy sur tout le site</div>
                            <div class="sa-toggle-desc">Les visiteurs utilisant un VPN ou proxy actif seront bloqués sur l'ensemble du site.</div>
                        </div>
                    </div>

                    <div class="sa-toggle-row">
                        <label class="sa-toggle">
                            <input type="checkbox" name="setting_country_block_enabled"
                                   {% if current.country_block_enabled %}checked{% endif %}>
                            <span class="sa-toggle__rail"></span>
                        </label>
                        <div>
                            <div class="sa-toggle-label">Activer le filtrage par pays</div>
                            <div class="sa-toggle-desc">Seuls les pays cochés dans la grille seront autorisés. Une liste vide = tous autorisés.</div>
                        </div>
                    </div>

                </div>
            </div>

            {# IPs de confiance #}
            <div class="sa-card">
                <div class="sa-card__header">
                    <span><i class="fas fa-list-check" style="color:var(--success);"></i> IPs de confiance</span>
                </div>
                <div class="sa-card__body">
                    <textarea name="trusted_ips" class="sa-input" rows="6"
                              placeholder="82.66.56.201&#10;10.0.0.0/8&#10;192.168.1.0/24">{{ current.trusted_ips }}</textarea>
                    <div class="sa-hint">
                        Une entrée par ligne. Accepte les IPs exactes (<code>82.66.56.201</code>)
                        et les plages CIDR (<code>82.66.0.0/16</code>).
                        Ces IPs contournent tous les blocages.
                    </div>
                </div>
            </div>

            {# Outil de diagnostic #}
            <div class="sa-card">
                <div class="sa-card__header">
                    <span><i class="fas fa-stethoscope" style="color:var(--info);"></i> Diagnostic IP en temps réel</span>
                    {% if not current.ipqs_api_key %}
                        <span class="sa-warn-badge"><i class="fas fa-exclamation-triangle me-1"></i>Clé IPQS manquante</span>
                    {% endif %}
                </div>
                <div class="sa-card__body">
                    <div class="sa-diag-group">
                        <input type="text" id="diagIpInput" class="sa-diag-input"
                               placeholder="ex. 82.66.56.201" maxlength="45">
                        <button type="button" id="diagBtn" class="sa-diag-btn">
                            <i class="fas fa-search"></i> Analyser
                        </button>
                    </div>
                    <div id="diagResult" class="sa-diag-result"></div>
                    <div class="sa-hint" style="margin-top:10px;">
                        Interroge IPQualityScore en temps réel et évalue les règles locales
                        (trusted, VPN, pays autorisé).
                    </div>
                </div>
            </div>

        </div>{# /col-lg-5 #}

        {# ═══ COLONNE DROITE ═══ #}
        <div class="col-lg-7">
            <div class="sa-card" style="height:auto;">
                <div class="sa-card__header">
                    <span><i class="fas fa-globe" style="color:#74b9ff;"></i> Pays autorisés</span>
                    <span class="sa-count-badge" id="countryCount">{{ selected_codes|length }} / {{ total_countries }}</span>
                </div>
                <div class="sa-card__body">

                    {# Recherche #}
                    <input type="text" id="countrySearch" class="sa-search"
                           placeholder="🔍 Rechercher un pays ou code ISO...">

                    {# Onglets régions #}
                    <div class="sa-region-tabs">
                        <button type="button" class="sa-tab active" data-region="all">Tous</button>
                        {% for regionKey, regionLabel in region_labels %}
                            <button type="button" class="sa-tab" data-region="{{ regionKey }}">{{ regionLabel }}</button>
                        {% endfor %}
                    </div>

                    {# Sélection rapide #}
                    <div class="sa-sel-btns">
                        <button type="button" id="selectAll" class="sa-sel-btn sa-sel-btn--green">
                            <i class="fas fa-check-double"></i> Tout sélectionner
                        </button>
                        <button type="button" id="deselectAll" class="sa-sel-btn sa-sel-btn--red">
                            <i class="fas fa-times"></i> Tout désélectionner
                        </button>
                    </div>

                    {# Grille pays #}
                    <div class="sa-country-grid" id="countryGrid">
                        {% for regionKey, regionCountries in countries_by_region %}
                            {% for country in regionCountries %}
                                {% set isSelected = country.code in selected_codes %}
                                <label class="sa-country{{ isSelected ? ' selected' : '' }}"
                                       data-region="{{ country.region }}"
                                       data-name="{{ country.name|lower }}"
                                       data-code="{{ country.code }}">
                                    <input type="checkbox" value="{{ country.code }}"
                                           {% if isSelected %}checked{% endif %}>
                                    <span class="sa-country__flag">{{ country.code|country_flag }}</span>
                                    <span class="sa-country__name" title="{{ country.name }}">{{ country.name }}</span>
                                </label>
                            {% endfor %}
                        {% endfor %}
                    </div>

                </div>
            </div>
        </div>{# /col-lg-7 #}

    </div>{# /row #}

    {# Barre sticky Enregistrer #}
    <div class="sa-save-bar">
        <button type="submit" class="sa-save-btn">
            <i class="fas fa-save" style="margin-right:8px;"></i>Enregistrer les règles
        </button>
    </div>

</form>
{% endblock %}

{% block admin_js %}
<script nonce="{{ csp_nonce() }}">
(function () {
    'use strict';

    // ── Grille pays ──────────────────────────────────────────────────────
    const grid   = document.getElementById('countryGrid');
    const hidden = document.getElementById('allowedCountriesInput');
    const badge  = document.getElementById('countryCount');

    function updateCount() {
        const codes = Array.from(
            grid.querySelectorAll('input[type=checkbox]:checked')
        ).map(cb => cb.value);
        hidden.value = codes.join(',');
        badge.textContent = codes.length + ' / {{ total_countries }}';
    }

    grid.addEventListener('click', function (e) {
        const card = e.target.closest('.sa-country');
        if (!card) return;
        const cb = card.querySelector('input[type=checkbox]');
        if (!cb) return;
        cb.checked = !cb.checked;
        card.classList.toggle('selected', cb.checked);
        updateCount();
    });

    // ── Filtrage région ──────────────────────────────────────────────────
    let activeRegion = 'all';
    let searchQuery  = '';

    document.querySelectorAll('.sa-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.sa-tab').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            activeRegion = btn.dataset.region;
            applyFilter();
        });
    });

    document.getElementById('countrySearch').addEventListener('input', function () {
        searchQuery = this.value.toLowerCase().trim();
        applyFilter();
    });

    function applyFilter() {
        grid.querySelectorAll('.sa-country').forEach(function (card) {
            const regionOk = activeRegion === 'all' || card.dataset.region === activeRegion;
            const searchOk = searchQuery === ''
                || card.dataset.name.includes(searchQuery)
                || card.dataset.code.toLowerCase().includes(searchQuery);
            card.style.display = (regionOk && searchOk) ? '' : 'none';
        });
    }

    // ── Sélection rapide ─────────────────────────────────────────────────
    document.getElementById('selectAll').addEventListener('click', function () {
        grid.querySelectorAll('.sa-country').forEach(function (card) {
            if (card.style.display === 'none') return;
            const cb = card.querySelector('input[type=checkbox]');
            if (cb) { cb.checked = true; card.classList.add('selected'); }
        });
        updateCount();
    });

    document.getElementById('deselectAll').addEventListener('click', function () {
        grid.querySelectorAll('.sa-country').forEach(function (card) {
            if (card.style.display === 'none') return;
            const cb = card.querySelector('input[type=checkbox]');
            if (cb) { cb.checked = false; card.classList.remove('selected'); }
        });
        updateCount();
    });

    // ── Diagnostic ───────────────────────────────────────────────────────
    const diagBtn    = document.getElementById('diagBtn');
    const diagInput  = document.getElementById('diagIpInput');
    const diagResult = document.getElementById('diagResult');

    diagBtn.addEventListener('click', function () {
        const ip = diagInput.value.trim();
        if (!ip) { diagInput.focus(); return; }

        diagResult.style.display = 'block';
        diagResult.classList.remove('error');
        diagResult.textContent = 'Analyse en cours…';

        fetch('{{ path('admin_security_access_diagnostic') }}?ip=' + encodeURIComponent(ip))
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.error) {
                    diagResult.classList.add('error');
                    diagResult.textContent = '⚠ ' + data.error;
                } else {
                    diagResult.classList.remove('error');
                    diagResult.textContent = JSON.stringify(data, null, 2);
                }
            })
            .catch(function (err) {
                diagResult.classList.add('error');
                diagResult.textContent = 'Erreur réseau : ' + err.message;
            });
    });

    diagInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); diagBtn.click(); }
    });

    // ── Tester mon IP ────────────────────────────────────────────────────
    var monIpBtn    = document.getElementById('monIpBtn');
    var monIpResult = document.getElementById('monIpResult');

    monIpBtn.addEventListener('click', function () {
        monIpResult.style.display = 'block';
        monIpResult.innerHTML = '<span style="color:var(--text-secondary)"><i class="fas fa-spinner fa-spin me-1"></i> Analyse en cours…</span>';

        fetch('{{ path('admin_security_access_mon_ip') }}')
            .then(function (r) { return r.json(); })
            .then(function (d) {
                function row(label, value, cls) {
                    cls = cls || '';
                    return '<div class="sa-monip-row"><span class="sa-monip-key">' + label + '</span>'
                         + '<span class="sa-monip-val ' + cls + '">' + value + '</span></div>';
                }
                function bool(v, okLabel, warnLabel) {
                    if (v === null || v === undefined) return '<span style="color:var(--text-secondary)">N/A (clé API absente)</span>';
                    return v ? '<span class="sa-monip-val--ok">✅ ' + (okLabel || 'oui') + '</span>'
                             : '<span class="sa-monip-val--danger">🔴 ' + (warnLabel || 'non') + '</span>';
                }

                var html = row('IP détectée par le serveur', d.ip, 'sa-monip-val--ok');
                html += row('Clé API IPQS', d.api_key_set ? '✅ configurée' : '❌ manquante', d.api_key_set ? 'sa-monip-val--ok' : 'sa-monip-val--danger');
                html += row('API a répondu', d.api_responded ? '✅ oui' : (d.api_key_set ? '❌ erreur' : 'N/A'), d.api_responded ? 'sa-monip-val--ok' : 'sa-monip-val--danger');
                html += row('IP de confiance', d.trusted ? '✅ oui (bypass)' : 'non');
                html += row('Blocage VPN activé', d.vpn_block_enabled ? '✅ oui' : '❌ non', d.vpn_block_enabled ? 'sa-monip-val--ok' : 'sa-monip-val--off');
                html += row('VPN/Proxy détecté', bool(d.vpn_detected, 'oui (bloquerait)', 'non'));
                html += row('Filtrage pays activé', d.country_block_enabled ? '✅ oui' : '❌ non', d.country_block_enabled ? 'sa-monip-val--ok' : 'sa-monip-val--off');
                html += row('Pays détecté', d.country_code ? '🌍 ' + d.country_code : 'N/A');
                html += row('Pays autorisé', bool(d.country_allowed, 'oui', 'non (bloquerait)'));
                if (d.allowed_countries) {
                    html += row('Pays configurés', d.allowed_countries);
                }

                var verdictClass = d.blocked ? 'sa-monip-verdict--blocked' : 'sa-monip-verdict--pass';
                var verdictIcon  = d.blocked ? '🚫' : '✅';
                html += '<div class="sa-monip-verdict ' + verdictClass + '">'
                     + verdictIcon + ' ' + d.block_reason + '</div>';

                monIpResult.innerHTML = html;
            })
            .catch(function (err) {
                monIpResult.innerHTML = '<span style="color:var(--danger)">Erreur réseau : ' + err.message + '</span>';
            });
    });

    updateCount();
}());
</script>
{% endblock %}
