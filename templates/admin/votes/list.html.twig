{% extends 'admin/base.html.twig' %}

{% block page_title %}Votes{% endblock %}
{% block title %}Nexarena Admin - Votes{% endblock %}

{% block admin_css %}
    .filter-select {
        padding: 6px 12px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 13px;
    }
    .filter-select:focus {
        outline: none;
        border-color: var(--accent);
    }
    .vote-provider {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
    }
    .vote-provider--discord {
        background: rgba(88,101,242,0.12);
        color: #5865F2;
        border: 1px solid rgba(88,101,242,0.2);
    }
    .vote-provider--steam {
        background: rgba(27,40,56,0.3);
        color: #66c0f4;
        border: 1px solid rgba(102,192,244,0.2);
    }
    .vote-provider--unknown {
        background: rgba(255,255,255,0.05);
        color: var(--text-secondary);
        border: 1px solid var(--border-color);
    }
    .vote-id-col {
        font-size: 12px;
        color: var(--text-secondary);
        font-family: monospace;
    }
    .vote-ip {
        font-size: 12px;
        color: var(--text-secondary);
        font-family: monospace;
    }
    .vote-platform-id {
        font-size: 11px;
        color: var(--text-secondary);
        font-family: monospace;
        display: block;
        margin-top: 2px;
        max-width: 160px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .vote-vpn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 8px;
    }
    .vote-vpn--checked {
        background: rgba(28,200,138,0.1);
        color: #1cc88a;
    }
    .vote-vpn--unchecked {
        background: rgba(246,194,62,0.1);
        color: #f6c23e;
    }
{% endblock %}

{% block admin_body %}
    <div class="admin-table">
        <div class="admin-table__header">
            <h3>Votes recents ({{ votes|length }})</h3>
            <form method="get" style="display:flex;gap:10px;align-items:center;">
                <select name="server" class="filter-select" onchange="this.form.submit()">
                    <option value="">Tous les serveurs</option>
                    {% for s in servers %}
                        <option value="{{ s.id }}" {{ currentServer and currentServer.id == s.id ? 'selected' : '' }}>{{ s.name }}</option>
                    {% endfor %}
                </select>
                {% if currentServer %}
                    <a href="{{ path('admin_votes_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                        <i class="fas fa-times"></i> Reset
                    </a>
                {% endif %}
            </form>
        </div>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Serveur</th>
                    <th>Methode</th>
                    <th>Utilisateur</th>
                    <th>ID Plateforme</th>
                    <th>IP</th>
                    <th>VPN</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for vote in votes %}
                    <tr>
                        <td class="vote-id-col">{{ vote.id }}</td>
                        <td>
                            {% if vote.server %}
                                <strong>{{ vote.server.name }}</strong>
                            {% else %}
                                <span style="color:var(--text-secondary);">Supprime</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if vote.voteProvider == 'discord' %}
                                <span class="vote-provider vote-provider--discord">
                                    <i class="fab fa-discord"></i> Discord
                                </span>
                            {% elseif vote.voteProvider == 'steam' %}
                                <span class="vote-provider vote-provider--steam">
                                    <i class="fab fa-steam"></i> Steam
                                </span>
                            {% else %}
                                <span class="vote-provider vote-provider--unknown">
                                    <i class="fas fa-question-circle"></i> {{ vote.voteProvider ?? 'Inconnu' }}
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            {% if vote.user %}
                                <strong>{{ vote.user.username }}</strong>
                            {% elseif vote.voterUsername %}
                                {{ vote.voterUsername }}
                            {% else %}
                                <span style="color:var(--text-secondary);">Anonyme</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if vote.discordId %}
                                <span class="vote-platform-id" title="{{ vote.discordId }}">
                                    <i class="fab fa-discord" style="color:#5865F2;"></i> {{ vote.discordId }}
                                </span>
                            {% endif %}
                            {% if vote.steamId %}
                                <span class="vote-platform-id" title="{{ vote.steamId }}">
                                    <i class="fab fa-steam" style="color:#66c0f4;"></i> {{ vote.steamId }}
                                </span>
                            {% endif %}
                            {% if not vote.discordId and not vote.steamId %}
                                <span style="color:var(--text-secondary);">—</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if vote.voterIp %}
                                <code class="vote-ip">{{ vote.voterIp }}</code>
                            {% else %}
                                <span style="color:var(--text-secondary);">—</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if vote.vpnChecked %}
                                <span class="vote-vpn vote-vpn--checked">
                                    <i class="fas fa-shield-alt"></i> OK
                                </span>
                            {% else %}
                                <span class="vote-vpn vote-vpn--unchecked">
                                    <i class="fas fa-exclamation-triangle"></i> Non
                                </span>
                            {% endif %}
                        </td>
                        <td style="color:var(--text-secondary);font-size:13px;white-space:nowrap;">
                            {{ vote.votedAt|date('d/m/Y H:i') }}
                        </td>
                        <td>
                            {% if is_granted('ROLE_MANAGER') %}
                                <form method="post" action="{{ path('admin_votes_delete', {id: vote.id}) }}" onsubmit="return confirm('Supprimer ce vote ? Les compteurs du serveur seront mis a jour.');" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_vote_' ~ vote.id) }}">
                                    <button type="submit" class="btn-admin btn-admin--sm" style="background:var(--danger);color:#fff;border:none;" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" style="text-align:center;color:var(--text-secondary);padding:40px;">
                            <i class="fas fa-vote-yea" style="font-size:36px;margin-bottom:10px;display:block;"></i>
                            Aucun vote enregistre.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
