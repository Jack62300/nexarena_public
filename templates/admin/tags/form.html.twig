{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ tag ? 'Modifier' : 'Ajouter un tag' }}{% endblock %}
{% block title %}Nexarena Admin - {{ tag ? 'Modifier' : 'Nouveau' }} tag{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus {
        outline: none;
        border-color: var(--accent);
    }
    .form-check-admin {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .form-check-admin input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
    }
    .color-preview {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        margin-top: 8px;
    }
    .color-preview__swatch {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .color-preview__tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 6px;
    }
{% endblock %}

{% block admin_body %}
    <div style="max-width:800px;">
        <div class="admin-table">
            <div class="admin-table__header">
                <h3>{{ tag ? 'Modifier le tag' : 'Ajouter un tag' }}</h3>
                <a href="{{ path('admin_tags_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
            <div style="padding:25px;">
                <form method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('tag_form') }}">

                    <div class="form-group">
                        <label for="name">Nom</label>
                        <input type="text" id="name" name="name" class="form-control-admin" value="{{ tag ? tag.name : '' }}" required placeholder="Ex: PvP, ESX, QBCore..." maxlength="50">
                    </div>

                    <div class="form-group">
                        <label for="color">Couleur</label>
                        <input type="color" id="color" name="color" value="{{ tag and tag.color ? tag.color : '#45f882' }}" style="width:60px;height:40px;border:1px solid var(--border-color);border-radius:6px;background:var(--bg-darker);cursor:pointer;">
                        <div class="color-preview" id="colorPreview">
                            <div class="color-preview__swatch" id="colorSwatch" style="background:{{ tag and tag.color ? tag.color : '#45f882' }};"></div>
                            <span class="color-preview__tag" id="colorTag" style="background:{{ tag and tag.color ? tag.color : '#45f882' }}20;color:{{ tag and tag.color ? tag.color : '#45f882' }};border:1px solid {{ tag and tag.color ? tag.color : '#45f882' }}40;">
                                <i class="fas fa-hashtag"></i> Apercu
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="position">Position (ordre d'affichage)</label>
                        <input type="number" id="position" name="position" class="form-control-admin" value="{{ tag ? tag.position : 0 }}" min="0">
                    </div>

                    <div class="form-group">
                        <label class="form-check-admin">
                            <input type="checkbox" name="is_active" value="1" {{ (tag is null or tag.isActive) ? 'checked' : '' }}>
                            Actif
                        </label>
                    </div>

                    <div style="display:flex;gap:10px;padding-top:10px;">
                        <button type="submit" class="btn-admin btn-admin--primary">
                            <i class="fas fa-save"></i> {{ tag ? 'Enregistrer' : 'Creer' }}
                        </button>
                        <a href="{{ path('admin_tags_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% block admin_js %}
<script>
(function() {
    var colorInput = document.getElementById('color');
    var swatch = document.getElementById('colorSwatch');
    var tag = document.getElementById('colorTag');

    colorInput.addEventListener('input', function() {
        var c = colorInput.value;
        swatch.style.background = c;
        tag.style.background = c + '20';
        tag.style.color = c;
        tag.style.borderColor = c + '40';
    });
})();
</script>
{% endblock %}
