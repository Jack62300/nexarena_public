{% extends 'admin/base.html.twig' %}

{% block page_title %}Tags{% endblock %}
{% block title %}Nexarena Admin - Tags{% endblock %}

{% block admin_body %}
    <div class="admin-table">
        <div class="admin-table__header">
            <h3>Tags serveurs</h3>
            <a href="{{ path('admin_tags_new') }}" class="btn-admin btn-admin--primary">
                <i class="fas fa-plus"></i> Ajouter
            </a>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Couleur</th>
                    <th>Nom</th>
                    <th>Slug</th>
                    <th>Position</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for tag in tags %}
                    <tr>
                        <td>
                            {% if tag.color %}
                                <span style="display:inline-block;width:24px;height:24px;border-radius:6px;background:{{ tag.color }};border:1px solid rgba(255,255,255,0.1);"></span>
                            {% else %}
                                <span style="color:var(--text-secondary);font-size:12px;">—</span>
                            {% endif %}
                        </td>
                        <td><strong>{{ tag.name }}</strong></td>
                        <td style="color:var(--text-secondary);font-size:12px;">{{ tag.slug }}</td>
                        <td style="color:var(--text-secondary);">{{ tag.position }}</td>
                        <td>
                            {% if tag.isActive %}
                                <span class="status-dot status-dot--active"></span>Actif
                            {% else %}
                                <span class="status-dot status-dot--inactive"></span>Inactif
                            {% endif %}
                        </td>
                        <td>
                            <div style="display:flex;gap:8px;">
                                <a href="{{ path('admin_tags_edit', {id: tag.id}) }}" class="btn-admin btn-admin--outline btn-admin--sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                {% if is_granted('ROLE_MANAGER') %}
                                    <form method="post" action="{{ path('admin_tags_delete', {id: tag.id}) }}" onsubmit="return confirm('Supprimer ce tag ?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ tag.id) }}">
                                        <button type="submit" class="btn-admin btn-admin--sm" style="background:var(--danger);color:#fff;border:none;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align:center;color:var(--text-secondary);padding:30px;">
                            Aucun tag pour le moment.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
