{% extends 'admin/base.html.twig' %}

{% block page_title %}Succès{% endblock %}
{% block title %}Nexarena Admin — Succès{% endblock %}

{% block admin_body %}
{% set criteriaLabels = constant('App\\Entity\\Achievement::CRITERIA_LABELS') %}

<div class="admin-table">
    <div class="admin-table__header">
        <h3><i class="fas fa-trophy" style="color:var(--warning);margin-right:8px;"></i>Succès</h3>
        <a href="{{ path('admin_achievements_new') }}" class="btn-admin btn-admin--primary">
            <i class="fas fa-plus"></i> Ajouter
        </a>
    </div>

    <table>
        <thead>
            <tr>
                <th>Icône</th>
                <th>Nom</th>
                <th>Rareté</th>
                <th>Critère</th>
                <th>Seuil</th>
                <th>Récompense</th>
                <th>Attribués</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for achievement in achievements %}
                {% set rc = achievement.rarityColor %}
                <tr>
                    <td>
                        {% if achievement.iconFileName %}
                            <img src="{{ asset('uploads/achievements/' ~ achievement.iconFileName) }}"
                                 alt="{{ achievement.name }}"
                                 style="width:44px;height:44px;object-fit:contain;border-radius:10px;
                                        border:2px solid {{ rc }};box-shadow:0 0 10px {{ rc }}44;">
                        {% else %}
                            <div style="width:44px;height:44px;border-radius:10px;border:2px solid {{ rc }};
                                        display:flex;align-items:center;justify-content:center;background:{{ rc }}18;">
                                <i class="fas fa-trophy" style="color:{{ rc }};font-size:18px;"></i>
                            </div>
                        {% endif %}
                    </td>

                    <td>
                        <strong>{{ achievement.name }}</strong>
                        {% if achievement.description %}
                            <br>
                            <small style="color:var(--text-secondary);">
                                {{ achievement.description|slice(0, 72) }}{{ achievement.description|length > 72 ? '…' }}
                            </small>
                        {% endif %}
                    </td>

                    <td>
                        <span class="role-badge" style="background:{{ rc }}22;color:{{ rc }};border:1px solid {{ rc }}44;">
                            <i class="fas fa-circle" style="font-size:6px;vertical-align:middle;margin-right:4px;"></i>
                            {{ achievement.rarityLabel }}
                        </span>
                    </td>

                    <td style="color:var(--text-secondary);font-size:12px;">
                        {% if achievement.criteria and achievement.criteria['type'] is defined %}
                            {{ criteriaLabels[achievement.criteria['type']] ?? achievement.criteria['type'] }}
                        {% else %}
                            <span style="opacity:.35;">—</span>
                        {% endif %}
                    </td>

                    <td style="color:var(--text-secondary);">
                        {% if achievement.criteria and achievement.criteria['threshold'] is defined %}
                            <strong style="color:var(--text-primary);">{{ achievement.criteria['threshold'] }}</strong>
                        {% else %}
                            <span style="opacity:.35;">—</span>
                        {% endif %}
                    </td>

                    <td style="font-size:12px;white-space:nowrap;">
                        {% if achievement.rewardNexbits > 0 %}
                            <span style="color:#ffd700;"><i class="fas fa-coins"></i> {{ achievement.rewardNexbits }}</span>
                        {% endif %}
                        {% if achievement.rewardNexbits > 0 and achievement.rewardNexboost > 0 %}
                            <span style="color:var(--text-secondary);margin:0 3px;">+</span>
                        {% endif %}
                        {% if achievement.rewardNexboost > 0 %}
                            <span style="color:#ff6b35;"><i class="fas fa-bolt"></i> {{ achievement.rewardNexboost }}</span>
                        {% endif %}
                        {% if achievement.rewardNexbits == 0 and achievement.rewardNexboost == 0 %}
                            <span style="opacity:.35;">—</span>
                        {% endif %}
                    </td>

                    <td>
                        <span style="font-weight:700;color:var(--accent);">
                            {{ achievement.userAchievements|length }}
                        </span>
                    </td>

                    <td>
                        {% if achievement.isActive %}
                            <span class="status-dot status-dot--active"></span>Actif
                        {% else %}
                            <span class="status-dot status-dot--inactive"></span>Inactif
                        {% endif %}
                    </td>

                    <td>
                        <div style="display:flex;gap:6px;">
                            <a href="{{ path('admin_achievements_edit', {id: achievement.id}) }}"
                               class="btn-admin btn-admin--outline btn-admin--sm">
                                <i class="fas fa-edit"></i>
                            </a>
                            {% if is_granted('ROLE_MANAGER') %}
                                <form method="post"
                                      action="{{ path('admin_achievements_delete', {id: achievement.id}) }}"
                                      onsubmit="return confirm('Supprimer « {{ achievement.name }} » ?');"
                                      style="display:inline;">
                                    <input type="hidden" name="_token"
                                           value="{{ csrf_token('delete_' ~ achievement.id) }}">
                                    <button type="submit" class="btn-admin btn-admin--sm"
                                            style="background:var(--danger);color:#fff;border:none;">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="9" style="text-align:center;padding:60px 20px;">
                        <i class="fas fa-trophy"
                           style="font-size:40px;color:var(--text-secondary);opacity:.15;display:block;margin-bottom:14px;"></i>
                        <p style="color:var(--text-secondary);margin:0 0 18px;">Aucun succès pour le moment.</p>
                        <a href="{{ path('admin_achievements_new') }}" class="btn-admin btn-admin--primary">
                            <i class="fas fa-plus"></i> Créer le premier succès
                        </a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
