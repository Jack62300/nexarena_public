{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ achievement ? 'Modifier le succès' : 'Nouveau succès' }}{% endblock %}
{% block title %}Nexarena Admin — Succès{% endblock %}

{% block admin_css %}
.form-group { margin-bottom: 20px; }
.form-group label {
    display: block;
    margin-bottom: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.form-control-admin {
    width: 100%;
    padding: 10px 14px;
    background: var(--bg-darker);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--text-primary);
    font-size: 14px;
    transition: border-color .2s;
}
.form-control-admin:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(69,248,130,.1); }
textarea.form-control-admin { resize: vertical; }
select.form-control-admin option { background: var(--bg-darker); }
.form-check-admin { display: flex; align-items: center; gap: 10px; cursor: pointer; }
.form-check-admin input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent); }
.icon-preview { width: 72px; height: 72px; object-fit: contain; border-radius: 10px; border: 1px solid var(--border-color); margin-bottom: 8px; display: block; }
{% endblock %}

{% block admin_body %}
<div style="max-width:800px;">
    <div class="admin-table">
        <div class="admin-table__header">
            <h3>{{ achievement ? 'Modifier «&nbsp;' ~ achievement.name ~ '&nbsp;»' : 'Nouveau succès' }}</h3>
            <a href="{{ path('admin_achievements_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
        </div>

        <div style="padding:25px;">
            {{ form_start(form, {attr: {enctype: 'multipart/form-data'}}) }}

            <div class="form-group">
                <label for="{{ form.name.vars.id }}">Nom du succès *</label>
                {{ form_widget(form.name, {attr: {class: 'form-control-admin', placeholder: 'Ex: Pionnier, Premier vote…'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-group">
                <label for="{{ form.description.vars.id }}">Description</label>
                {{ form_widget(form.description, {attr: {class: 'form-control-admin', rows: 3, placeholder: 'Comment obtenir ce succès…'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="{{ form.rarity.vars.id }}">Rareté</label>
                        {{ form_widget(form.rarity, {attr: {class: 'form-control-admin'}}) }}
                        {{ form_errors(form.rarity) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="{{ form.criteriaType.vars.id }}">Critère automatique</label>
                        {{ form_widget(form.criteriaType, {attr: {class: 'form-control-admin', id: 'criteriaType'}}) }}
                        {{ form_errors(form.criteriaType) }}
                    </div>
                </div>
            </div>

            <div class="form-group" id="thresholdWrapper">
                <label for="{{ form.criteriaThreshold.vars.id }}">Seuil (nombre requis)</label>
                {{ form_widget(form.criteriaThreshold, {attr: {class: 'form-control-admin'}}) }}
                <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">
                    Nombre minimum pour déclencher l'attribution automatique.
                </div>
                {{ form_errors(form.criteriaThreshold) }}
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="{{ form.rewardNexbits.vars.id }}">
                            <i class="fas fa-coins" style="color:#ffd700;margin-right:4px;"></i> Récompense NexBits
                        </label>
                        {{ form_widget(form.rewardNexbits, {attr: {class: 'form-control-admin', placeholder: '0'}}) }}
                        <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">
                            NexBits crédités sur le compte de l'utilisateur à l'obtention.
                        </div>
                        {{ form_errors(form.rewardNexbits) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="{{ form.rewardNexboost.vars.id }}">
                            <i class="fas fa-bolt" style="color:#ff6b35;margin-right:4px;"></i> Récompense NexBoost
                        </label>
                        {{ form_widget(form.rewardNexboost, {attr: {class: 'form-control-admin', placeholder: '0'}}) }}
                        <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">
                            NexBoost crédités sur le compte de l'utilisateur à l'obtention.
                        </div>
                        {{ form_errors(form.rewardNexboost) }}
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label for="{{ form.iconFile.vars.id }}">Icône</label>
                {% if achievement and achievement.iconFileName %}
                    <img src="{{ asset('uploads/achievements/' ~ achievement.iconFileName) }}"
                         alt="" class="icon-preview">
                {% endif %}
                {{ form_widget(form.iconFile, {attr: {style: 'color:var(--text-secondary);'}}) }}
                {{ form_errors(form.iconFile) }}
                <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">
                    JPEG, PNG, GIF, WebP, SVG — max 2 Mo
                </div>
            </div>

            <div class="form-group">
                <label class="form-check-admin">
                    {{ form_widget(form.isActive) }}
                    Succès actif (visible et attribuable)
                </label>
                {{ form_errors(form.isActive) }}
            </div>

            <div style="display:flex;gap:10px;padding-top:10px;border-top:1px solid var(--border-color);">
                <button type="submit" class="btn-admin btn-admin--primary">
                    <i class="fas fa-save"></i> {{ achievement ? 'Enregistrer' : 'Créer' }}
                </button>
                <a href="{{ path('admin_achievements_list') }}" class="btn-admin btn-admin--outline">
                    Annuler
                </a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

    {# ── Utilisateurs ayant ce succès (edit mode) ── #}
    {% if achievement %}
    <div class="admin-table" style="margin-top:20px;">
        <div class="admin-table__header">
            <h3>
                <i class="fas fa-users" style="margin-right:6px;color:var(--accent);"></i>
                Attribués
                <span class="role-badge" style="background:rgba(69,248,130,.12);color:var(--accent);border:1px solid rgba(69,248,130,.25);margin-left:8px;">
                    {{ awardedUsers|length }}
                </span>
            </h3>
            {% if is_granted('achievements.manage') %}
                <form method="post"
                      action="{{ path('admin_achievements_award', {id: achievement.id}) }}"
                      style="display:flex;gap:8px;align-items:center;">
                    <input type="hidden" name="_token"
                           value="{{ csrf_token('achievement_award_' ~ achievement.id) }}">
                    <input type="text" name="username"
                           class="form-control-admin"
                           placeholder="Pseudo utilisateur"
                           style="max-width:200px;padding:6px 12px;font-size:13px;"
                           required>
                    <button type="submit" class="btn-admin btn-admin--primary btn-admin--sm">
                        <i class="fas fa-plus"></i> Attribuer
                    </button>
                </form>
            {% endif %}
        </div>

        <div style="padding:18px 22px;">
            {% if awardedUsers|length > 0 %}
                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    {% for ua in awardedUsers %}
                        <div style="display:inline-flex;align-items:center;gap:8px;
                                    background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);
                                    border-radius:8px;padding:6px 10px;">
                            <span style="font-size:13px;font-weight:600;">{{ ua.user.username }}</span>
                            <span style="font-size:11px;color:var(--text-secondary);">{{ ua.awardedAt|date('d/m/Y') }}</span>
                            {% if is_granted('achievements.manage') %}
                                <form method="post"
                                      action="{{ path('admin_achievements_revoke', {id: achievement.id, userId: ua.user.id}) }}"
                                      style="margin:0;"
                                      onsubmit="return confirm('Révoquer ce succès de {{ ua.user.username }} ?');">
                                    <input type="hidden" name="_token"
                                           value="{{ csrf_token('achievement_revoke_' ~ achievement.id ~ '_' ~ ua.user.id) }}">
                                    <button type="submit"
                                            style="background:none;border:none;cursor:pointer;padding:0 2px;
                                                   color:var(--danger);font-size:12px;line-height:1;opacity:.7;"
                                            onmouseover="this.style.opacity=1"
                                            onmouseout="this.style.opacity=.7">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p style="color:var(--text-secondary);font-size:13px;margin:0;text-align:center;padding:20px 0;">
                    Aucun utilisateur n'a encore ce succès.
                </p>
            {% endif %}
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}

{% block admin_js %}
<script nonce="{{ csp_nonce() }}">
const criteriaTypeEl   = document.getElementById('{{ form.criteriaType.vars.id }}');
const thresholdWrapper = document.getElementById('thresholdWrapper');

function updateThreshold() {
    const val  = criteriaTypeEl?.value;
    const hide = !val || val === 'custom' || val === 'premium_purchase';
    if (thresholdWrapper) thresholdWrapper.style.display = hide ? 'none' : '';
}

criteriaTypeEl?.addEventListener('change', updateThreshold);
updateThreshold();
</script>
{% endblock %}
