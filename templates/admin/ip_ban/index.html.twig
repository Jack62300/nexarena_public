{% extends 'admin/base.html.twig' %}

{% block page_title %}Bans IP{% endblock %}
{% block title %}Nexarena Admin — Bans IP{% endblock %}

{% block admin_css %}
.filter-btn {
    cursor: pointer;
    padding: .45rem 1.1rem;
    border: 1px solid #444;
    background: var(--bg-card, #1a1a2e);
    color: var(--text-secondary, #aaa);
    border-radius: 6px;
    font-size: .85rem;
    transition: all .15s;
    text-decoration: none;
}
.filter-btn:hover { border-color: #888; color: #fff; }
.filter-btn.active { background: #dc2626; border-color: #dc2626; color: #fff; }

.duration-fields { display: none; }
.duration-fields.show { display: flex; }

.badge-perm { background: rgba(220,38,38,.15); color: #f87171; border: 1px solid rgba(220,38,38,.3); padding: 3px 10px; border-radius: 99px; font-size: .75rem; font-weight: 700; }
.badge-temp { background: rgba(251,146,60,.15); color: #fb923c; border: 1px solid rgba(251,146,60,.3); padding: 3px 10px; border-radius: 99px; font-size: .75rem; font-weight: 700; }
.badge-expired { background: rgba(107,114,128,.15); color: #9ca3af; border: 1px solid rgba(107,114,128,.3); padding: 3px 10px; border-radius: 99px; font-size: .75rem; font-weight: 700; }
{% endblock %}

{% block admin_body %}
<div class="admin-table">
    <div class="admin-table__header">
        <h3><i class="fas fa-ban me-2 text-danger"></i>Bans IP
            {% if total > 0 %}
                <span class="badge bg-danger ms-2">{{ total }} actif{{ total > 1 ? 's' : '' }}</span>
            {% endif %}
        </h3>
        <span class="text-muted" style="font-size:.85rem;">Bloquez des adresses IP temporairement ou définitivement</span>
    </div>

    {# ── Filtres ── #}
    <div class="d-flex gap-2 flex-wrap mb-4 p-3">
        <a href="{{ path('admin_ip_bans_index', {filter: 'active'}) }}"     class="filter-btn {{ filter == 'active'    ? 'active' : '' }}"><i class="fas fa-shield-alt me-1"></i>Actifs</a>
        <a href="{{ path('admin_ip_bans_index', {filter: 'permanent'}) }}"  class="filter-btn {{ filter == 'permanent' ? 'active' : '' }}"><i class="fas fa-infinity me-1"></i>Permanents</a>
        <a href="{{ path('admin_ip_bans_index', {filter: 'temporary'}) }}"  class="filter-btn {{ filter == 'temporary' ? 'active' : '' }}"><i class="fas fa-clock me-1"></i>Temporaires</a>
        <a href="{{ path('admin_ip_bans_index', {filter: 'expired'}) }}"    class="filter-btn {{ filter == 'expired'   ? 'active' : '' }}"><i class="fas fa-history me-1"></i>Expirés / Révoqués</a>
        <a href="{{ path('admin_ip_bans_index', {filter: null}) }}"         class="filter-btn {{ filter is null or filter == '' ? 'active' : '' }}"><i class="fas fa-list me-1"></i>Tous</a>
    </div>

    <div class="row g-4 px-3 pb-3">

        {# ── Formulaire ajout ── #}
        <div class="col-lg-4">
            <div class="admin-card p-4">
                <h5 class="mb-3"><i class="fas fa-plus-circle me-1 text-danger"></i>Ajouter un ban</h5>
                <form method="post" action="{{ path('admin_ip_bans_add') }}" id="addBanForm">
                    <input type="hidden" name="_token" value="{{ csrf_token('ip_ban_add') }}">

                    <div class="mb-3">
                        <label class="form-label">Adresse IP <span class="text-danger">*</span></label>
                        <input type="text" name="ip_address" class="form-control font-monospace"
                               placeholder="ex: 192.168.1.1" required maxlength="45"
                               pattern="^(\d{1,3}\.){3}\d{1,3}$|^([0-9a-fA-F:]+)$">
                        <small class="text-muted">IPv4 ou IPv6</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Type de ban</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="type" id="typePerm"
                                       value="permanent" checked onchange="toggleDuration(this)">
                                <label class="form-check-label" for="typePerm">
                                    <i class="fas fa-infinity text-danger me-1"></i>Permanent
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="type" id="typeTemp"
                                       value="temporary" onchange="toggleDuration(this)">
                                <label class="form-check-label" for="typeTemp">
                                    <i class="fas fa-clock text-warning me-1"></i>Temporaire
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 duration-fields" id="durationFields">
                        <label class="form-label">Durée <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="number" name="duration" class="form-control" min="1" max="8760"
                                   placeholder="ex: 24" id="durationInput">
                            <select name="duration_unit" class="form-select" style="max-width:120px;" id="durationUnit">
                                <option value="hours">Heure(s)</option>
                                <option value="days">Jour(s)</option>
                            </select>
                        </div>
                        <small class="text-muted" id="durationHint">Max : 8760 heures (1 an)</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Raison <span class="text-muted">(optionnel)</span></label>
                        <textarea name="reason" class="form-control" rows="2"
                                  placeholder="ex: Spam, tentative de brute force…" maxlength="500"></textarea>
                    </div>

                    <button type="submit" class="btn btn-danger w-100">
                        <i class="fas fa-ban me-1"></i>Bannir cette IP
                    </button>
                </form>
            </div>
        </div>

        {# ── Liste des bans ── #}
        <div class="col-lg-8">
            <div class="admin-card p-4">
                <h5 class="mb-3">Bans ({{ bans|length }})</h5>

                {% if bans is empty %}
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-check-circle fa-3x mb-3 text-success opacity-50"></i>
                        <p>Aucun ban dans cette catégorie.</p>
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle" style="font-size:.88rem;">
                            <thead>
                                <tr>
                                    <th>Adresse IP</th>
                                    <th>Type</th>
                                    <th>Durée / Expiration</th>
                                    <th>Raison</th>
                                    <th>Par</th>
                                    <th>Date</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for ban in bans %}
                                {% set isCurrent = ban.isCurrent() %}
                                <tr class="{{ not isCurrent ? 'opacity-50' : '' }}">
                                    <td>
                                        <code class="{{ isCurrent ? 'text-danger' : 'text-muted' }}">
                                            {{ ban.ipAddress }}
                                        </code>
                                        {% if not isCurrent %}
                                            <br><small class="text-muted">
                                                {% if ban.revokedAt %}révoqué{% else %}expiré{% endif %}
                                            </small>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if ban.type == 'permanent' %}
                                            <span class="badge-perm"><i class="fas fa-infinity me-1"></i>Permanent</span>
                                        {% else %}
                                            <span class="badge-temp"><i class="fas fa-clock me-1"></i>Temporaire</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-muted small">
                                        {% if ban.type == 'permanent' %}
                                            <span class="text-danger">∞</span>
                                        {% else %}
                                            {{ ban.formattedDuration }}<br>
                                            {% if ban.expiresAt %}
                                                {% if isCurrent %}
                                                    <span class="text-warning">expire le {{ ban.expiresAt|date('d/m/Y H:i') }}</span>
                                                {% else %}
                                                    <span class="text-muted">expiré le {{ ban.expiresAt|date('d/m/Y H:i') }}</span>
                                                {% endif %}
                                            {% endif %}
                                        {% endif %}
                                    </td>
                                    <td class="text-muted" style="max-width:180px; white-space:normal;">
                                        {{ ban.reason ?? '—' }}
                                    </td>
                                    <td class="text-muted small">{{ ban.bannedBy ? ban.bannedBy.username : '—' }}</td>
                                    <td class="text-muted small">{{ ban.createdAt|date('d/m/Y H:i') }}</td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            {% if isCurrent %}
                                                <form method="post" action="{{ path('admin_ip_bans_revoke', {id: ban.id}) }}"
                                                      onsubmit="return confirm('Lever le ban de {{ ban.ipAddress }} ?')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('ip_ban_revoke_' ~ ban.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Lever le ban">
                                                        <i class="fas fa-unlock"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                            {% if is_granted('ROLE_RESPONSABLE') %}
                                                <form method="post" action="{{ path('admin_ip_bans_delete', {id: ban.id}) }}"
                                                      onsubmit="return confirm('Supprimer définitivement ce ban ?')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('ip_ban_delete_' ~ ban.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>

<script nonce="{{ csp_nonce() }}">
function toggleDuration(radio) {
    var fields = document.getElementById('durationFields');
    var input  = document.getElementById('durationInput');
    var hint   = document.getElementById('durationHint');
    var unit   = document.getElementById('durationUnit');

    if (radio.value === 'temporary') {
        fields.classList.add('show');
        input.required = true;
    } else {
        fields.classList.remove('show');
        input.required = false;
    }
}

// Mise à jour du hint selon l'unité choisie
document.getElementById('durationUnit').addEventListener('change', function() {
    var hint = document.getElementById('durationHint');
    var input = document.getElementById('durationInput');
    if (this.value === 'hours') {
        hint.textContent = 'Max : 8760 heures (1 an)';
        input.max = 8760;
    } else {
        hint.textContent = 'Max : 365 jours (1 an)';
        input.max = 365;
    }
});
</script>
{% endblock %}
