{% extends 'admin/base.html.twig' %}

{% block page_title %}Modifier le serveur{% endblock %}
{% block title %}Nexarena Admin - Modifier {{ server.name }}{% endblock %}

{% block admin_css %}
    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control-admin {
        width: 100%;
        padding: 10px 14px;
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control-admin:focus { outline: none; border-color: var(--accent); }
    textarea.form-control-admin { min-height: 80px; resize: vertical; }
    .form-check-admin { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    .form-check-admin input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent); }
    .info-card { background: var(--bg-darker); border: 1px solid var(--border-color); border-radius: 8px; padding: 16px; margin-bottom: 20px; }
    .info-card h5 { font-size: 13px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
    .info-row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 13px; border-bottom: 1px solid var(--border-color); }
    .info-row:last-child { border-bottom: none; }
    .info-row span:first-child { color: var(--text-secondary); }
{% endblock %}

{% block admin_body %}
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="admin-table">
                <div class="admin-table__header">
                    <h3>Modifier : {{ server.name }}</h3>
                    <a href="{{ path('admin_servers_list') }}" class="btn-admin btn-admin--outline btn-admin--sm">
                        <i class="fas fa-arrow-left"></i> Retour
                    </a>
                </div>
                <div style="padding:25px;">
                    {{ form_start(form) }}

                        <div class="form-group">
                            <label for="{{ form.name.vars.id }}">Nom du serveur</label>
                            {{ form_widget(form.name, {'attr': {'class': 'form-control-admin'}}) }}
                            {{ form_errors(form.name) }}
                        </div>

                        <div class="form-group">
                            <label for="{{ form.shortDescription.vars.id }}">Description courte</label>
                            {{ form_widget(form.shortDescription, {'attr': {'class': 'form-control-admin', 'maxlength': 255}}) }}
                            {{ form_errors(form.shortDescription) }}
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="{{ form.ip.vars.id }}">Adresse IP</label>
                                    {{ form_widget(form.ip, {'attr': {'class': 'form-control-admin'}}) }}
                                    {{ form_errors(form.ip) }}
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="{{ form.port.vars.id }}">Port</label>
                                    {{ form_widget(form.port, {'attr': {'class': 'form-control-admin'}}) }}
                                    {{ form_errors(form.port) }}
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="{{ form.slots.vars.id }}">Slots</label>
                                    {{ form_widget(form.slots, {'attr': {'class': 'form-control-admin'}}) }}
                                    {{ form_errors(form.slots) }}
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="{{ form.website.vars.id }}">Site web</label>
                                    {{ form_widget(form.website, {'attr': {'class': 'form-control-admin'}}) }}
                                    {{ form_errors(form.website) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="{{ form.discordUrl.vars.id }}">Discord</label>
                                    {{ form_widget(form.discordUrl, {'attr': {'class': 'form-control-admin'}}) }}
                                    {{ form_errors(form.discordUrl) }}
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="{{ form.twitchChannel.vars.id }}">Chaîne Twitch</label>
                            {{ form_widget(form.twitchChannel, {'attr': {'class': 'form-control-admin', 'placeholder': 'nom_de_la_chaine'}}) }}
                            {{ form_errors(form.twitchChannel) }}
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="form-check-admin">
                                        {{ form_widget(form.isActive) }}
                                        Serveur actif
                                    </label>
                                    {{ form_errors(form.isActive) }}
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="form-check-admin">
                                        {{ form_widget(form.isApproved) }}
                                        Approuvé
                                    </label>
                                    {{ form_errors(form.isApproved) }}
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="form-check-admin">
                                        {{ form_widget(form.isPrivate) }}
                                        Serveur privé
                                    </label>
                                    {{ form_errors(form.isPrivate) }}
                                </div>
                            </div>
                        </div>

                        <div style="display:flex;gap:10px;padding-top:10px;">
                            <button type="submit" class="btn-admin btn-admin--primary">
                                <i class="fas fa-save"></i> Enregistrer
                            </button>
                            <a href="{{ path('admin_servers_list') }}" class="btn-admin btn-admin--outline">Annuler</a>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="info-card">
                <h5>Informations</h5>
                <div class="info-row">
                    <span>ID</span>
                    <span>#{{ server.id }}</span>
                </div>
                <div class="info-row">
                    <span>Propriétaire</span>
                    <span>{{ server.owner ? server.owner.username : '—' }}</span>
                </div>
                <div class="info-row">
                    <span>Catégorie</span>
                    <span>{{ server.category ? server.category.name : '—' }}</span>
                </div>
                <div class="info-row">
                    <span>Sous-catégorie</span>
                    <span>{{ server.gameCategory ? server.gameCategory.name : '—' }}</span>
                </div>
                <div class="info-row">
                    <span>Type</span>
                    <span>{{ server.serverType ? server.serverType.name : '—' }}</span>
                </div>
                <div class="info-row">
                    <span>Créé le</span>
                    <span>{{ server.createdAt ? server.createdAt|time_ago : '—' }}</span>
                </div>
                <div class="info-row">
                    <span>Modifié le</span>
                    <span>{{ server.updatedAt ? server.updatedAt|time_ago : '—' }}</span>
                </div>
            </div>

            <div class="info-card">
                <h5>Statistiques</h5>
                <div class="info-row">
                    <span>Votes ce mois</span>
                    <span><strong>{{ server.monthlyVotes }}</strong></span>
                </div>
                <div class="info-row">
                    <span>Votes total</span>
                    <span><strong>{{ server.totalVotes }}</strong></span>
                </div>
                <div class="info-row">
                    <span>Webhook</span>
                    <span>
                        {% if server.webhookEnabled %}
                            <span style="color:var(--success);">Activé</span>
                        {% else %}
                            <span style="color:var(--text-secondary);">Désactivé</span>
                        {% endif %}
                    </span>
                </div>
            </div>

            <div class="info-card">
                <h5>Clé API</h5>
                <div style="font-family:monospace;font-size:11px;word-break:break-all;color:var(--accent);padding:8px;background:var(--bg-dark);border-radius:4px;">
                    {{ server.apiToken }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
