{% extends 'admin/base.html.twig' %}

{% block title %}Nexarena Admin — Serveur Ubuntu{% endblock %}
{% block page_title %}Serveur Ubuntu{% endblock %}

{% block admin_css %}
.sa-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:1rem; margin-bottom:1.5rem; }
.sa-card { background:var(--admin-card-bg,#1e1f2e); border:1px solid var(--admin-border,#2d2f45); border-radius:10px; padding:1.25rem; }
.sa-card__label { font-size:.72rem; color:#8b8fa8; text-transform:uppercase; letter-spacing:.05em; margin-bottom:.4rem; }
.sa-card__val { font-size:1.5rem; font-weight:700; color:#e0e0f0; }
.sa-card__sub { font-size:.8rem; color:#8b8fa8; margin-top:.2rem; }
.sa-section { background:var(--admin-card-bg,#1e1f2e); border:1px solid var(--admin-border,#2d2f45); border-radius:10px; padding:1.5rem; margin-bottom:1.5rem; }
.sa-section h3 { font-size:1rem; font-weight:600; color:#e0e0f0; margin-bottom:1rem; display:flex; align-items:center; gap:.5rem; }
.sa-section h3 i { color:#6c7af0; }
.svc-row { display:flex; align-items:center; gap:.75rem; padding:.6rem 0; border-bottom:1px solid rgba(255,255,255,.04); }
.svc-row:last-child { border-bottom:none; }
.svc-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.svc-dot--on  { background:#45f882; box-shadow:0 0 6px #45f882; }
.svc-dot--off { background:#e84b4b; }
.svc-name { flex:1; font-size:.9rem; color:#d0d4f0; font-family:monospace; }
.svc-btns { display:flex; gap:.4rem; }
.btn-sa { padding:.25rem .65rem; font-size:.78rem; border-radius:5px; border:none; cursor:pointer; transition:.15s; font-weight:500; }
.btn-sa--blue   { background:#3b5bdb; color:#fff; }
.btn-sa--blue:hover { background:#4c6ef5; }
.btn-sa--green  { background:#2f9e44; color:#fff; }
.btn-sa--green:hover { background:#37b24d; }
.btn-sa--red    { background:#c92a2a; color:#fff; }
.btn-sa--red:hover { background:#e03131; }
.btn-sa--gray   { background:#374151; color:#d0d4f0; }
.btn-sa--gray:hover { background:#4b5563; }
.btn-sa--orange { background:#d9480f; color:#fff; }
.btn-sa--orange:hover { background:#e8590c; }
.ip-table { width:100%; border-collapse:collapse; font-size:.85rem; }
.ip-table th { color:#8b8fa8; font-weight:600; text-align:left; padding:.5rem .75rem; border-bottom:1px solid rgba(255,255,255,.07); font-size:.75rem; text-transform:uppercase; }
.ip-table td { padding:.5rem .75rem; color:#d0d4f0; border-bottom:1px solid rgba(255,255,255,.04); font-family:monospace; }
.ip-table tr:last-child td { border-bottom:none; }
.log-box { background:#0d0e17; border:1px solid #2d2f45; border-radius:6px; padding:.75rem 1rem; font-size:.78rem; font-family:monospace; color:#c0c7e8; white-space:pre-wrap; word-break:break-all; max-height:350px; overflow-y:auto; margin-top:.75rem; }
.sa-input { background:#0d0e17; border:1px solid #2d2f45; border-radius:6px; padding:.45rem .75rem; color:#e0e0f0; font-size:.85rem; width:100%; outline:none; }
.sa-input:focus { border-color:#6c7af0; }
.sa-textarea { background:#0d0e17; border:1px solid #2d2f45; border-radius:6px; padding:.6rem .75rem; color:#e0e0f0; font-size:.8rem; font-family:monospace; width:100%; outline:none; resize:vertical; min-height:300px; }
.sa-textarea:focus { border-color:#6c7af0; }
.pkg-badge { display:inline-block; background:#1e3a5f; color:#90cdf4; border-radius:4px; padding:.1rem .45rem; font-size:.75rem; font-family:monospace; }
.pkg-badge--new { background:#1a3a2a; color:#68d391; }
.progress-bar-wrap { background:#0d0e17; border-radius:4px; height:8px; overflow:hidden; margin-top:.3rem; }
.progress-bar-fill { height:100%; border-radius:4px; transition:width .4s; }
.jail-block { background:#0d0e17; border:1px solid #2d2f45; border-radius:8px; padding:1rem; margin-bottom:.75rem; }
.jail-block h4 { font-size:.85rem; font-weight:600; color:#e0e0f0; font-family:monospace; margin-bottom:.6rem; }
.jail-stats { display:flex; gap:1.5rem; flex-wrap:wrap; font-size:.82rem; color:#8b8fa8; margin-bottom:.6rem; }
.jail-stats span b { color:#d0d4f0; }
.tab-bar { display:flex; gap:.5rem; margin-bottom:1.25rem; flex-wrap:wrap; }
.tab-btn { padding:.45rem 1rem; border-radius:6px; border:1px solid #2d2f45; background:transparent; color:#8b8fa8; font-size:.82rem; cursor:pointer; transition:.15s; }
.tab-btn.active, .tab-btn:hover { background:#3b5bdb; border-color:#3b5bdb; color:#fff; }
.tab-pane { display:none; }
.tab-pane.active { display:block; }
.flash-toast { position:fixed; bottom:1.5rem; right:1.5rem; z-index:9999; display:flex; flex-direction:column; gap:.5rem; }
.toast-item { background:#1e1f2e; border:1px solid; border-radius:8px; padding:.75rem 1.25rem; font-size:.85rem; color:#e0e0f0; min-width:280px; animation:fadeIn .2s; }
.toast-item--ok  { border-color:#2f9e44; }
.toast-item--err { border-color:#c92a2a; }
@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
.config-select { background:#0d0e17; border:1px solid #2d2f45; border-radius:6px; padding:.45rem .75rem; color:#e0e0f0; font-size:.85rem; outline:none; cursor:pointer; }
.config-select:focus { border-color:#6c7af0; }
.spinner { display:inline-block; width:14px; height:14px; border:2px solid rgba(255,255,255,.25); border-top-color:#fff; border-radius:50%; animation:spin .6s linear infinite; vertical-align:middle; margin-right:.3rem; }
@keyframes spin { to { transform:rotate(360deg); } }
{% endblock %}

{% block admin_body %}
<div class="flash-toast" id="flashToast"></div>

<div style="padding:1.5rem;">

    {# ── Onglets ── #}
    <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1.25rem;">
        <div class="tab-bar" style="margin-bottom:0;flex:1;">
            <button class="tab-btn active" onclick="showTab('system')"><i class="fas fa-server"></i> Système</button>
            <button class="tab-btn" onclick="showTab('services')"><i class="fas fa-cogs"></i> Services</button>
            <button class="tab-btn" onclick="showTab('firewall')"><i class="fas fa-shield-alt"></i> Firewall</button>
            <button class="tab-btn" onclick="showTab('fail2ban')"><i class="fas fa-user-slash"></i> Fail2ban</button>
            <button class="tab-btn" onclick="showTab('apt')"><i class="fas fa-box-open"></i> Paquets APT</button>
            <button class="tab-btn" onclick="showTab('logs')"><i class="fas fa-scroll"></i> Logs</button>
            <button class="tab-btn" onclick="showTab('symfony')"><i class="fas fa-code"></i> Symfony</button>
            <button class="tab-btn" onclick="showTab('processes')"><i class="fas fa-microchip"></i> Processus</button>
            <button class="tab-btn" onclick="showTab('network')"><i class="fas fa-network-wired"></i> Réseau</button>
            <button class="tab-btn" onclick="showTab('php')"><i class="fab fa-php"></i> PHP</button>
            <button class="tab-btn" onclick="showTab('cron')"><i class="fas fa-clock"></i> Cron</button>
            <button class="tab-btn" onclick="showTab('config')"><i class="fas fa-file-code"></i> Config</button>
        </div>
        <div style="font-size:.75rem;color:#8b8fa8;white-space:nowrap;text-align:right;">
            <span id="autoRefreshStatus"><span class="spinner"></span> Actualisation auto</span><br>
            <span id="lastRefreshed">—</span>
        </div>
    </div>

    {# ══════════════════════ ONGLET SYSTÈME ══════════════════════ #}
    <div class="tab-pane active" id="tab-system">

        <div class="sa-grid">
            <div class="sa-card">
                <div class="sa-card__label"><i class="fas fa-clock"></i> Uptime</div>
                <div class="sa-card__val" style="font-size:1.1rem;" id="si-uptime">{{ systemInfo.uptime ?: '—' }}</div>
            </div>
            <div class="sa-card">
                <div class="sa-card__label"><i class="fas fa-microchip"></i> Charge CPU</div>
                <div class="sa-card__val" id="si-load1">{{ systemInfo.load['1m'] }}</div>
                <div class="sa-card__sub">5m: <b id="si-load5">{{ systemInfo.load['5m'] }}</b> | 15m: <b id="si-load15">{{ systemInfo.load['15m'] }}</b></div>
            </div>
            <div class="sa-card">
                <div class="sa-card__label"><i class="fas fa-memory"></i> RAM</div>
                <div class="sa-card__val" id="si-mem-pct">{{ systemInfo.memory.percent }}%</div>
                <div class="sa-card__sub" id="si-mem-detail">{{ systemInfo.memory.used }} Mo / {{ systemInfo.memory.total }} Mo</div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar-fill" id="si-mem-bar"
                         style="width:{{ systemInfo.memory.percent }}%;
                                background:{{ systemInfo.memory.percent > 85 ? '#e03131' : (systemInfo.memory.percent > 60 ? '#f08c00' : '#2f9e44') }};"></div>
                </div>
            </div>
            <div class="sa-card">
                <div class="sa-card__label"><i class="fas fa-hdd"></i> Disque /</div>
                <div class="sa-card__val" id="si-disk-pct">{{ systemInfo.disk.percent }}%</div>
                <div class="sa-card__sub" id="si-disk-detail">{{ systemInfo.disk.used }} / {{ systemInfo.disk.total }}</div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar-fill" id="si-disk-bar"
                         style="width:{{ systemInfo.disk.percent }}%;
                                background:{{ systemInfo.disk.percent > 85 ? '#e03131' : (systemInfo.disk.percent > 60 ? '#f08c00' : '#2f9e44') }};"></div>
                </div>
            </div>
        </div>

        <div style="text-align:right;">
            <button class="btn-sa btn-sa--blue" onclick="refreshSystemInfo()"><i class="fas fa-sync-alt"></i> Actualiser</button>
        </div>
    </div>

    {# ══════════════════════ ONGLET SERVICES ══════════════════════ #}
    <div class="tab-pane" id="tab-services">
        <div class="sa-section">
            <h3><i class="fas fa-cogs"></i> État des services</h3>

            {% set serviceLabels = {'nginx': 'nginx', 'php8.4-fpm': 'php8.4-fpm', 'fail2ban': 'fail2ban', 'mariadb': 'mariadb'} %}
            {% for svc, active in servicesStatus %}
            <div class="svc-row" id="svcrow-{{ svc|replace({'.': '_', '-': '_'}) }}">
                <div class="svc-dot {{ active ? 'svc-dot--on' : 'svc-dot--off' }}" id="svcstatus-{{ svc|replace({'.': '_', '-': '_'}) }}"></div>
                <div class="svc-name">{{ svc }}</div>
                <div class="svc-btns">
                    <button class="btn-sa btn-sa--green" onclick="svcAction('restart','{{ svc }}')">
                        <i class="fas fa-redo"></i> Restart
                    </button>
                    {% if svc in ['nginx', 'php8.4-fpm'] %}
                    <button class="btn-sa btn-sa--blue" onclick="svcAction('reload','{{ svc }}')">
                        <i class="fas fa-sync"></i> Reload
                    </button>
                    {% endif %}
                    <button class="btn-sa btn-sa--gray" onclick="svcLog('{{ svc }}')">
                        <i class="fas fa-scroll"></i> Logs
                    </button>
                </div>
            </div>
            {% endfor %}
        </div>

        <div class="sa-section" id="logSection" style="display:none;">
            <h3><i class="fas fa-scroll"></i> Journal : <span id="logTitle">—</span></h3>
            <div class="log-box" id="logBox">Chargement…</div>
        </div>
    </div>

    {# ══════════════════════ ONGLET FIREWALL ══════════════════════ #}
    <div class="tab-pane" id="tab-firewall">

        <div class="sa-section">
            <h3><i class="fas fa-ban"></i> Bannir une IP (iptables f2b-global)</h3>
            <div style="display:flex;gap:.75rem;align-items:flex-end;flex-wrap:wrap;">
                <div style="flex:1;min-width:220px;">
                    <label style="font-size:.78rem;color:#8b8fa8;display:block;margin-bottom:.35rem;">Adresse IP</label>
                    <input type="text" class="sa-input" id="banIpInput" placeholder="ex: 1.2.3.4">
                </div>
                <button class="btn-sa btn-sa--red" onclick="firewallBan()"><i class="fas fa-ban"></i> Bannir</button>
            </div>
        </div>

        <div class="sa-section">
            <h3><i class="fas fa-shield-alt"></i> IPs bannies (<span id="fwCount">{{ firewall.ips|length }}</span>)
                <button class="btn-sa btn-sa--gray" style="margin-left:auto;" onclick="refreshFirewall()"><i class="fas fa-sync-alt"></i></button>
            </h3>

            {% if firewall.ips is empty %}
            <p style="color:#8b8fa8;font-size:.85rem;" id="fwEmpty">Aucune IP bannie.</p>
            {% else %}
            <p style="color:#8b8fa8;font-size:.85rem;" id="fwEmpty" style="display:none"></p>
            {% endif %}

            <table class="ip-table" id="fwTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Adresse IP</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="fwBody">
                    {% for rule in firewall.ips %}
                    <tr id="fwrow-{{ rule.ip|replace({'.': '_'}) }}">
                        <td>{{ rule.num }}</td>
                        <td>{{ rule.ip }}</td>
                        <td><button class="btn-sa btn-sa--green" onclick="firewallUnban('{{ rule.ip }}')"><i class="fas fa-unlock"></i> Débannir</button></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ══════════════════════ ONGLET FAIL2BAN ══════════════════════ #}
    <div class="tab-pane" id="tab-fail2ban">

        <div style="text-align:right;margin-bottom:1rem;">
            <button class="btn-sa btn-sa--blue" onclick="refreshFail2ban()"><i class="fas fa-sync-alt"></i> Actualiser</button>
        </div>

        <div id="f2bContent">
        {% if fail2ban.success %}
            {% for jail, data in fail2ban.jails %}
            <div class="jail-block" id="jail-{{ jail }}">
                <h4><i class="fas fa-lock" style="color:#6c7af0;"></i> {{ jail }}</h4>
                <div class="jail-stats">
                    <span>Échecs: <b>{{ data.failed_current }}</b> / {{ data.failed_total }} total</span>
                    <span>Bannis: <b>{{ data.banned_current }}</b> / {{ data.banned_total }} total</span>
                </div>
                {% if data.banned_ips is not empty %}
                <table class="ip-table" style="margin-top:.5rem;">
                    <thead>
                        <tr><th>IP bannie</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                        {% for ip in data.banned_ips %}
                        <tr>
                            <td>{{ ip }}</td>
                            <td><button class="btn-sa btn-sa--green" onclick="f2bUnban('{{ ip }}','{{ jail }}')">
                                <i class="fas fa-unlock"></i> Débannir
                            </button></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <p style="color:#8b8fa8;font-size:.82rem;margin:0;">Aucune IP bannie dans ce jail.</p>
                {% endif %}
            </div>
            {% else %}
            <p style="color:#8b8fa8;">Aucun jail actif.</p>
            {% endfor %}
        {% else %}
            <p style="color:#e03131;">Impossible de récupérer le statut Fail2ban.</p>
        {% endif %}
        </div>
    </div>

    {# ══════════════════════ ONGLET APT ══════════════════════ #}
    <div class="tab-pane" id="tab-apt">

        <div class="sa-grid" style="grid-template-columns:repeat(auto-fill,minmax(260px,1fr));">
            <div class="sa-card">
                <div class="sa-card__label"><i class="fas fa-box-open"></i> Paquets à mettre à jour</div>
                <div class="sa-card__val" id="aptCount">{{ upgradable.count }}</div>
                <div style="display:flex;gap:.5rem;margin-top:.75rem;flex-wrap:wrap;">
                    <button class="btn-sa btn-sa--blue" onclick="aptUpdate()"><i class="fas fa-sync-alt"></i> apt update</button>
                    <button class="btn-sa btn-sa--green" id="btnAptUpgrade" onclick="aptUpgrade()" {% if upgradable.count == 0 %}disabled style="opacity:.5;cursor:not-allowed;"{% endif %}>
                        <i class="fas fa-arrow-up"></i> apt upgrade
                    </button>
                    <button class="btn-sa btn-sa--gray" onclick="refreshAptList()"><i class="fas fa-list"></i> Actualiser liste</button>
                </div>
            </div>
        </div>

        {% if upgradable.packages is not empty %}
        <div class="sa-section">
            <h3><i class="fas fa-list"></i> Paquets disponibles ({{ upgradable.count }})</h3>
            <table class="ip-table" id="aptTable">
                <thead>
                    <tr><th>Paquet</th><th>Version actuelle</th><th>Nouvelle version</th></tr>
                </thead>
                <tbody id="aptBody">
                    {% for pkg in upgradable.packages %}
                    <tr>
                        <td>{{ pkg.name }}</td>
                        <td><span class="pkg-badge">{{ pkg.old }}</span></td>
                        <td><span class="pkg-badge pkg-badge--new">{{ pkg.new }}</span></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        <div class="sa-section" id="aptLogSection" style="display:none;">
            <h3><i class="fas fa-terminal"></i> Sortie APT</h3>
            <div class="log-box" id="aptLog"></div>
        </div>
    </div>

    {# ══════════════════════ ONGLET CONFIG ══════════════════════ #}
    <div class="tab-pane" id="tab-config">

        <div class="sa-section">
            <h3><i class="fas fa-file-code"></i> Éditer un fichier de configuration</h3>

            <div style="display:flex;gap:.75rem;align-items:flex-end;flex-wrap:wrap;margin-bottom:1rem;">
                <div>
                    <label style="font-size:.78rem;color:#8b8fa8;display:block;margin-bottom:.35rem;">Fichier</label>
                    <select class="config-select" id="configKey" onchange="loadConfig()">
                        <option value="">— Choisir —</option>
                        {% for key, path in configFiles %}
                        <option value="{{ key }}">{{ key }} ({{ path }})</option>
                        {% endfor %}
                    </select>
                </div>
                <button class="btn-sa btn-sa--blue" onclick="loadConfig()"><i class="fas fa-upload"></i> Charger</button>
            </div>

            <textarea class="sa-textarea" id="configContent" placeholder="Sélectionnez un fichier pour l'éditer…" spellcheck="false"></textarea>

            <div style="display:flex;gap:.75rem;margin-top:.75rem;flex-wrap:wrap;">
                <button class="btn-sa btn-sa--green" onclick="saveConfig()"><i class="fas fa-save"></i> Enregistrer</button>
                <span style="font-size:.78rem;color:#8b8fa8;align-self:center;" id="configStatus"></span>
            </div>
            <div style="margin-top:.5rem;padding:.6rem .8rem;background:#1a1b0a;border:1px solid #8b6914;border-radius:6px;font-size:.78rem;color:#f0c040;">
                <i class="fas fa-exclamation-triangle"></i>
                <b>Attention</b> — Toute modification incorrecte peut rendre le serveur inaccessible. Faites une sauvegarde avant d'éditer.
            </div>
        </div>
    </div>

    {# ══════════════════════ ONGLET LOGS ══════════════════════ #}
    <div class="tab-pane" id="tab-logs">
        <div class="sa-section">
            <h3><i class="fas fa-scroll"></i> Logs</h3>
            <div style="display:flex;gap:.75rem;align-items:flex-end;flex-wrap:wrap;margin-bottom:1rem;">
                <div>
                    <label style="font-size:.78rem;color:#8b8fa8;display:block;margin-bottom:.35rem;">Source</label>
                    <select class="config-select" id="logKey">
                        {% set logLabels = {
                            'symfony_prod': 'Symfony prod.log',
                            'symfony_dev':  'Symfony dev.log',
                            'nginx_access': 'Nginx access.log',
                            'nginx_error':  'Nginx error.log',
                            'php_fpm':      'PHP-FPM error.log',
                            'mariadb':      'MariaDB error.log',
                            'fail2ban':     'Fail2ban.log',
                            'auth':         'Auth.log',
                            'syslog':       'Syslog',
                        } %}
                        {% for key, label in logLabels %}
                        <option value="{{ key }}">{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label style="font-size:.78rem;color:#8b8fa8;display:block;margin-bottom:.35rem;">Lignes</label>
                    <select class="config-select" id="logLines">
                        <option value="100">100</option>
                        <option value="300" selected>300</option>
                        <option value="500">500</option>
                        <option value="1000">1000</option>
                    </select>
                </div>
                <button class="btn-sa btn-sa--blue" onclick="loadLog()"><i class="fas fa-download"></i> Charger</button>
                <button class="btn-sa btn-sa--green" onclick="loadLog()" id="btnLogRefresh"><i class="fas fa-sync-alt"></i> Actualiser</button>
            </div>
            <div style="display:flex;gap:.75rem;align-items:flex-end;flex-wrap:wrap;margin-bottom:.75rem;">
                <div style="flex:1;min-width:200px;">
                    <label style="font-size:.78rem;color:#8b8fa8;display:block;margin-bottom:.35rem;">Rechercher dans le log</label>
                    <input type="text" class="sa-input" id="logSearch" placeholder="ex: ERROR, 404, exception…">
                </div>
                <button class="btn-sa btn-sa--gray" onclick="searchLog()"><i class="fas fa-search"></i> Chercher</button>
                <button class="btn-sa btn-sa--gray" onclick="clearLogSearch()"><i class="fas fa-times"></i> Effacer</button>
            </div>
            <div class="log-box" id="logContent" style="max-height:500px;">(Sélectionnez une source et cliquez Charger)</div>
        </div>
    </div>

    {# ══════════════════════ ONGLET SYMFONY ══════════════════════ #}
    <div class="tab-pane" id="tab-symfony">
        <div class="sa-section">
            <h3><i class="fas fa-code"></i> Symfony — Commandes</h3>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.75rem;margin-bottom:1rem;">
                <button class="btn-sa btn-sa--blue" style="padding:.6rem 1rem;font-size:.85rem;" onclick="symfonyCmd('cache:clear')">
                    <i class="fas fa-trash-alt"></i> cache:clear (prod)
                </button>
                <button class="btn-sa btn-sa--blue" style="padding:.6rem 1rem;font-size:.85rem;" onclick="symfonyCmd('cache:warmup')">
                    <i class="fas fa-fire"></i> cache:warmup (prod)
                </button>
                <button class="btn-sa btn-sa--gray" style="padding:.6rem 1rem;font-size:.85rem;" onclick="symfonyCmd('migrations:status')">
                    <i class="fas fa-database"></i> migrations:status
                </button>
                <button class="btn-sa btn-sa--orange" style="padding:.6rem 1rem;font-size:.85rem;" onclick="confirmSymfonyCmd('migrations:migrate','Lancer les migrations Doctrine ?')">
                    <i class="fas fa-arrow-up"></i> migrations:migrate
                </button>
                <button class="btn-sa btn-sa--gray" style="padding:.6rem 1rem;font-size:.85rem;" onclick="symfonyCmd('messenger:stop')">
                    <i class="fas fa-stop"></i> messenger:stop-workers
                </button>
                <button class="btn-sa btn-sa--gray" style="padding:.6rem 1rem;font-size:.85rem;" onclick="symfonyCmd('router:match')">
                    <i class="fas fa-route"></i> debug:router
                </button>
            </div>
            <div class="sa-section" id="symfonyOutput" style="display:none;margin-bottom:0;">
                <h3><i class="fas fa-terminal"></i> Sortie : <span id="symfonyCmd">—</span></h3>
                <div class="log-box" id="symfonyLog"></div>
            </div>
        </div>
    </div>

    {# ══════════════════════ ONGLET PROCESSUS ══════════════════════ #}
    <div class="tab-pane" id="tab-processes">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
            <span style="font-size:.85rem;color:#8b8fa8;">Top 20 processus par CPU</span>
            <button class="btn-sa btn-sa--blue" onclick="refreshProcesses()"><i class="fas fa-sync-alt"></i> Actualiser</button>
        </div>
        <div class="sa-section" style="padding:0;overflow:hidden;">
            <table class="ip-table" id="procTable">
                <thead>
                    <tr>
                        <th>User</th><th>PID</th><th>CPU%</th><th>MEM%</th><th>RSS (Ko)</th><th>Stat</th><th>Commande</th><th>Action</th>
                    </tr>
                </thead>
                <tbody id="procBody">
                    <tr><td colspan="8" style="text-align:center;color:#8b8fa8;padding:1.5rem;">Cliquez Actualiser pour charger</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ══════════════════════ ONGLET RÉSEAU ══════════════════════ #}
    <div class="tab-pane" id="tab-network">
        <div style="text-align:right;margin-bottom:1rem;">
            <button class="btn-sa btn-sa--blue" onclick="refreshNetwork()"><i class="fas fa-sync-alt"></i> Actualiser</button>
        </div>
        <div class="sa-grid">
            <div class="sa-card">
                <div class="sa-card__label"><i class="fas fa-globe"></i> Connexions HTTP actives</div>
                <div class="sa-card__val" id="httpConnCount">—</div>
                <div class="sa-card__sub">(ports 80 + 443)</div>
            </div>
        </div>
        <div class="sa-section">
            <h3><i class="fas fa-plug"></i> Ports en écoute</h3>
            <table class="ip-table" id="portsTable">
                <thead><tr><th>Proto</th><th>Adresse locale</th><th>Processus</th></tr></thead>
                <tbody id="portsBody">
                    <tr><td colspan="3" style="text-align:center;color:#8b8fa8;padding:1rem;">Cliquez Actualiser</td></tr>
                </tbody>
            </table>
            <div class="log-box" id="portsRaw" style="display:none;margin-top:.75rem;"></div>
        </div>
        <div class="sa-section">
            <h3><i class="fas fa-chart-bar"></i> Statistiques connexions</h3>
            <div class="log-box" id="connStats" style="max-height:200px;">(Cliquez Actualiser)</div>
        </div>
    </div>

    {# ══════════════════════ ONGLET PHP ══════════════════════ #}
    <div class="tab-pane" id="tab-php">
        <div class="sa-grid">
            <div class="sa-card">
                <div class="sa-card__label"><i class="fab fa-php"></i> Version PHP</div>
                <div class="sa-card__val" style="font-size:1.1rem;">{{ phpInfo.version }}</div>
            </div>
            <div class="sa-card">
                <div class="sa-card__label"><i class="fas fa-memory"></i> OPcache utilisé</div>
                <div class="sa-card__val" id="opcUsed">{{ opcache.used_mb ?? '—' }} Mo</div>
                <div class="sa-card__sub" id="opcDetail">{{ opcache.cached_scripts ?? '—' }} scripts en cache</div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar-fill" id="opcBar"
                         style="width:{{ opcache.percent ?? 0 }}%;background:{{ (opcache.percent ?? 0) > 85 ? '#e03131' : '#3b5bdb' }};"></div>
                </div>
            </div>
            <div class="sa-card">
                <div class="sa-card__label"><i class="fas fa-chart-line"></i> OPcache hits/misses</div>
                <div class="sa-card__val" id="opcHits" style="font-size:1rem;">{{ opcache.hits ?? '—' }} / {{ opcache.misses ?? '—' }}</div>
                <div class="sa-card__sub">hits / misses</div>
            </div>
        </div>

        <div style="display:flex;gap:.75rem;margin-bottom:1rem;flex-wrap:wrap;">
            <button class="btn-sa btn-sa--blue" onclick="refreshOpcache()"><i class="fas fa-sync-alt"></i> Actualiser OPcache</button>
            <button class="btn-sa btn-sa--orange" onclick="resetOpcache()"><i class="fas fa-trash-alt"></i> Vider OPcache</button>
        </div>

        <div class="sa-section">
            <h3><i class="fas fa-sliders-h"></i> Paramètres PHP clés</h3>
            <table class="ip-table">
                <thead><tr><th>Paramètre</th><th>Valeur</th></tr></thead>
                <tbody>
                    {% for key, val in phpInfo.ini %}
                    <tr><td style="font-family:monospace;">{{ key }}</td><td style="font-family:monospace;color:#45f882;">{{ val }}</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="sa-section">
            <h3><i class="fas fa-puzzle-piece"></i> Extensions PHP ({{ phpInfo.extensions|length }})</h3>
            <div style="display:flex;flex-wrap:wrap;gap:.4rem;">
                {% for ext in phpInfo.extensions %}
                    {% if ext and not (ext starts with '[') %}
                    <span style="background:#1e2535;border:1px solid #2d2f45;border-radius:4px;padding:.15rem .5rem;font-size:.75rem;font-family:monospace;color:#90cdf4;">{{ ext }}</span>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>

    {# ══════════════════════ ONGLET CRON ══════════════════════ #}
    <div class="tab-pane" id="tab-cron">
        <div style="text-align:right;margin-bottom:1rem;">
            <button class="btn-sa btn-sa--blue" onclick="refreshCron()"><i class="fas fa-sync-alt"></i> Actualiser</button>
        </div>
        <div class="sa-section">
            <h3><i class="fas fa-user-secret"></i> Crontab root</h3>
            <div class="log-box" id="cronRoot">{{ sas is defined ? '' : '(Cliquez Actualiser)' }}</div>
        </div>
        <div class="sa-section">
            <h3><i class="fas fa-globe"></i> Crontab www-data</h3>
            <div class="log-box" id="cronWwwData">(Cliquez Actualiser)</div>
        </div>
        <div class="sa-section">
            <h3><i class="fas fa-file-alt"></i> /etc/crontab (système)</h3>
            <div class="log-box" id="cronSystem">(Cliquez Actualiser)</div>
        </div>
    </div>

</div>{# /padding #}
{% endblock admin_body %}

{% block admin_js %}
<script nonce="{{ csp_nonce() }}">
const CSRF = '{{ csrf_token('server_admin') }}';
const BASE = '{{ path('admin_server_admin_index') }}';

// ── Tabs ────────────────────────────────────────────────────────────────
function showTab(name) {
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    event.target.closest('.tab-btn').classList.add('active');
}

// ── Toast ────────────────────────────────────────────────────────────────
function toast(msg, ok) {
    const el = document.createElement('div');
    el.className = 'toast-item toast-item--' + (ok ? 'ok' : 'err');
    el.innerHTML = '<i class="fas fa-' + (ok ? 'check-circle' : 'exclamation-circle') + '"></i> ' + msg;
    document.getElementById('flashToast').appendChild(el);
    setTimeout(() => el.remove(), 4500);
}

// ── POST helper ──────────────────────────────────────────────────────────
async function postJson(url, data) {
    const fd = new FormData();
    fd.append('_token', CSRF);
    for (const [k, v] of Object.entries(data)) fd.append(k, v);
    const r = await fetch(url, { method:'POST', body: fd });
    return r.json();
}

// ── URL helper ───────────────────────────────────────────────────────────
function url(path) { return BASE.replace(/\/+$/, '') + path; }

// ── Dernière actualisation ────────────────────────────────────────────────
function updateLastRefreshed() {
    const now = new Date();
    document.getElementById('lastRefreshed').textContent =
        'Mis à jour ' + now.getHours().toString().padStart(2,'0') + ':' +
        now.getMinutes().toString().padStart(2,'0') + ':' +
        now.getSeconds().toString().padStart(2,'0');
}

// ── Système ──────────────────────────────────────────────────────────────
async function refreshSystemInfo(silent) {
    try {
        const d = await (await fetch(url('/system/info'))).json();
        document.getElementById('si-uptime').textContent  = d.uptime || '—';
        document.getElementById('si-load1').textContent   = d.load['1m'];
        document.getElementById('si-load5').textContent   = d.load['5m'];
        document.getElementById('si-load15').textContent  = d.load['15m'];
        document.getElementById('si-mem-pct').textContent    = d.memory.percent + '%';
        document.getElementById('si-mem-detail').textContent = d.memory.used + ' Mo / ' + d.memory.total + ' Mo';
        document.getElementById('si-mem-bar').style.width    = d.memory.percent + '%';
        document.getElementById('si-disk-pct').textContent    = d.disk.percent + '%';
        document.getElementById('si-disk-detail').textContent = d.disk.used + ' / ' + d.disk.total;
        document.getElementById('si-disk-bar').style.width    = d.disk.percent + '%';
        if (!silent) toast('Informations système actualisées.', true);
        updateLastRefreshed();
    } catch(e) {}
}

// ── Services status (auto-refresh) ───────────────────────────────────────
async function refreshServicesStatus(silent) {
    try {
        const d = await (await fetch(url('/services/status'))).json();
        for (const [svc, active] of Object.entries(d)) {
            const key = svc.replaceAll('.','_').replaceAll('-','_');
            const dot = document.getElementById('svcstatus-' + key);
            if (dot) dot.className = 'svc-dot ' + (active ? 'svc-dot--on' : 'svc-dot--off');
        }
        updateLastRefreshed();
    } catch(e) {}
}

// ── Services ─────────────────────────────────────────────────────────────
async function svcAction(action, svc) {
    const svcKey = svc.replaceAll('.','_').replaceAll('-','_');
    const dot = document.getElementById('svcstatus-' + svcKey);
    dot && (dot.style.opacity = '.3');
    const d = await postJson(url('/service/' + action), { service: svc });
    if (dot) {
        dot.style.opacity = '1';
        dot.className = 'svc-dot ' + (d.success ? 'svc-dot--on' : 'svc-dot--off');
    }
    toast((d.success ? svc + ' ' + (action==='restart'?'redémarré':'rechargé') + '.' : ('Erreur: ' + d.output)), d.success);
}

async function svcLog(svc) {
    const sec = document.getElementById('logSection');
    const box = document.getElementById('logBox');
    document.getElementById('logTitle').textContent = svc;
    sec.style.display = '';
    box.textContent = 'Chargement…';
    sec.scrollIntoView({ behavior:'smooth', block:'start' });
    const d = await (await fetch(url('/service/log?service=') + encodeURIComponent(svc))).json();
    box.textContent = d.output || '(vide)';
    box.scrollTop = box.scrollHeight;
}

// ── Firewall ─────────────────────────────────────────────────────────────
async function firewallBan() {
    const ip = document.getElementById('banIpInput').value.trim();
    if (!ip) { toast('Entrez une adresse IP.', false); return; }
    const d = await postJson(url('/firewall/ban'), { ip });
    toast(d.success ? 'IP ' + ip + ' bannie.' : ('Erreur: ' + d.output), d.success);
    if (d.success) { document.getElementById('banIpInput').value = ''; refreshFirewall(); }
}

async function firewallUnban(ip) {
    const d = await postJson(url('/firewall/unban'), { ip });
    toast(d.success ? 'IP ' + ip + ' débannie.' : ('Erreur: ' + d.output), d.success);
    if (d.success) refreshFirewall();
}

async function refreshFirewall() {
    const d = await (await fetch(url('/firewall/list'))).json();
    const body = document.getElementById('fwBody');
    const empty = document.getElementById('fwEmpty');
    document.getElementById('fwCount').textContent = d.ips.length;
    body.innerHTML = '';
    if (d.ips.length === 0) { if(empty) empty.style.display=''; return; }
    if (empty) empty.style.display = 'none';
    d.ips.forEach(r => {
        const tr = document.createElement('tr');
        const safeKey = r.ip.replaceAll('.','_');
        tr.id = 'fwrow-' + safeKey;
        tr.innerHTML = `<td>${r.num}</td><td>${r.ip}</td><td><button class="btn-sa btn-sa--green" onclick="firewallUnban('${r.ip}')"><i class="fas fa-unlock"></i> Débannir</button></td>`;
        body.appendChild(tr);
    });
}

// ── Fail2ban ─────────────────────────────────────────────────────────────
async function f2bUnban(ip, jail) {
    const d = await postJson(url('/fail2ban/unban'), { ip, jail });
    toast(d.success ? ip + ' débanni de ' + jail + '.' : ('Erreur: ' + d.output), d.success);
    if (d.success) refreshFail2ban();
}

async function refreshFail2ban() {
    const box = document.getElementById('f2bContent');
    box.innerHTML = '<span class="spinner"></span> Chargement…';
    const d = await (await fetch(url('/fail2ban/status'))).json();
    if (!d.success) { box.innerHTML = '<p style="color:#e03131;">Erreur Fail2ban.</p>'; return; }
    const jails = d.jails;
    let html = '';
    for (const [jail, data] of Object.entries(jails)) {
        html += `<div class="jail-block"><h4><i class="fas fa-lock" style="color:#6c7af0;"></i> ${jail}</h4>
        <div class="jail-stats">
            <span>Échecs: <b>${data.failed_current}</b> / ${data.failed_total} total</span>
            <span>Bannis: <b>${data.banned_current}</b> / ${data.banned_total} total</span>
        </div>`;
        if (data.banned_ips && data.banned_ips.length > 0) {
            html += `<table class="ip-table" style="margin-top:.5rem;"><thead><tr><th>IP</th><th>Action</th></tr></thead><tbody>`;
            data.banned_ips.forEach(ip => {
                html += `<tr><td>${ip}</td><td><button class="btn-sa btn-sa--green" onclick="f2bUnban('${ip}','${jail}')"><i class="fas fa-unlock"></i> Débannir</button></td></tr>`;
            });
            html += `</tbody></table>`;
        } else {
            html += `<p style="color:#8b8fa8;font-size:.82rem;margin:0;">Aucune IP bannie.</p>`;
        }
        html += `</div>`;
    }
    if (!html) html = '<p style="color:#8b8fa8;">Aucun jail actif.</p>';
    box.innerHTML = html;
}

// ── APT ───────────────────────────────────────────────────────────────────
async function aptUpdate() {
    const sec = document.getElementById('aptLogSection');
    const log = document.getElementById('aptLog');
    sec.style.display = '';
    log.textContent = 'apt update en cours…';
    const d = await postJson(url('/apt/update'), {});
    log.textContent = d.output || '(vide)';
    toast(d.success ? 'apt update terminé.' : 'Erreur apt update.', d.success);
    if (d.success) {
        const u = await (await fetch(url('/apt/upgradable'))).json();
        document.getElementById('aptCount').textContent = u.count;
        const body = document.getElementById('aptBody');
        if (body) {
            body.innerHTML = '';
            u.packages.forEach(p => {
                const tr = document.createElement('tr');
                tr.innerHTML = `<td>${p.name}</td><td><span class="pkg-badge">${p.old}</span></td><td><span class="pkg-badge pkg-badge--new">${p.new}</span></td>`;
                body.appendChild(tr);
            });
        }
    }
}

async function aptUpgrade() {
    if (!confirm('Lancer apt upgrade ? Cela mettra à jour tous les paquets listés.')) return;
    const sec = document.getElementById('aptLogSection');
    const log = document.getElementById('aptLog');
    sec.style.display = '';
    log.textContent = 'apt upgrade en cours (peut prendre plusieurs minutes)…';
    const d = await postJson(url('/apt/upgrade'), {});
    log.textContent = d.output || '(vide)';
    toast(d.success ? 'apt upgrade terminé.' : 'Erreur apt upgrade.', d.success);
    if (d.success) await refreshAptList();
}

async function refreshAptList() {
    try {
        const u = await (await fetch(url('/apt/upgradable'))).json();
        document.getElementById('aptCount').textContent = u.count;
        const btn = document.getElementById('btnAptUpgrade');
        if (btn) { btn.disabled = u.count === 0; btn.style.opacity = u.count === 0 ? '.5' : '1'; btn.style.cursor = u.count === 0 ? 'not-allowed' : ''; }
        const body = document.getElementById('aptBody');
        if (body) {
            body.innerHTML = '';
            u.packages.forEach(p => {
                const tr = document.createElement('tr');
                tr.innerHTML = `<td>${p.name}</td><td><span class="pkg-badge">${p.old}</span></td><td><span class="pkg-badge pkg-badge--new">${p.new}</span></td>`;
                body.appendChild(tr);
            });
        }
        toast('Liste APT actualisée (' + u.count + ' paquet(s)).', true);
        updateLastRefreshed();
    } catch(e) { toast('Erreur lors de l\'actualisation APT.', false); }
}

// ── Config ────────────────────────────────────────────────────────────────
async function loadConfig() {
    const key = document.getElementById('configKey').value;
    if (!key) return;
    document.getElementById('configStatus').textContent = 'Chargement…';
    const d = await (await fetch(url('/config/read?key=') + encodeURIComponent(key))).json();
    document.getElementById('configContent').value = d.success ? d.output : ('ERREUR: ' + d.output);
    document.getElementById('configStatus').textContent = d.success ? 'Chargé.' : 'Erreur.';
}

async function saveConfig() {
    const key = document.getElementById('configKey').value;
    const content = document.getElementById('configContent').value;
    if (!key) { toast('Sélectionnez un fichier d\'abord.', false); return; }
    if (!confirm('Enregistrer les modifications dans ' + key + ' ?')) return;
    document.getElementById('configStatus').textContent = 'Enregistrement…';
    const d = await postJson(url('/config/write'), { key, content });
    document.getElementById('configStatus').textContent = d.success ? 'Enregistré !' : 'Erreur.';
    toast(d.success ? 'Fichier enregistré.' : ('Erreur: ' + d.output), d.success);
}

// ── Logs ─────────────────────────────────────────────────────────────────
let logAutoRefreshTimer = null;

async function loadLog() {
    const key   = document.getElementById('logKey').value;
    const lines = document.getElementById('logLines').value;
    const box   = document.getElementById('logContent');
    if (!key) return;
    box.textContent = 'Chargement…';
    const d = await (await fetch(url('/logs/read?key=') + encodeURIComponent(key) + '&lines=' + lines)).json();
    box.textContent = d.success ? (d.output || '(vide)') : ('ERREUR: ' + d.output);
    box.scrollTop = box.scrollHeight;
}

async function searchLog() {
    const key = document.getElementById('logKey').value;
    const q   = document.getElementById('logSearch').value.trim();
    const box = document.getElementById('logContent');
    if (!key || !q) { toast('Sélectionnez une source et entrez un terme.', false); return; }
    box.textContent = 'Recherche en cours…';
    const d = await (await fetch(url('/logs/search?key=') + encodeURIComponent(key) + '&q=' + encodeURIComponent(q))).json();
    box.textContent = d.success ? (d.output || '(aucun résultat)') : ('ERREUR: ' + d.output);
    box.scrollTop = box.scrollHeight;
}

function clearLogSearch() {
    document.getElementById('logSearch').value = '';
    loadLog();
}

// ── Symfony ───────────────────────────────────────────────────────────────
async function symfonyCmd(cmd) {
    const sec = document.getElementById('symfonyOutput');
    const log = document.getElementById('symfonyLog');
    document.getElementById('symfonyCmd').textContent = cmd;
    sec.style.display = '';
    log.textContent = 'Exécution en cours…';
    sec.scrollIntoView({ behavior:'smooth', block:'start' });
    const d = await postJson(url('/symfony/run'), { cmd });
    log.textContent = d.output || '(vide)';
    toast(d.success ? cmd + ' terminé.' : 'Erreur: ' + d.output.substring(0,80), d.success);
}

function confirmSymfonyCmd(cmd, msg) {
    if (confirm(msg)) symfonyCmd(cmd);
}

// ── Processus ────────────────────────────────────────────────────────────
async function refreshProcesses() {
    const body = document.getElementById('procBody');
    body.innerHTML = '<tr><td colspan="8" style="text-align:center;color:#8b8fa8;padding:1rem;"><span class="spinner"></span> Chargement…</td></tr>';
    const d = await (await fetch(url('/processes'))).json();
    body.innerHTML = '';
    if (!d.success || !d.processes.length) {
        body.innerHTML = '<tr><td colspan="8" style="text-align:center;color:#8b8fa8;padding:1rem;">Aucun processus.</td></tr>';
        return;
    }
    d.processes.forEach(p => {
        const tr = document.createElement('tr');
        const cpuColor = parseFloat(p.cpu) > 50 ? '#e03131' : parseFloat(p.cpu) > 20 ? '#f08c00' : '#d0d4f0';
        const killBtn = (p.user === 'www-data' || p.user === 'nginx')
            ? `<button class="btn-sa btn-sa--red" onclick="killProc(${p.pid})"><i class="fas fa-times"></i></button>`
            : `<span style="color:#555;font-size:.75rem;">—</span>`;
        tr.innerHTML = `<td>${p.user}</td><td style="font-family:monospace;">${p.pid}</td>
            <td style="color:${cpuColor};font-weight:600;">${p.cpu}%</td>
            <td>${p.mem}%</td><td>${p.rss}</td><td>${p.stat}</td>
            <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${p.command}">${p.command}</td>
            <td>${killBtn}</td>`;
        body.appendChild(tr);
    });
    updateLastRefreshed();
}

async function killProc(pid) {
    if (!confirm('Envoyer SIGTERM au processus PID ' + pid + ' ?')) return;
    const d = await postJson(url('/process/kill'), { pid });
    toast(d.success ? 'Processus ' + pid + ' terminé.' : 'Erreur: ' + d.output, d.success);
    if (d.success) refreshProcesses();
}

// ── Réseau ───────────────────────────────────────────────────────────────
async function refreshNetwork() {
    const [ports, stats] = await Promise.all([
        (await fetch(url('/network/ports'))).json(),
        (await fetch(url('/network/stats'))).json(),
    ]);

    // HTTP connections
    document.getElementById('httpConnCount').textContent = stats.http?.count ?? '—';

    // Ports
    const body = document.getElementById('portsBody');
    const rawBox = document.getElementById('portsRaw');
    body.innerHTML = '';
    if (ports.ports && ports.ports.length) {
        if (rawBox) rawBox.style.display = 'none';
        ports.ports.forEach(p => {
            const tr = document.createElement('tr');
            tr.innerHTML = `<td><span style="background:${p.proto==='tcp'?'#1e3a5f':'#3a1e5f'};color:#90cdf4;border-radius:3px;padding:.1rem .4rem;font-size:.75rem;">${p.proto.toUpperCase()}</span></td><td>${p.local}</td><td>${p.process}</td>`;
            body.appendChild(tr);
        });
    } else if (ports.raw) {
        // Fallback: affiche le raw output
        body.innerHTML = '';
        if (rawBox) { rawBox.style.display = ''; rawBox.textContent = ports.raw; }
        else body.innerHTML = `<tr><td colspan="3"><pre style="color:#c0c7e8;font-size:.78rem;margin:0;">${ports.raw}</pre></td></tr>`;
    } else {
        body.innerHTML = '<tr><td colspan="3" style="text-align:center;color:#8b8fa8;">Aucun résultat.</td></tr>';
    }

    // Stats
    document.getElementById('connStats').textContent = stats.connections?.output ?? '—';
    updateLastRefreshed();
}

// ── PHP OPcache ───────────────────────────────────────────────────────────
async function refreshOpcache() {
    const d = await (await fetch(url('/php/opcache'))).json();
    document.getElementById('opcUsed').textContent    = (d.used_mb ?? '—') + ' Mo';
    document.getElementById('opcDetail').textContent  = (d.cached_scripts ?? '—') + ' scripts en cache';
    document.getElementById('opcHits').textContent    = (d.hits ?? '—') + ' / ' + (d.misses ?? '—');
    document.getElementById('opcBar').style.width     = (d.percent ?? 0) + '%';
    toast('OPcache actualisé.', true);
}

async function resetOpcache() {
    if (!confirm('Vider l\'OPcache ? Les prochaines requêtes recompileront les fichiers PHP.')) return;
    const d = await postJson(url('/php/opcache-reset'), {});
    toast(d.success ? 'OPcache vidé.' : 'Erreur: ' + d.output, d.success);
    if (d.success) refreshOpcache();
}

// ── Cron ─────────────────────────────────────────────────────────────────
async function refreshCron() {
    const d = await (await fetch(url('/cron'))).json();
    document.getElementById('cronRoot').textContent    = d.root    || '(vide)';
    document.getElementById('cronWwwData').textContent = d['www-data'] || '(vide)';
    document.getElementById('cronSystem').textContent  = d.system  || '(vide)';
    updateLastRefreshed();
}

// ── Auto-refresh ──────────────────────────────────────────────────────────
// Système : toutes les 10s
setInterval(() => refreshSystemInfo(true), 10000);
// Services : toutes les 15s
setInterval(() => refreshServicesStatus(true), 15000);
// Firewall : toutes les 30s
setInterval(() => refreshFirewall(), 30000);
// Fail2ban : toutes les 30s
setInterval(() => refreshFail2ban(), 30000);

// Premier refresh silencieux au chargement
(async () => {
    await refreshSystemInfo(true);
    await refreshServicesStatus(true);
})();
</script>
{% endblock admin_js %}
