{% extends 'base.html.twig' %}

{% block title %}Nexarena - Réinitialiser le mot de passe{% endblock %}

{% block header %}{% endblock %}

{% block body %}
<section class="signup__area team-bg section-pt-120 section-pb-120" data-background="{{ asset('assets/img/bg/team_bg.jpg') }}">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-6 col-lg-8">
                <div class="singUp-wrap">
                    <h2 class="title">Nouveau mot de passe</h2>
                    <p>Choisissez un nouveau mot de passe pour votre compte. Il doit contenir au moins 10 caractères.</p>

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}

                    <form action="{{ path('app_reset_password', {token: token}) }}" method="post" class="account__form">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">
                        <div class="form-grp">
                            <label for="password">Nouveau mot de passe</label>
                            <input id="password" type="password" name="password"
                                   placeholder="Minimum 10 caractères" minlength="10" required autofocus>
                        </div>
                        <div class="form-grp">
                            <label for="password_confirm">Confirmer le mot de passe</label>
                            <input id="password_confirm" type="password" name="password_confirm"
                                   placeholder="Confirmez votre mot de passe" minlength="10" required>
                        </div>
                        <button type="submit" class="btn btn-two arrow-btn">Réinitialiser le mot de passe</button>
                    </form>

                    <div class="account__switch">
                        <p><a href="{{ path('app_login') }}">Retour à la connexion</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
