{% extends 'base.html.twig' %}

{% block title %}Nexarena - Inscription{% endblock %}

{% block body %}

    {# breadcrumb-area #}
    <section class="breadcrumb-area" data-background="{{ asset('assets/img/bg/breadcrumb_bg01.jpg') }}">
        <div class="container">
            <div class="breadcrumb__wrapper">
                <div class="row">
                    <div class="col-xl-6 col-lg-7">
                        <div class="breadcrumb__content">
                            <h2 class="title">Inscription</h2>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Inscription</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                    <div class="col-xl-6 col-lg-5 position-relative d-none d-lg-block">
                        <div class="breadcrumb__img">
                            <img src="{{ asset('assets/img/others/breadcrumb_img02.png') }}" alt="img">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# signup-area #}
    <section class="signup__area team-bg section-pt-120 section-pb-120" data-background="{{ asset('assets/img/bg/team_bg.jpg') }}">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-6 col-lg-8">
                    <div class="singUp-wrap">
                        <h2 class="title">Créez votre compte</h2>
                        <p>Rejoignez Nexarena pour ajouter vos serveurs au classement et voter pour vos favoris !</p>

                        {% for message in app.flashes('error') %}
                            <div class="alert alert-danger">{{ message }}</div>
                        {% endfor %}

                        {# Boutons OAuth #}
                        <div class="account__social">
                            <a href="{{ path('app_oauth_connect', {provider: 'google'}) }}" class="account__social-btn">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M20.16 12.1932C20.16 11.5905 20.1059 11.011 20.0055 10.4546H12V13.7425H16.5746C16.3775 14.8051 15.7786 15.7053 14.8784 16.308V18.4407H17.6255C19.2327 16.961 20.16 14.7819 20.16 12.1932Z" fill="#4285F4" />
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12.0002 20.5C14.2952 20.5 16.2193 19.7389 17.6257 18.4407L14.8786 16.3079C14.1175 16.8179 13.1439 17.1193 12.0002 17.1193C9.78635 17.1193 7.91248 15.6241 7.24407 13.615H4.4043V15.8173C5.80294 18.5952 8.67749 20.5 12.0002 20.5Z" fill="#34A853" />
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M7.24387 13.6151C7.07387 13.1051 6.97728 12.5604 6.97728 12.0001C6.97728 11.4399 7.07387 10.8951 7.24387 10.3851V8.18286H4.40409C3.82841 9.33036 3.5 10.6285 3.5 12.0001C3.5 13.3717 3.82841 14.6699 4.40409 15.8174L7.24387 13.6151Z" fill="#FBBC05" />
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12.0002 6.88069C13.2482 6.88069 14.3686 7.30955 15.2495 8.15183L17.6875 5.71387C16.2155 4.34227 14.2914 3.5 12.0002 3.5C8.67748 3.5 5.80294 5.40478 4.4043 8.18273L7.24407 10.385C7.91248 8.37592 9.78635 6.88069 12.0002 6.88069Z" fill="#EA4335" />
                                </svg>
                                S'inscrire avec Google
                            </a>
                        </div>
                        <div class="account__social mt-10">
                            <a href="{{ path('app_oauth_connect', {provider: 'discord'}) }}" class="account__social-btn" style="background:#5865F2;color:#fff;">
                                <i class="fab fa-discord" style="font-size:20px;margin-right:8px;"></i>
                                S'inscrire avec Discord
                            </a>
                        </div>
                        <div class="account__social mt-10">
                            <a href="{{ path('app_oauth_connect', {provider: 'twitch'}) }}" class="account__social-btn" style="background:#9146FF;color:#fff;">
                                <i class="fab fa-twitch" style="font-size:20px;margin-right:8px;"></i>
                                S'inscrire avec Twitch
                            </a>
                        </div>
                        <div class="account__social mt-10">
                            <a href="{{ steam_login_url() }}" class="account__social-btn" style="background:#171a21;color:#fff;">
                                <i class="fab fa-steam" style="font-size:20px;margin-right:8px;"></i>
                                S'inscrire avec Steam
                            </a>
                        </div>

                        <div class="account__divider">
                            <span>OU</span>
                        </div>

                        {# Formulaire classique #}
                        {{ form_start(form, {'attr': {'class': 'account__form', 'id': 'register-form'}}) }}
                            <div class="form-grp">
                                <label for="{{ form.username.vars.id }}">Nom d'utilisateur</label>
                                {{ form_widget(form.username) }}
                                {{ form_errors(form.username) }}
                                <div id="username-bl-feedback" class="invalid-feedback d-block" style="display:none!important;color:#e74c3c;font-size:.85rem;margin-top:.25rem;"></div>
                            </div>
                            <div class="form-grp">
                                <label for="{{ form.email.vars.id }}">Email</label>
                                {{ form_widget(form.email) }}
                                {{ form_errors(form.email) }}
                                <div id="email-bl-feedback" class="invalid-feedback d-block" style="display:none!important;color:#e74c3c;font-size:.85rem;margin-top:.25rem;"></div>
                            </div>
                            <div class="form-grp">
                                <label for="{{ form.plainPassword.first.vars.id }}">Mot de passe</label>
                                {{ form_widget(form.plainPassword.first, {'attr': {'placeholder': 'Mot de passe (10 caractères min.)'}}) }}
                                {{ form_errors(form.plainPassword.first) }}
                            </div>
                            <div class="form-grp">
                                <label for="{{ form.plainPassword.second.vars.id }}">Confirmer le mot de passe</label>
                                {{ form_widget(form.plainPassword.second) }}
                                {{ form_errors(form.plainPassword.second) }}
                                {{ form_errors(form.plainPassword) }}
                            </div>
                            <div class="form-grp" style="display:flex;align-items:flex-start;gap:10px;margin:16px 0;">
                                <input type="checkbox" id="accept_terms" name="accept_terms" value="1" required
                                       style="margin-top:3px;width:18px;height:18px;flex-shrink:0;cursor:pointer;accent-color:#45f882;">
                                <label for="accept_terms" style="margin:0;font-size:14px;color:rgba(255,255,255,0.8);line-height:1.5;cursor:pointer;">
                                    J'ai lu et j'accepte le <a href="{{ path('page_reglement') }}" target="_blank" rel="noopener" style="color:#45f882;text-decoration:underline;">règlement de Nexarena</a> <span style="color:#e74a3b;">*</span>
                                </label>
                            </div>
                            <button type="submit" id="register-submit" class="btn btn-two arrow-btn">S'inscrire</button>
                        {{ form_end(form) }}

                        <script>
                        (function() {
                            const blCheckUrl = '{{ path('api_blacklist_check') }}';
                            const usernameInput = document.getElementById('{{ form.username.vars.id }}');
                            const emailInput    = document.getElementById('{{ form.email.vars.id }}');
                            const usernameFb    = document.getElementById('username-bl-feedback');
                            const emailFb       = document.getElementById('email-bl-feedback');
                            const submitBtn     = document.getElementById('register-submit');

                            let usernameOk = true;
                            let emailOk    = true;

                            function updateSubmit() {
                                submitBtn.disabled = !usernameOk || !emailOk;
                            }

                            function showError(el, msg) {
                                el.textContent = msg;
                                el.style.setProperty('display', 'block', 'important');
                            }

                            function clearError(el) {
                                el.textContent = '';
                                el.style.setProperty('display', 'none', 'important');
                            }

                            async function checkBlacklist(type, value) {
                                if (!value) return true;
                                try {
                                    const res = await fetch(blCheckUrl + '?type=' + encodeURIComponent(type) + '&value=' + encodeURIComponent(value));
                                    if (!res.ok) return true;
                                    const data = await res.json();
                                    return data;
                                } catch (e) {
                                    return { allowed: true };
                                }
                            }

                            if (usernameInput) {
                                usernameInput.addEventListener('blur', async () => {
                                    const val = usernameInput.value.trim();
                                    if (!val) return;
                                    const data = await checkBlacklist('username', val);
                                    if (!data.allowed) {
                                        showError(usernameFb, data.message);
                                        usernameOk = false;
                                    } else {
                                        clearError(usernameFb);
                                        usernameOk = true;
                                    }
                                    updateSubmit();
                                });
                                usernameInput.addEventListener('input', () => {
                                    if (!usernameOk) { clearError(usernameFb); usernameOk = true; updateSubmit(); }
                                });
                            }

                            if (emailInput) {
                                emailInput.addEventListener('blur', async () => {
                                    const val = emailInput.value.trim();
                                    if (!val) return;
                                    const data = await checkBlacklist('email_domain', val);
                                    if (!data.allowed) {
                                        showError(emailFb, data.message);
                                        emailOk = false;
                                    } else {
                                        clearError(emailFb);
                                        emailOk = true;
                                    }
                                    updateSubmit();
                                });
                                emailInput.addEventListener('input', () => {
                                    if (!emailOk) { clearError(emailFb); emailOk = true; updateSubmit(); }
                                });
                            }
                        })();
                        </script>

                        <div class="account__switch">
                            <p>Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
