<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Vérification 2FA - Nexarena</title>
    <link rel="icon" type="image/png" href="{{ asset('assets/img/logo/new_logo_hd.png') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/fontawesome-all.min.css') }}">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            background: #0b0b14;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            position: relative;
            overflow: hidden;
        }

        /* Background glow effects */
        body::before {
            content: '';
            position: fixed;
            top: -200px;
            left: 50%;
            transform: translateX(-50%);
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(69, 248, 130, 0.08) 0%, transparent 70%);
            pointer-events: none;
        }
        body::after {
            content: '';
            position: fixed;
            bottom: -200px;
            right: -100px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(69, 248, 130, 0.05) 0%, transparent 70%);
            pointer-events: none;
        }

        /* Logo bar */
        .tfa-logo {
            position: fixed;
            top: 24px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
        }
        .tfa-logo img {
            height: 36px;
            width: auto;
        }

        /* Card */
        .tfa-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 20px;
            padding: 48px 40px;
            width: 100%;
            max-width: 440px;
            backdrop-filter: blur(12px);
            position: relative;
            z-index: 1;
        }

        /* Icon */
        .tfa-icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: rgba(69, 248, 130, 0.1);
            border: 1px solid rgba(69, 248, 130, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 28px;
            color: #45f882;
        }

        /* Title */
        .tfa-title {
            color: #fff;
            font-size: 22px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 8px;
        }
        .tfa-subtitle {
            color: rgba(255, 255, 255, 0.45);
            font-size: 14px;
            text-align: center;
            margin-bottom: 32px;
            line-height: 1.6;
        }

        /* Error */
        .tfa-error {
            background: rgba(255, 71, 87, 0.1);
            border: 1px solid rgba(255, 71, 87, 0.3);
            border-radius: 10px;
            color: #ff6b6b;
            padding: 12px 16px;
            font-size: 14px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Input */
        .tfa-label {
            display: block;
            color: rgba(255, 255, 255, 0.6);
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .tfa-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 16px;
            color: #fff;
            font-size: 28px;
            font-weight: 700;
            text-align: center;
            letter-spacing: 10px;
            outline: none;
            transition: border-color 0.2s, background 0.2s;
            margin-bottom: 24px;
        }
        .tfa-input:focus {
            border-color: #45f882;
            background: rgba(69, 248, 130, 0.05);
        }
        .tfa-input::placeholder {
            color: rgba(255, 255, 255, 0.15);
            letter-spacing: 8px;
        }

        /* Submit button */
        .tfa-btn {
            width: 100%;
            padding: 15px;
            background: #45f882;
            border: none;
            border-radius: 12px;
            color: #0b0b14;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.1s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .tfa-btn:hover { opacity: 0.9; }
        .tfa-btn:active { transform: scale(0.98); }

        /* Footer link */
        .tfa-footer {
            text-align: center;
            margin-top: 24px;
        }
        .tfa-footer a {
            color: rgba(255, 255, 255, 0.35);
            font-size: 13px;
            text-decoration: none;
            transition: color 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .tfa-footer a:hover { color: rgba(255, 71, 87, 0.8); }

        /* Timer hint */
        .tfa-hint {
            text-align: center;
            color: rgba(255, 255, 255, 0.25);
            font-size: 12px;
            margin-top: 16px;
        }

        @media (max-width: 480px) {
            .tfa-card { padding: 32px 24px; margin: 16px; }
        }
    </style>
</head>
<body>

    <a href="{{ path('app_home') }}" class="tfa-logo">
        <img src="{{ asset('assets/img/logo/new_logo_hd.png') }}" alt="Nexarena">
    </a>

    <div class="tfa-card">
        <div class="tfa-icon">
            <i class="fas fa-shield-alt"></i>
        </div>

        <h1 class="tfa-title">Vérification en 2 étapes</h1>
        <p class="tfa-subtitle">
            Entrez le code à 6 chiffres généré par<br>votre application d'authentification.
        </p>

        {% if authenticationError %}
            <div class="tfa-error">
                <i class="fas fa-exclamation-circle"></i>
                {{ authenticationError.messageKey|default('')|trans(authenticationError.messageData|default([]), 'SchebTwoFactorBundle') }}
            </div>
        {% endif %}

        <form action="{{ path('2fa_login_check') }}" method="post">
            <input type="hidden" name="_trusted" value="0">

            <label class="tfa-label" for="totp-code">Code TOTP</label>
            <input
                id="totp-code"
                type="text"
                name="{{ authCodeParameterName }}"
                class="tfa-input"
                autocomplete="one-time-code"
                autofocus
                placeholder="000000"
                maxlength="6"
                pattern="[0-9]{6}"
                inputmode="numeric"
            >

            <button type="submit" class="tfa-btn">
                <i class="fas fa-check-circle"></i>
                Vérifier le code
            </button>
        </form>

        <p class="tfa-hint">
            <i class="fas fa-clock"></i> Le code se renouvelle toutes les 30 secondes
        </p>

        <div class="tfa-footer">
            <a href="{{ path('app_logout') }}">
                <i class="fas fa-sign-out-alt"></i>
                Annuler et se déconnecter
            </a>
        </div>
    </div>

</body>
</html>
