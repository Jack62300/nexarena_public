{% extends 'base.html.twig' %}

{% block title %}Verification 2FA - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block body %}

    {# breadcrumb-area #}
    <section class="breadcrumb-area" data-background="{{ asset('assets/img/bg/breadcrumb_bg01.jpg') }}">
        <div class="container">
            <div class="breadcrumb__wrapper">
                <div class="row">
                    <div class="col-xl-6 col-lg-7">
                        <div class="breadcrumb__content">
                            <h2 class="title">Verification 2FA</h2>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Verification 2FA</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                    <div class="col-xl-6 col-lg-5 position-relative d-none d-lg-block">
                        <div class="breadcrumb__img">
                            <img src="{{ asset('assets/img/others/breadcrumb_img02.png') }}" alt="img">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="signup__area team-bg section-pt-120 section-pb-120" data-background="{{ asset('assets/img/bg/team_bg.jpg') }}">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-5 col-lg-6">
                    <div class="singUp-wrap">
                        <h2 class="title" style="font-size:24px;"><i class="fas fa-shield-alt" style="color:#45f882;margin-right:10px;"></i>Authentification a deux facteurs</h2>
                        <p>Entrez le code a 6 chiffres genere par votre application d'authentification.</p>

                        {% if authenticationError %}
                            <div class="alert alert-danger">{{ authenticationError.messageKey|trans(authenticationError.messageData, 'SchebTwoFactorBundle') }}</div>
                        {% endif %}

                        <form action="{{ path('2fa_login_check') }}" method="post" class="account__form">
                            <div class="form-grp">
                                <label for="totp-code">Code TOTP</label>
                                <input id="totp-code" type="text" name="{{ authCodeParameterName }}" autocomplete="one-time-code" autofocus placeholder="000000" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" style="text-align:center;font-size:24px;letter-spacing:8px;font-weight:700;">
                            </div>
                            <input type="hidden" name="_trusted" value="0">
                            <button type="submit" class="btn btn-two arrow-btn" style="width:100%;">Verifier</button>
                        </form>

                        <div class="account__switch" style="margin-top:20px;">
                            <p><a href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt"></i> Annuler et se deconnecter</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
