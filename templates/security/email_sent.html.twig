{% extends 'base.html.twig' %}

{% block title %}Email envoyé — {{ setting('site_name') }}{% endblock %}

{% block body %}
<section class="breadcrumb-area" data-background="{{ asset('assets/img/bg/breadcrumb_bg01.jpg') }}">
    <div class="container">
        <div class="breadcrumb__wrapper">
            <div class="row">
                <div class="col-xl-6 col-lg-7">
                    <div class="breadcrumb__content">
                        <h2 class="title">Vérification Email</h2>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                <li class="breadcrumb-item active">Email envoyé</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="verify-email-section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="verify-card text-center">
                    <div class="verify-icon">
                        <i class="fas fa-envelope-open-text"></i>
                    </div>
                    <h2>Vérifiez votre boîte mail</h2>
                    <p class="verify-lead">Un email de confirmation a été envoyé à votre adresse. Cliquez sur le lien dans l'email pour activer votre compte.</p>

                    <div class="verify-steps">
                        <div class="verify-step">
                            <span class="step-num">1</span>
                            <span>Ouvrez votre boîte mail</span>
                        </div>
                        <div class="verify-step">
                            <span class="step-num">2</span>
                            <span>Cherchez un email de <strong>{{ setting('site_name') }}</strong></span>
                        </div>
                        <div class="verify-step">
                            <span class="step-num">3</span>
                            <span>Cliquez sur le bouton <strong>« Vérifier mon email »</strong></span>
                        </div>
                    </div>

                    <div class="verify-notice">
                        <i class="fas fa-info-circle"></i>
                        Vérifiez aussi vos spams si vous ne trouvez pas l'email. Le lien est valable <strong>24 heures</strong>.
                    </div>

                    {% for type, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} mt-3">{{ message }}</div>
                        {% endfor %}
                    {% endfor %}

                    <div class="verify-resend mt-4">
                        <p class="text-muted small mb-2">Vous n'avez pas reçu l'email ?</p>
                        <form action="{{ path('app_resend_verification_email') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('resend_verification') }}">
                            <div class="input-group">
                                <input type="email" name="email" class="form-control" placeholder="Votre adresse email" required>
                                <button type="submit" class="btn btn-outline-primary">Renvoyer</button>
                            </div>
                        </form>
                    </div>

                    <a href="{{ path('app_login') }}" class="btn btn-link mt-3">
                        <i class="fas fa-arrow-left me-1"></i> Retour à la connexion
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.verify-email-section { min-height: 70vh; display: flex; align-items: center; }
.verify-card {
    background: #0d1b2d;
    border: 1px solid rgba(69,248,130,0.15);
    border-radius: 20px;
    padding: 48px 40px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}
.verify-icon {
    width: 90px; height: 90px;
    background: rgba(69,248,130,0.1);
    border: 2px solid rgba(69,248,130,0.3);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 28px;
}
.verify-icon i { font-size: 36px; color: #45f882; }
.verify-card h2 { font-size: 26px; font-weight: 700; color: #fff; margin-bottom: 14px; }
.verify-lead { color: rgba(200,214,232,0.7); font-size: 15px; line-height: 1.7; margin-bottom: 32px; }
.verify-steps { text-align: left; margin-bottom: 28px; display: flex; flex-direction: column; gap: 12px; }
.verify-step {
    display: flex; align-items: center; gap: 14px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 14px; color: rgba(200,214,232,0.8);
}
.step-num {
    width: 28px; height: 28px;
    background: rgba(69,248,130,0.15);
    border: 1px solid rgba(69,248,130,0.3);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; color: #45f882;
    flex-shrink: 0;
}
.verify-notice {
    background: rgba(69,248,130,0.06);
    border: 1px solid rgba(69,248,130,0.15);
    border-radius: 10px;
    padding: 14px 18px;
    font-size: 13px; color: rgba(200,214,232,0.65);
    line-height: 1.6;
}
.verify-notice i { color: #45f882; margin-right: 6px; }
.verify-resend .input-group .form-control {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.1);
    color: #fff;
    border-radius: 8px 0 0 8px;
}
.verify-resend .input-group .form-control:focus { border-color: rgba(69,248,130,0.4); box-shadow: none; }
.verify-resend .btn-outline-primary {
    border-color: rgba(69,248,130,0.4);
    color: #45f882;
    border-radius: 0 8px 8px 0;
}
.verify-resend .btn-outline-primary:hover { background: rgba(69,248,130,0.1); }
</style>
{% endblock %}
