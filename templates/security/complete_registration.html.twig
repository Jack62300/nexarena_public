{% extends 'base.html.twig' %}

{% block title %}Nexarena - Finaliser l'inscription{% endblock %}

{% block body %}

    {# breadcrumb-area #}
    <section class="breadcrumb-area" data-background="{{ asset('assets/img/bg/breadcrumb_bg01.jpg') }}">
        <div class="container">
            <div class="breadcrumb__wrapper">
                <div class="row">
                    <div class="col-xl-6 col-lg-7">
                        <div class="breadcrumb__content">
                            <h2 class="title">Finaliser l'inscription</h2>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Finaliser l'inscription</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                    <div class="col-xl-6 col-lg-5 position-relative d-none d-lg-block">
                        <div class="breadcrumb__img">
                            <img src="{{ asset('assets/img/others/breadcrumb_img02.png') }}" alt="img">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# complete-registration-area #}
    <section class="signup__area team-bg section-pt-120 section-pb-120" data-background="{{ asset('assets/img/bg/team_bg.jpg') }}">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-6 col-lg-8">
                    <div class="singUp-wrap">
                        <h2 class="title">Derniere etape !</h2>

                        <div class="d-flex align-items-center gap-3 mb-3">
                            {% if pending.provider == 'steam' %}
                                <i class="fab fa-steam" style="font-size:28px;color:#fff;"></i>
                            {% elseif pending.provider == 'discord' %}
                                <i class="fab fa-discord" style="font-size:28px;color:#5865F2;"></i>
                            {% elseif pending.provider == 'twitch' %}
                                <i class="fab fa-twitch" style="font-size:28px;color:#9146FF;"></i>
                            {% elseif pending.provider == 'google' %}
                                <i class="fab fa-google" style="font-size:28px;color:#EA4335;"></i>
                            {% endif %}
                            <span style="color:#fff;font-size:16px;">
                                Connecte via <strong>{{ pending.provider|capitalize }}</strong> en tant que <strong>{{ pending.username }}</strong>
                            </span>
                        </div>

                        {% for message in app.flashes('error') %}
                            <div class="alert alert-danger">{{ message }}</div>
                        {% endfor %}

                        {# Referral notice #}
                        {% if pending.referral_code is defined and pending.referral_code %}
                            <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:rgba(69,248,130,0.06);border:1px solid rgba(69,248,130,0.2);border-radius:10px;margin-bottom:18px;">
                                <i class="fas fa-user-friends" style="color:#45f882;font-size:16px;"></i>
                                <span style="font-size:14px;color:#c9d1d9;">Vous avez ete invite par un membre de Nexarena !</span>
                            </div>
                        {% endif %}

                        <form action="{{ path('app_oauth_complete_registration') }}" method="post" class="account__form">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('oauth_complete') }}">

                            {% if pending.email is not defined or pending.email is empty %}
                                {# Email non fourni par le provider (ex: Steam) #}
                                <p class="mb-4" style="color:rgba(255,255,255,0.7);font-size:14px;">
                                    Votre provider ne nous a pas transmis votre adresse email. Veuillez la saisir pour finaliser votre inscription.
                                    Si vous avez déjà un compte Nexarena avec cette adresse, vos comptes seront automatiquement liés.
                                </p>
                                <div class="form-grp">
                                    <label for="email">Adresse email</label>
                                    <input type="email" id="email" name="email" value="{{ last_email }}" placeholder="votre@email.com" required autofocus>
                                </div>
                            {% else %}
                                <p class="mb-4" style="color:rgba(255,255,255,0.7);font-size:14px;">
                                    Pour finaliser votre inscription, définissez un mot de passe et acceptez le règlement de Nexarena.
                                </p>
                            {% endif %}

                            <div class="form-grp">
                                <label for="password">Mot de passe</label>
                                <input type="password" id="password" name="password" placeholder="Minimum 10 caractères" minlength="10" required>
                            </div>
                            <div class="form-grp">
                                <label for="password_confirm">Confirmer le mot de passe</label>
                                <input type="password" id="password_confirm" name="password_confirm" placeholder="Confirmez votre mot de passe" minlength="10" required>
                            </div>

                            <div style="display:flex;align-items:flex-start;gap:10px;margin:16px 0;">
                                <input type="checkbox" id="accept_terms" name="accept_terms" value="1" required
                                       style="margin-top:3px;width:18px;height:18px;flex-shrink:0;cursor:pointer;accent-color:#45f882;">
                                <label for="accept_terms" style="margin:0;font-size:14px;color:rgba(255,255,255,0.8);line-height:1.5;cursor:pointer;">
                                    J'ai lu et j'accepte le <a href="{{ path('page_reglement') }}" target="_blank" rel="noopener" style="color:#45f882;text-decoration:underline;">règlement de Nexarena</a> <span style="color:#e74a3b;">*</span>
                                </label>
                            </div>
                            <button type="submit" class="btn btn-two arrow-btn">Finaliser l'inscription</button>
                        </form>

                        <div class="account__switch mt-3">
                            <p><a href="{{ path('app_login') }}">Retour a la connexion</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
