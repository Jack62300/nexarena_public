{% extends 'base.html.twig' %}

{% block title %}Erreur 503 - Maintenance en cours{% endblock %}
{% block robots %}<meta name="robots" content="noindex, nofollow">{% endblock %}

{% block body %}
<section style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 60px 20px;">
    <div style="text-align: center; max-width: 560px;">
        <div style="font-size: 120px; color: #a371f7; margin-bottom: 10px; line-height: 1; text-shadow: 0 0 40px rgba(163,113,247,0.3);">
            <i class="fas fa-tools"></i>
        </div>
        <h1 style="font-size: 96px; font-weight: 800; color: #a371f7; margin: 0 0 10px; line-height: 1; text-shadow: 0 0 30px rgba(163,113,247,0.2);">503</h1>
        <h2 style="font-size: 28px; font-weight: 700; color: #e6edf3; margin: 0 0 16px; font-family: 'Barlow', sans-serif;">Maintenance en cours</h2>
        <p style="font-size: 16px; color: #8b949e; margin: 0 0 40px; line-height: 1.6;">
            Le site est temporairement indisponible pour maintenance.<br>
            Nous serons de retour tres bientot.
        </p>
        <a href="{{ path('app_home') }}" style="display: inline-flex; align-items: center; gap: 10px; padding: 14px 32px; background: #45f882; color: #0f161b; font-weight: 700; font-size: 15px; border-radius: 8px; text-decoration: none; transition: all 0.2s; box-shadow: 0 0 20px rgba(69,248,130,0.3);">
            <i class="fas fa-home"></i> Retour a l'accueil
        </a>
    </div>
</section>
{% endblock %}
