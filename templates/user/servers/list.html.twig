{% extends 'base.html.twig' %}

{% block title %}Mes serveurs - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<style>
    /* ===== PAGE LAYOUT ===== */
    .my-servers {
        position: relative;
        min-height: 80vh;
    }
    .my-servers__bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, #0d1b2a 0%, #0a1018 40%);
        z-index: 0;
    }
    .my-servers__bg-glow {
        position: absolute;
        width: 700px;
        height: 700px;
        border-radius: 50%;
        filter: blur(150px);
        opacity: 0.07;
        top: -200px;
        left: 50%;
        transform: translateX(-50%);
        background: #45f882;
        pointer-events: none;
    }
    .my-servers__inner {
        position: relative;
        z-index: 1;
        padding: 140px 0 80px;
    }

    /* ===== HEADER ===== */
    .my-servers__head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }
    .my-servers__title {
        font-size: 30px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.3px;
    }
    .my-servers__title span {
        background: linear-gradient(135deg, #45f882, #1cc88a);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .my-servers__count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 28px;
        height: 28px;
        padding: 0 8px;
        background: rgba(69,248,130,0.12);
        border: 1px solid rgba(69,248,130,0.2);
        border-radius: 14px;
        font-size: 13px;
        font-weight: 700;
        color: #45f882;
        margin-left: 12px;
        vertical-align: middle;
    }
    .btn-add-server {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        background: linear-gradient(135deg, #45f882 0%, #33d96e 100%);
        color: #0a1018;
        font-size: 14px;
        font-weight: 700;
        border-radius: 10px;
        border: none;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 20px rgba(69,248,130,0.25);
        font-family: var(--tg-heading-font-family);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .btn-add-server:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(69,248,130,0.35);
        color: #0a1018;
    }
    .btn-add-server i { font-size: 13px; }

    /* ===== STATS BAR ===== */
    .my-servers__stats {
        display: flex;
        gap: 16px;
        margin-bottom: 35px;
        flex-wrap: wrap;
    }
    .stat-chip {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 8px;
        font-size: 13px;
        color: #8b949e;
    }
    .stat-chip__value {
        font-weight: 700;
        color: #fff;
    }
    .stat-chip__icon {
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        font-size: 12px;
    }
    .stat-chip__icon--votes { background: rgba(69,248,130,0.12); color: #45f882; }
    .stat-chip__icon--total { background: rgba(54,185,204,0.12); color: #36b9cc; }
    .stat-chip__icon--active { background: rgba(28,200,138,0.12); color: #1cc88a; }
    .stat-chip__icon--pending { background: rgba(246,194,62,0.12); color: #f6c23e; }

    /* ===== SERVER CARD ===== */
    .sv-card {
        position: relative;
        background: #111c2a;
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 14px;
        margin-bottom: 20px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sv-card:hover {
        border-color: rgba(69,248,130,0.15);
        transform: translateY(-3px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.3), 0 0 0 1px rgba(69,248,130,0.08);
    }

    /* Banner top strip */
    .sv-card__banner {
        height: 90px;
        position: relative;
        overflow: hidden;
    }
    .sv-card__banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .sv-card__banner--default {
        background: linear-gradient(135deg, #162231 0%, #1a3a28 50%, #162231 100%);
    }
    .sv-card__banner::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 50px;
        background: linear-gradient(180deg, transparent, #111c2a);
    }

    /* Card body */
    .sv-card__body {
        padding: 0 24px 24px;
        position: relative;
    }

    /* Icon + title row */
    .sv-card__top {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-top: -28px;
        position: relative;
        z-index: 2;
        margin-bottom: 16px;
    }
    .sv-card__icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: linear-gradient(135deg, #45f882, #33d96e);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 6px 20px rgba(69,248,130,0.3);
        border: 3px solid #111c2a;
    }
    .sv-card__heading {
        flex: 1;
        min-width: 0;
        padding-top: 8px;
    }
    .sv-card__name {
        font-size: 18px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 6px;
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .sv-card__name a {
        color: inherit;
        text-decoration: none;
        transition: color 0.2s;
    }
    .sv-card__name a:hover { color: #45f882; }
    .sv-card__tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }
    .sv-card__tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.3px;
    }
    .sv-card__tag--approved { background: rgba(28,200,138,0.12); color: #1cc88a; }
    .sv-card__tag--pending { background: rgba(246,194,62,0.12); color: #f6c23e; }
    .sv-card__tag--inactive { background: rgba(139,148,158,0.12); color: #8b949e; }
    .sv-card__tag--active { background: rgba(54,185,204,0.10); color: #36b9cc; }
    .sv-card__tag--cat { background: rgba(69,248,130,0.08); color: rgba(255,255,255,0.5); }
    .sv-card__tag i { font-size: 9px; }

    /* Description */
    .sv-card__desc {
        color: #6e7a88;
        font-size: 13px;
        line-height: 1.6;
        margin-bottom: 18px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Stats row */
    .sv-card__stats {
        display: flex;
        gap: 4px;
        margin-bottom: 20px;
    }
    .sv-card__stat {
        flex: 1;
        text-align: center;
        padding: 12px 8px;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.04);
        border-radius: 10px;
        transition: background 0.2s;
    }
    .sv-card__stat:hover {
        background: rgba(255,255,255,0.04);
    }
    .sv-card__stat-value {
        display: block;
        font-size: 22px;
        font-weight: 800;
        color: #fff;
        line-height: 1;
        margin-bottom: 4px;
        font-family: var(--tg-heading-font-family);
    }
    .sv-card__stat-value--green { color: #45f882; }
    .sv-card__stat-label {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #5a6472;
        font-weight: 600;
    }

    /* Actions row */
    .sv-card__actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .sv-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 16px;
        border-radius: 8px;
        border: none;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
        letter-spacing: 0.3px;
        text-transform: uppercase;
        font-family: var(--tg-heading-font-family);
    }
    .sv-btn i { font-size: 11px; }
    .sv-btn--manage {
        background: linear-gradient(135deg, #45f882, #33d96e);
        color: #0a1018;
        box-shadow: 0 2px 10px rgba(69,248,130,0.2);
    }
    .sv-btn--manage:hover {
        box-shadow: 0 4px 18px rgba(69,248,130,0.35);
        transform: translateY(-1px);
        color: #0a1018;
    }
    .sv-btn--edit {
        background: rgba(255,255,255,0.06);
        color: #c9d1d9;
        border: 1px solid rgba(255,255,255,0.08);
    }
    .sv-btn--edit:hover {
        background: rgba(255,255,255,0.1);
        color: #fff;
        border-color: rgba(255,255,255,0.15);
    }
    .sv-btn--view {
        background: rgba(54,185,204,0.1);
        color: #36b9cc;
        border: 1px solid rgba(54,185,204,0.15);
    }
    .sv-btn--view:hover {
        background: rgba(54,185,204,0.18);
        color: #36b9cc;
    }
    .sv-btn--delete {
        background: transparent;
        color: #5a6472;
        border: 1px solid rgba(255,255,255,0.06);
        margin-left: auto;
    }
    .sv-btn--delete:hover {
        color: #e74a3b;
        background: rgba(231,74,59,0.08);
        border-color: rgba(231,74,59,0.2);
    }

    /* ===== EMPTY STATE ===== */
    .empty-state {
        text-align: center;
        padding: 80px 30px;
        background: #111c2a;
        border: 1px dashed rgba(255,255,255,0.08);
        border-radius: 16px;
    }
    .empty-state__icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(69,248,130,0.06);
        border: 1px solid rgba(69,248,130,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
    }
    .empty-state__icon i {
        font-size: 30px;
        color: rgba(69,248,130,0.4);
    }
    .empty-state h3 {
        color: #fff;
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 10px;
    }
    .empty-state p {
        color: #5a6472;
        font-size: 15px;
        margin-bottom: 30px;
        max-width: 380px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.6;
    }

    /* ===== FLASH ===== */
    .sv-flash {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        animation: svFlashIn 0.4s ease;
    }
    .sv-flash--success {
        background: rgba(69,248,130,0.08);
        border: 1px solid rgba(69,248,130,0.15);
        color: #45f882;
    }
    .sv-flash--error {
        background: rgba(231,74,59,0.08);
        border: 1px solid rgba(231,74,59,0.15);
        color: #e74a3b;
    }
    .sv-flash__close {
        margin-left: auto;
        background: none;
        border: none;
        color: inherit;
        opacity: 0.5;
        cursor: pointer;
        font-size: 16px;
        padding: 0;
        line-height: 1;
    }
    .sv-flash__close:hover { opacity: 1; }
    @keyframes svFlashIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 767px) {
        .my-servers__head {
            flex-direction: column;
            gap: 16px;
            align-items: flex-start;
        }
        .my-servers__stats {
            flex-direction: column;
            gap: 8px;
        }
        .sv-card__stats {
            flex-wrap: wrap;
        }
        .sv-card__stat {
            flex: 1 1 calc(50% - 2px);
            min-width: 0;
        }
        .sv-card__actions {
            flex-direction: column;
        }
        .sv-btn { justify-content: center; }
        .sv-btn--delete { margin-left: 0; }
        .my-servers__title { font-size: 24px; }
    }
</style>
{% endblock %}

{% block body %}
<section class="my-servers">
    <div class="my-servers__bg">
        <div class="my-servers__bg-glow"></div>
    </div>
    <div class="my-servers__inner">
        <div class="container">

            {# ── Flash Messages ── #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="sv-flash sv-flash--{{ type == 'success' ? 'success' : 'error' }}">
                        <i class="fas fa-{{ type == 'success' ? 'check-circle' : 'exclamation-triangle' }}"></i>
                        <span>{{ message }}</span>
                        <button class="sv-flash__close" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {# ── Header ── #}
            <div class="my-servers__head">
                <h2 class="my-servers__title">
                    Mes <span>serveurs</span>
                    {% if servers|length > 0 %}
                        <span class="my-servers__count">{{ servers|length }}</span>
                    {% endif %}
                </h2>
                <a href="{{ path('user_servers_new') }}" class="btn-add-server">
                    <i class="fas fa-plus"></i> Ajouter un serveur
                </a>
            </div>

            {# ── Stats Bar ── #}
            {% if servers|length > 0 %}
                {% set totalMonthly = 0 %}
                {% set totalAll = 0 %}
                {% set activeCount = 0 %}
                {% set pendingCount = 0 %}
                {% for s in servers %}
                    {% set totalMonthly = totalMonthly + s.monthlyVotes %}
                    {% set totalAll = totalAll + s.totalVotes %}
                    {% if s.isActive and s.isApproved %}{% set activeCount = activeCount + 1 %}{% endif %}
                    {% if not s.isApproved %}{% set pendingCount = pendingCount + 1 %}{% endif %}
                {% endfor %}
                <div class="my-servers__stats">
                    <div class="stat-chip">
                        <span class="stat-chip__icon stat-chip__icon--votes"><i class="fas fa-bolt"></i></span>
                        <span class="stat-chip__value">{{ totalMonthly }}</span> votes ce mois
                    </div>
                    <div class="stat-chip">
                        <span class="stat-chip__icon stat-chip__icon--total"><i class="fas fa-chart-bar"></i></span>
                        <span class="stat-chip__value">{{ totalAll }}</span> votes au total
                    </div>
                    <div class="stat-chip">
                        <span class="stat-chip__icon stat-chip__icon--active"><i class="fas fa-signal"></i></span>
                        <span class="stat-chip__value">{{ activeCount }}</span> en ligne
                    </div>
                    {% if pendingCount > 0 %}
                        <div class="stat-chip">
                            <span class="stat-chip__icon stat-chip__icon--pending"><i class="fas fa-clock"></i></span>
                            <span class="stat-chip__value">{{ pendingCount }}</span> en attente
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            {# ── Server Cards ── #}
            {% for server in servers %}
                <div class="sv-card">
                    {# Banner strip #}
                    <div class="sv-card__banner {% if not server.banner %}sv-card__banner--default{% endif %}">
                        {% if server.banner %}
                            <img src="{{ asset('uploads/servers/banners/' ~ server.banner) }}" alt="">
                        {% endif %}
                    </div>

                    <div class="sv-card__body">
                        {# Icon + Title #}
                        <div class="sv-card__top">
                            <div class="sv-card__icon">
                                {% if server.category and server.category.icon %}
                                    <i class="{{ server.category.icon }}"></i>
                                {% else %}
                                    <i class="fas fa-server"></i>
                                {% endif %}
                            </div>
                            <div class="sv-card__heading">
                                <h3 class="sv-card__name">
                                    {% if server.isApproved and server.isActive %}
                                        <a href="{{ path('server_show', {slug: server.slug}) }}">{{ server.name }}</a>
                                    {% else %}
                                        {{ server.name }}
                                    {% endif %}
                                </h3>
                                <div class="sv-card__tags">
                                    {% if server.isApproved %}
                                        <span class="sv-card__tag sv-card__tag--approved"><i class="fas fa-check"></i> Approuve</span>
                                    {% else %}
                                        <span class="sv-card__tag sv-card__tag--pending"><i class="fas fa-clock"></i> En attente</span>
                                    {% endif %}
                                    {% if server.isActive %}
                                        <span class="sv-card__tag sv-card__tag--active"><i class="fas fa-circle"></i> Actif</span>
                                    {% else %}
                                        <span class="sv-card__tag sv-card__tag--inactive"><i class="fas fa-circle"></i> Inactif</span>
                                    {% endif %}
                                    {% if server.category %}
                                        <span class="sv-card__tag sv-card__tag--cat">{{ server.category.name }}{% if server.gameCategory %} / {{ server.gameCategory.name }}{% endif %}</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        {# Description #}
                        {% if server.shortDescription %}
                            <p class="sv-card__desc">{{ server.shortDescription }}</p>
                        {% endif %}

                        {# Stats #}
                        <div class="sv-card__stats">
                            <div class="sv-card__stat">
                                <span class="sv-card__stat-value sv-card__stat-value--green">{{ server.monthlyVotes }}</span>
                                <span class="sv-card__stat-label">Votes / mois</span>
                            </div>
                            <div class="sv-card__stat">
                                <span class="sv-card__stat-value">{{ server.totalVotes }}</span>
                                <span class="sv-card__stat-label">Votes total</span>
                            </div>
                            {% if server.ip and server.port %}
                                <div class="sv-card__stat" id="user-players-{{ server.id }}">
                                    <span class="sv-card__stat-value" style="color:#8b949e;">...</span>
                                    <span class="sv-card__stat-label">Joueurs</span>
                                </div>
                            {% else %}
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value">{{ server.slots > 0 ? server.slots : '-' }}</span>
                                    <span class="sv-card__stat-label">Slots</span>
                                </div>
                            {% endif %}
                            <div class="sv-card__stat">
                                <span class="sv-card__stat-value">{{ server.createdAt ? server.createdAt|date('d/m/y') : '-' }}</span>
                                <span class="sv-card__stat-label">Cree le</span>
                            </div>
                        </div>

                        {# Actions #}
                        <div class="sv-card__actions">
                            <a href="{{ path('user_servers_manage', {id: server.id}) }}" class="sv-btn sv-btn--manage">
                                <i class="fas fa-cog"></i> Gestion
                            </a>
                            <a href="{{ path('user_servers_edit', {id: server.id}) }}" class="sv-btn sv-btn--edit">
                                <i class="fas fa-pen"></i> Modifier
                            </a>
                            {% if server.isApproved and server.isActive %}
                                <a href="{{ path('server_show', {slug: server.slug}) }}" class="sv-btn sv-btn--view">
                                    <i class="fas fa-external-link-alt"></i> Voir
                                </a>
                            {% endif %}
                            <form method="post" action="{{ path('user_servers_delete', {id: server.id}) }}" onsubmit="return confirm('Supprimer definitivement ce serveur ? Cette action est irreversible.');" style="display:inline;margin-left:auto;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_server_' ~ server.id) }}">
                                <button type="submit" class="sv-btn sv-btn--delete">
                                    <i class="fas fa-trash-alt"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% else %}
                {# Empty State #}
                <div class="empty-state">
                    <div class="empty-state__icon">
                        <i class="fas fa-server"></i>
                    </div>
                    <h3>Aucun serveur</h3>
                    <p>Vous n'avez pas encore ajoute de serveur. Ajoutez votre premier serveur et commencez a recevoir des votes !</p>
                    <a href="{{ path('user_servers_new') }}" class="btn-add-server">
                        <i class="fas fa-plus"></i> Ajouter un serveur
                    </a>
                </div>
            {% endfor %}

            {# ── Shared Servers ── #}
            {% if collaborations|default([])|length > 0 %}
            <div style="margin-top:50px;">
                <h2 class="my-servers__title">
                    Serveurs <span>partages</span>
                    <span class="my-servers__count">{{ collaborations|length }}</span>
                </h2>
                <p style="color:#5a6472;font-size:13px;margin-bottom:25px;">Serveurs sur lesquels vous etes collaborateur.</p>

                {% for collab in collaborations %}
                    {% set server = collab.server %}
                    <div class="sv-card">
                        {# Banner strip #}
                        <div class="sv-card__banner {% if not server.banner %}sv-card__banner--default{% endif %}">
                            {% if server.banner %}
                                <img src="{{ asset('uploads/servers/banners/' ~ server.banner) }}" alt="">
                            {% endif %}
                        </div>

                        <div class="sv-card__body">
                            {# Icon + Title #}
                            <div class="sv-card__top">
                                <div class="sv-card__icon" style="background:linear-gradient(135deg, #36b9cc, #2a93a3);">
                                    {% if server.category and server.category.icon %}
                                        <i class="{{ server.category.icon }}"></i>
                                    {% else %}
                                        <i class="fas fa-server"></i>
                                    {% endif %}
                                </div>
                                <div class="sv-card__heading">
                                    <h3 class="sv-card__name">
                                        {% if server.isApproved and server.isActive %}
                                            <a href="{{ path('server_show', {slug: server.slug}) }}">{{ server.name }}</a>
                                        {% else %}
                                            {{ server.name }}
                                        {% endif %}
                                    </h3>
                                    <div class="sv-card__tags">
                                        <span class="sv-card__tag" style="background:rgba(54,185,204,0.12);color:#36b9cc;">
                                            <i class="fas fa-users"></i> Collaborateur
                                        </span>
                                        {% if server.isApproved %}
                                            <span class="sv-card__tag sv-card__tag--approved"><i class="fas fa-check"></i> Approuve</span>
                                        {% else %}
                                            <span class="sv-card__tag sv-card__tag--pending"><i class="fas fa-clock"></i> En attente</span>
                                        {% endif %}
                                        {% if server.category %}
                                            <span class="sv-card__tag sv-card__tag--cat">{{ server.category.name }}{% if server.gameCategory %} / {{ server.gameCategory.name }}{% endif %}</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            {# Description #}
                            {% if server.shortDescription %}
                                <p class="sv-card__desc">{{ server.shortDescription }}</p>
                            {% endif %}

                            {# Stats #}
                            <div class="sv-card__stats">
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value sv-card__stat-value--green">{{ server.monthlyVotes }}</span>
                                    <span class="sv-card__stat-label">Votes / mois</span>
                                </div>
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value">{{ server.totalVotes }}</span>
                                    <span class="sv-card__stat-label">Votes total</span>
                                </div>
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value">{{ server.slots > 0 ? server.slots : '-' }}</span>
                                    <span class="sv-card__stat-label">Slots</span>
                                </div>
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value">{{ server.createdAt ? server.createdAt|date('d/m/y') : '-' }}</span>
                                    <span class="sv-card__stat-label">Cree le</span>
                                </div>
                            </div>

                            {# Actions #}
                            <div class="sv-card__actions">
                                {% set collabPerms = collab.permissions %}
                                {% set hasManagePerm = 'manage_webhooks' in collabPerms or 'manage_theme' in collabPerms or 'manage_api' in collabPerms or 'manage_status' in collabPerms or 'edit_images' in collabPerms or 'moderate_comments' in collabPerms %}
                                {% set hasEditPerm = 'edit_info' in collabPerms or 'edit_images' in collabPerms or 'edit_social' in collabPerms %}

                                {% if hasManagePerm or hasEditPerm %}
                                    <a href="{{ path('user_servers_manage', {id: server.id}) }}" class="sv-btn sv-btn--manage">
                                        <i class="fas fa-cog"></i> Gestion
                                    </a>
                                {% endif %}
                                {% if hasEditPerm %}
                                    <a href="{{ path('user_servers_edit', {id: server.id}) }}" class="sv-btn sv-btn--edit">
                                        <i class="fas fa-pen"></i> Modifier
                                    </a>
                                {% endif %}
                                {% if server.isApproved and server.isActive %}
                                    <a href="{{ path('server_show', {slug: server.slug}) }}" class="sv-btn sv-btn--view">
                                        <i class="fas fa-external-link-alt"></i> Voir
                                    </a>
                                {% endif %}
                                {% if 'delete_server' in collabPerms %}
                                    <form method="post" action="{{ path('user_servers_delete', {id: server.id}) }}" onsubmit="return confirm('Supprimer definitivement ce serveur ? Cette action est irreversible.');" style="display:inline;margin-left:auto;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_server_' ~ server.id) }}">
                                        <button type="submit" class="sv-btn sv-btn--delete">
                                            <i class="fas fa-trash-alt"></i> Supprimer
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            {% endif %}

        </div>
    </div>
</section>

{# Player count AJAX #}
{% set server_ids = [] %}
{% for server in servers %}
    {% if server.ip and server.port %}
        {% set server_ids = server_ids|merge([server.id]) %}
    {% endif %}
{% endfor %}
{% if server_ids|length > 0 %}
    <script>
    (function() {
        var ids = {{ server_ids|json_encode|raw }};
        ids.forEach(function(id) {
            fetch('/api/server-status/' + id)
            .then(function(r) { return r.json(); })
            .then(function(d) {
                var el = document.getElementById('user-players-' + id);
                if (!el) return;
                var val = el.querySelector('.sv-card__stat-value');
                if (d.online && d.queryType) {
                    val.textContent = d.players + '/' + d.maxPlayers;
                    val.style.color = '#1cc88a';
                } else if (d.queryType) {
                    val.textContent = 'Off';
                    val.style.color = '#e74a3b';
                } else {
                    val.textContent = '-';
                    val.style.color = '#8b949e';
                }
            })
            .catch(function() {
                var el = document.getElementById('user-players-' + id);
                if (el) {
                    el.querySelector('.sv-card__stat-value').textContent = '-';
                }
            });
        });
    })();
    </script>
{% endif %}
{% endblock %}
