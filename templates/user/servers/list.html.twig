{% extends 'base.html.twig' %}

{% block title %}Mes serveurs - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/user-servers/list.css') }}">
{% endblock %}

{% block body %}
<section class="my-servers">
    <div class="my-servers__bg">
        <div class="my-servers__bg-glow"></div>
    </div>
    <div class="my-servers__inner">
        <div class="container">

            {# ── Flash Messages ── #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="sv-flash sv-flash--{{ type == 'success' ? 'success' : 'error' }}">
                        <i class="fas fa-{{ type == 'success' ? 'check-circle' : 'exclamation-triangle' }}"></i>
                        <span>{{ message }}</span>
                        <button class="sv-flash__close" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {# ── Header ── #}
            <div class="my-servers__head">
                <h2 class="my-servers__title">
                    Mes <span>serveurs</span>
                    {% if servers|length > 0 %}
                        <span class="my-servers__count">{{ servers|length }}</span>
                    {% endif %}
                </h2>
                <a href="{{ path('user_servers_new') }}" class="btn-add-server">
                    <i class="fas fa-plus"></i> Ajouter un serveur
                </a>
            </div>

            {# ── Stats Bar ── #}
            {% if servers|length > 0 %}
                {% set totalMonthly = 0 %}
                {% set totalAll = 0 %}
                {% set activeCount = 0 %}
                {% set pendingCount = 0 %}
                {% for s in servers %}
                    {% set totalMonthly = totalMonthly + s.monthlyVotes %}
                    {% set totalAll = totalAll + s.totalVotes %}
                    {% if s.isActive and s.isApproved %}{% set activeCount = activeCount + 1 %}{% endif %}
                    {% if not s.isApproved %}{% set pendingCount = pendingCount + 1 %}{% endif %}
                {% endfor %}
                <div class="my-servers__stats">
                    <div class="stat-chip">
                        <span class="stat-chip__icon stat-chip__icon--votes"><i class="fas fa-bolt"></i></span>
                        <span class="stat-chip__value">{{ totalMonthly }}</span> votes ce mois
                    </div>
                    <div class="stat-chip">
                        <span class="stat-chip__icon stat-chip__icon--total"><i class="fas fa-chart-bar"></i></span>
                        <span class="stat-chip__value">{{ totalAll }}</span> votes au total
                    </div>
                    <div class="stat-chip">
                        <span class="stat-chip__icon stat-chip__icon--active"><i class="fas fa-signal"></i></span>
                        <span class="stat-chip__value">{{ activeCount }}</span> en ligne
                    </div>
                    {% if pendingCount > 0 %}
                        <div class="stat-chip">
                            <span class="stat-chip__icon stat-chip__icon--pending"><i class="fas fa-clock"></i></span>
                            <span class="stat-chip__value">{{ pendingCount }}</span> en attente
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            {# ── Server Cards ── #}
            {% for server in servers %}
                <div class="sv-card">
                    {# Banner strip #}
                    <div class="sv-card__banner {% if not server.banner %}sv-card__banner--default{% endif %}">
                        {% if server.banner %}
                            <img src="{{ asset('uploads/servers/banners/' ~ server.banner) }}" alt="">
                        {% endif %}
                    </div>

                    <div class="sv-card__body">
                        {# Icon + Title #}
                        <div class="sv-card__top">
                            <div class="sv-card__icon">
                                {% if server.category and server.category.icon %}
                                    <i class="{{ server.category.icon }}"></i>
                                {% else %}
                                    <i class="fas fa-server"></i>
                                {% endif %}
                            </div>
                            <div class="sv-card__heading">
                                <h3 class="sv-card__name">
                                    {% if server.isApproved and server.isActive %}
                                        <a href="{{ path('server_show', {slug: server.slug}) }}">{{ server.name }}</a>
                                    {% else %}
                                        {{ server.name }}
                                    {% endif %}
                                </h3>
                                <div class="sv-card__tags">
                                    {% if server.isApproved %}
                                        <span class="sv-card__tag sv-card__tag--approved"><i class="fas fa-check"></i> Approuve</span>
                                    {% else %}
                                        <span class="sv-card__tag sv-card__tag--pending"><i class="fas fa-clock"></i> En attente</span>
                                    {% endif %}
                                    {% if server.isActive %}
                                        <span class="sv-card__tag sv-card__tag--active"><i class="fas fa-circle"></i> Actif</span>
                                    {% else %}
                                        <span class="sv-card__tag sv-card__tag--inactive"><i class="fas fa-circle"></i> Inactif</span>
                                    {% endif %}
                                    {% if server.category %}
                                        <span class="sv-card__tag sv-card__tag--cat">{{ server.category.name }}{% if server.gameCategory %} / {{ server.gameCategory.name }}{% endif %}</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        {# Description #}
                        {% if server.shortDescription %}
                            <p class="sv-card__desc">{{ server.shortDescription }}</p>
                        {% endif %}

                        {# Stats #}
                        <div class="sv-card__stats">
                            <div class="sv-card__stat">
                                <span class="sv-card__stat-value sv-card__stat-value--green">{{ server.monthlyVotes }}</span>
                                <span class="sv-card__stat-label">Votes / mois</span>
                            </div>
                            <div class="sv-card__stat">
                                <span class="sv-card__stat-value">{{ server.totalVotes }}</span>
                                <span class="sv-card__stat-label">Votes total</span>
                            </div>
                            {% if server.ip and server.port %}
                                <div class="sv-card__stat" id="user-players-{{ server.id }}">
                                    <span class="sv-card__stat-value" style="color:#8b949e;">...</span>
                                    <span class="sv-card__stat-label">Joueurs</span>
                                </div>
                            {% else %}
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value">{{ server.slots > 0 ? server.slots : '-' }}</span>
                                    <span class="sv-card__stat-label">Slots</span>
                                </div>
                            {% endif %}
                            <div class="sv-card__stat">
                                <span class="sv-card__stat-value">{{ server.createdAt ? server.createdAt|time_ago('d/m/Y') : '-' }}</span>
                                <span class="sv-card__stat-label">Cree le</span>
                            </div>
                        </div>

                        {# Actions #}
                        <div class="sv-card__actions">
                            <a href="{{ path('user_servers_manage', {id: server.id}) }}" class="sv-btn sv-btn--manage">
                                <i class="fas fa-cog"></i> Gestion
                            </a>
                            <a href="{{ path('user_servers_edit', {id: server.id}) }}" class="sv-btn sv-btn--edit">
                                <i class="fas fa-pen"></i> Modifier
                            </a>
                            {% if server.isApproved and server.isActive %}
                                <a href="{{ path('server_show', {slug: server.slug}) }}" class="sv-btn sv-btn--view">
                                    <i class="fas fa-external-link-alt"></i> Voir
                                </a>
                            {% endif %}
                            <form method="post" action="{{ path('user_servers_delete', {id: server.id}) }}" onsubmit="return confirm('Supprimer definitivement ce serveur ? Cette action est irreversible.');" style="display:inline;margin-left:auto;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_server_' ~ server.id) }}">
                                <button type="submit" class="sv-btn sv-btn--delete">
                                    <i class="fas fa-trash-alt"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% else %}
                {# Empty State #}
                <div class="empty-state">
                    <div class="empty-state__icon">
                        <i class="fas fa-server"></i>
                    </div>
                    <h3>Aucun serveur</h3>
                    <p>Vous n'avez pas encore ajoute de serveur. Ajoutez votre premier serveur et commencez a recevoir des votes !</p>
                    <a href="{{ path('user_servers_new') }}" class="btn-add-server">
                        <i class="fas fa-plus"></i> Ajouter un serveur
                    </a>
                </div>
            {% endfor %}

            {# ── Shared Servers ── #}
            {% if collaborations|default([])|length > 0 %}
            <div style="margin-top:50px;">
                <h2 class="my-servers__title">
                    Serveurs <span>partages</span>
                    <span class="my-servers__count">{{ collaborations|length }}</span>
                </h2>
                <p style="color:#5a6472;font-size:13px;margin-bottom:25px;">Serveurs sur lesquels vous etes collaborateur.</p>

                {% for collab in collaborations %}
                    {% set server = collab.server %}
                    <div class="sv-card">
                        {# Banner strip #}
                        <div class="sv-card__banner {% if not server.banner %}sv-card__banner--default{% endif %}">
                            {% if server.banner %}
                                <img src="{{ asset('uploads/servers/banners/' ~ server.banner) }}" alt="">
                            {% endif %}
                        </div>

                        <div class="sv-card__body">
                            {# Icon + Title #}
                            <div class="sv-card__top">
                                <div class="sv-card__icon" style="background:linear-gradient(135deg, #36b9cc, #2a93a3);">
                                    {% if server.category and server.category.icon %}
                                        <i class="{{ server.category.icon }}"></i>
                                    {% else %}
                                        <i class="fas fa-server"></i>
                                    {% endif %}
                                </div>
                                <div class="sv-card__heading">
                                    <h3 class="sv-card__name">
                                        {% if server.isApproved and server.isActive %}
                                            <a href="{{ path('server_show', {slug: server.slug}) }}">{{ server.name }}</a>
                                        {% else %}
                                            {{ server.name }}
                                        {% endif %}
                                    </h3>
                                    <div class="sv-card__tags">
                                        <span class="sv-card__tag" style="background:rgba(54,185,204,0.12);color:#36b9cc;">
                                            <i class="fas fa-users"></i> Collaborateur
                                        </span>
                                        {% if server.isApproved %}
                                            <span class="sv-card__tag sv-card__tag--approved"><i class="fas fa-check"></i> Approuve</span>
                                        {% else %}
                                            <span class="sv-card__tag sv-card__tag--pending"><i class="fas fa-clock"></i> En attente</span>
                                        {% endif %}
                                        {% if server.category %}
                                            <span class="sv-card__tag sv-card__tag--cat">{{ server.category.name }}{% if server.gameCategory %} / {{ server.gameCategory.name }}{% endif %}</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            {# Description #}
                            {% if server.shortDescription %}
                                <p class="sv-card__desc">{{ server.shortDescription }}</p>
                            {% endif %}

                            {# Stats #}
                            <div class="sv-card__stats">
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value sv-card__stat-value--green">{{ server.monthlyVotes }}</span>
                                    <span class="sv-card__stat-label">Votes / mois</span>
                                </div>
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value">{{ server.totalVotes }}</span>
                                    <span class="sv-card__stat-label">Votes total</span>
                                </div>
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value">{{ server.slots > 0 ? server.slots : '-' }}</span>
                                    <span class="sv-card__stat-label">Slots</span>
                                </div>
                                <div class="sv-card__stat">
                                    <span class="sv-card__stat-value">{{ server.createdAt ? server.createdAt|time_ago('d/m/Y') : '-' }}</span>
                                    <span class="sv-card__stat-label">Cree le</span>
                                </div>
                            </div>

                            {# Actions #}
                            <div class="sv-card__actions">
                                {% set collabPerms = collab.permissions %}
                                {% set hasManagePerm = 'manage_webhooks' in collabPerms or 'manage_theme' in collabPerms or 'manage_api' in collabPerms or 'manage_status' in collabPerms or 'edit_images' in collabPerms or 'moderate_comments' in collabPerms %}
                                {% set hasEditPerm = 'edit_info' in collabPerms or 'edit_images' in collabPerms or 'edit_social' in collabPerms %}

                                {% if hasManagePerm or hasEditPerm %}
                                    <a href="{{ path('user_servers_manage', {id: server.id}) }}" class="sv-btn sv-btn--manage">
                                        <i class="fas fa-cog"></i> Gestion
                                    </a>
                                {% endif %}
                                {% if hasEditPerm %}
                                    <a href="{{ path('user_servers_edit', {id: server.id}) }}" class="sv-btn sv-btn--edit">
                                        <i class="fas fa-pen"></i> Modifier
                                    </a>
                                {% endif %}
                                {% if server.isApproved and server.isActive %}
                                    <a href="{{ path('server_show', {slug: server.slug}) }}" class="sv-btn sv-btn--view">
                                        <i class="fas fa-external-link-alt"></i> Voir
                                    </a>
                                {% endif %}
                                {% if 'delete_server' in collabPerms %}
                                    <form method="post" action="{{ path('user_servers_delete', {id: server.id}) }}" onsubmit="return confirm('Supprimer definitivement ce serveur ? Cette action est irreversible.');" style="display:inline;margin-left:auto;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_server_' ~ server.id) }}">
                                        <button type="submit" class="sv-btn sv-btn--delete">
                                            <i class="fas fa-trash-alt"></i> Supprimer
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            {% endif %}

        </div>
    </div>
</section>

{# Player count AJAX #}
{% set server_ids = [] %}
{% for server in servers %}
    {% if server.ip and server.port %}
        {% set server_ids = server_ids|merge([server.id]) %}
    {% endif %}
{% endfor %}
{% if server_ids|length > 0 %}
    <script>
    (function() {
        var ids = {{ server_ids|json_encode|raw }};
        ids.forEach(function(id) {
            fetch('/api/server-status/' + id)
            .then(function(r) { return r.json(); })
            .then(function(d) {
                var el = document.getElementById('user-players-' + id);
                if (!el) return;
                var val = el.querySelector('.sv-card__stat-value');
                if (d.online && d.queryType) {
                    val.textContent = d.players + '/' + d.maxPlayers;
                    val.style.color = '#1cc88a';
                } else if (d.queryType) {
                    val.textContent = 'Off';
                    val.style.color = '#e74a3b';
                } else {
                    val.textContent = '-';
                    val.style.color = '#8b949e';
                }
            })
            .catch(function() {
                var el = document.getElementById('user-players-' + id);
                if (el) {
                    el.querySelector('.sv-card__stat-value').textContent = '-';
                }
            });
        });
    })();
    </script>
{% endif %}
{% endblock %}
