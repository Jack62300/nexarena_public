{% extends 'base.html.twig' %}

{% block title %}Gestion - {{ server.name }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/user-servers/manage.css') }}">
{% endblock %}

{% block body %}
<section class="server-manage">
    <div class="container">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert" style="background:#162231;border:1px solid {{ type == 'success' ? '#1cc88a' : '#e74a3b' }};color:#fff;">
                    {{ message }}
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:15px;margin-bottom:10px;">
            <div>
                <h2 class="server-manage__title">Gestion : <span>{{ server.name }}</span></h2>
                <p class="server-manage__subtitle">
                    {% if server.isApproved %}
                        <span style="color:#1cc88a;"><i class="fas fa-check-circle"></i> Approuve</span>
                    {% else %}
                        <span style="color:#f6c23e;"><i class="fas fa-clock"></i> En attente d'approbation</span>
                    {% endif %}
                    &nbsp;|&nbsp;
                    {% if server.isActive %}
                        <span style="color:#36b9cc;">Actif</span>
                    {% else %}
                        <span style="color:#8b949e;">Inactif</span>
                    {% endif %}
                    {% if not is_owner %}
                        &nbsp;|&nbsp;
                        <span style="color:#36b9cc;"><i class="fas fa-users"></i> Collaborateur</span>
                    {% endif %}
                </p>
            </div>
            <div style="display:flex;gap:8px;">
                {% if can_edit_info or can_edit_images or can_edit_social %}
                    <a href="{{ path('user_servers_edit', {id: server.id}) }}" class="btn-action btn-action--outline">
                        <i class="fas fa-edit"></i> Modifier
                    </a>
                {% endif %}
                <a href="{{ path('user_servers_list') }}" class="btn-action btn-action--outline">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>
        </div>

        <div class="manage-tabs">
            <button type="button" class="manage-tabs__btn active" data-tab="gestion" onclick="switchManageTab('gestion')">
                <i class="fas fa-cogs"></i> Gestion
            </button>
            {% if can_manage_theme %}
            <button type="button" class="manage-tabs__btn" data-tab="theme" onclick="switchManageTab('theme')">
                <i class="fas fa-palette"></i> Theme
            </button>
            {% endif %}
            {% if can_manage_api %}
            <button type="button" class="manage-tabs__btn" data-tab="api" onclick="switchManageTab('api')">
                <i class="fas fa-code"></i> API
            </button>
            {% endif %}
            {% if is_owner and premium_enabled %}
            <button type="button" class="manage-tabs__btn" data-tab="premium" onclick="switchManageTab('premium')">
                <i class="fas fa-crown" style="color:#ffd700;"></i> Premium
            </button>
            {% endif %}
            {% if is_owner %}
            <button type="button" class="manage-tabs__btn" data-tab="stats" onclick="switchManageTab('stats')">
                <i class="fas fa-chart-line" style="color:#36b9cc;"></i> Stats
            </button>
            {% endif %}
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                {# ========== TAB: GESTION ========== #}
                <div id="tabGestion" class="manage-tab-panel active">
                {# === TOKEN API === #}
                {% if can_manage_api %}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-key"></i> Cle API</h4>
                    <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                        Cette cle permet d'acceder a l'API pour verifier les votes de votre serveur.
                        Ne la partagez jamais publiquement.
                    </p>
                    <div class="token-box">
                        <code id="apiToken">{{ server.apiToken }}</code>
                        <button type="button" class="btn-copy" onclick="navigator.clipboard.writeText(document.getElementById('apiToken').textContent); this.textContent='Copie !'; setTimeout(function(){document.querySelector('.btn-copy').textContent='Copier';}, 2000);">
                            Copier
                        </button>
                    </div>
                    <form method="post" action="{{ path('user_servers_regenerate_token', {id: server.id}) }}" onsubmit="return confirm('Regenerer la cle ? L\'ancienne cle ne fonctionnera plus.');" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('regenerate_token') }}">
                        <button type="submit" class="btn-action btn-action--danger" style="font-size:12px;">
                            <i class="fas fa-sync-alt"></i> Regenerer la cle
                        </button>
                    </form>
                    <p style="color:#5a5c69;font-size:12px;margin-top:12px;margin-bottom:0;">
                        <i class="fas fa-info-circle"></i> Consultez l'onglet <strong style="color:#45f882;cursor:pointer;" onclick="switchManageTab('api')">API</strong> pour la documentation complete.
                    </p>
                </div>
                {% endif %}

                {# === WEBHOOKS === #}
                {% if can_manage_webhooks %}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-satellite-dish"></i> Webhooks</h4>
                    <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                        Recevez une notification HTTP a chaque vote sur votre serveur.
                    </p>
                    <form method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('server_manage') }}">
                        <input type="hidden" name="_action" value="webhook">
                        <div class="form-group">
                            <label class="form-check-custom">
                                <input type="checkbox" name="webhook_enabled" value="1" {{ server.webhookEnabled ? 'checked' : '' }} onchange="document.getElementById('webhookUrlField').style.display = this.checked ? 'block' : 'none'">
                                Activer les webhooks
                            </label>
                        </div>
                        <div id="webhookUrlField" style="{{ server.webhookEnabled ? '' : 'display:none;' }}">
                            <div class="form-group">
                                <label for="webhook_url">URL du webhook</label>
                                <input type="url" id="webhook_url" name="webhook_url" class="form-input" value="{{ server.webhookUrl }}" placeholder="https://mon-site.fr/api/vote-callback">
                                <span class="form-hint">Un POST JSON sera envoye a cette URL a chaque vote. Header X-Webhook-Signature inclus si un secret est configure.</span>
                            </div>
                        </div>
                        <button type="submit" class="btn-action btn-action--primary">
                            <i class="fas fa-save"></i> Enregistrer
                        </button>
                    </form>
                </div>
                {% endif %}

                {# === STATUS SERVEUR === #}
                {% if can_manage_status %}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-signal"></i> Status du serveur</h4>
                    <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                        Affiche un indicateur "En ligne / Hors ligne" sur la page publique via un ping TCP sur l'IP:port.
                    </p>
                    {% if not server.ip or not server.port %}
                        <div style="background:rgba(246,194,62,0.08);border:1px solid rgba(246,194,62,0.2);border-radius:8px;padding:12px 16px;color:#f6c23e;font-size:13px;margin-bottom:15px;">
                            <i class="fas fa-exclamation-triangle"></i> Vous devez renseigner l'IP et le port de votre serveur pour utiliser cette fonctionnalite.
                        </div>
                    {% endif %}
                    <form method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('server_manage') }}">
                        <input type="hidden" name="_action" value="status_check">
                        <div class="form-group">
                            <label class="form-check-custom">
                                <input type="checkbox" {{ server.statusCheckEnabled ? 'checked' : '' }} onchange="this.form.submit()" {{ (not server.ip or not server.port) ? 'disabled' : '' }}>
                                Activer la verification du status
                            </label>
                        </div>
                    </form>
                    {% if server.statusCheckEnabled and server.ip and server.port %}
                        <div style="margin-top:12px;padding:12px 16px;background:#0a1018;border:1px solid #1e3048;border-radius:8px;">
                            <span style="font-size:13px;color:#8b949e;">Status actuel : </span>
                            <span id="statusPreview" style="font-size:13px;">
                                <i class="fas fa-spinner fa-spin" style="color:#5a5c69;"></i> Verification...
                            </span>
                        </div>
                    {% endif %}
                </div>
                {% endif %}

                {# === BANNIERE === #}
                {% if can_edit_images %}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-image"></i> Banniere</h4>
                    <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                        Banniere affichee en haut de la page publique de votre serveur (taille recommandee : 1920x400 pixels).
                    </p>
                    {% if server.banner %}
                        <img src="{{ asset('uploads/servers/banners/' ~ server.banner) }}" alt="Banniere" class="banner-preview" style="margin-bottom:15px;">
                    {% endif %}
                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" name="_token" value="{{ csrf_token('server_manage') }}">
                        <input type="hidden" name="_action" value="banner">
                        <div class="form-group">
                            <input type="file" name="banner" class="form-input" accept="image/*">
                            <span class="form-hint">Taille recommandee : 1920x400 pixels. Les images plus grandes seront redimensionnees.</span>
                        </div>
                        <button type="submit" class="btn-action btn-action--primary">
                            <i class="fas fa-upload"></i> Uploader
                        </button>
                    </form>
                </div>
                {% endif %}

                {# === TWITCH LIVE === #}
                {% if server.twitchChannel %}
                <div class="manage-card" style="border-color:rgba(145,70,255,0.2);">
                    <h4 class="manage-card__title" style="border-bottom-color:rgba(145,70,255,0.15);">
                        <i class="fab fa-twitch" style="color:#9146ff;"></i> Twitch Live
                        {% if twitch_sub and twitch_sub.isActive %}
                            <span style="margin-left:8px;font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(28,200,138,0.12);color:#1cc88a;border:1px solid rgba(28,200,138,0.2);font-weight:600;">Actif</span>
                        {% endif %}
                    </h4>

                    {% if not twitch_live_gated or (twitch_sub and twitch_sub.isActive) %}
                        {# Active subscription #}
                        <div style="background:linear-gradient(135deg,rgba(145,70,255,0.06),rgba(145,70,255,0.02));border:1px solid rgba(145,70,255,0.12);border-radius:12px;padding:20px;margin-bottom:16px;">
                            <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
                                <div style="width:46px;height:46px;border-radius:12px;background:rgba(145,70,255,0.15);display:flex;align-items:center;justify-content:center;">
                                    <i class="fab fa-twitch" style="font-size:22px;color:#9146ff;"></i>
                                </div>
                                <div>
                                    <div style="font-size:15px;font-weight:700;color:#e4e6eb;">{{ server.twitchChannel }}</div>
                                    <div style="font-size:12px;color:#8b949e;">
                                        Integration active
                                        {% if twitch_sub %}
                                            — Expire le {{ twitch_sub.expiresAt|date('d/m/Y') }}
                                            ({{ twitch_sub.daysRemaining }} jour{{ twitch_sub.daysRemaining > 1 ? 's' : '' }})
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
                                <span style="font-size:12px;color:#1cc88a;"><i class="fas fa-check-circle"></i> Player live integre</span>
                                <span style="font-size:12px;color:#1cc88a;margin-left:10px;"><i class="fas fa-check-circle"></i> Rediffusions</span>
                                <span style="font-size:12px;color:#1cc88a;margin-left:10px;"><i class="fas fa-check-circle"></i> Stats en direct</span>
                            </div>
                        </div>

                        {% if twitch_sub %}
                            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                {# Renew with NexBits #}
                                <form method="post" action="{{ path('user_servers_twitch_subscribe', {id: server.id}) }}" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('twitch_subscribe') }}">
                                    <input type="hidden" name="payment_method" value="nexbits">
                                    <button type="submit" class="btn-action btn-action--primary" style="font-size:12px;padding:6px 14px;">
                                        <i class="fas fa-redo"></i> Renouveler (+30j / {{ twitch_live_cost_tokens }} NexBits)
                                    </button>
                                </form>
                                {# Cancel #}
                                {% if twitch_sub.status != 'cancelled' %}
                                    <form method="post" action="{{ path('user_servers_twitch_cancel', {id: server.id}) }}" onsubmit="return confirm('Annuler l\'abonnement Twitch Live ? L\'acces reste actif jusqu\'a expiration.');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('twitch_cancel') }}">
                                        <button type="submit" class="btn-action btn-action--danger" style="font-size:12px;padding:6px 14px;">
                                            <i class="fas fa-times"></i> Annuler
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                            {% if twitch_sub.autoRenew %}
                                <div style="margin-top:10px;font-size:12px;color:#8b949e;">
                                    <i class="fas fa-sync-alt" style="color:#9146ff;"></i> Renouvellement automatique active (NexBits)
                                </div>
                            {% endif %}
                        {% endif %}
                    {% else %}
                        {# Not subscribed: offer #}
                        <div style="text-align:center;padding:20px 10px;">
                            <div style="width:60px;height:60px;border-radius:16px;background:linear-gradient(135deg,#9146ff,#6441a5);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                                <i class="fab fa-twitch" style="font-size:28px;color:#fff;"></i>
                            </div>
                            <h5 style="color:#e4e6eb;font-size:16px;margin-bottom:8px;">Integration Twitch Live</h5>
                            <p style="color:#8b949e;font-size:13px;margin-bottom:20px;max-width:400px;margin-left:auto;margin-right:auto;">
                                Integrez votre direct Twitch et vos rediffusions directement sur la page de votre serveur.
                                Attirez plus de visiteurs avec votre contenu live !
                            </p>

                            <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;justify-content:center;margin-bottom:16px;">
                                <div style="font-size:12px;color:#8b949e;">Ce que vous obtenez :</div>
                            </div>
                            <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:24px;">
                                <div style="padding:10px 16px;background:rgba(145,70,255,0.06);border:1px solid rgba(145,70,255,0.12);border-radius:10px;font-size:12px;color:#c4c9d2;">
                                    <i class="fas fa-play-circle" style="color:#9146ff;margin-right:4px;"></i> Player live integre
                                </div>
                                <div style="padding:10px 16px;background:rgba(145,70,255,0.06);border:1px solid rgba(145,70,255,0.12);border-radius:10px;font-size:12px;color:#c4c9d2;">
                                    <i class="fas fa-video" style="color:#9146ff;margin-right:4px;"></i> Rediffusions (VODs)
                                </div>
                                <div style="padding:10px 16px;background:rgba(145,70,255,0.06);border:1px solid rgba(145,70,255,0.12);border-radius:10px;font-size:12px;color:#c4c9d2;">
                                    <i class="fas fa-chart-line" style="color:#9146ff;margin-right:4px;"></i> Stats en direct
                                </div>
                            </div>

                            {# Price cards #}
                            <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:16px;">
                                {# NexBits option #}
                                <form method="post" action="{{ path('user_servers_twitch_subscribe', {id: server.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('twitch_subscribe') }}">
                                    <input type="hidden" name="payment_method" value="nexbits">
                                    <div style="background:#0d1a26;border:1px solid rgba(255,215,0,0.2);border-radius:14px;padding:20px 24px;min-width:180px;text-align:center;">
                                        <div style="font-size:11px;color:#ffd700;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">NexBits</div>
                                        <div style="font-size:28px;font-weight:800;color:#ffd700;">{{ twitch_live_cost_tokens }}</div>
                                        <div style="font-size:11px;color:#8b949e;margin-bottom:14px;">NexBits / mois</div>
                                        <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:#8b949e;cursor:pointer;justify-content:center;margin-bottom:12px;">
                                            <input type="checkbox" name="auto_renew" value="1" style="accent-color:#9146ff;width:14px;height:14px;">
                                            Renouveler automatiquement
                                        </label>
                                        <button type="submit" class="btn-action btn-action--primary" style="width:100%;background:linear-gradient(135deg,#ffd700,#ff6b35);color:#000;border:none;font-weight:700;border-radius:10px;padding:10px;">
                                            <i class="fas fa-coins"></i> Payer en NexBits
                                        </button>
                                        <div style="font-size:11px;color:#5a5c69;margin-top:8px;">Solde serveur : {{ server.tokenBalance }} NexBits</div>
                                    </div>
                                </form>

                                {# EUR option #}
                                <div style="background:#0d1a26;border:1px solid rgba(145,70,255,0.2);border-radius:14px;padding:20px 24px;min-width:180px;text-align:center;">
                                    <div style="font-size:11px;color:#9146ff;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">PayPal</div>
                                    <div style="font-size:28px;font-weight:800;color:#e4e6eb;">{{ twitch_live_cost_eur }}€</div>
                                    <div style="font-size:11px;color:#8b949e;margin-bottom:14px;">EUR / mois</div>
                                    <div id="twitchPaypalBtnContainer" style="margin-top:26px;">
                                        <a href="{{ path('premium_index') }}" class="btn-action btn-action--primary" style="width:100%;background:#0070ba;border:none;font-weight:700;border-radius:10px;padding:10px;color:#fff;text-decoration:none;display:block;">
                                            <i class="fab fa-paypal"></i> Payer via PayPal
                                        </a>
                                    </div>
                                    <div style="font-size:11px;color:#5a5c69;margin-top:8px;">Paiement securise</div>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
                {% else %}
                    <div class="manage-card" style="border-color:rgba(145,70,255,0.15);">
                        <h4 class="manage-card__title" style="border-bottom-color:rgba(145,70,255,0.1);">
                            <i class="fab fa-twitch" style="color:#9146ff;"></i> Twitch Live
                        </h4>
                        <div style="background:rgba(246,194,62,0.06);border:1px solid rgba(246,194,62,0.15);border-radius:10px;padding:14px 18px;color:#f6c23e;font-size:13px;">
                            <i class="fas fa-exclamation-triangle" style="margin-right:6px;"></i>
                            Renseignez votre nom de chaine Twitch dans les <strong><a href="{{ path('user_servers_edit', {id: server.id}) }}" style="color:#f6c23e;">informations du serveur</a></strong> (section Reseaux sociaux) pour activer cette fonctionnalite.
                        </div>
                    </div>
                {% endif %}

                {# === WIDGETS INTEGRABLES === #}
                {% set widget_gated = premium_feature_gated('widget') %}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-code"></i> Widgets integrables</h4>
                    <p style="color:#8b949e;font-size:13px;margin-bottom:20px;">
                        Integrez ces widgets sur votre site web pour afficher les informations de votre serveur.
                    </p>

                    {# Style selector: 5 options — presets always free, custom requires premium if gated #}
                    <div style="display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap;">
                        <button type="button" class="wg-style-btn wg-style-btn--active" data-style="dark" onclick="switchWidgetStyle('dark')">
                            <i class="fas fa-moon"></i> Sombre
                        </button>
                        <button type="button" class="wg-style-btn" data-style="light" onclick="switchWidgetStyle('light')">
                            <i class="fas fa-sun"></i> Clair
                        </button>
                        <button type="button" class="wg-style-btn" data-style="colored" onclick="switchWidgetStyle('colored')">
                            <i class="fas fa-fire"></i> Colore
                        </button>
                        <button type="button" class="wg-style-btn" data-style="compact" onclick="switchWidgetStyle('compact')">
                            <i class="fas fa-compress-alt"></i> Compact
                        </button>
                        {% if not widget_gated or has_premium_widget %}
                        <button type="button" class="wg-style-btn" data-style="custom" onclick="switchWidgetStyle('custom')">
                            <i class="fas fa-palette"></i> Personnalisable
                        </button>
                        {% else %}
                        <button type="button" class="wg-style-btn" data-style="custom" onclick="event.preventDefault();" data-bs-toggle="modal" data-bs-target="#premiumUnlockModal_widget"
                                style="opacity:0.6;cursor:pointer;">
                            <i class="fas fa-lock"></i> Personnalisable <i class="fas fa-crown" style="color:#ffd700;font-size:10px;"></i>
                        </button>
                        {% endif %}
                    </div>

                    {# Style description #}
                    <div id="wgStyleDesc" style="font-size:12px;color:#5a5c69;margin-bottom:16px;padding:8px 12px;background:#0d1a26;border-radius:8px;">
                        <i class="fas fa-info-circle" style="margin-right:4px;"></i> Fond transparent, texte blanc, accent vert — ideal pour les sites sombres.
                    </div>

                    {# Widget type: Card / Voters #}
                    <div style="display:flex;gap:4px;margin-bottom:20px;">
                        <button type="button" class="widget-tab widget-tab--active" data-tab="card" onclick="switchWidgetTab('card')">
                            <i class="fas fa-id-card"></i> Fiche Serveur
                        </button>
                        <button type="button" class="widget-tab" data-tab="voters" onclick="switchWidgetTab('voters')">
                            <i class="fas fa-trophy"></i> Top Votants
                        </button>
                    </div>

                    {# Custom controls (hidden by default) #}
                    <div id="wgCustomControls" style="display:none;margin-bottom:20px;">
                        <div style="background:#0d1a26;border:1px solid #1e3048;border-radius:10px;padding:18px;">
                            <div style="font-size:13px;font-weight:700;color:#e4e6eb;margin-bottom:14px;">
                                <i class="fas fa-sliders-h" style="color:#45f882;margin-right:6px;"></i> Personnalisation
                            </div>
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                                <div>
                                    <label style="display:block;margin-bottom:6px;font-size:12px;font-weight:600;color:#8b949e;">Couleur d'accent</label>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <input type="color" id="wgAccent" value="#45f882" onchange="updateWidgetPreview()" style="width:36px;height:36px;border:none;border-radius:6px;cursor:pointer;background:none;padding:0;">
                                        <span id="wgAccentHex" style="font-family:monospace;font-size:12px;color:#8b949e;">#45f882</span>
                                    </div>
                                </div>
                                <div>
                                    <label style="display:block;margin-bottom:6px;font-size:12px;font-weight:600;color:#8b949e;">Fond</label>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <input type="color" id="wgBg" value="#162231" onchange="updateWidgetPreview()" style="width:36px;height:36px;border:none;border-radius:6px;cursor:pointer;background:none;padding:0;" disabled>
                                        <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:#8b949e;cursor:pointer;">
                                            <input type="checkbox" id="wgBgTransparent" checked onchange="toggleBgTransparent()" style="accent-color:#45f882;width:14px;height:14px;">
                                            Transparent
                                        </label>
                                    </div>
                                </div>
                                <div>
                                    <label style="display:block;margin-bottom:6px;font-size:12px;font-weight:600;color:#8b949e;">Texte</label>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <input type="color" id="wgText" value="#ffffff" onchange="updateWidgetPreview()" style="width:36px;height:36px;border:none;border-radius:6px;cursor:pointer;background:none;padding:0;">
                                        <span id="wgTextHex" style="font-family:monospace;font-size:12px;color:#8b949e;">#ffffff</span>
                                    </div>
                                </div>
                                <div>
                                    <label style="display:block;margin-bottom:6px;font-size:12px;font-weight:600;color:#8b949e;">Bord arrondi : <span id="wgRadiusVal">12</span>px</label>
                                    <input type="range" id="wgRadius" min="0" max="30" value="12" oninput="updateWidgetPreview()" style="width:100%;accent-color:#45f882;">
                                </div>
                                <div style="grid-column:1/-1;display:flex;gap:20px;flex-wrap:wrap;">
                                    <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#e4e6eb;cursor:pointer;">
                                        <input type="checkbox" id="wgHideFooter" onchange="updateWidgetPreview()" style="accent-color:#45f882;width:16px;height:16px;">
                                        Masquer le footer
                                    </label>
                                    <label id="wgHideDescLabel" style="display:flex;align-items:center;gap:6px;font-size:13px;color:#e4e6eb;cursor:pointer;">
                                        <input type="checkbox" id="wgHideDesc" onchange="updateWidgetPreview()" style="accent-color:#45f882;width:16px;height:16px;">
                                        Masquer la description
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Preview #}
                    <div style="margin-bottom:20px;">
                        <label style="display:block;margin-bottom:8px;font-size:12px;font-weight:600;color:#8b949e;text-transform:uppercase;letter-spacing:0.5px;">Apercu</label>
                        <div id="wgPreviewContainer" class="wg-preview-dark">
                            <iframe id="wgPreviewIframe" width="350" height="400" frameborder="0" scrolling="no" style="border:none;border-radius:8px;max-width:100%;"></iframe>
                        </div>
                    </div>

                    {# Embed code #}
                    <div>
                        <label style="display:block;margin-bottom:8px;font-size:12px;font-weight:600;color:#8b949e;text-transform:uppercase;letter-spacing:0.5px;">Code d'integration</label>
                        <div style="display:flex;gap:8px;align-items:stretch;">
                            <textarea readonly class="form-input" id="wgEmbedCode" rows="2" style="font-family:monospace;font-size:11px;resize:none;flex:1;"></textarea>
                            <button type="button" class="btn-action btn-action--primary" style="white-space:nowrap;align-self:stretch;" onclick="copyWidgetCode('wgEmbedCode', this)">
                                <i class="fas fa-copy"></i> Copier
                            </button>
                        </div>
                    </div>
                </div>
                {% if widget_gated and not has_premium_widget %}
                {% include 'includes/_premium_unlock_modal.html.twig' with {
                    server: server,
                    feature: 'widget',
                    feature_label: 'Widget personnalise',
                    cost: widget_cost,
                    user_balance: server.tokenBalance
                } %}
                {% endif %}

                {# === COMMENTAIRES === #}
                {% if can_moderate_comments %}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-comments"></i> Commentaires ({{ comments|length }})</h4>
                    {% if comments|length > 0 %}
                        {% for comment in comments %}
                            <div class="comment-item">
                                <div class="comment-avatar">
                                    {% if comment.author.avatar %}
                                        <img src="{{ comment.author.avatar }}" alt="{{ comment.author.username }}">
                                    {% else %}
                                        {{ comment.author.username|slice(0, 1)|upper }}
                                    {% endif %}
                                </div>
                                <div class="comment-body">
                                    <div class="comment-header">
                                        <span class="comment-author">{{ comment.author.username }}</span>
                                        <span class="comment-date">{{ comment.createdAt|date('d/m/Y H:i') }}</span>
                                        {% if comment.isFlagged %}
                                            <span class="comment-flagged-badge"><i class="fas fa-flag"></i> Signale</span>
                                        {% endif %}
                                    </div>
                                    <div class="comment-content">{{ comment.content|e|nl2br }}</div>
                                    {% if not comment.isFlagged %}
                                        <button type="button" class="comment-flag-btn" onclick="openFlagModal({{ comment.id }})">
                                            <i class="fas fa-flag"></i> Signaler
                                        </button>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="comment-empty">
                            <i class="fas fa-comments" style="font-size:24px;color:#3d4250;margin-bottom:8px;display:block;"></i>
                            Aucun commentaire pour le moment.
                        </div>
                    {% endif %}
                </div>
                {% endif %}

                {# === RECRUTEMENT === #}
                {% if can_manage_recruitment %}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-bullhorn"></i> Recrutement ({{ recruitment_listings|length }})</h4>
                    <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                        Gerez vos annonces de recrutement pour ce serveur.
                    </p>
                    <a href="{{ path('user_recruitment_new', {serverId: server.id}) }}" class="btn-action btn-action--primary" style="margin-bottom:18px;">
                        <i class="fas fa-plus"></i> Creer une annonce
                    </a>
                    {% if recruitment_listings|length > 0 %}
                        {% for listing in recruitment_listings %}
                            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 0;border-bottom:1px solid #1e3048;flex-wrap:wrap;">
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:14px;font-weight:600;color:#e4e6eb;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                        {{ listing.title }}
                                    </div>
                                    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                                        {% if listing.status == 'draft' %}
                                            <span style="font-size:11px;padding:2px 8px;border-radius:8px;background:rgba(139,148,158,0.12);color:#8b949e;border:1px solid rgba(139,148,158,0.2);font-weight:600;">Brouillon</span>
                                        {% elseif listing.status == 'pending' %}
                                            <span style="font-size:11px;padding:2px 8px;border-radius:8px;background:rgba(246,194,62,0.12);color:#f6c23e;border:1px solid rgba(246,194,62,0.2);font-weight:600;">En attente</span>
                                        {% elseif listing.status == 'approved' %}
                                            <span style="font-size:11px;padding:2px 8px;border-radius:8px;background:rgba(28,200,138,0.12);color:#1cc88a;border:1px solid rgba(28,200,138,0.2);font-weight:600;">Approuvee</span>
                                        {% elseif listing.status == 'revision_requested' %}
                                            <span style="font-size:11px;padding:2px 8px;border-radius:8px;background:rgba(231,74,59,0.12);color:#e74a3b;border:1px solid rgba(231,74,59,0.2);font-weight:600;">Revision</span>
                                        {% elseif listing.status == 'rejected' %}
                                            <span style="font-size:11px;padding:2px 8px;border-radius:8px;background:rgba(231,74,59,0.12);color:#e74a3b;border:1px solid rgba(231,74,59,0.2);font-weight:600;">Refusee</span>
                                        {% endif %}
                                        {% if listing.requiresLogin %}
                                            <span style="font-size:11px;padding:2px 8px;border-radius:8px;background:rgba(54,185,204,0.12);color:#36b9cc;border:1px solid rgba(54,185,204,0.2);font-weight:600;"><i class="fas fa-lock" style="margin-right:2px;"></i> Membres</span>
                                        {% endif %}
                                        <span style="font-size:11px;color:#5a5c69;">{{ listing.formFields|length }} champ{{ listing.formFields|length > 1 ? 's' : '' }}</span>
                                        <span style="font-size:11px;color:#5a5c69;">{{ listing.createdAt|date('d/m/Y') }}</span>
                                    </div>
                                </div>
                                <div style="display:flex;gap:6px;flex-shrink:0;">
                                    <a href="{{ path('user_recruitment_edit', {id: listing.id}) }}" class="btn-action btn-action--outline" style="padding:5px 10px;font-size:11px;">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="{{ path('user_recruitment_form_builder', {id: listing.id}) }}" class="btn-action btn-action--outline" style="padding:5px 10px;font-size:11px;">
                                        <i class="fas fa-list"></i> Formulaire
                                    </a>
                                    <a href="{{ path('user_recruitment_applications', {id: listing.id}) }}" class="btn-action btn-action--outline" style="padding:5px 10px;font-size:11px;">
                                        <i class="fas fa-inbox"></i> Candidatures
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="comment-empty">
                            <i class="fas fa-bullhorn" style="font-size:24px;color:#3d4250;margin-bottom:8px;display:block;"></i>
                            Aucun recrutement pour le moment.
                        </div>
                    {% endif %}
                </div>
                {% endif %}
                </div>{# /tabGestion #}

                {# ========== TAB: THEME ========== #}
                {% if can_manage_theme %}
                <div id="tabTheme" class="manage-tab-panel">
                    {% set theme_gated = premium_feature_gated('theme') %}
                    {% if theme_gated and not has_premium_theme %}
                    <div class="manage-card" style="text-align:center;padding:40px 20px;">
                        <i class="fas fa-lock" style="font-size:48px;color:#ffd700;margin-bottom:16px;display:block;"></i>
                        <h4 style="color:#fff;margin-bottom:8px;">Theme personnalise</h4>
                        <p style="color:#8b949e;font-size:14px;margin-bottom:20px;">
                            Debloquez les themes personnalises pour votre serveur avec des NexBits.
                        </p>
                        <button type="button" class="btn-action btn-action--primary" data-bs-toggle="modal" data-bs-target="#premiumUnlockModal_theme"
                                style="background:linear-gradient(135deg,#ffd700,#ff6b35);color:#000;border:none;font-weight:700;padding:10px 24px;border-radius:10px;">
                            <i class="fas fa-crown"></i> Debloquer ({{ theme_cost }} NexBits)
                        </button>
                        <div style="margin-top:12px;">
                            <a href="{{ path('premium_index') }}" style="color:#ffd700;font-size:13px;text-decoration:underline;">
                                Acheter des NexBits
                            </a>
                        </div>
                    </div>
                    {% include 'includes/_premium_unlock_modal.html.twig' with {
                        server: server,
                        feature: 'theme',
                        feature_label: 'Theme personnalise',
                        cost: theme_cost,
                        user_balance: server.tokenBalance
                    } %}
                    {% else %}
                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-palette"></i> Theme de la page</h4>
                        <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                            Choisissez un theme visuel pour la page publique de votre serveur.
                        </p>
                        <form method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('server_manage') }}">
                            <input type="hidden" name="_action" value="page_template">
                            <input type="hidden" name="page_template" id="selectedTheme" value="{{ server.pageTemplate }}">

                            <div class="theme-grid">
                                {% for key, t in themes %}
                                    <div class="theme-card {{ server.pageTemplate == key ? 'theme-card--active' : '' }}"
                                         data-theme="{{ key }}"
                                         onclick="selectTheme('{{ key }}')">
                                        <div class="theme-card__preview" style="background: linear-gradient(135deg, {{ t.primary }} 0%, {{ t.secondary }} 100%);">
                                            <i class="{{ t.icon }}" style="color:#fff;font-size:20px;"></i>
                                        </div>
                                        <div class="theme-card__name">{{ t.label }}</div>
                                        <div class="theme-card__dot" style="background:{{ t.primary }};"></div>
                                    </div>
                                {% endfor %}
                            </div>

                            <button type="submit" class="btn-action btn-action--primary" style="margin-top:20px;">
                                <i class="fas fa-save"></i> Appliquer le theme
                            </button>
                        </form>
                    </div>
                    {% endif %}
                </div>
                {% endif %}

                {# ========== TAB: API ========== #}
                {% if can_manage_api %}
                <div id="tabApi" class="manage-tab-panel">
                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-key"></i> Cle API</h4>
                        <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                            Cette cle permet d'acceder a l'API pour verifier les votes de votre serveur.
                            Ne la partagez jamais publiquement.
                        </p>
                        <div class="token-box">
                            <code id="apiTokenApi">{{ server.apiToken }}</code>
                            <button type="button" class="btn-copy" onclick="navigator.clipboard.writeText(document.getElementById('apiTokenApi').textContent); this.textContent='Copie !'; var b=this; setTimeout(function(){b.textContent='Copier';}, 2000);">
                                Copier
                            </button>
                        </div>
                    </div>

                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-shield-alt"></i> Restriction par IP</h4>
                        <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                            L'acces a l'API est automatiquement restreint a l'adresse IP de votre serveur.
                            Pour modifier l'IP autorisee, modifiez l'IP dans les <a href="{{ path('user_servers_edit', {id: server.id}) }}" style="color:#45f882;text-decoration:underline;">informations du serveur</a>.
                        </p>
                        {% if server.ip %}
                            <div style="padding:10px 14px;background:rgba(69,248,130,0.06);border:1px solid rgba(69,248,130,0.15);border-radius:6px;font-size:12px;">
                                <i class="fas fa-lock" style="color:#45f882;margin-right:6px;"></i>
                                <span style="color:#45f882;font-weight:600;">Protection active</span>
                                <span style="color:#8b949e;"> — Seule l'IP <strong style="color:#e4e6eb;font-family:monospace;">{{ server.ip }}</strong> peut utiliser la cle API.</span>
                            </div>
                        {% else %}
                            <div style="padding:10px 14px;background:rgba(255,193,7,0.06);border:1px solid rgba(255,193,7,0.15);border-radius:6px;font-size:12px;">
                                <i class="fas fa-unlock" style="color:#ffc107;margin-right:6px;"></i>
                                <span style="color:#ffc107;font-weight:600;">Acces ouvert</span>
                                <span style="color:#8b949e;"> — Aucune IP configuree. Renseignez l'IP du serveur pour activer la protection.</span>
                            </div>
                        {% endif %}
                    </div>

                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-book"></i> Documentation API</h4>
                        <p style="color:#8b949e;font-size:13px;margin-bottom:20px;">
                            Utilisez ces endpoints pour integrer le systeme de vote Nexarena dans vos plugins et applications.
                            Tous les endpoints utilisent votre cle API.
                        </p>

                        <div style="margin-bottom:8px;">
                            <span class="api-route__label">Base URL</span>
                        </div>
                        <div class="api-example" style="margin-bottom:25px;margin-top:4px;">
                            <span>{{ app.request.schemeAndHttpHost }}/api/v1/servers/{token}</span>
                        </div>

                        {# Route 1: Vote by username #}
                        <div class="api-route">
                            <div class="api-route__header">
                                <span class="api-route__method">GET</span>
                                <span class="api-route__path">/vote/{username}</span>
                            </div>
                            <p class="api-route__desc">Verifie si un joueur a vote recemment par son pseudo Nexarena.</p>
                            <div class="api-route__label">Exemple</div>
                            <div class="api-example" style="margin-top:4px;">
                                GET <span>/api/v1/servers/{{ server.apiToken|slice(0, 8) }}...{{ server.apiToken|slice(-4) }}/vote/Notch</span>
                            </div>
                            <div class="api-route__response">
                                <div class="api-route__label" style="margin-top:8px;">Reponse</div>
                                <pre>{{ '{"voted": true, "username": "Notch", "voted_at": "2026-01-15T14:30:00+00:00"}' }}</pre>
                            </div>
                        </div>

                        {# Route 2: Vote by Discord ID #}
                        <div class="api-route">
                            <div class="api-route__header">
                                <span class="api-route__method">GET</span>
                                <span class="api-route__path">/vote/discord/{discordId}</span>
                            </div>
                            <p class="api-route__desc">Verifie si un utilisateur a vote via son ID Discord.</p>
                            <div class="api-route__label">Exemple</div>
                            <div class="api-example" style="margin-top:4px;">
                                GET <span>/api/v1/servers/{token}/vote/discord/123456789012345678</span>
                            </div>
                            <div class="api-route__response">
                                <div class="api-route__label" style="margin-top:8px;">Reponse</div>
                                <pre>{{ '{"voted": true, "discord_id": "123456789012345678", "voted_at": "2026-01-15T14:30:00+00:00"}' }}</pre>
                            </div>
                        </div>

                        {# Route 3: Vote by IP #}
                        <div class="api-route">
                            <div class="api-route__header">
                                <span class="api-route__method">GET</span>
                                <span class="api-route__path">/vote/ip/{ip}</span>
                            </div>
                            <p class="api-route__desc">Verifie si un vote a ete effectue depuis une adresse IP.</p>
                            <div class="api-route__label">Exemple</div>
                            <div class="api-example" style="margin-top:4px;">
                                GET <span>/api/v1/servers/{token}/vote/ip/192.168.1.1</span>
                            </div>
                            <div class="api-route__response">
                                <div class="api-route__label" style="margin-top:8px;">Reponse</div>
                                <pre>{{ '{"voted": true, "ip": "192.168.1.1", "voted_at": "2026-01-15T14:30:00+00:00"}' }}</pre>
                            </div>
                        </div>

                        {# Route 4: Vote by User ID #}
                        <div class="api-route">
                            <div class="api-route__header">
                                <span class="api-route__method">GET</span>
                                <span class="api-route__path">/vote/user/{userId}</span>
                            </div>
                            <p class="api-route__desc">Verifie si un utilisateur Nexarena a vote via son ID utilisateur.</p>
                            <div class="api-route__label">Exemple</div>
                            <div class="api-example" style="margin-top:4px;">
                                GET <span>/api/v1/servers/{token}/vote/user/42</span>
                            </div>
                            <div class="api-route__response">
                                <div class="api-route__label" style="margin-top:8px;">Reponse</div>
                                <pre>{{ '{"voted": true, "user_id": 42, "voted_at": "2026-01-15T14:30:00+00:00"}' }}</pre>
                            </div>
                        </div>

                        {# Route 5: Stats #}
                        <div class="api-route">
                            <div class="api-route__header">
                                <span class="api-route__method">GET</span>
                                <span class="api-route__path">/stats</span>
                            </div>
                            <p class="api-route__desc">Recupere les statistiques generales de votre serveur.</p>
                            <div class="api-route__label">Exemple</div>
                            <div class="api-example" style="margin-top:4px;">
                                GET <span>/api/v1/servers/{token}/stats</span>
                            </div>
                            <div class="api-route__response">
                                <div class="api-route__label" style="margin-top:8px;">Reponse</div>
                                <pre>{{ '{"server_id": 1, "name": "Mon Serveur", "slug": "mon-serveur", "monthly_votes": 150, "total_votes": 1200, "category": "Minecraft", "game_category": "Survie", "is_active": true}' }}</pre>
                            </div>
                        </div>

                        {# Route 6: Voters #}
                        <div class="api-route">
                            <div class="api-route__header">
                                <span class="api-route__method">GET</span>
                                <span class="api-route__path">/voters</span>
                            </div>
                            <p class="api-route__desc">Liste paginee des votants avec leur nombre de votes. Parametres : <code style="color:#45f882;">page</code> (defaut: 1), <code style="color:#45f882;">limit</code> (defaut: 20, max: 50).</p>
                            <div class="api-route__label">Exemple</div>
                            <div class="api-example" style="margin-top:4px;">
                                GET <span>/api/v1/servers/{token}/voters?page=1&amp;limit=10</span>
                            </div>
                            <div class="api-route__response">
                                <div class="api-route__label" style="margin-top:8px;">Reponse</div>
                                <pre>{{ '{"server_id": 1, "page": 1, "limit": 10, "total_voters": 45, "voters": [{"username": "Notch", "votes": 12, "last_vote": "2026-01-15T14:30:00+00:00"}]}' }}</pre>
                            </div>
                        </div>
                    </div>

                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-puzzle-piece"></i> Plugins</h4>
                        <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                            Integrez le systeme de vote sur votre serveur avec nos plugins officiels.
                        </p>
                        <a href="{{ path('plugins_index') }}" class="btn-action btn-action--primary">
                            <i class="fas fa-download"></i> Voir les plugins disponibles
                        </a>
                    </div>

                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-shield-alt"></i> Rate Limiting</h4>
                        <p style="color:#8b949e;font-size:13px;">
                            L'API est limitee a <strong style="color:#e4e6eb;">60 requetes par minute</strong> par adresse IP.
                            Les reponses incluent les headers <code style="color:#45f882;">X-RateLimit-Remaining</code> et <code style="color:#45f882;">X-RateLimit-Limit</code>.
                        </p>
                    </div>
                </div>
                {% endif %}

                {# ========== TAB: PREMIUM ========== #}
                {% if is_owner and premium_enabled %}
                <div id="tabPremium" class="manage-tab-panel">
                    {# === SOLDE SERVEUR === #}
                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-wallet" style="color:#ffd700;"></i> Solde du serveur</h4>
                        <div style="display:flex;gap:16px;flex-wrap:wrap;">
                            <div style="flex:1;min-width:160px;padding:16px 20px;background:rgba(255,107,53,0.08);border:1px solid rgba(255,107,53,0.2);border-radius:10px;text-align:center;">
                                <div style="font-size:28px;font-weight:800;color:#ff6b35;">{{ server.boostTokenBalance }}</div>
                                <div style="font-size:12px;color:#8b949e;margin-top:4px;">NexBoost</div>
                            </div>
                            <div style="flex:1;min-width:160px;padding:16px 20px;background:rgba(255,190,24,0.08);border:1px solid rgba(255,190,24,0.2);border-radius:10px;text-align:center;">
                                <div style="font-size:28px;font-weight:800;color:#ffd700;">{{ server.tokenBalance }}</div>
                                <div style="font-size:12px;color:#8b949e;margin-top:4px;">NexBits</div>
                            </div>
                        </div>
                    </div>

                    {# === DEPOT DE JETONS === #}
                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-arrow-circle-down" style="color:#1cc88a;"></i> Deposer des jetons</h4>
                        <div style="background:rgba(231,74,59,0.08);border:1px solid rgba(231,74,59,0.2);border-radius:10px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:#e74a3b;">
                            <i class="fas fa-exclamation-triangle" style="margin-right:6px;"></i>
                            <strong>Irreversible</strong> — Les jetons deposes sur le serveur ne peuvent pas etre retires. Ils seront utilises pour les fonctionnalites premium du serveur (boosts, themes, Twitch, recrutement...).
                        </div>
                        <div style="font-size:13px;color:#8b949e;margin-bottom:14px;">
                            Votre solde personnel : <strong style="color:#ffd700;">{{ app.user.tokenBalance }} NexBits</strong> / <strong style="color:#ff6b35;">{{ app.user.boostTokenBalance }} NexBoost</strong>
                            &mdash; <a href="{{ path('premium_index') }}" style="color:#ffd700;text-decoration:underline;">Acheter</a>
                        </div>
                        <form method="post" onsubmit="return confirmDeposit();">
                            <input type="hidden" name="_token" value="{{ csrf_token('server_manage') }}">
                            <input type="hidden" name="_action" value="deposit">
                            <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px;">
                                <div style="flex:1;min-width:140px;">
                                    <label style="display:block;margin-bottom:6px;font-size:12px;font-weight:600;color:#8b949e;">NexBits</label>
                                    <input type="number" name="deposit_nexbits" id="depositNexbits" class="form-input" value="0" min="0" max="{{ app.user.tokenBalance }}" style="text-align:center;">
                                </div>
                                <div style="flex:1;min-width:140px;">
                                    <label style="display:block;margin-bottom:6px;font-size:12px;font-weight:600;color:#8b949e;">NexBoost</label>
                                    <input type="number" name="deposit_nexboost" id="depositNexboost" class="form-input" value="0" min="0" max="{{ app.user.boostTokenBalance }}" style="text-align:center;">
                                </div>
                            </div>
                            <button type="submit" class="btn-action btn-action--primary" style="background:linear-gradient(135deg,#1cc88a,#17a673);border:none;">
                                <i class="fas fa-arrow-circle-down"></i> Deposer sur le serveur
                            </button>
                        </form>
                    </div>

                    {# === BOOSTS (MISES EN AVANT) === #}
                    {% if can_manage_boost %}
                    <div class="manage-card">
                        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:16px;">
                            <h4 class="manage-card__title" style="margin-bottom:0;border-bottom:none;padding-bottom:0;"><i class="fas fa-bolt" style="color:#ff6b35;"></i> Mises en avant</h4>
                            <a href="{{ path('featured_booking', {id: server.id}) }}" class="btn-action btn-action--primary" style="background:linear-gradient(135deg,#ff6b35,#ffd700);color:#000;border:none;font-size:12px;padding:6px 14px;">
                                <i class="fas fa-calendar-alt"></i> Reserver
                            </a>
                        </div>
                        {% if server_bookings|length > 0 %}
                            <div style="overflow-x:auto;">
                                <table style="width:100%;border-collapse:collapse;font-size:13px;">
                                    <thead>
                                        <tr style="border-bottom:1px solid #1e3048;">
                                            <th style="padding:8px 10px;text-align:center;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Scope</th>
                                            <th style="padding:8px 10px;text-align:center;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Pos.</th>
                                            <th style="padding:8px 10px;text-align:left;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Debut</th>
                                            <th style="padding:8px 10px;text-align:left;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Fin</th>
                                            <th style="padding:8px 10px;text-align:center;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Cout</th>
                                            <th style="padding:8px 10px;text-align:center;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Statut</th>
                                            <th style="padding:8px 10px;text-align:right;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% set now = "now"|date("U") %}
                                        {% for booking in server_bookings %}
                                            {% set starts = booking.startsAt|date("U") %}
                                            {% set ends = booking.endsAt|date("U") %}
                                            {% if now < starts %}
                                                {% set status = 'upcoming' %}
                                            {% elseif now >= starts and now < ends %}
                                                {% set status = 'active' %}
                                            {% else %}
                                                {% set status = 'past' %}
                                            {% endif %}
                                            <tr style="border-bottom:1px solid #1e3048;{{ status == 'past' ? 'opacity:0.5;' : '' }}">
                                                <td style="padding:10px;text-align:center;">
                                                    {% if booking.scope == 'homepage' %}
                                                        <span style="font-size:10px;padding:2px 8px;border-radius:4px;background:rgba(255,215,0,0.1);color:#ffd700;border:1px solid rgba(255,215,0,0.2);">Accueil</span>
                                                    {% else %}
                                                        <span style="font-size:10px;padding:2px 8px;border-radius:4px;background:rgba(69,248,130,0.1);color:#45f882;border:1px solid rgba(69,248,130,0.2);">{{ booking.gameCategory ? booking.gameCategory.name : 'Jeu' }}</span>
                                                    {% endif %}
                                                </td>
                                                <td style="padding:10px;text-align:center;color:#ffd700;font-weight:700;">#{{ booking.position }}</td>
                                                <td style="padding:10px;color:#e4e6eb;">{{ booking.startsAt|date('d/m/Y H:i') }}</td>
                                                <td style="padding:10px;color:#e4e6eb;">{{ booking.endsAt|date('d/m/Y H:i') }}</td>
                                                <td style="padding:10px;text-align:center;color:#ff6b35;font-weight:600;">{{ booking.boostTokensUsed }} <i class="fas fa-bolt" style="font-size:10px;"></i></td>
                                                <td style="padding:10px;text-align:center;">
                                                    {% if status == 'active' %}
                                                        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(28,200,138,0.12);color:#1cc88a;border:1px solid rgba(28,200,138,0.2);font-weight:600;">
                                                            <i class="fas fa-circle" style="font-size:6px;vertical-align:middle;margin-right:3px;"></i> En cours
                                                        </span>
                                                    {% elseif status == 'upcoming' %}
                                                        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(54,185,204,0.12);color:#36b9cc;border:1px solid rgba(54,185,204,0.2);font-weight:600;">
                                                            <i class="fas fa-clock" style="font-size:10px;margin-right:3px;"></i> Planifie
                                                        </span>
                                                    {% else %}
                                                        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(139,148,158,0.12);color:#8b949e;border:1px solid rgba(139,148,158,0.2);font-weight:600;">
                                                            Termine
                                                        </span>
                                                    {% endif %}
                                                </td>
                                                <td style="padding:10px;text-align:right;">
                                                    {% if status == 'upcoming' %}
                                                        <form method="post" action="{{ path('user_servers_cancel_boost', {id: server.id, bookingId: booking.id}) }}" onsubmit="return confirm('Annuler cette reservation ? Les NexBoost seront recredites.');" style="display:inline;">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('cancel_boost_' ~ booking.id) }}">
                                                            <button type="submit" class="btn-action btn-action--danger" style="padding:4px 10px;font-size:11px;">
                                                                <i class="fas fa-times"></i> Annuler
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div style="text-align:center;padding:30px 10px;color:#5a5c69;">
                                <i class="fas fa-bolt" style="font-size:28px;color:#3d4250;margin-bottom:10px;display:block;"></i>
                                Aucune mise en avant pour ce serveur.
                                <div style="margin-top:10px;">
                                    <a href="{{ path('featured_booking', {id: server.id}) }}" style="color:#ff6b35;font-size:13px;text-decoration:underline;">Reserver un creneau</a>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                    {% endif %}{# can_manage_boost #}

                    {# === HISTORIQUE DES TRANSACTIONS SERVEUR === #}
                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-receipt" style="color:#36b9cc;"></i> Historique des transactions du serveur</h4>
                        {% if server_transactions|length > 0 %}
                            <div style="overflow-x:auto;">
                                <table style="width:100%;border-collapse:collapse;font-size:13px;">
                                    <thead>
                                        <tr style="border-bottom:1px solid #1e3048;">
                                            <th style="padding:8px 10px;text-align:left;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">N°</th>
                                            <th style="padding:8px 10px;text-align:left;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Date</th>
                                            <th style="padding:8px 10px;text-align:center;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Type</th>
                                            <th style="padding:8px 10px;text-align:left;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Par</th>
                                            <th style="padding:8px 10px;text-align:left;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">Description</th>
                                            <th style="padding:8px 10px;text-align:center;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">NexBits</th>
                                            <th style="padding:8px 10px;text-align:center;color:#8b949e;font-weight:600;font-size:11px;text-transform:uppercase;">NexBoost</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for tx in server_transactions %}
                                            <tr style="border-bottom:1px solid #1e3048;">
                                                <td style="padding:10px;color:#8b949e;font-family:monospace;font-size:12px;">#{{ tx.id }}</td>
                                                <td style="padding:10px;color:#e4e6eb;white-space:nowrap;">{{ tx.createdAt|date('d/m/Y H:i') }}</td>
                                                <td style="padding:10px;text-align:center;">
                                                    {% if tx.type == 'deposit' %}
                                                        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(28,200,138,0.12);color:#1cc88a;border:1px solid rgba(28,200,138,0.2);font-weight:600;">Depot</span>
                                                    {% elseif tx.type == 'spend' %}
                                                        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(255,107,53,0.12);color:#ff6b35;border:1px solid rgba(255,107,53,0.2);font-weight:600;">Depense</span>
                                                    {% elseif tx.type == 'refund' %}
                                                        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(54,185,204,0.12);color:#36b9cc;border:1px solid rgba(54,185,204,0.2);font-weight:600;">Remboursement</span>
                                                    {% else %}
                                                        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:rgba(139,148,158,0.12);color:#8b949e;border:1px solid rgba(139,148,158,0.2);font-weight:600;">{{ tx.type }}</span>
                                                    {% endif %}
                                                </td>
                                                <td style="padding:10px;color:#c9d1d9;font-size:12px;">
                                                    {{ tx.user ? tx.user.username : '—' }}
                                                </td>
                                                <td style="padding:10px;color:#c9d1d9;font-size:12px;max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="{{ tx.description }}">
                                                    {{ tx.description ?? '—' }}
                                                </td>
                                                <td style="padding:10px;text-align:center;">
                                                    {% if tx.tokensAmount != 0 %}
                                                        <span style="color:{{ tx.tokensAmount > 0 ? '#1cc88a' : '#e74a3b' }};font-weight:600;">
                                                            {{ tx.tokensAmount > 0 ? '+' : '' }}{{ tx.tokensAmount }}
                                                        </span>
                                                    {% else %}
                                                        <span style="color:#5a5c69;">—</span>
                                                    {% endif %}
                                                </td>
                                                <td style="padding:10px;text-align:center;">
                                                    {% if tx.boostTokensAmount != 0 %}
                                                        <span style="color:{{ tx.boostTokensAmount > 0 ? '#1cc88a' : '#e74a3b' }};font-weight:600;">
                                                            {{ tx.boostTokensAmount > 0 ? '+' : '' }}{{ tx.boostTokensAmount }}
                                                        </span>
                                                    {% else %}
                                                        <span style="color:#5a5c69;">—</span>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div style="text-align:center;padding:30px 10px;color:#5a5c69;">
                                <i class="fas fa-receipt" style="font-size:28px;color:#3d4250;margin-bottom:10px;display:block;"></i>
                                Aucune transaction pour ce serveur.
                                <div style="margin-top:10px;">
                                    Deposez des jetons ci-dessus pour commencer.
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
                {% endif %}

                {# ========== TAB: STATS ========== #}
                {% if is_owner %}
                <div id="tabStats" class="manage-tab-panel">
                    {% if is_stats_gated and not has_stats %}
                    {# ── VERROUILLE ── #}
                    <div class="manage-card" style="text-align:center;padding:40px 20px;">
                        <i class="fas fa-lock" style="font-size:48px;color:#36b9cc;margin-bottom:16px;display:block;"></i>
                        <h4 style="color:#fff;margin-bottom:8px;">Statistiques avancees</h4>
                        <p style="color:#8b949e;font-size:14px;margin-bottom:8px;">
                            Debloque les graphiques complets sur 30 jours :
                        </p>
                        <ul style="color:#8b949e;font-size:13px;list-style:none;padding:0;margin-bottom:20px;">
                            <li><i class="fas fa-chart-line" style="color:#36b9cc;margin-right:6px;"></i> Vues et votes quotidiens (30 j)</li>
                            <li><i class="fas fa-clock" style="color:#36b9cc;margin-right:6px;"></i> Repartition horaire des votes</li>
                            <li><i class="fab fa-discord" style="color:#36b9cc;margin-right:6px;"></i> Votes par plateforme (Discord / Steam)</li>
                        </ul>
                        <div style="display:flex;justify-content:center;gap:16px;flex-wrap:wrap;margin-bottom:20px;">
                            <div style="padding:10px 18px;background:rgba(54,185,204,0.08);border:1px solid rgba(54,185,204,0.2);border-radius:8px;">
                                <i class="fas fa-coins" style="color:#36b9cc;"></i>
                                <span style="color:#fff;font-weight:700;margin-left:6px;">{{ stats_cost }}</span>
                                <span style="color:#8b949e;font-size:12px;"> NexBits</span>
                            </div>
                            <div style="padding:10px 18px;background:rgba(255,190,24,0.08);border:1px solid rgba(255,190,24,0.2);border-radius:8px;">
                                <span style="color:#8b949e;font-size:12px;">Solde serveur : </span>
                                <span style="color:#ffd700;font-weight:700;">{{ server.tokenBalance }}</span>
                                <span style="color:#8b949e;font-size:12px;"> NexBits</span>
                            </div>
                        </div>
                        {% if server.tokenBalance >= stats_cost %}
                        <form method="post" action="{{ path('user_servers_stats_unlock', {id: server.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('stats_unlock_' ~ server.id) }}">
                            <button type="submit" class="btn-action btn-action--primary" style="background:linear-gradient(135deg,#36b9cc,#1a7a8a);color:#fff;border:none;margin:0 auto;">
                                <i class="fas fa-unlock"></i> Debloquer pour {{ stats_cost }} NexBits
                            </button>
                        </form>
                        {% else %}
                        <p style="color:#e74a3b;font-size:13px;margin:0;">
                            <i class="fas fa-exclamation-circle"></i> Solde insuffisant. Deposez des NexBits depuis l'onglet <strong style="cursor:pointer;" onclick="switchManageTab('premium')">Premium</strong>.
                        </p>
                        {% endif %}
                    </div>
                    {% else %}
                    {# ── DEBLOQUE ── #}

                    {# KPI cards #}
                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-chart-line" style="color:#36b9cc;"></i> Statistiques — 30 derniers jours</h4>
                        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-bottom:0;">
                            <div style="padding:14px;background:rgba(54,185,204,0.08);border:1px solid rgba(54,185,204,0.2);border-radius:10px;text-align:center;">
                                <div style="font-size:26px;font-weight:800;color:#36b9cc;">{{ stats_data.monthly_views }}</div>
                                <div style="font-size:12px;color:#8b949e;margin-top:4px;">Vues / mois</div>
                            </div>
                            <div style="padding:14px;background:rgba(69,248,130,0.08);border:1px solid rgba(69,248,130,0.2);border-radius:10px;text-align:center;">
                                <div style="font-size:26px;font-weight:800;color:#45f882;">{{ stats_data.monthly_votes }}</div>
                                <div style="font-size:12px;color:#8b949e;margin-top:4px;">Votes / mois</div>
                            </div>
                            <div style="padding:14px;background:rgba(255,190,24,0.08);border:1px solid rgba(255,190,24,0.2);border-radius:10px;text-align:center;">
                                <div style="font-size:26px;font-weight:800;color:#ffd700;">{{ stats_data.total_clicks }}</div>
                                <div style="font-size:12px;color:#8b949e;margin-top:4px;">Clics total</div>
                            </div>
                            <div style="padding:14px;background:rgba(255,107,53,0.08);border:1px solid rgba(255,107,53,0.2);border-radius:10px;text-align:center;">
                                <div style="font-size:26px;font-weight:800;color:#ff6b35;">{{ stats_data.total_votes }}</div>
                                <div style="font-size:12px;color:#8b949e;margin-top:4px;">Votes total</div>
                            </div>
                        </div>
                    </div>

                    {# Dual line chart: views + votes over 30 days #}
                    <div class="manage-card">
                        <h4 class="manage-card__title"><i class="fas fa-chart-area" style="color:#36b9cc;"></i> Vues &amp; Votes quotidiens</h4>
                        <canvas id="chartDailyStats" height="120"></canvas>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                        {# Doughnut: providers #}
                        <div class="manage-card">
                            <h4 class="manage-card__title" style="font-size:13px;"><i class="fas fa-pie-chart" style="color:#36b9cc;"></i> Providers</h4>
                            <canvas id="chartProviders" height="180"></canvas>
                        </div>
                        {# Bar: hours #}
                        <div class="manage-card" style="grid-column:1/-1;">
                            <h4 class="manage-card__title" style="font-size:13px;"><i class="fas fa-clock" style="color:#36b9cc;"></i> Votes par heure (0–23h)</h4>
                            <canvas id="chartHours" height="100"></canvas>
                        </div>
                    </div>

                    {# Chart.js CDN + init #}
                    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
                    <script>
                    (function() {
                        var baseOpts = {
                            responsive: true,
                            animation: { duration: 600 },
                            plugins: { legend: { labels: { color: '#8b949e', font: { size: 12 } } } }
                        };
                        var gridColor  = 'rgba(255,255,255,0.05)';
                        var tickColor  = '#8b949e';
                        var scalesXY   = {
                            x: { ticks: { color: tickColor, font: { size: 11 } }, grid: { color: gridColor } },
                            y: { ticks: { color: tickColor, font: { size: 11 } }, grid: { color: gridColor }, beginAtZero: true }
                        };

                        // ── Daily views + votes ──
                        var dailyData = {{ stats_data.daily_views|json_encode|raw }};
                        var votesData = {{ stats_data.daily_votes|json_encode|raw }};
                        var labels30  = dailyData.map(function(r){ return r.date.slice(5); });
                        new Chart(document.getElementById('chartDailyStats'), {
                            type: 'line',
                            data: {
                                labels: labels30,
                                datasets: [
                                    { label: 'Vues',  data: dailyData.map(function(r){ return r.views; }),
                                      borderColor: '#36b9cc', backgroundColor: 'rgba(54,185,204,0.12)',
                                      tension: 0.3, fill: true, pointRadius: 2 },
                                    { label: 'Votes', data: votesData.map(function(r){ return r.votes; }),
                                      borderColor: '#45f882', backgroundColor: 'rgba(69,248,130,0.10)',
                                      tension: 0.3, fill: true, pointRadius: 2 }
                                ]
                            },
                            options: Object.assign({}, baseOpts, { scales: scalesXY })
                        });

                        // ── Provider doughnut ──
                        var provData = {{ stats_data.vote_providers|json_encode|raw }};
                        var provColors = ['#5865f2','#b5bac1','#36b9cc','#45f882','#ffd700','#ff6b35'];
                        new Chart(document.getElementById('chartProviders'), {
                            type: 'doughnut',
                            data: {
                                labels: provData.map(function(r){ return r.provider === 'unknown' ? 'Autre' : r.provider.charAt(0).toUpperCase() + r.provider.slice(1); }),
                                datasets: [{ data: provData.map(function(r){ return r.votes; }),
                                    backgroundColor: provColors, borderWidth: 0 }]
                            },
                            options: Object.assign({}, baseOpts, { cutout: '65%' })
                        });

                        // ── Hourly bar ──
                        var hourData = {{ stats_data.vote_hours|json_encode|raw }};
                        new Chart(document.getElementById('chartHours'), {
                            type: 'bar',
                            data: {
                                labels: hourData.map(function(r){ return r.hour + 'h'; }),
                                datasets: [{ label: 'Votes', data: hourData.map(function(r){ return r.votes; }),
                                    backgroundColor: 'rgba(54,185,204,0.6)', borderColor: '#36b9cc', borderWidth: 1 }]
                            },
                            options: Object.assign({}, baseOpts, { scales: scalesXY, plugins: { legend: { display: false } } })
                        });
                    })();
                    </script>
                    {% endif %}
                </div>
                {% endif %}

            </div>

            <div class="col-lg-4">
                {# === STATISTIQUES === #}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-chart-bar"></i> Statistiques</h4>
                    <div class="stat-grid">
                        <div class="stat-item">
                            <div class="stat-item__value">{{ server.monthlyVotes }}</div>
                            <div class="stat-item__label">Votes / mois</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-item__value">{{ server.totalVotes }}</div>
                            <div class="stat-item__label">Votes total</div>
                        </div>
                    </div>
                </div>

                {# === INFOS RAPIDES === #}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-info-circle"></i> Infos</h4>
                    <div style="font-size:13px;">
                        <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #1e3048;">
                            <span style="color:#8b949e;">Categorie</span>
                            <span style="color:#fff;">{{ server.category ? server.category.name : '—' }}</span>
                        </div>
                        {% if server.gameCategory %}
                        <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #1e3048;">
                            <span style="color:#8b949e;">Jeu</span>
                            <span style="color:#fff;">{{ server.gameCategory.name }}</span>
                        </div>
                        {% endif %}
                        {% if server.serverType %}
                        <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #1e3048;">
                            <span style="color:#8b949e;">Type</span>
                            <span style="color:#fff;">{{ server.serverType.name }}</span>
                        </div>
                        {% endif %}
                        {% if server.ip %}
                        <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #1e3048;">
                            <span style="color:#8b949e;">IP</span>
                            <span style="color:#fff;font-family:monospace;">{{ server.ip }}{% if server.port %}:{{ server.port }}{% endif %}</span>
                        </div>
                        {% endif %}
                        <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #1e3048;">
                            <span style="color:#8b949e;">Cree le</span>
                            <span style="color:#fff;">{{ server.createdAt|date('d/m/Y') }}</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;padding:6px 0;">
                            <span style="color:#8b949e;">Slug</span>
                            <span style="color:#45f882;">/serveur/{{ server.slug }}</span>
                        </div>
                    </div>
                </div>

                {# === LIENS RAPIDES === #}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-external-link-alt"></i> Liens rapides</h4>
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        {% if server.isApproved and server.isActive %}
                            <a href="{{ path('server_show', {slug: server.slug}) }}" class="btn-action btn-action--outline" style="justify-content:center;">
                                <i class="fas fa-eye"></i> Voir la page publique
                            </a>
                        {% endif %}
                        {% if can_edit_info or can_edit_images or can_edit_social %}
                            <a href="{{ path('user_servers_edit', {id: server.id}) }}" class="btn-action btn-action--outline" style="justify-content:center;">
                                <i class="fas fa-edit"></i> Modifier le serveur
                            </a>
                        {% endif %}
                    </div>
                </div>

                {# === COLLABORATEURS (owner only) === #}
                {% if is_owner %}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-users"></i> Collaborateurs</h4>

                    {# Add form #}
                    <form method="post" action="{{ path('user_servers_collab_add', {id: server.id}) }}" style="margin-bottom:18px;">
                        <input type="hidden" name="_token" value="{{ csrf_token('collab_add') }}">
                        <div style="display:flex;gap:8px;">
                            <input type="text" name="username" class="form-input" placeholder="Nom d'utilisateur" required style="flex:1;">
                            <button type="submit" class="btn-action btn-action--primary" style="white-space:nowrap;">
                                <i class="fas fa-plus"></i> Ajouter
                            </button>
                        </div>
                    </form>

                    {# Collaborator list #}
                    {% if collaborators|length > 0 %}
                        {% for collab in collaborators %}
                            <div class="collab-item">
                                <div class="collab-item__header">
                                    <div class="collab-item__avatar">
                                        {% set collabAvatar = user_avatar(collab.user) %}
                                        {% if collabAvatar %}
                                            <img src="{{ collabAvatar starts with 'http' ? collabAvatar : asset(collabAvatar) }}" alt="{{ collab.user.username }}">
                                        {% else %}
                                            {{ collab.user.username|slice(0, 1)|upper }}
                                        {% endif %}
                                    </div>
                                    <div class="collab-item__info">
                                        <div class="collab-item__name">{{ collab.user.username }}</div>
                                        <div class="collab-item__date">Ajoute le {{ collab.addedAt|date('d/m/Y') }}</div>
                                    </div>
                                    <form method="post" action="{{ path('user_servers_collab_remove', {id: server.id, collabId: collab.id}) }}" onsubmit="return confirm('Retirer ce collaborateur ?');" style="margin:0;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('collab_remove_' ~ collab.id) }}">
                                        <button type="submit" class="btn-action btn-action--danger" style="padding:5px 10px;font-size:11px;">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </form>
                                </div>

                                {# Permissions form #}
                                <form method="post" action="{{ path('user_servers_collab_update', {id: server.id, collabId: collab.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('collab_perms_' ~ collab.id) }}">
                                    <div class="collab-perms-grid">
                                        {% for code, label in permissions %}
                                            <label class="collab-perm-check">
                                                <input type="checkbox" name="permissions[]" value="{{ code }}" {{ collab.hasPermission(code) ? 'checked' : '' }}>
                                                {{ label }}
                                            </label>
                                        {% endfor %}
                                    </div>
                                    <div class="collab-item__actions">
                                        <button type="submit" class="btn-action btn-action--primary" style="padding:5px 12px;font-size:11px;">
                                            <i class="fas fa-save"></i> Sauvegarder
                                        </button>
                                    </div>
                                </form>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="collab-empty">
                            <i class="fas fa-user-plus" style="font-size:20px;color:#3d4250;margin-bottom:6px;display:block;"></i>
                            Aucun collaborateur pour le moment.
                        </div>
                    {% endif %}
                </div>
                {% endif %}

                {# === BOOST / MISE EN AVANT === #}
                {% if can_manage_boost and premium_enabled %}
                <div class="manage-card">
                    <h4 class="manage-card__title"><i class="fas fa-bolt" style="color:#ff6b35;"></i> Mise en avant</h4>
                    <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                        Reservez un emplacement pour mettre votre serveur en avant sur la page d'accueil.
                        Consultez l'onglet <strong style="color:#ffd700;cursor:pointer;" onclick="switchManageTab('premium')">Premium</strong> pour voir vos reservations et transactions.
                    </p>
                    <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
                        <div style="padding:8px 16px;background:rgba(255,107,53,0.1);border:1px solid rgba(255,107,53,0.2);border-radius:8px;">
                            <i class="fas fa-bolt" style="color:#ff6b35;"></i>
                            <span style="color:#fff;font-weight:600;margin-left:4px;">{{ server.boostTokenBalance }}</span>
                            <span style="color:#8b949e;font-size:12px;"> NexBoost</span>
                        </div>
                        <div style="padding:8px 16px;background:rgba(255,190,24,0.08);border:1px solid rgba(255,190,24,0.2);border-radius:8px;">
                            <i class="fas fa-coins" style="color:#ffd700;"></i>
                            <span style="color:#fff;font-weight:600;margin-left:4px;">{{ server.tokenBalance }}</span>
                            <span style="color:#8b949e;font-size:12px;"> NexBits</span>
                        </div>
                    </div>
                    <a href="{{ path('featured_booking', {id: server.id}) }}" class="btn-action btn-action--primary" style="background:linear-gradient(135deg,#ff6b35,#ffd700);color:#000;border:none;">
                        <i class="fas fa-calendar-alt"></i> Reserver une date
                    </a>
                </div>
                {% endif %}

                {# === SUPPRIMER === #}
                {% if can_delete_server %}
                <div class="manage-card" style="border-color:rgba(231,74,59,0.2);">
                    <h4 class="manage-card__title" style="border-bottom-color:rgba(231,74,59,0.2);">
                        <i class="fas fa-exclamation-triangle" style="color:#e74a3b;"></i> Zone de danger
                    </h4>
                    <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                        La suppression d'un serveur est irreversible. Toutes les donnees associees seront perdues.
                    </p>
                    <form method="post" action="{{ path('user_servers_delete', {id: server.id}) }}" onsubmit="return confirm('Supprimer definitivement ce serveur ? Cette action est irreversible.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_server_' ~ server.id) }}">
                        <button type="submit" class="btn-action btn-action--danger">
                            <i class="fas fa-trash-alt"></i> Supprimer le serveur
                        </button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# === FLAG MODAL === #}
{% if can_moderate_comments %}
<div class="flag-modal" id="flagModal">
    <div class="flag-modal__content">
        <div class="flag-modal__title"><i class="fas fa-flag" style="color:#f6c23e;"></i>&nbsp; Signaler ce commentaire</div>
        <form id="flagForm" method="post" action="">
            <input type="hidden" name="_token" id="flagToken" value="">
            <textarea name="reason" class="flag-modal__textarea" placeholder="Raison du signalement (optionnel)..." maxlength="255"></textarea>
            <div class="flag-modal__actions">
                <button type="button" class="flag-modal__cancel" onclick="closeFlagModal()">Annuler</button>
                <button type="submit" class="flag-modal__submit"><i class="fas fa-flag"></i>&nbsp; Signaler</button>
            </div>
        </form>
    </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
<script>
/* === Manage tabs === */
window.switchManageTab = function(tab) {
    document.querySelectorAll('.manage-tabs__btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.getAttribute('data-tab') === tab);
    });
    document.querySelectorAll('.manage-tab-panel').forEach(function(panel) {
        panel.classList.remove('active');
    });
    var target = document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1));
    if (target) target.classList.add('active');
};

/* === Deposit confirmation === */
window.confirmDeposit = function() {
    var nb = parseInt(document.getElementById('depositNexbits').value) || 0;
    var boost = parseInt(document.getElementById('depositNexboost').value) || 0;
    if (nb <= 0 && boost <= 0) {
        alert('Veuillez saisir un montant a deposer.');
        return false;
    }
    var parts = [];
    if (nb > 0) parts.push(nb + ' NexBits');
    if (boost > 0) parts.push(boost + ' NexBoost');
    return confirm('Deposer ' + parts.join(' + ') + ' sur ce serveur ?\n\nCette action est IRREVERSIBLE. Les jetons ne pourront pas etre retires.');
};

window.copyWidgetCode = function(textareaId, btn) {
    var textarea = document.getElementById(textareaId);
    if (!textarea) return;
    navigator.clipboard.writeText(textarea.value).then(function() {
        var orig = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check"></i> Copie !';
        setTimeout(function() { btn.innerHTML = orig; }, 2000);
    });
};

window.selectTheme = function(key) {
    document.getElementById('selectedTheme').value = key;
    document.querySelectorAll('.theme-card').forEach(function(card) {
        card.classList.toggle('theme-card--active', card.getAttribute('data-theme') === key);
    });
};

/* === Widget configurator === */
(function() {
    var baseCardUrl = '{{ url("widget_card", {slug: server.slug}) }}';
    var baseVotersUrl = '{{ url("widget_voters", {slug: server.slug}) }}';
    var currentTab = 'card';
    var currentStyle = 'dark';

    // Heights: card with full desc (255 chars = ~5-6 lines) | voters = 500
    var CARD_FULL = 400;
    var CARD_NO_DESC = 240;
    var CARD_NO_FOOTER = 360;
    var CARD_COMPACT = 205;
    var VOTERS_H = 500;

    // Preset configs: { url params, card height, voters height, previewClass, description }
    var presets = {
        dark: {
            params: 'mode=dark&bg=1a1a2e',
            cardH: CARD_FULL, votersH: VOTERS_H,
            preview: 'wg-preview-dark',
            desc: '<i class="fas fa-info-circle" style="margin-right:4px;"></i> Fond sombre, texte blanc, accent vert — ideal pour tous les sites.'
        },
        light: {
            params: 'mode=light',
            cardH: CARD_FULL, votersH: VOTERS_H,
            preview: 'wg-preview-light',
            desc: '<i class="fas fa-info-circle" style="margin-right:4px;"></i> Fond blanc, texte sombre, accent vert — ideal pour les sites clairs.'
        },
        colored: {
            params: 'mode=dark&accent=ff4655&bg=1a1a2e&radius=20',
            cardH: CARD_FULL, votersH: VOTERS_H,
            preview: 'wg-preview-colored',
            desc: '<i class="fas fa-info-circle" style="margin-right:4px;"></i> Accent rouge, fond sombre, bords arrondis — style gaming.'
        },
        compact: {
            params: 'mode=dark&bg=1a1a2e&hideFooter=1&hideDesc=1',
            cardH: CARD_COMPACT, votersH: VOTERS_H,
            preview: 'wg-preview-dark',
            desc: '<i class="fas fa-info-circle" style="margin-right:4px;"></i> Version compacte sans description ni footer — gain de place.'
        }
    };

    function buildPresetUrl(style) {
        var base = currentTab === 'card' ? baseCardUrl : baseVotersUrl;
        return base + '?' + presets[style].params;
    }

    function buildCustomUrl() {
        var base = currentTab === 'card' ? baseCardUrl : baseVotersUrl;
        var bgTransparent = document.getElementById('wgBgTransparent').checked;
        var accent = document.getElementById('wgAccent').value;
        var bg = bgTransparent ? 'transparent' : document.getElementById('wgBg').value;
        var text = document.getElementById('wgText').value;
        var radius = document.getElementById('wgRadius').value;
        var hideFooter = document.getElementById('wgHideFooter').checked;
        var hideDesc = document.getElementById('wgHideDesc').checked;

        var params = ['mode=dark'];
        if (accent !== '#45f882') params.push('accent=' + accent.replace('#', ''));
        if (bg !== 'transparent') params.push('bg=' + bg.replace('#', ''));
        if (text !== '#ffffff') params.push('text=' + text.replace('#', ''));
        if (radius !== '12') params.push('radius=' + radius);
        if (hideFooter) params.push('hideFooter=1');
        if (hideDesc && currentTab === 'card') params.push('hideDesc=1');
        return base + '?' + params.join('&');
    }

    function getCustomHeight() {
        if (currentTab === 'voters') return VOTERS_H;
        var hideDesc = document.getElementById('wgHideDesc').checked;
        var hideFooter = document.getElementById('wgHideFooter').checked;
        if (hideDesc && hideFooter) return CARD_COMPACT;
        if (hideDesc) return CARD_NO_DESC;
        if (hideFooter) return CARD_NO_FOOTER;
        return CARD_FULL;
    }

    window.updateWidgetPreview = function() {
        var url, height, previewClass;

        if (currentStyle === 'custom') {
            url = buildCustomUrl();
            height = getCustomHeight();
            previewClass = 'wg-preview-dark';
            document.getElementById('wgAccentHex').textContent = document.getElementById('wgAccent').value;
            document.getElementById('wgTextHex').textContent = document.getElementById('wgText').value;
            document.getElementById('wgRadiusVal').textContent = document.getElementById('wgRadius').value;
        } else {
            var p = presets[currentStyle];
            url = buildPresetUrl(currentStyle);
            height = currentTab === 'card' ? p.cardH : p.votersH;
            previewClass = p.preview;
        }

        document.getElementById('wgPreviewContainer').className = previewClass;
        var iframe = document.getElementById('wgPreviewIframe');
        iframe.src = url;
        iframe.height = height;
        document.getElementById('wgEmbedCode').value = '<iframe src="' + url + '" width="350" height="' + height + '" frameborder="0" scrolling="no" style="border:none;"></iframe>';
    };

    window.switchWidgetStyle = function(style) {
        currentStyle = style;
        document.querySelectorAll('.wg-style-btn').forEach(function(el) {
            el.classList.toggle('wg-style-btn--active', el.getAttribute('data-style') === style);
        });
        document.getElementById('wgCustomControls').style.display = style === 'custom' ? 'block' : 'none';

        // Update description
        var descEl = document.getElementById('wgStyleDesc');
        if (style === 'custom') {
            descEl.innerHTML = '<i class="fas fa-info-circle" style="margin-right:4px;"></i> Basé sur le mode sombre — personnalisez chaque aspect du widget.';
        } else {
            descEl.innerHTML = presets[style].desc;
        }

        // Show/hide desc checkbox (only for custom + card)
        var descLabel = document.getElementById('wgHideDescLabel');
        if (descLabel) descLabel.style.display = (style === 'custom' && currentTab === 'card') ? 'flex' : 'none';

        updateWidgetPreview();
    };

    window.switchWidgetTab = function(tab) {
        currentTab = tab;
        document.querySelectorAll('.widget-tab').forEach(function(el) {
            el.classList.toggle('widget-tab--active', el.getAttribute('data-tab') === tab);
        });
        var descLabel = document.getElementById('wgHideDescLabel');
        if (descLabel) descLabel.style.display = (currentStyle === 'custom' && tab === 'card') ? 'flex' : 'none';
        updateWidgetPreview();
    };

    window.toggleBgTransparent = function() {
        document.getElementById('wgBg').disabled = document.getElementById('wgBgTransparent').checked;
        updateWidgetPreview();
    };

    updateWidgetPreview();
})();
</script>
{% if server.statusCheckEnabled and server.ip and server.port %}
<script>
(function() {
    fetch('/serveur/{{ server.slug }}/status')
    .then(function(r) { return r.json(); })
    .then(function(d) {
        var el = document.getElementById('statusPreview');
        if (!el) return;
        if (d.online === true) {
            el.innerHTML = '<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#1cc88a;margin-right:6px;"></span><span style="color:#1cc88a;font-weight:600;">En ligne</span>';
        } else if (d.online === false) {
            el.innerHTML = '<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#e74a3b;margin-right:6px;"></span><span style="color:#e74a3b;font-weight:600;">Hors ligne</span>';
        } else {
            el.innerHTML = '<span style="color:#5a5c69;">Indisponible</span>';
        }
    })
    .catch(function() {
        var el = document.getElementById('statusPreview');
        if (el) el.innerHTML = '<span style="color:#5a5c69;">Erreur</span>';
    });
})();
</script>
{% endif %}

{% if can_moderate_comments %}
<script>
(function() {
    var flagTokens = {
        {% for comment in comments %}
            {% if not comment.isFlagged %}
                {{ comment.id }}: '{{ csrf_token('flag_comment_' ~ comment.id) }}',
            {% endif %}
        {% endfor %}
    };

    window.openFlagModal = function(commentId) {
        var modal = document.getElementById('flagModal');
        var form = document.getElementById('flagForm');
        var tokenInput = document.getElementById('flagToken');
        if (!modal || !form) return;
        form.action = '{{ path('user_servers_manage', {id: server.id}) }}/comment/' + commentId + '/flag';
        tokenInput.value = flagTokens[commentId] || '';
        modal.classList.add('active');
    };

    window.closeFlagModal = function() {
        var modal = document.getElementById('flagModal');
        if (modal) modal.classList.remove('active');
    };

    var flagModal = document.getElementById('flagModal');
    if (flagModal) {
        flagModal.addEventListener('click', function(e) {
            if (e.target === flagModal) closeFlagModal();
        });
    }
})();
</script>
{% endif %}
{% endblock %}
