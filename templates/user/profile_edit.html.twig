{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/profile.css') }}">
<style>
.edit-profile { padding: 80px 0; min-height: 60vh; }
.edit-section { margin-bottom: 24px; }
.edit-card { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); border-radius:12px; padding:24px; margin-bottom:20px; }
.edit-card__title { font-size:16px; font-weight:600; color:#fff; margin-bottom:16px; display:flex; align-items:center; gap:8px; }
.edit-card__title i { color:#45f882; }
.edit-input { width:100%; background:#1a1a2e; border:1px solid rgba(255,255,255,0.1); border-radius:8px; padding:10px 14px; color:#fff; font-size:14px; }
.edit-input:focus { border-color:#45f882; outline:none; }
.edit-label { display:block; font-size:13px; color:#8b949e; margin-bottom:6px; }
.edit-group { margin-bottom:16px; }
.edit-toggle { display:flex; align-items:center; gap:10px; margin-bottom:8px; }
.edit-toggle input[type="checkbox"] { accent-color:#45f882; width:18px; height:18px; cursor:pointer; }
.edit-toggle label { font-size:13px; color:#c9d1d9; cursor:pointer; }
.game-row { display:flex; gap:8px; margin-bottom:8px; align-items:center; }
.game-row input { flex:1; }
.game-row .btn-remove { background:none; border:none; color:#ff4757; cursor:pointer; font-size:16px; padding:4px 8px; }
.btn-add-game { background:none; border:1px dashed rgba(255,255,255,0.15); color:#8b949e; padding:8px 14px; border-radius:8px; cursor:pointer; font-size:13px; transition:all .2s; }
.btn-add-game:hover { color:#45f882; border-color:#45f882; }
</style>
{% endblock %}

{% block body %}

    {# breadcrumb-area #}
    <section class="breadcrumb-area" data-background="{{ asset('assets/img/bg/breadcrumb_bg01.jpg') }}">
        <div class="container">
            <div class="breadcrumb__wrapper">
                <div class="row">
                    <div class="col-xl-6 col-lg-7">
                        <div class="breadcrumb__content">
                            <h2 class="title">Modifier mon profil</h2>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                    <li class="breadcrumb-item"><a href="{{ path('profile_show', {username: app.user.username}) }}">Mon profil</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Modifier</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                    <div class="col-xl-6 col-lg-5 position-relative d-none d-lg-block">
                        <div class="breadcrumb__img">
                            <img src="{{ asset('assets/img/others/breadcrumb_img02.png') }}" alt="img">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="edit-profile" data-background="{{ asset('assets/img/bg/team_bg.jpg') }}">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">

                    {% for message in app.flashes('success') %}
                        <div class="profile-flash profile-flash--success"><i class="fas fa-check-circle"></i> {{ message }}</div>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <div class="profile-flash profile-flash--error"><i class="fas fa-exclamation-circle"></i> {{ message }}</div>
                    {% endfor %}

                    <form method="post" action="{{ path('user_profile_edit') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('profile_edit') }}">

                        {# ── Bio ── #}
                        <div class="edit-card">
                            <h3 class="edit-card__title"><i class="fas fa-quote-left"></i> Presentation</h3>
                            <div class="edit-group">
                                <div id="bioEditor" style="min-height:150px;background:#1a1a2e;border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;"></div>
                                <textarea name="bio" id="bioContent" style="display:none;">{{ app.user.bio|default('') }}</textarea>
                            </div>
                        </div>

                        {# ── Pseudos sociaux ── #}
                        <div class="edit-card">
                            <h3 class="edit-card__title"><i class="fas fa-link"></i> Reseaux & pseudos</h3>

                            <div class="edit-group">
                                <label class="edit-label"><i class="fab fa-discord" style="color:#5865f2;"></i> Pseudo Discord</label>
                                <input type="text" name="discord_username" class="edit-input" value="{{ app.user.discordUsername }}" maxlength="100" placeholder="Ex: MonPseudo#1234">
                            </div>

                            <div class="edit-group">
                                <label class="edit-label"><i class="fab fa-steam" style="color:#1b2838;"></i> Pseudo Steam</label>
                                <input type="text" name="steam_username" class="edit-input" value="{{ app.user.steamUsername }}" maxlength="100" placeholder="Ex: SteamUser123">
                            </div>

                            <div class="edit-group">
                                <label class="edit-label"><i class="fab fa-twitch" style="color:#9146ff;"></i> Pseudo Twitch</label>
                                <input type="text" name="twitch_username" class="edit-input" value="{{ app.user.twitchUsername }}" maxlength="100" placeholder="Ex: TwitchStreamer">
                            </div>

                            <div class="edit-group">
                                <label class="edit-label"><i class="fas fa-gamepad" style="color:#45f882;"></i> Pseudos de jeux</label>
                                <div id="gameUsernamesContainer">
                                    {% if app.user.gameUsernames %}
                                        {% for game, name in app.user.gameUsernames %}
                                            <div class="game-row">
                                                <input type="text" name="game_usernames[{{ game }}]" class="edit-input" value="{{ name }}" placeholder="Pseudo" maxlength="100" data-game="{{ game }}">
                                                <input type="text" class="edit-input" value="{{ game }}" placeholder="Nom du jeu" maxlength="50" style="max-width:160px;" onchange="updateGameKey(this)">
                                                <button type="button" class="btn-remove" onclick="this.closest('.game-row').remove();"><i class="fas fa-trash"></i></button>
                                            </div>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                                <button type="button" class="btn-add-game" id="btnAddGame"><i class="fas fa-plus"></i> Ajouter un jeu</button>
                            </div>
                        </div>

                        {# ── Visibilite ── #}
                        <div class="edit-card">
                            <h3 class="edit-card__title"><i class="fas fa-eye"></i> Visibilite du profil</h3>
                            <p style="font-size:13px;color:#8b949e;margin-bottom:16px;">Choisissez quelles informations sont visibles sur votre profil public.</p>

                            {% set vis = app.user.profileVisibility %}

                            <div class="edit-toggle">
                                <input type="checkbox" name="vis_email" value="1" id="visEmail" {{ vis.email|default(false) ? 'checked' : '' }}>
                                <label for="visEmail"><i class="fas fa-envelope" style="color:#f0a030;"></i> Adresse email</label>
                            </div>
                            <div class="edit-toggle">
                                <input type="checkbox" name="vis_discord" value="1" id="visDiscord" {{ vis.discord|default(false) ? 'checked' : '' }}>
                                <label for="visDiscord"><i class="fab fa-discord" style="color:#5865f2;"></i> Pseudo Discord</label>
                            </div>
                            <div class="edit-toggle">
                                <input type="checkbox" name="vis_steam" value="1" id="visSteam" {{ vis.steam|default(false) ? 'checked' : '' }}>
                                <label for="visSteam"><i class="fab fa-steam"></i> Pseudo Steam</label>
                            </div>
                            <div class="edit-toggle">
                                <input type="checkbox" name="vis_twitch" value="1" id="visTwitch" {{ vis.twitch|default(false) ? 'checked' : '' }}>
                                <label for="visTwitch"><i class="fab fa-twitch" style="color:#9146ff;"></i> Pseudo Twitch</label>
                            </div>
                            <div class="edit-toggle">
                                <input type="checkbox" name="vis_games" value="1" id="visGames" {{ vis.games|default(false) ? 'checked' : '' }}>
                                <label for="visGames"><i class="fas fa-gamepad" style="color:#45f882;"></i> Pseudos de jeux</label>
                            </div>
                            <div class="edit-toggle">
                                <input type="checkbox" name="vis_servers" value="1" id="visServers" {{ vis.servers|default(true) ? 'checked' : '' }}>
                                <label for="visServers"><i class="fas fa-server" style="color:#45f882;"></i> Mes serveurs</label>
                            </div>
                        </div>

                        <div style="display:flex;gap:12px;">
                            <button type="submit" class="btn-action btn-action--primary"><i class="fas fa-save"></i> Enregistrer</button>
                            <a href="{{ path('profile_show', {username: app.user.username}) }}" class="btn-action" style="background:#2a2a3e;color:#8b949e;">Annuler</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </section>

{% endblock %}

{% block javascripts %}
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Quill editor for bio
    var quill = new Quill('#bioEditor', {
        theme: 'snow',
        placeholder: 'Presentez-vous en quelques mots...',
        modules: {
            toolbar: [
                ['bold', 'italic', 'underline'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                ['link'],
                ['clean']
            ]
        }
    });

    // Load existing bio
    var bioContent = document.getElementById('bioContent');
    if (bioContent.value) {
        quill.root.innerHTML = bioContent.value;
    }

    // Sync on form submit
    quill.root.closest('form').addEventListener('submit', function() {
        var html = quill.root.innerHTML;
        bioContent.value = (html === '<p><br></p>') ? '' : html;
    });

    // Add game username row
    var container = document.getElementById('gameUsernamesContainer');
    document.getElementById('btnAddGame').addEventListener('click', function() {
        var idx = Date.now();
        var row = document.createElement('div');
        row.className = 'game-row';
        row.innerHTML = '<input type="text" name="game_usernames[game_' + idx + ']" class="edit-input" placeholder="Pseudo" maxlength="100">' +
            '<input type="text" class="edit-input" placeholder="Nom du jeu" maxlength="50" style="max-width:160px;" onchange="updateGameKey(this)">' +
            '<button type="button" class="btn-remove" onclick="this.closest(\'.game-row\').remove();"><i class="fas fa-trash"></i></button>';
        container.appendChild(row);
    });
});

function updateGameKey(input) {
    var nameInput = input.closest('.game-row').querySelector('input[name^="game_usernames"]');
    var gameName = input.value.trim().replace(/[^a-zA-Z0-9_\- ]/g, '').substring(0, 50);
    if (gameName) {
        var value = nameInput.value;
        nameInput.name = 'game_usernames[' + gameName + ']';
        nameInput.value = value;
    }
}
</script>
{% endblock %}
