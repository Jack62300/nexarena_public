{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil — {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/profile.css') }}">
<style>
/* ───── Page ───── */
.edit-page {
    padding: 90px 0 80px;
    min-height: 100vh;
    background: #0a1018;
}

/* ───── Hero ───── */
.edit-hero {
    background: linear-gradient(135deg, #0f1c2d 0%, #162231 60%, #0f1c2d 100%);
    border: 1px solid #1e3048;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 28px;
}
.edit-hero__bar {
    height: 4px;
    background: linear-gradient(90deg, #45f882 0%, #00c6ff 50%, #45f882 100%);
    background-size: 200% 100%;
    animation: ep-shimmer 3s linear infinite;
}
@keyframes ep-shimmer { 0%{background-position:0 0} 100%{background-position:200% 0} }
.edit-hero__body {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 24px 28px;
    flex-wrap: wrap;
}
.edit-hero__avatar {
    width: 80px; height: 80px;
    border-radius: 50%;
    border: 3px solid rgba(69,248,130,0.35);
    background: #0a1018;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; flex-shrink: 0;
    box-shadow: 0 0 20px rgba(69,248,130,0.12);
    cursor: pointer;
    position: relative;
}
.edit-hero__avatar img { width:100%; height:100%; object-fit:cover; }
.edit-hero__avatar i { font-size:32px; color:rgba(255,255,255,0.2); }
.edit-hero__avatar-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.55);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity .2s;
}
.edit-hero__avatar:hover .edit-hero__avatar-overlay { opacity: 1; }
.edit-hero__avatar-overlay i { font-size: 20px; color: #45f882; }
.edit-hero__info { flex: 1; min-width: 0; }
.edit-hero__name {
    font-size: 22px; font-weight: 800; color: #e6edf3;
    margin-bottom: 4px;
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
}
.edit-hero__subtitle { font-size: 13px; color: #8b949e; }
.edit-hero__subtitle i { color: #45f882; margin-right: 4px; }
.edit-hero__actions { display: flex; gap: 8px; flex-shrink: 0; }

/* ───── Section cards ───── */
.ep-card {
    background: #162231;
    border: 1px solid #1e3048;
    border-radius: 12px;
    padding: 22px;
    margin-bottom: 20px;
}
.ep-card:last-child { margin-bottom: 0; }
.ep-card__title {
    font-size: 13px; font-weight: 700;
    color: #8b949e;
    text-transform: uppercase; letter-spacing: 0.6px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid #1e3048;
    display: flex; align-items: center; gap: 8px;
}
.ep-card__title i { color: #45f882; }

/* ───── Form inputs ───── */
.ep-group { margin-bottom: 18px; }
.ep-group:last-child { margin-bottom: 0; }
.ep-label {
    display: block;
    font-size: 12px; font-weight: 600;
    color: #8b949e;
    text-transform: uppercase; letter-spacing: 0.4px;
    margin-bottom: 8px;
}
.ep-label i { margin-right: 5px; }
.ep-input {
    width: 100%;
    background: #0d1b2d;
    border: 1px solid #1e3048;
    border-radius: 8px;
    padding: 10px 14px;
    color: #e6edf3;
    font-size: 14px;
    transition: border-color .2s;
}
.ep-input:focus { border-color: #45f882; outline: none; }
.ep-input::placeholder { color: #3d5068; }

/* ───── Visibility toggles ───── */
.ep-toggle {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px;
    background: #0d1b2d;
    border: 1px solid #1e3048;
    border-radius: 8px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: border-color .2s;
}
.ep-toggle:last-child { margin-bottom: 0; }
.ep-toggle:hover { border-color: rgba(69,248,130,0.3); }
.ep-toggle input[type="checkbox"] { accent-color: #45f882; width: 17px; height: 17px; cursor: pointer; flex-shrink: 0; }
.ep-toggle-label { font-size: 13px; color: #c9d1d9; flex: 1; display: flex; align-items: center; gap: 7px; }
.ep-toggle-label i { font-size: 13px; width: 16px; text-align: center; }
.ep-toggle-hint { font-size: 11px; color: #3d5068; }

/* ───── Game username rows ───── */
.ep-game-row { display: flex; gap: 8px; margin-bottom: 8px; align-items: center; }
.ep-game-row input { flex: 1; }
.ep-game-row .ep-btn-rm {
    background: none; border: none;
    color: #c9314a; cursor: pointer;
    padding: 8px 10px; border-radius: 6px;
    transition: background .2s;
}
.ep-game-row .ep-btn-rm:hover { background: rgba(201,49,74,0.1); }
.ep-btn-add {
    background: none;
    border: 1px dashed #1e3048;
    color: #8b949e;
    padding: 8px 14px; border-radius: 8px;
    cursor: pointer; font-size: 13px;
    transition: all .2s; margin-top: 4px;
}
.ep-btn-add:hover { color: #45f882; border-color: rgba(69,248,130,0.4); }

/* ───── Avatar upload zone ───── */
.ep-avatar-zone {
    display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
}
.ep-avatar-preview {
    width: 80px; height: 80px;
    border-radius: 50%;
    border: 3px solid rgba(69,248,130,0.3);
    background: #0a1018;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; flex-shrink: 0;
}
.ep-avatar-preview img { width:100%; height:100%; object-fit:cover; }
.ep-avatar-preview i { font-size:28px; color:rgba(255,255,255,0.15); }
.ep-avatar-upload-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 18px;
    background: rgba(69,248,130,0.07);
    border: 1px solid rgba(69,248,130,0.2);
    border-radius: 8px; color: #45f882;
    font-size: 13px; font-weight: 600;
    cursor: pointer; transition: all .2s;
}
.ep-avatar-upload-btn:hover { background: rgba(69,248,130,0.14); border-color: rgba(69,248,130,0.4); }
.ep-avatar-hint { font-size: 11px; color: #3d5068; margin-top: 5px; }

/* ───── Sidebar ───── */
.ep-sidebar-card {
    background: #162231;
    border: 1px solid #1e3048;
    border-radius: 12px;
    padding: 18px;
    margin-bottom: 18px;
}
.ep-sidebar-card:last-child { margin-bottom: 0; }
.ep-sidebar-title {
    font-size: 12px; font-weight: 700;
    color: #8b949e;
    text-transform: uppercase; letter-spacing: 0.6px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid #1e3048;
    display: flex; align-items: center; gap: 7px;
}
.ep-sidebar-title i { color: #45f882; }

/* Preview items */
.ep-preview-item {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 13px;
}
.ep-preview-item:last-child { border-bottom: none; padding-bottom: 0; }
.ep-preview-item:first-child { padding-top: 0; }
.ep-preview-icon {
    width: 28px; height: 28px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.ep-preview-icon i { font-size: 12px; color: #fff; }
.ep-preview-name { color: #e6edf3; font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ep-preview-empty { color: #3d5068; font-size: 12px; font-style: italic; }

/* Buttons */
.ep-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 18px; border-radius: 8px;
    font-size: 13px; font-weight: 600;
    cursor: pointer; transition: all .2s;
    border: none; text-decoration: none;
}
.ep-btn--primary { background: #45f882; color: #0a1018; }
.ep-btn--primary:hover { background: #3de074; color: #0a1018; }
.ep-btn--outline { background: transparent; color: #8b949e; border: 1px solid #1e3048; }
.ep-btn--outline:hover { color: #e6edf3; border-color: #2d4a66; background: rgba(255,255,255,0.03); }

/* Flash */
.ep-flash {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 18px; border-radius: 8px;
    margin-bottom: 20px; font-size: 14px; font-weight: 500;
}
.ep-flash--success { background: rgba(69,248,130,0.08); border: 1px solid rgba(69,248,130,0.2); color: #45f882; }
.ep-flash--error   { background: rgba(220,53,69,0.08);  border: 1px solid rgba(220,53,69,0.2);  color: #dc3545; }

/* Bio editor override */
.ql-toolbar.ql-snow { background: #0d1b2d; border-color: #1e3048 !important; border-radius: 8px 8px 0 0; }
.ql-container.ql-snow { background: #0d1b2d; border-color: #1e3048 !important; border-radius: 0 0 8px 8px; min-height: 140px; }
.ql-editor { color: #e6edf3; font-size: 14px; min-height: 140px; }
.ql-editor.ql-blank::before { color: #3d5068; font-style: normal; }
.ql-snow .ql-stroke { stroke: #8b949e; }
.ql-snow .ql-fill { fill: #8b949e; }
.ql-snow .ql-picker { color: #8b949e; }
.ql-snow .ql-picker-options { background: #162231; border-color: #1e3048; }
.ql-snow.ql-toolbar button:hover .ql-stroke,
.ql-snow.ql-toolbar button.ql-active .ql-stroke { stroke: #45f882; }

@media (max-width: 767px) {
    .edit-hero__body { padding: 18px; gap: 16px; }
    .edit-hero__actions { width: 100%; }
}

#bioEditor .ql-editor.ql-blank::before {
    color: #3d5068;          /* blanc */
    opacity: 1;           /* important sinon Quill met une opacité */
}

/* ───── Wheel ───── */
.wheel-card {
    background: linear-gradient(135deg, #0f1c2d 0%, #162231 100%);
    border: 1px solid rgba(69,248,130,0.15);
    border-radius: 12px;
    padding: 18px;
    margin-bottom: 18px;
    position: relative;
    overflow: hidden;
}
.wheel-card::before {
    content: '';
    position: absolute; inset: -1px;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(69,248,130,0.2), rgba(0,198,255,0.1), rgba(69,248,130,0.2));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
}
.wheel-card__title {
    font-size: 12px; font-weight: 700;
    color: #45f882;
    text-transform: uppercase; letter-spacing: 0.6px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(69,248,130,0.1);
    display: flex; align-items: center; gap: 7px;
}
.wheel-canvas-wrap {
    position: relative;
    width: 280px; height: 280px;
    margin: 0 auto 16px;
}
.wheel-canvas-wrap canvas {
    width: 100%; height: 100%;
    border-radius: 50%;
    box-shadow: 0 0 30px rgba(69,248,130,0.08), inset 0 0 20px rgba(0,0,0,0.3);
}
.wheel-pointer {
    position: absolute;
    top: -8px; left: 50%;
    transform: translateX(-50%);
    width: 0; height: 0;
    border-left: 12px solid transparent;
    border-right: 12px solid transparent;
    border-top: 22px solid #45f882;
    filter: drop-shadow(0 2px 6px rgba(69,248,130,0.5));
    z-index: 2;
}
.wheel-info {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 12px; font-size: 12px; color: #8b949e;
}
.wheel-info strong { color: #e6edf3; }
.wheel-info .free-badge {
    padding: 2px 8px; border-radius: 4px;
    background: rgba(69,248,130,0.1); color: #45f882;
    font-weight: 700; font-size: 11px;
    border: 1px solid rgba(69,248,130,0.2);
}
.wheel-spin-btn {
    width: 100%; padding: 11px;
    border-radius: 8px; border: none;
    background: linear-gradient(135deg, #45f882, #2dd66b);
    color: #0a1018; font-size: 14px; font-weight: 800;
    cursor: pointer; transition: all .3s;
    text-transform: uppercase; letter-spacing: 0.5px;
}
.wheel-spin-btn:hover:not(:disabled) {
    box-shadow: 0 0 20px rgba(69,248,130,0.4);
    transform: translateY(-1px);
}
.wheel-spin-btn:disabled {
    opacity: 0.4; cursor: not-allowed;
    background: rgba(69,248,130,0.15); color: rgba(69,248,130,0.4);
}
.wheel-spin-btn.spinning {
    animation: pulse-spin 0.6s ease infinite;
}
@keyframes pulse-spin {
    0%, 100% { box-shadow: 0 0 10px rgba(69,248,130,0.2); }
    50% { box-shadow: 0 0 25px rgba(69,248,130,0.5); }
}
.wheel-result-overlay {
    position: absolute; inset: 0;
    background: rgba(10,16,24,0.92);
    border-radius: 12px;
    display: none; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 10; text-align: center; padding: 20px;
}
.wheel-result-overlay.active { display: flex; }
.wheel-result-overlay .result-icon {
    font-size: 40px; margin-bottom: 10px;
}
.wheel-result-overlay .result-label {
    font-size: 20px; font-weight: 800; color: #e6edf3;
    margin-bottom: 6px;
}
.wheel-result-overlay .result-detail {
    font-size: 13px; color: #8b949e; margin-bottom: 16px;
}
.wheel-result-overlay .result-close {
    padding: 7px 20px; border-radius: 6px;
    background: rgba(69,248,130,0.1); border: 1px solid rgba(69,248,130,0.2);
    color: #45f882; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: all .2s;
}
.wheel-result-overlay .result-close:hover { background: rgba(69,248,130,0.18); }
.wheel-result-overlay.jackpot {
    background: radial-gradient(ellipse at center, rgba(255,215,0,0.15) 0%, rgba(10,16,24,0.95) 70%);
}
.wheel-result-overlay.jackpot .result-icon { color: #ffd700; animation: jackpot-glow 1s ease infinite alternate; }
.wheel-result-overlay.jackpot .result-label { color: #ffd700; }
@keyframes jackpot-glow {
    0% { text-shadow: 0 0 10px rgba(255,215,0,0.3); }
    100% { text-shadow: 0 0 30px rgba(255,215,0,0.8), 0 0 60px rgba(255,215,0,0.3); }
}
</style>
{% endblock %}

{% block body %}
<section class="edit-page">
    <div class="container">

        {# Flash messages #}
        {% for msg in app.flashes('success') %}
            <div class="ep-flash ep-flash--success"><i class="fas fa-check-circle"></i> {{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="ep-flash ep-flash--error"><i class="fas fa-exclamation-circle"></i> {{ msg }}</div>
        {% endfor %}

        {# ── Hero ── #}
        <div class="edit-hero">
            <div class="edit-hero__bar"></div>
            <div class="edit-hero__body">
                {# Avatar cliquable → ouvre le sélecteur de fichier #}
                <label for="avatarInput" style="cursor:pointer;">
                    <div class="edit-hero__avatar">
                        <div id="heroAvatarPreview" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;border-radius:50%;overflow:hidden;">
                            {% if app.user.avatar starts with 'http' %}
                                <img src="{{ app.user.avatar }}" alt="Avatar" style="width:100%;height:100%;object-fit:cover;">
                            {% elseif app.user.avatar %}
                                <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="Avatar" style="width:100%;height:100%;object-fit:cover;">
                            {% else %}
                                <i class="fas fa-user" style="font-size:32px;color:rgba(255,255,255,0.2);"></i>
                            {% endif %}
                        </div>
                        <div class="edit-hero__avatar-overlay">
                            <i class="fas fa-camera"></i>
                        </div>
                    </div>
                </label>

                <div class="edit-hero__info">
                    <div class="edit-hero__name">
                        {{ app.user.username }}
                        {% if app.user.isTwoFactorEnabled %}
                            <span style="font-size:11px;padding:3px 9px;border-radius:4px;background:rgba(69,248,130,0.1);color:#45f882;border:1px solid rgba(69,248,130,0.2);font-weight:600;">
                                <i class="fas fa-shield-alt"></i> 2FA
                            </span>
                        {% endif %}
                    </div>
                    <div class="edit-hero__subtitle">
                        <i class="fas fa-pen"></i> Modifier mon profil
                        <span style="margin:0 8px;opacity:.3;">·</span>
                        <i class="fas fa-calendar-alt" style="color:#8b949e;"></i>
                        <span style="color:#8b949e;"> Membre depuis {{ app.user.createdAt ? app.user.createdAt|time_ago('d/m/Y') : 'N/A' }}</span>
                    </div>
                </div>

                <div class="edit-hero__actions">
                    <a href="{{ path('profile_show', {username: app.user.username}) }}" class="ep-btn ep-btn--outline">
                        <i class="fas fa-eye"></i> Mon profil
                    </a>
                    <a href="{{ path('user_settings') }}" class="ep-btn ep-btn--outline">
                        <i class="fas fa-cog"></i>
                    </a>
                </div>
            </div>
        </div>

        {# ── Avatar form (invisible, soumis automatiquement) ── #}
        <form action="{{ path('user_settings_avatar') }}" method="post" enctype="multipart/form-data" id="avatarForm">
            <input type="hidden" name="_token" value="{{ csrf_token('profile_avatar') }}">
            <input type="file" name="avatar" id="avatarInput" style="display:none;" accept="image/jpeg,image/png,image/gif,image/webp">
        </form>

        <div class="row g-4">

            {# ══════════ COLONNE PRINCIPALE ══════════ #}
            <div class="col-lg-8">

                <form method="post" action="{{ path('user_profile_edit') }}" id="editForm">
                    <input type="hidden" name="_token" value="{{ csrf_token('profile_edit') }}">

                    {# ── Pseudo ── #}
                    <div class="ep-card">
                        <div class="ep-card__title"><i class="fas fa-at"></i> Pseudo</div>
                        <div class="ep-group" style="margin-bottom:0;">
                            <label class="ep-label" for="usernameInput"><i class="fas fa-user"></i> Nom d'utilisateur</label>
                            <input type="text" id="usernameInput" name="username" class="ep-input"
                                   value="{{ app.user.username }}"
                                   minlength="3" maxlength="30"
                                   pattern="[a-zA-Z0-9_\-]+"
                                   placeholder="MonPseudo"
                                   autocomplete="username"
                                   oninput="updateUsernamePreview(this.value)">
                            <div style="margin-top:8px;font-size:12px;color:#3d5068;display:flex;align-items:center;gap:6px;">
                                <i class="fas fa-info-circle" style="color:#45f882;"></i>
                                3 à 30 caractères — lettres, chiffres, <code style="background:#0d1b2d;padding:1px 5px;border-radius:3px;color:#8b949e;">_</code> et <code style="background:#0d1b2d;padding:1px 5px;border-radius:3px;color:#8b949e;">-</code> uniquement.
                                Votre URL de profil : <span id="usernamePreviewUrl" style="color:#45f882;"></span>
                            </div>
                        </div>
                    </div>

                    {# ── Bio ── #}
                    <div class="ep-card">
                        <div class="ep-card__title"><i class="fas fa-quote-left"></i> Présentation</div>
                        <div class="ep-group">
                            <div id="bioEditor"></div>
                            <textarea name="bio" id="bioContent" style="display:none;">{{ app.user.bio|default('') }}</textarea>
                        </div>
                    </div>

                    {# ── Réseaux & pseudos ── #}
                    <div class="ep-card">
                        <div class="ep-card__title"><i class="fas fa-link"></i> Réseaux & pseudos</div>

                        <div class="ep-group">
                            <label class="ep-label"><i class="fab fa-discord" style="color:#5865f2;"></i> Discord</label>
                            <input type="text" name="discord_username" class="ep-input" value="{{ app.user.discordUsername }}" maxlength="100" placeholder="MonPseudo#1234">
                        </div>

                        <div class="ep-group">
                            <label class="ep-label"><i class="fab fa-steam" style="color:#c2a952;"></i> Steam</label>
                            <input type="text" name="steam_username" class="ep-input" value="{{ app.user.steamUsername }}" maxlength="100" placeholder="SteamUser123">
                        </div>

                        <div class="ep-group">
                            <label class="ep-label"><i class="fab fa-twitch" style="color:#9146ff;"></i> Twitch</label>
                            <input type="text" name="twitch_username" class="ep-input" value="{{ app.user.twitchUsername }}" maxlength="100" placeholder="TwitchStreamer">
                        </div>

                        <div class="ep-group" style="margin-bottom:0;">
                            <label class="ep-label"><i class="fas fa-gamepad" style="color:#45f882;"></i> Pseudos de jeux</label>
                            <div id="gameUsernamesContainer">
                                {% if app.user.gameUsernames %}
                                    {% for game, name in app.user.gameUsernames %}
                                        <div class="ep-game-row">
                                            <input type="text" name="game_usernames[{{ game }}]" class="ep-input" value="{{ name }}" placeholder="Pseudo" maxlength="100" data-game="{{ game }}">
                                            <input type="text" class="ep-input" value="{{ game }}" placeholder="Nom du jeu" maxlength="50" style="max-width:160px;" onchange="updateGameKey(this)">
                                            <button type="button" class="ep-btn-rm" onclick="this.closest('.ep-game-row').remove();">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                            <button type="button" class="ep-btn-add" id="btnAddGame">
                                <i class="fas fa-plus"></i> Ajouter un jeu
                            </button>
                        </div>
                    </div>

                    {# ── Visibilité ── #}
                    <div class="ep-card">
                        <div class="ep-card__title"><i class="fas fa-eye"></i> Visibilité du profil</div>
                        <p style="font-size:13px;color:#8b949e;margin-bottom:16px;line-height:1.6;">
                            Choisissez quelles informations sont visibles sur votre profil public.
                        </p>

                        {% set vis = app.user.profileVisibility %}

                        <label class="ep-toggle">
                            <input type="checkbox" name="vis_discord" value="1" id="visDiscord" {{ vis.discord|default(false) ? 'checked' : '' }}>
