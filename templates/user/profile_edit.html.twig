{% block javascripts %}
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {

    // ── Avatar — preview + auto-submit ──
    var avatarInput   = document.getElementById('avatarInput');
    var avatarForm    = document.getElementById('avatarForm');
    var heroPreview   = document.getElementById('heroAvatarPreview');
    var sidePreview   = document.getElementById('sideAvatarPreview');
    var avatarFileName = document.getElementById('avatarFileName');

    if (avatarInput) {
        avatarInput.addEventListener('change', function () {
            if (!this.files || !this.files[0]) return;
            var file = this.files[0];
            avatarFileName.textContent = file.name;

            var reader = new FileReader();
            reader.onload = function (e) {
                var img = '<img src="' + e.target.result + '" alt="Avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">';
                heroPreview.innerHTML = img;
                sidePreview.innerHTML = '<img src="' + e.target.result + '" alt="Avatar" style="width:100%;height:100%;object-fit:cover;">';
            };
            reader.readAsDataURL(file);
            avatarForm.submit();
        });
    }

    // ── Quill bio editor ──
    var quill = new Quill('#bioEditor', {
        theme: 'snow',
        placeholder: 'Présentez-vous en quelques mots...',
        modules: {
            toolbar: [
                ['bold', 'italic', 'underline'],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['link'],
                ['clean']
            ]
        }
    });

    var bioContent = document.getElementById('bioContent');
    if (bioContent.value) {
        quill.root.innerHTML = bioContent.value;
    }

    document.getElementById('editForm').addEventListener('submit', function () {
        var html = quill.root.innerHTML;
        bioContent.value = (html === '<p><br></p>') ? '' : html;
    });

    // ── Game username rows ──
    var container = document.getElementById('gameUsernamesContainer');
    document.getElementById('btnAddGame').addEventListener('click', function () {
        var idx = Date.now();
        var row = document.createElement('div');
        row.className = 'ep-game-row';
        row.innerHTML =
            '<input type="text" name="game_usernames[game_' + idx + ']" class="ep-input" placeholder="Pseudo" maxlength="100">' +
            '<input type="text" class="ep-input" placeholder="Nom du jeu" maxlength="50" style="max-width:160px;" onchange="updateGameKey(this)">' +
            '<button type="button" class="ep-btn-rm" onclick="this.closest(\'.ep-game-row\').remove();">' +
                '<i class="fas fa-trash-alt"></i>' +
            '</button>';
        container.appendChild(row);
        row.querySelector('input').focus();
    });
});

function updateGameKey(input) {
    var nameInput = input.closest('.ep-game-row').querySelector('input[name^="game_usernames"]');
    var gameName = input.value.trim().replace(/[^a-zA-Z0-9_\- ]/g, '').substring(0, 50);
    if (gameName && nameInput) {
        var val = nameInput.value;
        nameInput.name = 'game_usernames[' + gameName + ']';
        nameInput.value = val;
    }
}
</script>
{% endblock %}
