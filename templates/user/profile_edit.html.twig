{% block javascripts %}
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function () {

    // ── Avatar — preview + auto-submit ──
    var avatarInput   = document.getElementById('avatarInput');
    var avatarForm    = document.getElementById('avatarForm');
    var heroPreview   = document.getElementById('heroAvatarPreview');
    var sidePreview   = document.getElementById('sideAvatarPreview');
    var avatarFileName = document.getElementById('avatarFileName');

    if (avatarInput) {
        avatarInput.addEventListener('change', function () {
            if (!this.files || !this.files[0]) return;
            var file = this.files[0];
            avatarFileName.textContent = file.name;

            var reader = new FileReader();
            reader.onload = function (e) {
                var img = '<img src="' + e.target.result + '" alt="Avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">';
                heroPreview.innerHTML = img;
                sidePreview.innerHTML = '<img src="' + e.target.result + '" alt="Avatar" style="width:100%;height:100%;object-fit:cover;">';
            };
            reader.readAsDataURL(file);
            avatarForm.submit();
        });
    }

    // ── Quill bio editor ──
    var quill = new Quill('#bioEditor', {
        theme: 'snow',
        placeholder: 'Présentez-vous en quelques mots...',
        modules: {
            toolbar: [
                ['bold', 'italic', 'underline'],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['link'],
                ['clean']
            ]
        }
    });

    var bioContent = document.getElementById('bioContent');
    if (bioContent.value) {
        quill.root.innerHTML = bioContent.value;
    }

    document.getElementById('editForm').addEventListener('submit', function () {
        var html = quill.root.innerHTML;
        bioContent.value = (html === '<p><br></p>') ? '' : html;
    });

    // ── Game username rows ──
    var container = document.getElementById('gameUsernamesContainer');
    document.getElementById('btnAddGame').addEventListener('click', function () {
        var idx = Date.now();
        var row = document.createElement('div');
        row.className = 'ep-game-row';
        row.innerHTML =
            '<input type="text" name="game_usernames[game_' + idx + ']" class="ep-input" placeholder="Pseudo" maxlength="100">' +
            '<input type="text" class="ep-input" placeholder="Nom du jeu" maxlength="50" style="max-width:160px;" onchange="updateGameKey(this)">' +
            '<button type="button" class="ep-btn-rm" onclick="this.closest(\'.ep-game-row\').remove();">' +
                '<i class="fas fa-trash-alt"></i>' +
            '</button>';
        container.appendChild(row);
        row.querySelector('input').focus();
    });
});

function updateGameKey(input) {
    var nameInput = input.closest('.ep-game-row').querySelector('input[name^="game_usernames"]');
    var gameName = input.value.trim().replace(/[^a-zA-Z0-9_\- ]/g, '').substring(0, 50);
    if (gameName && nameInput) {
        var val = nameInput.value;
        nameInput.name = 'game_usernames[' + gameName + ']';
        nameInput.value = val;
    }
}

// ── Username preview URL ──
var baseProfileUrl = '{{ url('profile_show', {username: '__USERNAME__'})|replace({'__USERNAME__': '__USERNAME__'}) }}';
function updateUsernamePreview(val) {
    var el = document.getElementById('usernamePreviewUrl');
    if (!el) return;
    var valid = /^[a-zA-Z0-9_\-]{3,30}$/.test(val);
    if (valid) {
        el.textContent = baseProfileUrl.replace('__USERNAME__', val);
        el.style.color = '#45f882';
    } else if (val.length > 0) {
        el.textContent = 'Format invalide';
        el.style.color = '#e74a3b';
    } else {
        el.textContent = '';
    }
}
// Init on load
document.addEventListener('DOMContentLoaded', function() {
    var inp = document.getElementById('usernameInput');
    if (inp) updateUsernamePreview(inp.value);
});

// ── Wheel ──
{% if wheel_enabled %}
(function() {
    var canvas = document.getElementById('wheelCanvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var prizes = {{ wheel_prizes|json_encode|raw }};
    var numSections = prizes.length;
    var arc = (2 * Math.PI) / numSections;
    var currentAngle = 0;
    var spinning = false;

    var colors = [
        '#2d8a4e', '#1a5c3a', '#45f882', '#1e7a42',
        '#33a55d', '#0f4a2e', '#3dd672', '#165e38',
        '#28944f', '#0d3f26', '#4afc8e', '#ffd700'
    ];

    function drawWheel(angle) {
        ctx.clearRect(0, 0, 560, 560);
        ctx.save();
        ctx.translate(280, 280);
        ctx.rotate(angle);

        for (var i = 0; i < numSections; i++) {
            var startAngle = i * arc - Math.PI / 2;
            var endAngle = startAngle + arc;

            // Section fill
            ctx.beginPath();
            ctx.moveTo(0, 0);
            ctx.arc(0, 0, 270, startAngle, endAngle);
            ctx.closePath();
            ctx.fillStyle = colors[i];
            ctx.fill();

            // Border
            ctx.strokeStyle = 'rgba(0,0,0,0.3)';
            ctx.lineWidth = 1.5;
            ctx.stroke();

            // Text
            ctx.save();
            ctx.rotate(startAngle + arc / 2);
            ctx.textAlign = 'right';
            ctx.fillStyle = i === 11 ? '#0a1018' : '#fff';
            ctx.font = (i === 11 ? 'bold 15px' : '13px') + ' system-ui, -apple-system, sans-serif';
            ctx.fillText(prizes[i].label, 255, 5);
            ctx.restore();
        }

        // Center circle
        ctx.beginPath();
        ctx.arc(0, 0, 35, 0, 2 * Math.PI);
        ctx.fillStyle = '#0a1018';
        ctx.fill();
        ctx.strokeStyle = '#45f882';
        ctx.lineWidth = 3;
        ctx.stroke();

        ctx.font = 'bold 10px system-ui, sans-serif';
        ctx.fillStyle = '#45f882';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('SPIN', 0, 0);

        ctx.restore();

        // Outer ring
        ctx.beginPath();
        ctx.arc(280, 280, 272, 0, 2 * Math.PI);
        ctx.strokeStyle = 'rgba(69,248,130,0.2)';
        ctx.lineWidth = 4;
        ctx.stroke();
    }

    drawWheel(0);

    var spinBtn = document.getElementById('wheelSpinBtn');
    var resultOverlay = document.getElementById('wheelResult');
    var resultIcon = document.getElementById('wheelResultIcon');
    var resultLabel = document.getElementById('wheelResultLabel');
    var resultDetail = document.getElementById('wheelResultDetail');
    var resultClose = document.getElementById('wheelResultClose');
    var freeSpinsEl = document.getElementById('wheelFreeSpins');
    var balanceEl = document.getElementById('wheelBalance');
    var boostBalanceEl = document.getElementById('wheelBoostBalance');
    var csrfToken = '{{ csrf_token("wheel_spin") }}';

    function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }

    spinBtn.addEventListener('click', function() {
        if (spinning) return;
        spinning = true;
        spinBtn.disabled = true;
        spinBtn.classList.add('spinning');
        spinBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> En cours...';

        var formData = new FormData();
        formData.append('_token', csrfToken);

        fetch('{{ path("wheel_spin") }}', { method: 'POST', body: formData })
            .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
            .then(function(res) {
                if (!res.ok) {
                    spinning = false;
                    spinBtn.disabled = false;
                    spinBtn.classList.remove('spinning');
                    updateBtnLabel(parseInt(freeSpinsEl.textContent));
                    alert(res.data.error || 'Erreur');
                    return;
                }

                var d = res.data;
                var targetIndex = d.sectionIndex;

                // Calculate target angle: spin several full rotations + land on the right section
                // The pointer is at top (12 o'clock = -PI/2), sections are drawn clockwise
                // Target: center of section at index targetIndex
                var sectionAngle = targetIndex * arc + arc / 2;
                var targetAngle = (2 * Math.PI - sectionAngle);
                var fullSpins = 5 + Math.floor(Math.random() * 3); // 5-7 full rotations
                var totalAngle = fullSpins * 2 * Math.PI + targetAngle;

                var startAngle = currentAngle % (2 * Math.PI);
                var duration = 4000;
                var startTime = null;

                function animate(ts) {
                    if (!startTime) startTime = ts;
                    var elapsed = ts - startTime;
                    var t = Math.min(elapsed / duration, 1);
                    var eased = easeOutCubic(t);

                    currentAngle = startAngle + eased * totalAngle;
                    drawWheel(currentAngle);

                    if (t < 1) {
                        requestAnimationFrame(animate);
                    } else {
                        // Animation done — show result
                        spinning = false;
                        spinBtn.classList.remove('spinning');

                        freeSpinsEl.textContent = d.remainingFreeSpins;
                        balanceEl.textContent = d.newBalance.nexbits;
                        boostBalanceEl.textContent = d.newBalance.nexboost;

                        // Update free badge
                        var freeParent = freeSpinsEl.parentElement;
                        var existingBadge = freeParent.querySelector('.free-badge');
                        if (d.remainingFreeSpins > 0) {
                            if (!existingBadge) {
                                var badge = document.createElement('span');
                                badge.className = 'free-badge';
                                badge.textContent = 'GRATUIT';
                                freeParent.appendChild(badge);
                            }
                        } else if (existingBadge) {
                            existingBadge.remove();
                        }

                        updateBtnLabel(d.remainingFreeSpins);
                        spinBtn.disabled = false;

                        // Show result overlay
                        var isJackpot = d.isJackpot;
                        var isLoss = d.prize.nexbits === 0 && d.prize.nexboost === 0;

                        resultOverlay.className = 'wheel-result-overlay active' + (isJackpot ? ' jackpot' : '');

                        if (isJackpot) {
                            resultIcon.innerHTML = '<i class="fas fa-crown"></i>';
                            resultLabel.textContent = 'JACKPOT !';
                            resultDetail.innerHTML = '<strong style="color:#ffd700;">' + d.prize.nexbits + ' NexBits + ' + d.prize.nexboost + ' NexBoost</strong>';
                        } else if (isLoss) {
                            resultIcon.innerHTML = '<i class="fas fa-times-circle" style="color:#c9314a;"></i>';
                            resultLabel.textContent = 'Perdu !';
                            resultDetail.textContent = 'Pas de chance, retentez votre chance !';
                        } else {
                            resultIcon.innerHTML = '<i class="fas fa-coins" style="color:#45f882;"></i>';
                            resultLabel.textContent = d.prize.label;
                            var detailParts = [];
                            if (d.prize.nexbits > 0) detailParts.push('+' + d.prize.nexbits + ' NexBits');
                            if (d.prize.nexboost > 0) detailParts.push('+' + d.prize.nexboost + ' NexBoost');
                            resultDetail.innerHTML = '<strong style="color:#45f882;">' + detailParts.join(' & ') + '</strong>';
                        }

                        // Update CSRF token for next spin
                        fetch('{{ path("wheel_spin") }}', { method: 'HEAD' }).catch(function(){});
                    }
                }
                requestAnimationFrame(animate);
            })
            .catch(function(err) {
                spinning = false;
                spinBtn.disabled = false;
                spinBtn.classList.remove('spinning');
                updateBtnLabel(parseInt(freeSpinsEl.textContent));
                alert('Erreur reseau.');
            });
    });

    resultClose.addEventListener('click', function() {
        resultOverlay.classList.remove('active');
    });

    function updateBtnLabel(freeSpins) {
        if (freeSpins > 0) {
            spinBtn.innerHTML = '<i class="fas fa-dharmachakra"></i> Tourner (gratuit)';
        } else {
            spinBtn.innerHTML = '<i class="fas fa-dharmachakra"></i> Tourner ({{ wheel_spin_cost }} NexBits)';
        }
    }
})();
{% endif %}
</script>
{% endblock %}
