{% extends 'base.html.twig' %}

{% block title %}Mes recrutements - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<style>
    .recruit-page { padding: 120px 0 80px; min-height: 100vh; position: relative; }
    .recruit-page::before {
        content: '';
        position: absolute;
        top: 0; left: 50%;
        transform: translateX(-50%);
        width: 600px; height: 600px;
        background: radial-gradient(circle, rgba(69,248,130,0.06) 0%, transparent 70%);
        pointer-events: none;
    }

    .recruit-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }
    .recruit-header h1 {
        font-size: 28px;
        font-weight: 800;
        text-transform: uppercase;
    }
    .recruit-header h1 span { color: #45f882; }

    .recruit-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 22px;
        background: linear-gradient(135deg, #45f882, #2bc866);
        color: #0a1018;
        font-weight: 700;
        font-size: 13px;
        border-radius: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s;
        border: none;
        cursor: pointer;
        text-decoration: none;
    }
    .recruit-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(69,248,130,0.25); color: #0a1018; }

    .recruit-card {
        background: rgba(22,34,49,0.6);
        border: 1px solid rgba(69,248,130,0.08);
        border-radius: 12px;
        padding: 22px;
        margin-bottom: 16px;
        transition: all 0.3s;
    }
    .recruit-card:hover { border-color: rgba(69,248,130,0.2); transform: translateY(-1px); }

    .recruit-card__top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 15px;
        margin-bottom: 12px;
    }
    .recruit-card__title {
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        margin: 0;
    }
    .recruit-card__server {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        margin-top: 4px;
    }
    .recruit-card__server i { color: #45f882; }

    .recruit-status {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }
    .recruit-status--draft { background: rgba(90,92,105,0.2); color: #8b949e; border: 1px solid rgba(90,92,105,0.3); }
    .recruit-status--pending { background: rgba(246,194,62,0.12); color: #f6c23e; border: 1px solid rgba(246,194,62,0.3); }
    .recruit-status--approved { background: rgba(28,200,138,0.12); color: #1cc88a; border: 1px solid rgba(28,200,138,0.3); }
    .recruit-status--revision_requested { background: rgba(54,185,204,0.12); color: #36b9cc; border: 1px solid rgba(54,185,204,0.3); }
    .recruit-status--rejected { background: rgba(231,74,59,0.12); color: #e74a3b; border: 1px solid rgba(231,74,59,0.3); }

    .recruit-card__meta {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 14px;
        font-size: 13px;
        color: rgba(255,255,255,0.45);
    }
    .recruit-card__meta i { width: 16px; text-align: center; margin-right: 4px; }

    .recruit-card__actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .recruit-card__btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
    }
    .recruit-card__btn:hover { background: rgba(255,255,255,0.08); color: #fff; }
    .recruit-card__btn--primary { background: rgba(69,248,130,0.1); color: #45f882; border-color: rgba(69,248,130,0.2); }
    .recruit-card__btn--primary:hover { background: rgba(69,248,130,0.2); color: #45f882; }
    .recruit-card__btn--danger { color: rgba(231,74,59,0.7); border-color: rgba(231,74,59,0.15); }
    .recruit-card__btn--danger:hover { color: #e74a3b; background: rgba(231,74,59,0.08); }

    .recruit-alert {
        padding: 14px 18px;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 10px;
    }
    .recruit-alert--info { background: rgba(54,185,204,0.08); border: 1px solid rgba(54,185,204,0.2); color: #36b9cc; }
    .recruit-alert--danger { background: rgba(231,74,59,0.08); border: 1px solid rgba(231,74,59,0.2); color: #e74a3b; }

    .recruit-empty {
        text-align: center;
        padding: 60px 20px;
        color: rgba(255,255,255,0.4);
    }
    .recruit-empty i { font-size: 48px; margin-bottom: 15px; display: block; color: rgba(255,255,255,0.15); }
    .recruit-empty p { font-size: 15px; margin-bottom: 20px; }

    .recruit-server-select {
        margin-bottom: 30px;
    }
    .recruit-server-select label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: rgba(255,255,255,0.6);
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .recruit-server-select select {
        background: rgba(10,16,24,0.8);
        border: 1px solid rgba(69,248,130,0.1);
        color: #fff;
        padding: 10px 16px;
        border-radius: 8px;
        font-size: 14px;
        min-width: 300px;
    }
    .recruit-server-select select:focus { border-color: #45f882; outline: none; }
</style>
{% endblock %}

{% block body %}
<section class="recruit-page">
    <div class="container">

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="recruit-alert recruit-alert--{{ type == 'error' ? 'danger' : 'info' }}">
                    <i class="fas fa-{{ type == 'error' ? 'exclamation-triangle' : 'info-circle' }}"></i> {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="recruit-header">
            <h1><i class="fas fa-bullhorn"></i> Mes <span>recrutements</span></h1>
        </div>

        {# Server select + create button #}
        <div class="recruit-server-select">
            <label>Creer une annonce pour un de vos serveurs</label>
            <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
                <select id="serverSelect">
                    <option value="">-- Choisir un serveur --</option>
                    {% for server in app.user.servers %}
                        <option value="{{ server.id }}">{{ server.name }}</option>
                    {% endfor %}
                </select>
                <button type="button" class="recruit-btn" onclick="createListing()">
                    <i class="fas fa-plus"></i> Creer une annonce
                </button>
            </div>
        </div>

        {% if listings|length > 0 %}
            {% for listing in listings %}
                <div class="recruit-card">
                    <div class="recruit-card__top">
                        <div>
                            <h3 class="recruit-card__title">{{ listing.title }}</h3>
                            <div class="recruit-card__server"><i class="fas fa-server"></i> {{ listing.server.name }}</div>
                        </div>
                        <span class="recruit-status recruit-status--{{ listing.status }}">
                            {% if listing.status == 'draft' %}Brouillon
                            {% elseif listing.status == 'pending' %}En attente
                            {% elseif listing.status == 'approved' %}Approuvee
                            {% elseif listing.status == 'revision_requested' %}Revision demandee
                            {% elseif listing.status == 'rejected' %}Rejetee
                            {% endif %}
                        </span>
                    </div>

                    {% if listing.revisionReason and listing.status == 'revision_requested' %}
                        <div class="recruit-alert recruit-alert--info" style="margin-bottom:14px;">
                            <strong>Raison de la revision :</strong> {{ listing.revisionReason }}
                        </div>
                    {% endif %}

                    {% if listing.rejectionReason and listing.status == 'rejected' %}
                        <div class="recruit-alert recruit-alert--danger" style="margin-bottom:14px;">
                            <strong>Raison du rejet :</strong> {{ listing.rejectionReason }}
                        </div>
                    {% endif %}

                    <div class="recruit-card__meta">
                        <span><i class="fas fa-calendar"></i> {{ listing.createdAt|date('d/m/Y') }}</span>
                        <span><i class="fas fa-clipboard-list"></i> {{ listing.formFields|length }} champ{{ listing.formFields|length > 1 ? 's' : '' }}</span>
                        <span><i class="fas fa-users"></i> {{ listing.applications|length }} candidature{{ listing.applications|length > 1 ? 's' : '' }}</span>
                        {% if listing.isPubliclyVisible %}
                            <span style="color:#45f882;"><i class="fas fa-globe"></i> Publique</span>
                        {% endif %}
                    </div>

                    <div class="recruit-card__actions">
                        <a href="{{ path('user_recruitment_edit', {id: listing.id}) }}" class="recruit-card__btn">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        <a href="{{ path('user_recruitment_form_builder', {id: listing.id}) }}" class="recruit-card__btn recruit-card__btn--primary">
                            <i class="fas fa-clipboard-list"></i> Formulaire
                        </a>
                        {% if listing.status in ['draft', 'revision_requested'] %}
                            <form method="post" action="{{ path('user_recruitment_submit', {id: listing.id}) }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('recruitment_submit_' ~ listing.id) }}">
                                <button type="submit" class="recruit-card__btn recruit-card__btn--primary">
                                    <i class="fas fa-paper-plane"></i> Soumettre
                                </button>
                            </form>
                        {% endif %}
                        {% if listing.applications|length > 0 %}
                            <a href="{{ path('user_recruitment_applications', {id: listing.id}) }}" class="recruit-card__btn">
                                <i class="fas fa-inbox"></i> Candidatures
                            </a>
                        {% endif %}
                        {% if listing.isPubliclyVisible %}
                            <a href="{{ path('recruitment_show', {slug: listing.slug}) }}" class="recruit-card__btn" target="_blank">
                                <i class="fas fa-external-link-alt"></i> Voir
                            </a>
                        {% endif %}
                        <form method="post" action="{{ path('user_recruitment_delete', {id: listing.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette annonce et toutes ses candidatures ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('recruitment_delete_' ~ listing.id) }}">
                            <button type="submit" class="recruit-card__btn recruit-card__btn--danger">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="recruit-empty">
                <i class="fas fa-bullhorn"></i>
                <p>Vous n'avez aucune annonce de recrutement.</p>
            </div>
        {% endif %}

    </div>
</section>
{% endblock %}

{% block scripts %}
<script>
function createListing() {
    var sel = document.getElementById('serverSelect');
    if (!sel.value) {
        alert('Veuillez choisir un serveur.');
        return;
    }
    window.location.href = '{{ path('user_recruitment_new', {serverId: '__ID__'}) }}'.replace('__ID__', sel.value);
}
</script>
{% endblock %}
