{% extends 'base.html.twig' %}

{% block title %}Candidature de {{ application.applicantName }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/user-recruitment/application-detail.css') }}">
{% endblock %}

{% block body %}
<section class="appd-page">
    <div class="container" style="max-width:800px;">

        <a href="{{ path('user_recruitment_applications', {id: listing.id}) }}" class="appd-back">
            <i class="fas fa-arrow-left"></i> Retour aux candidatures
        </a>

        <h1 class="appd-title">Candidature de <span>{{ application.applicantName }}</span></h1>
        <p class="appd-subtitle">{{ listing.title }} &mdash; {{ listing.server.name }}</p>

        {# Status + Actions #}
        <div class="appd-card">
            <div class="appd-section"><i class="fas fa-flag"></i> Statut</div>
            <div>
                {% if application.status == 'accepted' %}
                    <span class="appd-status appd-status--accepted"><i class="fas fa-check-circle"></i> Acceptee</span>
                {% elseif application.status == 'rejected' %}
                    <span class="appd-status appd-status--rejected"><i class="fas fa-times-circle"></i> Refusee</span>
                {% else %}
                    <span class="appd-status appd-status--pending"><i class="fas fa-clock"></i> En attente</span>
                {% endif %}
            </div>

            {% if application.reviewedBy %}
                <div class="appd-review-info">
                    <p>Traite par <strong style="color:#fff;">{{ application.reviewedBy.username }}</strong> le {{ application.reviewedAt|time_ago }}</p>
                    {% if application.statusComment %}
                        <div class="comment">{{ application.statusComment }}</div>
                    {% endif %}
                </div>
            {% endif %}

            {% if application.status == 'pending' %}
                <div class="appd-actions">
                    <button class="appd-btn appd-btn--accept" onclick="openReviewModal('accept')">
                        <i class="fas fa-check"></i> Accepter
                    </button>
                    <button class="appd-btn appd-btn--reject" onclick="openReviewModal('reject')">
                        <i class="fas fa-times"></i> Refuser
                    </button>
                    {% if not application.chatEnabled %}
                        <form method="post" action="{{ path('user_recruitment_application_chat_enable', {id: listing.id, appId: application.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('app_chat_enable_' ~ application.id) }}">
                            <button type="submit" class="appd-btn appd-btn--chat">
                                <i class="fas fa-comments"></i> Activer le chat
                            </button>
                        </form>
                    {% endif %}
                </div>
            {% elseif not application.chatEnabled %}
                <div class="appd-actions">
                    <form method="post" action="{{ path('user_recruitment_application_chat_enable', {id: listing.id, appId: application.id}) }}" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('app_chat_enable_' ~ application.id) }}">
                        <button type="submit" class="appd-btn appd-btn--chat">
                            <i class="fas fa-comments"></i> Activer le chat
                        </button>
                    </form>
                </div>
            {% endif %}
        </div>

        {# Applicant Info #}
        <div class="appd-card">
            <div class="appd-section"><i class="fas fa-user"></i> Informations du candidat</div>
            <div class="appd-info-grid">
                <div class="appd-info-item">
                    <label>Nom</label>
                    <span>{{ application.applicantName }}</span>
                </div>
                <div class="appd-info-item">
                    <label>Email</label>
                    <span><a href="mailto:{{ application.applicantEmail }}" style="color:#45f882;">{{ application.applicantEmail }}</a></span>
                </div>
                <div class="appd-info-item">
                    <label>Compte Nexarena</label>
                    <span>
                        {% if application.applicantUser %}
                            <i class="fas fa-check-circle" style="color:#45f882;"></i> {{ application.applicantUser.username }}
                        {% else %}
                            <span style="color:rgba(255,255,255,0.35);">Visiteur (non inscrit)</span>
                        {% endif %}
                    </span>
                </div>
                <div class="appd-info-item">
                    <label>Date de candidature</label>
                    <span>{{ application.createdAt|time_ago }}</span>
                </div>
            </div>
        </div>

        {# Responses #}
        <div class="appd-card">
            <div class="appd-section"><i class="fas fa-clipboard-check"></i> Reponses au formulaire</div>

            {% set formFields = listing.formFields %}
            {% for key, value in application.responses %}
                {% set fieldIndex = key %}
                {% set field = formFields[fieldIndex] is defined ? formFields[fieldIndex] : null %}
                <div class="appd-response">
                    <div class="appd-response__label">
                        {% if field %}
                            {{ field.label }}
                            <span style="font-size:10px;color:rgba(255,255,255,0.25);margin-left:6px;">({{ field.type }})</span>
                        {% else %}
                            Champ #{{ key }}
                        {% endif %}
                    </div>
                    <div class="appd-response__value">
                        {% if value is iterable %}
                            {{ value|join(', ') }}
                        {% else %}
                            {{ value ?: '-' }}
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <div style="text-align:center;padding:20px;color:rgba(255,255,255,0.3);font-size:14px;">
                    Aucune reponse enregistree.
                </div>
            {% endfor %}
        </div>

        {# Chat Panel #}
        {% if application.chatEnabled %}
            <div class="chat-panel" id="chatPanel">
                <div class="chat-header">
                    <h3><i class="fas fa-comments"></i> Chat avec le candidat</h3>
                </div>
                <div class="chat-messages" id="chatMessages">
                    <div class="chat-empty" id="chatEmpty">
                        <i class="fas fa-comment-dots"></i>
                        Aucun message pour le moment. Envoyez le premier !
                    </div>
                </div>
                <div class="chat-input">
                    <input type="text" id="chatInput" placeholder="Votre message..." maxlength="2000" autocomplete="off">
                    <button onclick="sendMessage()" id="chatSendBtn"><i class="fas fa-paper-plane"></i> Envoyer</button>
                </div>
            </div>
        {% endif %}

    </div>
</section>

{# Review Modal #}
<div class="appd-modal-overlay" id="reviewModal">
    <div class="appd-modal">
        <h3 id="reviewModalTitle">Accepter la candidature</h3>
        <form id="reviewForm" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('app_review_' ~ application.id) }}">
            <textarea name="comment" placeholder="Commentaire (facultatif)..." maxlength="2000"></textarea>
            <div class="appd-modal-actions">
                <button type="button" class="appd-modal-cancel" onclick="closeReviewModal()">Annuler</button>
                <button type="submit" class="appd-btn" id="reviewSubmitBtn">Confirmer</button>
            </div>
        </form>
    </div>
</div>

<script>
// Review modal
function openReviewModal(action) {
    var modal = document.getElementById('reviewModal');
    var form = document.getElementById('reviewForm');
    var title = document.getElementById('reviewModalTitle');
    var btn = document.getElementById('reviewSubmitBtn');

    if (action === 'accept') {
        title.textContent = 'Accepter la candidature';
        btn.className = 'appd-btn appd-btn--accept';
        btn.innerHTML = '<i class="fas fa-check"></i> Accepter';
        form.action = '{{ path('user_recruitment_application_accept', {id: listing.id, appId: application.id}) }}';
    } else {
        title.textContent = 'Refuser la candidature';
        btn.className = 'appd-btn appd-btn--reject';
        btn.innerHTML = '<i class="fas fa-times"></i> Refuser';
        form.action = '{{ path('user_recruitment_application_reject', {id: listing.id, appId: application.id}) }}';
    }

    modal.classList.add('active');
}

function closeReviewModal() {
    document.getElementById('reviewModal').classList.remove('active');
}

document.getElementById('reviewModal').addEventListener('click', function(e) {
    if (e.target === this) closeReviewModal();
});

{% if application.chatEnabled %}
// Chat
var currentUserId = {{ app.user.id }};
var lastMessageId = 0;
var chatUrl = '{{ path('api_recruitment_chat_messages', {appId: application.id}) }}';
var sendUrl = '{{ path('api_recruitment_chat_send', {appId: application.id}) }}';

function escapeHtml(text) {
    var d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
}

function renderMessage(msg) {
    var isMine = msg.senderId === currentUserId;
    return '<div class="chat-msg ' + (isMine ? 'chat-msg--mine' : 'chat-msg--other') + '">' +
        '<div>' + escapeHtml(msg.content) + '</div>' +
        '<div class="chat-msg__meta">' +
            '<span class="chat-msg__sender">' + escapeHtml(msg.senderName) + '</span> &middot; ' + escapeHtml(msg.createdAt) +
        '</div>' +
    '</div>';
}

function loadMessages() {
    fetch(chatUrl + '?after=' + lastMessageId, { credentials: 'same-origin' })
        .then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function(messages) {
            if (Array.isArray(messages) && messages.length > 0) {
                var container = document.getElementById('chatMessages');
                var empty = document.getElementById('chatEmpty');
                if (empty) empty.remove();

                messages.forEach(function(msg) {
                    container.insertAdjacentHTML('beforeend', renderMessage(msg));
                    lastMessageId = msg.id;
                });

                container.scrollTop = container.scrollHeight;
            }
        })
        .catch(function(e) { console.error('Chat load error:', e); });
}

function sendMessage() {
    var input = document.getElementById('chatInput');
    var content = input.value.trim();
    if (!content) return;

    var btn = document.getElementById('chatSendBtn');
    btn.disabled = true;

    fetch(sendUrl, {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: content })
    })
    .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
    })
    .then(function(msg) {
        if (msg.id) {
            var container = document.getElementById('chatMessages');
            var empty = document.getElementById('chatEmpty');
            if (empty) empty.remove();

            container.insertAdjacentHTML('beforeend', renderMessage(msg));
            lastMessageId = msg.id;
            container.scrollTop = container.scrollHeight;
            input.value = '';
        }
        btn.disabled = false;
    })
    .catch(function(e) { console.error('Chat send error:', e); btn.disabled = false; });
}

document.getElementById('chatInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') { e.preventDefault(); sendMessage(); }
});

loadMessages();
setInterval(loadMessages, 3000);
{% endif %}
</script>
{% endblock %}
