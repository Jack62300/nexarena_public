{% extends 'base.html.twig' %}

{% block title %}Candidatures - {{ listing.title }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<style>
    .apps-page { padding: 120px 0 80px; min-height: 100vh; }
    .apps-back {
        display: inline-flex; align-items: center; gap: 8px;
        color: rgba(255,255,255,0.5); font-size: 13px; margin-bottom: 20px;
        text-decoration: none; transition: color 0.2s;
    }
    .apps-back:hover { color: #45f882; }
    .apps-title { font-size: 26px; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; }
    .apps-title span { color: #45f882; }
    .apps-subtitle { color: rgba(255,255,255,0.5); font-size: 14px; margin-bottom: 30px; }

    .apps-card {
        background: rgba(22,34,49,0.6);
        border: 1px solid rgba(69,248,130,0.08);
        border-radius: 12px;
        overflow: hidden;
    }
    .apps-card table { width: 100%; border-collapse: collapse; }
    .apps-card th {
        padding: 12px 20px; text-align: left;
        font-size: 11px; text-transform: uppercase; letter-spacing: 1px;
        color: rgba(255,255,255,0.4); border-bottom: 1px solid rgba(255,255,255,0.05);
        background: rgba(0,0,0,0.15);
    }
    .apps-card td {
        padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.03); font-size: 14px;
    }
    .apps-card tr:last-child td { border-bottom: none; }
    .apps-card tr:hover td { background: rgba(255,255,255,0.02); }

    .apps-unread {
        display: inline-block; width: 8px; height: 8px;
        background: #45f882; border-radius: 50%; margin-right: 8px;
    }
    .apps-link {
        color: #45f882; text-decoration: none; font-weight: 600; transition: color 0.2s;
    }
    .apps-link:hover { color: #2bc866; }

    .apps-empty {
        text-align: center; padding: 50px; color: rgba(255,255,255,0.35);
    }
    .apps-empty i { font-size: 40px; display: block; margin-bottom: 12px; color: rgba(255,255,255,0.15); }

    .apps-badge {
        display: inline-block; padding: 3px 10px; border-radius: 6px;
        font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .apps-badge--pending { background: rgba(255,193,7,0.15); color: #ffc107; }
    .apps-badge--accepted { background: rgba(69,248,130,0.15); color: #45f882; }
    .apps-badge--rejected { background: rgba(220,53,69,0.15); color: #dc3545; }
</style>
{% endblock %}

{% block body %}
<section class="apps-page">
    <div class="container" style="max-width:1000px;">

        <a href="{{ path('user_recruitment_list') }}" class="apps-back">
            <i class="fas fa-arrow-left"></i> Retour a mes recrutements
        </a>

        <h1 class="apps-title"><span>Candidatures</span></h1>
        <p class="apps-subtitle">{{ listing.title }} &mdash; {{ listing.server.name }} &mdash; {{ applications|length }} candidature{{ applications|length > 1 ? 's' : '' }}</p>

        <div class="apps-card">
            {% if applications|length > 0 %}
                <table>
                    <thead>
                        <tr>
                            <th></th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Utilisateur</th>
                            <th>Statut</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for app in applications %}
                            <tr>
                                <td style="width:20px;">
                                    {% if not app.isRead %}
                                        <span class="apps-unread" title="Non lu"></span>
                                    {% endif %}
                                </td>
                                <td style="font-weight:{{ app.isRead ? '400' : '700' }};">
                                    {{ app.applicantName }}
                                </td>
                                <td>{{ app.applicantEmail }}</td>
                                <td>
                                    {% if app.applicantUser %}
                                        <span style="color:#45f882;">{{ app.applicantUser.username }}</span>
                                    {% else %}
                                        <span style="color:rgba(255,255,255,0.3);">Visiteur</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if app.status == 'accepted' %}
                                        <span class="apps-badge apps-badge--accepted"><i class="fas fa-check"></i> Acceptee</span>
                                    {% elseif app.status == 'rejected' %}
                                        <span class="apps-badge apps-badge--rejected"><i class="fas fa-times"></i> Refusee</span>
                                    {% else %}
                                        <span class="apps-badge apps-badge--pending"><i class="fas fa-clock"></i> En attente</span>
                                    {% endif %}
                                </td>
                                <td style="white-space:nowrap;">{{ app.createdAt|date('d/m/Y H:i') }}</td>
                                <td>
                                    <a href="{{ path('user_recruitment_application_detail', {id: listing.id, appId: app.id}) }}" class="apps-link">
                                        <i class="fas fa-eye"></i> Voir
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div class="apps-empty">
                    <i class="fas fa-inbox"></i>
                    Aucune candidature pour le moment.
                </div>
            {% endif %}
        </div>

    </div>
</section>
{% endblock %}
