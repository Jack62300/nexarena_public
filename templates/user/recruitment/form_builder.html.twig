{% extends 'base.html.twig' %}

{% block title %}Formulaire - {{ listing.title }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/user-recruitment/form-builder.css') }}">
{% endblock %}

{% block body %}
<section class="fb-page">
    <div class="container">

        <a href="{{ path('user_recruitment_list') }}" class="fb-back">
            <i class="fas fa-arrow-left"></i> Retour a mes recrutements
        </a>

        <h1 class="fb-title">Constructeur de <span>formulaire</span></h1>
        <p class="fb-subtitle">{{ listing.title }} &mdash; {{ listing.server.name }}</p>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:13px;background:{{ type == 'error' ? 'rgba(231,74,59,0.1)' : 'rgba(69,248,130,0.08)' }};border:1px solid {{ type == 'error' ? 'rgba(231,74,59,0.2)' : 'rgba(69,248,130,0.15)' }};color:{{ type == 'error' ? '#e74a3b' : '#45f882' }};">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form method="post" id="formBuilderForm">
            <input type="hidden" name="_token" value="{{ csrf_token('recruitment_form_builder') }}">
            <input type="hidden" name="form_fields" id="formFieldsInput" value="">

            <div class="fb-layout">
                {# LEFT: Field Editor #}
                <div class="fb-panel">
                    <div class="fb-panel__title"><i class="fas fa-tools"></i> Champs du formulaire</div>

                    <div class="fb-add-bar">
                        <select id="fieldTypeSelect">
                            <option value="text">Texte court</option>
                            <option value="textarea">Texte long</option>
                            <option value="email">Email</option>
                            <option value="number">Nombre</option>
                            <option value="select">Liste deroulante</option>
                            <option value="radio">Boutons radio</option>
                            <option value="checkbox">Case a cocher</option>
                        </select>
                        <button type="button" class="fb-add-btn" onclick="addField()">
                            <i class="fas fa-plus"></i> Ajouter
                        </button>
                    </div>

                    <div id="fieldsContainer"></div>
                    <div id="fieldsEmpty" class="fb-empty" style="display:none;">
                        <i class="fas fa-clipboard-list"></i>
                        Ajoutez des champs pour construire votre formulaire.
                    </div>
                    <div class="fb-count"><span id="fieldCount">0</span> / 20 champs</div>
                </div>

                {# RIGHT: Preview #}
                <div class="fb-panel">
                    <div class="fb-panel__title"><i class="fas fa-eye"></i> Previsualisation</div>
                    <div id="previewContainer"></div>
                    <div id="previewEmpty" class="fb-preview-empty" style="display:none;">
                        <i class="fas fa-eye-slash"></i>
                        La previsualisation apparaitra ici.
                    </div>
                </div>
            </div>

            <div class="fb-submit-bar">
                <a href="{{ path('user_recruitment_list') }}" class="fb-btn fb-btn--outline">Annuler</a>
                <button type="submit" class="fb-btn fb-btn--primary">
                    <i class="fas fa-save"></i> Enregistrer le formulaire
                </button>
            </div>
        </form>

    </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
(function() {
    var fields = {{ listing.formFields|json_encode|raw }};
    var container = document.getElementById('fieldsContainer');
    var emptyMsg = document.getElementById('fieldsEmpty');
    var previewContainer = document.getElementById('previewContainer');
    var previewEmpty = document.getElementById('previewEmpty');
    var countEl = document.getElementById('fieldCount');
    var hiddenInput = document.getElementById('formFieldsInput');
    var MAX_FIELDS = 20;

    var typeLabels = {
        text: 'Texte court', textarea: 'Texte long', email: 'Email',
        number: 'Nombre', select: 'Liste deroulante', radio: 'Radio', checkbox: 'Checkbox'
    };

    function render() {
        container.innerHTML = '';
        previewContainer.innerHTML = '';
        countEl.textContent = fields.length;

        if (fields.length === 0) {
            emptyMsg.style.display = '';
            previewEmpty.style.display = '';
        } else {
            emptyMsg.style.display = 'none';
            previewEmpty.style.display = 'none';
        }

        fields.forEach(function(f, i) {
            container.appendChild(buildFieldCard(f, i));
            previewContainer.appendChild(buildPreview(f, i));
        });

        serialize();
    }

    function buildFieldCard(f, idx) {
        var div = document.createElement('div');
        div.className = 'fb-field';
        var hasOpts = (f.type === 'select' || f.type === 'radio');
        var optsHtml = '';
        if (hasOpts) {
            var options = f.options || [''];
            optsHtml = '<div class="fb-options">' +
                '<span class="fb-field__label">Options</span>';
            options.forEach(function(opt, oi) {
                optsHtml += '<div class="fb-options__row">' +
                    '<input type="text" class="fb-field__input fb-options__input" value="' + esc(opt) + '" data-idx="' + idx + '" data-oi="' + oi + '" onchange="updateOption(this)">' +
                    '<button type="button" class="fb-options__remove" onclick="removeOption(' + idx + ',' + oi + ')" title="Supprimer"><i class="fas fa-times"></i></button>' +
                    '</div>';
            });
            optsHtml += '<button type="button" class="fb-options__add" onclick="addOption(' + idx + ')"><i class="fas fa-plus"></i> Ajouter une option</button></div>';
        }

        div.innerHTML =
            '<div class="fb-field__header">' +
                '<span class="fb-field__type">' + (typeLabels[f.type] || f.type) + '</span>' +
                '<div class="fb-field__btns">' +
                    (idx > 0 ? '<button type="button" class="fb-field__btn" onclick="moveField(' + idx + ',-1)" title="Monter"><i class="fas fa-arrow-up"></i></button>' : '') +
                    (idx < fields.length - 1 ? '<button type="button" class="fb-field__btn" onclick="moveField(' + idx + ',1)" title="Descendre"><i class="fas fa-arrow-down"></i></button>' : '') +
                    '<button type="button" class="fb-field__btn fb-field__btn--danger" onclick="removeField(' + idx + ')" title="Supprimer"><i class="fas fa-trash"></i></button>' +
                '</div>' +
            '</div>' +
            '<div class="fb-field__row">' +
                '<span class="fb-field__label">Label</span>' +
                '<input type="text" class="fb-field__input" value="' + esc(f.label) + '" data-idx="' + idx + '" data-prop="label" onchange="updateProp(this)">' +
            '</div>' +
            '<div class="fb-field__row">' +
                '<span class="fb-field__label">Placeholder</span>' +
                '<input type="text" class="fb-field__input" value="' + esc(f.placeholder || '') + '" data-idx="' + idx + '" data-prop="placeholder" onchange="updateProp(this)">' +
            '</div>' +
            '<div class="fb-field__check">' +
                '<input type="checkbox" id="req_' + idx + '" ' + (f.required ? 'checked' : '') + ' onchange="toggleRequired(' + idx + ', this.checked)">' +
                '<label for="req_' + idx + '">Obligatoire</label>' +
            '</div>' +
            optsHtml;
        return div;
    }

    function buildPreview(f, idx) {
        var div = document.createElement('div');
        div.className = 'fb-preview-field';
        var reqMark = f.required ? '<span class="req">*</span>' : '';
        var html = '<label class="fb-preview-label">' + esc(f.label) + reqMark + '</label>';

        if (f.type === 'text' || f.type === 'email' || f.type === 'number') {
            html += '<input type="' + f.type + '" class="fb-preview-input" placeholder="' + esc(f.placeholder || '') + '" disabled>';
        } else if (f.type === 'textarea') {
            html += '<textarea class="fb-preview-input fb-preview-textarea" placeholder="' + esc(f.placeholder || '') + '" disabled></textarea>';
        } else if (f.type === 'select') {
            html += '<select class="fb-preview-input fb-preview-select" disabled>';
            html += '<option value="">' + esc(f.placeholder || 'Choisir...') + '</option>';
            (f.options || []).forEach(function(opt) {
                html += '<option>' + esc(opt) + '</option>';
            });
            html += '</select>';
        } else if (f.type === 'radio') {
            html += '<div class="fb-preview-radio">';
            (f.options || []).forEach(function(opt, oi) {
                html += '<label><input type="radio" name="preview_radio_' + idx + '" disabled> ' + esc(opt) + '</label>';
            });
            html += '</div>';
        } else if (f.type === 'checkbox') {
            html += '<div class="fb-preview-checkbox"><label><input type="checkbox" disabled> ' + esc(f.placeholder || f.label) + '</label></div>';
        }

        div.innerHTML = html;
        return div;
    }

    function serialize() {
        hiddenInput.value = JSON.stringify(fields);
    }

    function esc(str) {
        var d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML.replace(/"/g, '&quot;');
    }

    // Global functions
    window.addField = function() {
        if (fields.length >= MAX_FIELDS) { alert('Maximum 20 champs.'); return; }
        var type = document.getElementById('fieldTypeSelect').value;
        var f = { label: 'Nouveau champ', type: type, required: false, placeholder: '' };
        if (type === 'select' || type === 'radio') { f.options = ['Option 1']; }
        fields.push(f);
        render();
    };

    window.removeField = function(idx) {
        if (!confirm('Supprimer ce champ ?')) return;
        fields.splice(idx, 1);
        render();
    };

    window.moveField = function(idx, dir) {
        var newIdx = idx + dir;
        if (newIdx < 0 || newIdx >= fields.length) return;
        var tmp = fields[idx];
        fields[idx] = fields[newIdx];
        fields[newIdx] = tmp;
        render();
    };

    window.updateProp = function(el) {
        var idx = parseInt(el.dataset.idx);
        var prop = el.dataset.prop;
        fields[idx][prop] = el.value;
        render();
    };

    window.toggleRequired = function(idx, val) {
        fields[idx].required = val;
        render();
    };

    window.updateOption = function(el) {
        var idx = parseInt(el.dataset.idx);
        var oi = parseInt(el.dataset.oi);
        fields[idx].options[oi] = el.value;
        render();
    };

    window.addOption = function(idx) {
        if (!fields[idx].options) fields[idx].options = [];
        if (fields[idx].options.length >= 50) return;
        fields[idx].options.push('');
        render();
    };

    window.removeOption = function(idx, oi) {
        fields[idx].options.splice(oi, 1);
        render();
    };

    // Init
    render();
})();
</script>
{% endblock %}
