{% extends 'base.html.twig' %}

{% block title %}{{ profileUser.username }} - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/profile.css') }}">
<style>
.pub-profile { padding: 80px 0; min-height: 60vh; }
.pub-profile__header { display:flex; align-items:center; gap:24px; margin-bottom:32px; flex-wrap:wrap; }
.pub-profile__avatar { width:120px; height:120px; border-radius:50%; overflow:hidden; border:3px solid #45f882; flex-shrink:0; background:#1a1a2e; display:flex; align-items:center; justify-content:center; }
.pub-profile__avatar img { width:100%; height:100%; object-fit:cover; }
.pub-profile__avatar i { font-size:48px; color:#8b949e; }
.pub-profile__info h1 { font-size:28px; font-weight:700; color:#fff; margin:0 0 4px; }
.pub-profile__info .member-since { font-size:13px; color:#8b949e; }
.pub-profile__actions { margin-left:auto; display:flex; gap:8px; flex-wrap:wrap; }
.pub-profile__share { background:#2a2a3e; color:#8b949e; border:1px solid #3a3a4e; padding:8px 14px; border-radius:8px; cursor:pointer; font-size:13px; transition:all .2s; }
.pub-profile__share:hover { color:#45f882; border-color:#45f882; }
.pub-profile__share.copied { color:#45f882; border-color:#45f882; }

.pub-section { margin-bottom:32px; }
.pub-section__title { font-size:18px; font-weight:600; color:#fff; margin-bottom:16px; display:flex; align-items:center; gap:8px; }
.pub-section__title i { color:#45f882; }

.pub-bio { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); border-radius:12px; padding:20px; color:#c9d1d9; font-size:14px; line-height:1.7; }
.pub-bio p { margin-bottom:8px; }

.pub-socials { display:flex; flex-wrap:wrap; gap:10px; }
.pub-social { display:flex; align-items:center; gap:8px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:8px; padding:8px 14px; font-size:13px; color:#c9d1d9; }
.pub-social i { font-size:16px; }
.pub-social--discord i { color:#5865f2; }
.pub-social--steam i { color:#1b2838; }
.pub-social--twitch i { color:#9146ff; }
.pub-social--game i { color:#45f882; }
.pub-social--email i { color:#f0a030; }

.pub-badges { display:flex; flex-wrap:wrap; gap:12px; }
.pub-badge { display:flex; align-items:center; gap:10px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:10px 16px; transition:transform .2s; }
.pub-badge:hover { transform:translateY(-2px); }
.pub-badge__icon { width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:18px; }
.pub-badge__icon img { width:100%; height:100%; object-fit:contain; border-radius:6px; }
.pub-badge__name { font-size:14px; font-weight:600; color:#fff; }
.pub-badge__date { font-size:11px; color:#8b949e; }

.pub-servers { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:16px; }
.pub-server { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); border-radius:12px; padding:16px; transition:all .2s; text-decoration:none; display:block; }
.pub-server:hover { border-color:#45f882; transform:translateY(-2px); }
.pub-server__name { font-size:16px; font-weight:600; color:#fff; margin-bottom:4px; }
.pub-server__cat { font-size:12px; color:#8b949e; }
.pub-server__votes { font-size:13px; color:#45f882; margin-top:8px; }

.pub-empty { color:#8b949e; font-size:14px; font-style:italic; }
</style>
{% endblock %}

{% block body %}

    {# breadcrumb-area #}
    <section class="breadcrumb-area" data-background="{{ asset('assets/img/bg/breadcrumb_bg01.jpg') }}">
        <div class="container">
            <div class="breadcrumb__wrapper">
                <div class="row">
                    <div class="col-xl-6 col-lg-7">
                        <div class="breadcrumb__content">
                            <h2 class="title">{{ profileUser.username }}</h2>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Profil</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                    <div class="col-xl-6 col-lg-5 position-relative d-none d-lg-block">
                        <div class="breadcrumb__img">
                            <img src="{{ asset('assets/img/others/breadcrumb_img02.png') }}" alt="img">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pub-profile" data-background="{{ asset('assets/img/bg/team_bg.jpg') }}">
        <div class="container">

            {# Flash messages #}
            {% for message in app.flashes('success') %}
                <div class="profile-flash profile-flash--success"><i class="fas fa-check-circle"></i> {{ message }}</div>
            {% endfor %}

            {# ── Header ── #}
            <div class="pub-profile__header">
                <div class="pub-profile__avatar">
                    {% if profileUser.avatar starts with 'http' %}
                        <img src="{{ profileUser.avatar }}" alt="{{ profileUser.username }}">
                    {% elseif profileUser.avatar %}
                        <img src="{{ asset('uploads/avatars/' ~ profileUser.avatar) }}" alt="{{ profileUser.username }}">
                    {% else %}
                        <i class="fas fa-user"></i>
                    {% endif %}
                </div>
                <div class="pub-profile__info">
                    <h1>{{ profileUser.username }}</h1>
                    <div class="member-since"><i class="fas fa-calendar-alt"></i> Membre depuis {{ profileUser.createdAt ? profileUser.createdAt|date('d/m/Y') : 'N/A' }}</div>
                </div>
                <div class="pub-profile__actions">
                    {% if isOwnProfile %}
                        <a href="{{ path('user_profile_edit') }}" class="pub-profile__share"><i class="fas fa-pen"></i> Modifier</a>
                        <a href="{{ path('user_settings') }}" class="pub-profile__share"><i class="fas fa-cog"></i> Parametres</a>
                    {% endif %}
                    <button type="button" class="pub-profile__share" id="btnShareProfile" data-url="{{ url('profile_show', {username: profileUser.username}) }}">
                        <i class="fas fa-share-alt"></i> Partager
                    </button>
                </div>
            </div>

            {# ── Bio ── #}
            {% if profileUser.bio %}
                <div class="pub-section">
                    <h3 class="pub-section__title"><i class="fas fa-quote-left"></i> Presentation</h3>
                    <div class="pub-bio">{{ profileUser.bio|raw }}</div>
                </div>
            {% elseif isOwnProfile %}
                <div class="pub-section">
                    <h3 class="pub-section__title"><i class="fas fa-quote-left"></i> Presentation</h3>
                    <div class="pub-empty">Aucune presentation. <a href="{{ path('user_profile_edit') }}" style="color:#45f882;">Ajouter une bio</a></div>
                </div>
            {% endif %}

            {# ── Socials ── #}
            {% set hasSocials = (profileUser.isFieldVisible('email') and profileUser.email)
                or (profileUser.isFieldVisible('discord') and profileUser.discordUsername)
                or (profileUser.isFieldVisible('steam') and profileUser.steamUsername)
                or (profileUser.isFieldVisible('twitch') and profileUser.twitchUsername)
                or (profileUser.isFieldVisible('games') and profileUser.gameUsernames)
                or isOwnProfile %}

            {% if hasSocials %}
                <div class="pub-section">
                    <h3 class="pub-section__title"><i class="fas fa-link"></i> Reseaux & pseudos</h3>
                    <div class="pub-socials">
                        {% if (profileUser.isFieldVisible('email') or isOwnProfile) and profileUser.email %}
                            <div class="pub-social pub-social--email">
                                <i class="fas fa-envelope"></i> {{ profileUser.email }}
                                {% if isOwnProfile and not profileUser.isFieldVisible('email') %}
                                    <span style="font-size:10px;color:#8b949e;">(masque)</span>
                                {% endif %}
                            </div>
                        {% endif %}
                        {% if (profileUser.isFieldVisible('discord') or isOwnProfile) and profileUser.discordUsername %}
                            <div class="pub-social pub-social--discord">
                                <i class="fab fa-discord"></i> {{ profileUser.discordUsername }}
                                {% if isOwnProfile and not profileUser.isFieldVisible('discord') %}
                                    <span style="font-size:10px;color:#8b949e;">(masque)</span>
                                {% endif %}
                            </div>
                        {% endif %}
                        {% if (profileUser.isFieldVisible('steam') or isOwnProfile) and profileUser.steamUsername %}
                            <div class="pub-social pub-social--steam">
                                <i class="fab fa-steam"></i> {{ profileUser.steamUsername }}
                                {% if isOwnProfile and not profileUser.isFieldVisible('steam') %}
                                    <span style="font-size:10px;color:#8b949e;">(masque)</span>
                                {% endif %}
                            </div>
                        {% endif %}
                        {% if (profileUser.isFieldVisible('twitch') or isOwnProfile) and profileUser.twitchUsername %}
                            <div class="pub-social pub-social--twitch">
                                <i class="fab fa-twitch"></i> {{ profileUser.twitchUsername }}
                                {% if isOwnProfile and not profileUser.isFieldVisible('twitch') %}
                                    <span style="font-size:10px;color:#8b949e;">(masque)</span>
                                {% endif %}
                            </div>
                        {% endif %}
                        {% if (profileUser.isFieldVisible('games') or isOwnProfile) and profileUser.gameUsernames %}
                            {% for game, name in profileUser.gameUsernames %}
                                <div class="pub-social pub-social--game">
                                    <i class="fas fa-gamepad"></i> {{ game }}: <strong>{{ name }}</strong>
                                </div>
                            {% endfor %}
                            {% if isOwnProfile and not profileUser.isFieldVisible('games') %}
                                <span style="font-size:10px;color:#8b949e;">(masque)</span>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {# ── Badges ── #}
            {% if badges|length > 0 %}
                <div class="pub-section">
                    <h3 class="pub-section__title"><i class="fas fa-award"></i> Badges ({{ badges|length }})</h3>
                    <div class="pub-badges">
                        {% for ub in badges %}
                            <div class="pub-badge" {% if ub.badge.color %}style="border-color:{{ ub.badge.color }};"{% endif %}>
                                <div class="pub-badge__icon" {% if ub.badge.color %}style="background:{{ ub.badge.color }}22;"{% endif %}>
                                    {% if ub.badge.iconFileName %}
                                        <img src="{{ asset('uploads/badges/' ~ ub.badge.iconFileName) }}" alt="{{ ub.badge.name }}">
                                    {% else %}
                                        <i class="fas fa-award" {% if ub.badge.color %}style="color:{{ ub.badge.color }};"{% endif %}></i>
                                    {% endif %}
                                </div>
                                <div>
                                    <div class="pub-badge__name">{{ ub.badge.name }}</div>
                                    <div class="pub-badge__date">{{ ub.awardedAt|date('d/m/Y') }}</div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# ── Servers ── #}
            {% if servers|length > 0 %}
                <div class="pub-section">
                    <h3 class="pub-section__title"><i class="fas fa-server"></i> Serveurs ({{ servers|length }})</h3>
                    <div class="pub-servers">
                        {% for server in servers %}
                            <a href="{{ path('server_show', {id: server.id, slug: server.slug}) }}" class="pub-server">
                                <div class="pub-server__name">{{ server.name }}</div>
                                <div class="pub-server__cat">
                                    {{ server.category.name }}
                                    {% if server.gameCategory %} / {{ server.gameCategory.name }}{% endif %}
                                </div>
                                <div class="pub-server__votes"><i class="fas fa-chart-line"></i> {{ server.monthlyVotes }} votes ce mois</div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% elseif isOwnProfile %}
                <div class="pub-section">
                    <h3 class="pub-section__title"><i class="fas fa-server"></i> Serveurs</h3>
                    <div class="pub-empty">Aucun serveur. <a href="{{ path('user_servers_new') }}" style="color:#45f882;">Ajouter un serveur</a></div>
                </div>
            {% endif %}

        </div>
    </section>

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('btnShareProfile');
    if (btn) {
        btn.addEventListener('click', function() {
            var url = this.dataset.url;
            if (navigator.clipboard) {
                navigator.clipboard.writeText(url).then(function() {
                    btn.classList.add('copied');
                    btn.innerHTML = '<i class="fas fa-check"></i> Copie !';
                    setTimeout(function() {
                        btn.classList.remove('copied');
                        btn.innerHTML = '<i class="fas fa-share-alt"></i> Partager';
                    }, 2000);
                });
            } else {
                // Fallback
                var input = document.createElement('input');
                input.value = url;
                document.body.appendChild(input);
                input.select();
                document.execCommand('copy');
                document.body.removeChild(input);
                btn.innerHTML = '<i class="fas fa-check"></i> Copie !';
                setTimeout(function() { btn.innerHTML = '<i class="fas fa-share-alt"></i> Partager'; }, 2000);
            }
        });
    }
});
</script>
{% endblock %}
