{% extends 'base.html.twig' %}

{% block title %}Parametres - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/profile.css') }}">
{% endblock %}

{% block body %}

    {# breadcrumb-area #}
    <section class="breadcrumb-area" data-background="{{ asset('assets/img/bg/breadcrumb_bg01.jpg') }}">
        <div class="container">
            <div class="breadcrumb__wrapper">
                <div class="row">
                    <div class="col-xl-6 col-lg-7">
                        <div class="breadcrumb__content">
                            <h2 class="title">Parametres</h2>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Parametres</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                    <div class="col-xl-6 col-lg-5 position-relative d-none d-lg-block">
                        <div class="breadcrumb__img">
                            <img src="{{ asset('assets/img/others/breadcrumb_img02.png') }}" alt="img">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="profile-page" data-background="{{ asset('assets/img/bg/team_bg.jpg') }}">
        <div class="container">
            <h2 class="profile-page__title"><span>Mes</span> parametres</h2>
            <p class="profile-page__subtitle">Gerez votre compte, votre avatar et votre securite.</p>
            <div style="margin-bottom:20px;">
                <a href="{{ path('profile_show', {username: app.user.username}) }}" class="btn-action btn-action--primary" style="font-size:13px;padding:8px 16px;">
                    <i class="fas fa-user"></i> Voir mon profil public
                </a>
            </div>

            {# Flash messages #}
            {% for message in app.flashes('success') %}
                <div class="profile-flash profile-flash--success"><i class="fas fa-check-circle"></i> {{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="profile-flash profile-flash--error"><i class="fas fa-exclamation-circle"></i> {{ message }}</div>
            {% endfor %}

            <div class="row">
                <div class="col-lg-6">

                    {# ── Avatar Card ── #}
                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-camera"></i> Avatar</h3>
                        <div class="avatar-upload">
                            <div class="avatar-preview" id="avatarPreview">
                                {% if app.user.avatar starts with 'http' %}
                                    <img src="{{ app.user.avatar }}" alt="Avatar">
                                {% elseif app.user.avatar %}
                                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="Avatar">
                                {% else %}
                                    <i class="fas fa-user"></i>
                                {% endif %}
                            </div>
                            <div>
                                <form action="{{ path('user_settings_avatar') }}" method="post" enctype="multipart/form-data" id="avatarForm">
                                    <input type="hidden" name="_token" value="{{ csrf_token('profile_avatar') }}">
                                    <input type="file" name="avatar" id="avatarInput" class="avatar-upload__input" accept="image/jpeg,image/png,image/gif,image/webp">
                                    <label for="avatarInput" class="avatar-upload__label"><i class="fas fa-upload"></i> Choisir une image</label>
                                    <span class="avatar-upload__name" id="avatarFileName">JPG, PNG, GIF ou WebP - 2 Mo max</span>
                                </form>
                            </div>
                        </div>
                    </div>

                    {# ── Email Card ── #}
                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-envelope"></i> Adresse email</h3>
                        <form action="{{ path('user_settings_email') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('profile_email') }}">
                            <div class="form-group">
                                <label for="email">Email</label>
                                <input type="email" id="email" name="email" class="form-input" value="{{ app.user.email }}" required>
                            </div>
                            <button type="submit" class="btn-action btn-action--primary"><i class="fas fa-save"></i> Enregistrer</button>
                        </form>
                    </div>

                </div>
                <div class="col-lg-6">

                    {# ── Password Card ── #}
                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-lock"></i> Mot de passe</h3>
                        <form action="{{ path('user_settings_password') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('profile_password') }}">
                            {% if app.user.password %}
                                <div class="form-group">
                                    <label for="currentPassword">Mot de passe actuel</label>
                                    <input type="password" id="currentPassword" name="current_password" class="form-input" required>
                                </div>
                            {% endif %}
                            <div class="form-group">
                                <label for="newPassword">Nouveau mot de passe</label>
                                <input type="password" id="newPassword" name="new_password" class="form-input" required minlength="10">
                                <div class="form-hint">Minimum 10 caracteres</div>
                            </div>
                            <div class="form-group">
                                <label for="confirmPassword">Confirmer le mot de passe</label>
                                <input type="password" id="confirmPassword" name="confirm_password" class="form-input" required minlength="10">
                            </div>
                            <button type="submit" class="btn-action btn-action--primary"><i class="fas fa-save"></i> Modifier</button>
                        </form>
                    </div>

                    {# ── 2FA Card ── #}
                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-shield-alt"></i> Authentification a deux facteurs (2FA)</h3>

                        {% if app.user.isTwoFactorEnabled %}
                            <div class="twofa-status twofa-status--active">
                                <i class="fas fa-check-circle"></i> 2FA active
                            </div>
                            <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                                Votre compte est protege par l'authentification a deux facteurs via une application TOTP.
                            </p>
                            <form action="{{ path('user_settings_2fa_disable') }}" method="post" onsubmit="return confirm('Etes-vous sur de vouloir desactiver le 2FA ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('profile_2fa') }}">
                                {% if app.user.password %}
                                <div style="margin-bottom:12px;">
                                    <label style="display:block;font-size:13px;color:#8b949e;margin-bottom:4px;">Mot de passe actuel</label>
                                    <input type="password" name="password" required class="profile-input" placeholder="Confirmez votre mot de passe" style="max-width:300px;">
                                </div>
                                {% endif %}
                                <button type="submit" class="btn-action btn-action--danger"><i class="fas fa-times"></i> Desactiver le 2FA</button>
                            </form>
                        {% else %}
                            <div class="twofa-status twofa-status--inactive">
                                <i class="fas fa-times-circle"></i> 2FA desactive
                            </div>
                            <p style="color:#8b949e;font-size:13px;margin-bottom:15px;">
                                Protegez votre compte en activant l'authentification a deux facteurs avec une application comme Google Authenticator ou Authy.
                            </p>
                            <button type="button" class="btn-action btn-action--primary" id="btn2faEnable">
                                <i class="fas fa-qrcode"></i> Activer le 2FA
                            </button>
                            <div class="twofa-msg" id="twofaMsg"></div>

                            <div class="twofa-setup" id="twofaSetup">
                                <div class="twofa-qr" id="twofaQr"></div>
                                <div class="twofa-secret" id="twofaSecret"></div>
                                <p style="color:#8b949e;font-size:13px;text-align:center;margin-bottom:15px;">
                                    Scannez le QR code avec votre application, puis entrez le code a 6 chiffres pour confirmer.
                                </p>
                                <div class="twofa-confirm">
                                    <input type="text" id="twofaCode" class="form-input" placeholder="000000" maxlength="6" pattern="[0-9]{6}" inputmode="numeric">
                                    <button type="button" class="btn-action btn-action--primary" id="btn2faConfirm"><i class="fas fa-check"></i></button>
                                </div>
                                <div class="twofa-msg twofa-msg--confirm" id="twofaConfirmMsg"></div>
                            </div>
                        {% endif %}
                    </div>

                </div>
            </div>

            {# ── Comptes liés Card ── #}
            <div class="form-card" style="margin-top:24px;">
                <h3 class="form-card__title"><i class="fas fa-link"></i> Comptes liés (OAuth)</h3>
                <p style="color:#8b949e;font-size:13px;margin-bottom:20px;">
                    Gérez les comptes externes connectés à votre profil. Déconnecter un compte supprime uniquement le lien — vous pouvez le reconnecter à tout moment.
                </p>

                {% set providers = [
                    {key: 'discord', label: 'Discord',  icon: 'fab fa-discord',  color: '#5865f2', id: app.user.discordId},
                    {key: 'google',  label: 'Google',   icon: 'fab fa-google',   color: '#ea4335', id: app.user.googleId},
                    {key: 'twitch',  label: 'Twitch',   icon: 'fab fa-twitch',   color: '#9146ff', id: app.user.twitchId},
                    {key: 'steam',   label: 'Steam',    icon: 'fab fa-steam',    color: '#1b2838', id: app.user.steamId},
                ] %}

                <div style="display:flex;flex-direction:column;gap:12px;">
                    {% for p in providers %}
                        <div style="display:flex;align-items:center;gap:14px;padding:14px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:10px;">
                            <div style="width:40px;height:40px;border-radius:10px;background:{{ p.color }};display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="{{ p.icon }}" style="color:#fff;font-size:18px;"></i>
                            </div>
                            <div style="flex:1;min-width:0;">
                                <div style="font-weight:600;color:#e6edf3;font-size:14px;">{{ p.label }}</div>
                                {% if p.id %}
                                    <div style="font-size:12px;color:#45f882;margin-top:2px;"><i class="fas fa-check-circle"></i> Connecté</div>
                                {% else %}
                                    <div style="font-size:12px;color:#8b949e;margin-top:2px;"><i class="fas fa-times-circle"></i> Non connecté</div>
                                {% endif %}
                            </div>
                            {% if p.id %}
                                <form method="post" action="{{ path('user_settings_oauth_disconnect', {provider: p.key}) }}"
                                      onsubmit="return confirm('Déconnecter votre compte {{ p.label }} ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('oauth_disconnect_' ~ p.key) }}">
                                    <button type="submit" style="padding:6px 14px;background:rgba(231,74,59,0.12);color:#e74a3b;border:1px solid rgba(231,74,59,0.25);border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;"
                                            onmouseover="this.style.background='rgba(231,74,59,0.25)'" onmouseout="this.style.background='rgba(231,74,59,0.12)'">
                                        <i class="fas fa-unlink"></i> Déconnecter
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>

        </div>
    </section>

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Avatar file input - auto-submit on change
    var avatarInput = document.getElementById('avatarInput');
    var avatarForm = document.getElementById('avatarForm');
    var avatarFileName = document.getElementById('avatarFileName');
    var avatarPreview = document.getElementById('avatarPreview');

    if (avatarInput) {
        avatarInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                avatarFileName.textContent = this.files[0].name;
                // Preview
                var reader = new FileReader();
                reader.onload = function(e) {
                    avatarPreview.innerHTML = '<img src="' + e.target.result + '" alt="Preview">';
                };
                reader.readAsDataURL(this.files[0]);
                // Auto-submit
                avatarForm.submit();
            }
        });
    }

    // 2FA Enable
    var btn2faEnable = document.getElementById('btn2faEnable');
    var twofaSetup = document.getElementById('twofaSetup');
    var twofaQr = document.getElementById('twofaQr');
    var twofaSecret = document.getElementById('twofaSecret');
    var twofaMsg = document.getElementById('twofaMsg');
    var twofaConfirmMsg = document.getElementById('twofaConfirmMsg');
    var btn2faConfirm = document.getElementById('btn2faConfirm');
    var twofaCode = document.getElementById('twofaCode');
    var csrfToken = '{{ csrf_token('profile_2fa') }}';

    if (btn2faEnable) {
        btn2faEnable.addEventListener('click', function() {
            btn2faEnable.disabled = true;
            btn2faEnable.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Chargement...';
            twofaMsg.className = 'twofa-msg';
            twofaMsg.textContent = '';

            var formData = new FormData();
            formData.append('_token', csrfToken);

            fetch('{{ path('user_settings_2fa_enable') }}', {
                method: 'POST',
                body: formData
            })
            .then(function(r) {
                if (!r.ok) {
                    return r.text().then(function(text) {
                        try { var j = JSON.parse(text); throw new Error(j.error || 'Erreur serveur (' + r.status + ')'); }
                        catch(e) { if (e.message) throw e; throw new Error('Erreur serveur (' + r.status + ')'); }
                    });
                }
                return r.json();
            })
            .then(function(data) {
                if (data.error) {
                    twofaMsg.className = 'twofa-msg twofa-msg--error';
                    twofaMsg.textContent = data.error;
                    btn2faEnable.disabled = false;
                    btn2faEnable.innerHTML = '<i class="fas fa-qrcode"></i> Activer le 2FA';
                    return;
                }
                twofaQr.innerHTML = '<img src="' + data.qr + '" alt="QR Code">';
                twofaSecret.innerHTML = '<code>' + data.secret + '</code><small>Cle secrete manuelle (si le QR code ne fonctionne pas)</small>';
                twofaSetup.classList.add('active');
                btn2faEnable.style.display = 'none';
                twofaCode.focus();
            })
            .catch(function(err) {
                twofaMsg.className = 'twofa-msg twofa-msg--error';
                twofaMsg.textContent = err.message || 'Une erreur est survenue.';
                btn2faEnable.disabled = false;
                btn2faEnable.innerHTML = '<i class="fas fa-qrcode"></i> Activer le 2FA';
            });
        });
    }

    if (btn2faConfirm) {
        btn2faConfirm.addEventListener('click', function() {
            var code = twofaCode.value.trim();
            if (code.length !== 6) {
                twofaConfirmMsg.className = 'twofa-msg twofa-msg--confirm twofa-msg--error';
                twofaConfirmMsg.textContent = 'Entrez un code a 6 chiffres.';
                return;
            }

            btn2faConfirm.disabled = true;

            var formData = new FormData();
            formData.append('_token', csrfToken);
            formData.append('code', code);

            fetch('{{ path('user_settings_2fa_confirm') }}', {
                method: 'POST',
                body: formData
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.error) {
                    twofaConfirmMsg.className = 'twofa-msg twofa-msg--confirm twofa-msg--error';
                    twofaConfirmMsg.textContent = data.error;
                    btn2faConfirm.disabled = false;
                    return;
                }
                twofaConfirmMsg.className = 'twofa-msg twofa-msg--confirm twofa-msg--success';
                twofaConfirmMsg.textContent = data.message;
                setTimeout(function() { location.reload(); }, 1500);
            })
            .catch(function() {
                twofaConfirmMsg.className = 'twofa-msg twofa-msg--confirm twofa-msg--error';
                twofaConfirmMsg.textContent = 'Une erreur est survenue.';
                btn2faConfirm.disabled = false;
            });
        });

        // Allow Enter key on code input
        if (twofaCode) {
            twofaCode.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    btn2faConfirm.click();
                }
            });
        }
    }
});
</script>
{% endblock %}
