{% extends 'base.html.twig' %}

{% block title %}Parametres - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/profile.css') }}">
<style>
/* ───── Wheel Pro Gaming ───── */
.wheel-card {
    background: linear-gradient(145deg, #0b1420 0%, #0f1a2a 50%, #0b1420 100%);
    border: 1px solid rgba(69,248,130,0.12);
    border-radius: 16px;
    padding: 24px;
    position: relative;
    overflow: hidden;
}
.wheel-card::before {
    content: '';
    position: absolute; inset: -1px;
    border-radius: 16px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(69,248,130,0.25), transparent 40%, transparent 60%, rgba(69,248,130,0.25));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
}
.wheel-card__title {
    font-size: 13px; font-weight: 800;
    color: #45f882;
    text-transform: uppercase; letter-spacing: 1.2px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(69,248,130,0.08);
    display: flex; align-items: center; gap: 8px;
    text-shadow: 0 0 20px rgba(69,248,130,0.3);
}
.wheel-stage {
    position: relative;
    width: 320px; height: 320px;
    margin: 0 auto 20px;
}
.wheel-stage canvas {
    width: 100%; height: 100%;
    border-radius: 50%;
}
.wheel-pointer-wrap {
    position: absolute;
    top: -2px; left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    filter: drop-shadow(0 3px 8px rgba(69,248,130,0.6));
}
.wheel-pointer-wrap svg { display: block; }
.wheel-stats {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 10px; margin-bottom: 14px;
}
.wheel-stat {
    background: rgba(15,26,42,0.8);
    border: 1px solid rgba(69,248,130,0.08);
    border-radius: 10px;
    padding: 10px 12px;
    text-align: center;
}
.wheel-stat__value {
    font-size: 18px; font-weight: 800;
    color: #45f882;
    line-height: 1;
    margin-bottom: 3px;
}
.wheel-stat__value--boost { color: #00c6ff; }
.wheel-stat__label {
    font-size: 10px; font-weight: 600;
    color: #5a6a7e;
    text-transform: uppercase; letter-spacing: 0.5px;
}
.wheel-stat--free .wheel-stat__value { color: #ffd700; }
.wheel-info-bar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px; font-size: 12px; color: #5a6a7e;
    padding: 0 2px;
}
.wheel-info-bar strong { color: #c9d1d9; font-weight: 700; }
.free-badge {
    display: inline-block;
    padding: 2px 8px; border-radius: 4px;
    background: linear-gradient(135deg, rgba(255,215,0,0.15), rgba(255,215,0,0.05));
    color: #ffd700;
    font-weight: 800; font-size: 10px;
    border: 1px solid rgba(255,215,0,0.25);
    text-transform: uppercase; letter-spacing: 0.5px;
    animation: free-pulse 2s ease infinite;
}
@keyframes free-pulse {
    0%,100% { box-shadow: 0 0 4px rgba(255,215,0,0.1); }
    50% { box-shadow: 0 0 12px rgba(255,215,0,0.3); }
}
.wheel-spin-btn {
    width: 100%; padding: 14px 20px;
    border-radius: 10px; border: none;
    background: linear-gradient(135deg, #45f882 0%, #2dd66b 50%, #22c55e 100%);
    color: #0a1018; font-size: 14px; font-weight: 900;
    cursor: pointer; transition: all .25s;
    text-transform: uppercase; letter-spacing: 1px;
    position: relative; overflow: hidden;
}
.wheel-spin-btn::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s;
}
.wheel-spin-btn:hover:not(:disabled)::before { transform: translateX(100%); }
.wheel-spin-btn:hover:not(:disabled) {
    box-shadow: 0 0 30px rgba(69,248,130,0.4), 0 4px 15px rgba(69,248,130,0.2);
    transform: translateY(-2px);
}
.wheel-spin-btn:active:not(:disabled) { transform: translateY(0); }
.wheel-spin-btn:disabled {
    opacity: 0.35; cursor: not-allowed;
    background: rgba(69,248,130,0.12); color: rgba(69,248,130,0.35);
}
.wheel-spin-btn.spinning {
    background: linear-gradient(135deg, #1a7a3a, #156d32);
    color: #45f882;
    animation: btn-pulse 0.8s ease infinite;
}
@keyframes btn-pulse {
    0%,100% { box-shadow: 0 0 8px rgba(69,248,130,0.15); }
    50% { box-shadow: 0 0 20px rgba(69,248,130,0.35); }
}
.wheel-result-overlay {
    position: absolute; inset: 0;
    background: rgba(8,14,22,0.95);
    backdrop-filter: blur(8px);
    border-radius: 16px;
    display: none; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 10; text-align: center; padding: 24px;
}
.wheel-result-overlay.active { display: flex; }
.wheel-result-overlay .result-icon { font-size: 48px; margin-bottom: 12px; }
.wheel-result-overlay .result-label {
    font-size: 22px; font-weight: 900; color: #e6edf3;
    margin-bottom: 8px; letter-spacing: 0.5px;
}
.wheel-result-overlay .result-detail {
    font-size: 14px; color: #8b949e; margin-bottom: 20px;
}
.wheel-result-overlay .result-close {
    padding: 10px 28px; border-radius: 8px;
    background: rgba(69,248,130,0.08); border: 1px solid rgba(69,248,130,0.2);
    color: #45f882; font-size: 13px; font-weight: 700;
    cursor: pointer; transition: all .2s;
    text-transform: uppercase; letter-spacing: 0.5px;
}
.wheel-result-overlay .result-close:hover {
    background: rgba(69,248,130,0.15);
    box-shadow: 0 0 15px rgba(69,248,130,0.15);
}
.wheel-result-overlay.jackpot {
    background: radial-gradient(ellipse at center, rgba(255,215,0,0.12) 0%, rgba(8,14,22,0.97) 70%);
}
.wheel-result-overlay.jackpot .result-icon { color: #ffd700; animation: jackpot-glow 1s ease infinite alternate; }
.wheel-result-overlay.jackpot .result-label { color: #ffd700; text-shadow: 0 0 20px rgba(255,215,0,0.5); }
@keyframes jackpot-glow {
    0% { text-shadow: 0 0 10px rgba(255,215,0,0.3); transform: scale(1); }
    100% { text-shadow: 0 0 40px rgba(255,215,0,0.8), 0 0 80px rgba(255,215,0,0.3); transform: scale(1.05); }
}
.wheel-result-overlay.loss .result-icon { color: #f85149; }
.wheel-result-overlay.loss .result-label { color: #f85149; }
@media (max-width: 480px) {
    .wheel-stage { width: 280px; height: 280px; }
    .wheel-card { padding: 16px; }
    .wheel-stats { gap: 8px; }
}
</style>
{% endblock %}

{% block body %}
<section class="settings-page">
    <div class="container">

        {# ── Flash messages ── #}
        {% for message in app.flashes('success') %}
            <div class="profile-flash profile-flash--success"><i class="fas fa-check-circle"></i> {{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="profile-flash profile-flash--error"><i class="fas fa-exclamation-circle"></i> {{ message }}</div>
        {% endfor %}

        {# ── Header ── #}
        <div class="settings-header">
            <div class="settings-header__avatar">
                {% if app.user.avatar starts with 'http' %}
                    <img src="{{ app.user.avatar }}" alt="Avatar">
                {% elseif app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="Avatar">
                {% else %}
                    <i class="fas fa-user"></i>
                {% endif %}
            </div>
            <div class="settings-header__info">
                <div class="settings-header__name">{{ app.user.username }}</div>
                <div class="settings-header__meta">
                    <span class="settings-header__meta-item"><i class="fas fa-envelope"></i> {{ app.user.email }}</span>
                    {% if app.user.isTwoFactorEnabled %}
                        <span class="settings-header__meta-item" style="color:#45f882;"><i class="fas fa-shield-alt"></i> 2FA actif</span>
                    {% else %}
                        <span class="settings-header__meta-item" style="color:#8b949e;"><i class="fas fa-shield-alt"></i> 2FA inactif</span>
                    {% endif %}
                </div>
            </div>
            <div class="settings-header__actions">
                <a href="{{ path('user_profile_edit') }}" class="btn-action btn-action--outline">
                    <i class="fas fa-pen"></i> Modifier le profil
                </a>
                <a href="{{ path('profile_show', {username: app.user.username}) }}" class="btn-action btn-action--outline">
                    <i class="fas fa-user"></i> Mon profil
                </a>
            </div>
        </div>

        {# ── Tab navigation ── #}
        <div class="settings-tabs">
            <button type="button" class="settings-tabs__btn active" data-tab="profil" onclick="switchSettingsTab('profil')">
                <i class="fas fa-user-circle"></i> Profil
            </button>
            <button type="button" class="settings-tabs__btn" data-tab="securite" onclick="switchSettingsTab('securite')">
                <i class="fas fa-lock"></i> Securite
            </button>
            <button type="button" class="settings-tabs__btn" data-tab="twofa" onclick="switchSettingsTab('twofa')">
                <i class="fas fa-shield-alt"></i> Authentification 2FA
            </button>
            {% if wheel_enabled %}
            <button type="button" class="settings-tabs__btn" data-tab="roue" onclick="switchSettingsTab('roue')">
                <i class="fas fa-dharmachakra"></i> Roue
            </button>
            {% endif %}
        </div>

        <div class="row g-4">

            {# ══════════ MAIN COL ══════════ #}
            <div class="col-lg-8">

                {# ── PANEL: Profil ── #}
                <div id="tabProfil" class="settings-panel active">

                    {# Email #}
                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-envelope"></i> Adresse email</h3>
                        <form action="{{ path('user_settings_email') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('profile_email') }}">
                            <div class="form-group">
                                <label for="email">Email</label>
                                <input type="email" id="email" name="email" class="form-input" value="{{ app.user.email }}" required>
                            </div>
                            <button type="submit" class="btn-action btn-action--primary"><i class="fas fa-save"></i> Enregistrer</button>
                        </form>
                    </div>

                </div>

                {# ── PANEL: Securite ── #}
                <div id="tabSecurite" class="settings-panel">

                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-key"></i> Modifier le mot de passe</h3>
                        <form action="{{ path('user_settings_password') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('profile_password') }}">
                            {% if app.user.password %}
                                <div class="form-group">
                                    <label for="currentPassword">Mot de passe actuel</label>
                                    <input type="password" id="currentPassword" name="current_password" class="form-input" required placeholder="••••••••••">
                                </div>
                            {% endif %}
                            <div class="form-group">
                                <label for="newPassword">Nouveau mot de passe</label>
                                <input type="password" id="newPassword" name="new_password" class="form-input" required minlength="10" placeholder="••••••••••">
                                <div class="form-hint">Minimum 10 caracteres</div>
                            </div>
                            <div class="form-group">
                                <label for="confirmPassword">Confirmer le mot de passe</label>
                                <input type="password" id="confirmPassword" name="confirm_password" class="form-input" required minlength="10" placeholder="••••••••••">
                            </div>
                            <button type="submit" class="btn-action btn-action--primary"><i class="fas fa-save"></i> Modifier le mot de passe</button>
                        </form>
                    </div>

                </div>

                {# ── PANEL: 2FA ── #}
                <div id="tabTwofa" class="settings-panel">

                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-shield-alt"></i> Authentification a deux facteurs</h3>

                        {% if app.user.isTwoFactorEnabled %}
                            <div class="twofa-status twofa-status--active">
                                <i class="fas fa-check-circle"></i> 2FA active
                            </div>
                            <p style="color:#8b949e;font-size:13px;margin-bottom:20px;line-height:1.6;">
                                Votre compte est protege par l'authentification a deux facteurs via une application TOTP (Google Authenticator, Authy, etc.).
                            </p>
                            <form action="{{ path('user_settings_2fa_disable') }}" method="post" onsubmit="return confirm('Etes-vous sur de vouloir desactiver le 2FA ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('profile_2fa') }}">
                                {% if app.user.password %}
                                <div class="form-group">
                                    <label>Confirmez avec votre mot de passe</label>
                                    <input type="password" name="password" required class="form-input" placeholder="Mot de passe actuel" style="max-width:320px;">
                                </div>
                                {% endif %}
                                <button type="submit" class="btn-action btn-action--danger"><i class="fas fa-times"></i> Desactiver le 2FA</button>
                            </form>

                        {% else %}
                            <div class="twofa-status twofa-status--inactive">
                                <i class="fas fa-times-circle"></i> 2FA desactive
                            </div>
                            <p style="color:#8b949e;font-size:13px;margin-bottom:20px;line-height:1.6;">
                                Protegez votre compte avec une couche de securite supplementaire. Une application comme <strong style="color:#e6edf3;">Google Authenticator</strong> ou <strong style="color:#e6edf3;">Authy</strong> sera necessaire.
                            </p>
                            <button type="button" class="btn-action btn-action--primary" id="btn2faEnable">
                                <i class="fas fa-qrcode"></i> Activer le 2FA
                            </button>
                            <div class="twofa-msg" id="twofaMsg"></div>

                            <div class="twofa-setup" id="twofaSetup">
                                <div class="twofa-qr" id="twofaQr"></div>
                                <div class="twofa-secret" id="twofaSecret"></div>
                                <p style="color:#8b949e;font-size:13px;text-align:center;margin-bottom:16px;">
                                    Scannez le QR code avec votre application, puis entrez le code a 6 chiffres pour confirmer.
                                </p>
                                <div class="twofa-confirm">
                                    <input type="text" id="twofaCode" class="form-input" placeholder="000000" maxlength="6" pattern="[0-9]{6}" inputmode="numeric">
                                    <button type="button" class="btn-action btn-action--primary" id="btn2faConfirm"><i class="fas fa-check"></i></button>
                                </div>
                                <div class="twofa-msg twofa-msg--confirm" id="twofaConfirmMsg"></div>
                            </div>
                        {% endif %}

                    </div>

                </div>

                {# ── PANEL: Roue communautaire ── #}
                {% if wheel_enabled %}
                <div id="tabRoue" class="settings-panel">

                    <div class="wheel-card" id="wheelCard">
                        <div class="wheel-card__title">
                            <i class="fas fa-dharmachakra"></i> Roue communautaire
                        </div>

                        <div class="wheel-stats">
                            <div class="wheel-stat">
                                <div class="wheel-stat__value" id="wheelBalance">{{ app.user.tokenBalance }}</div>
                                <div class="wheel-stat__label"><i class="fas fa-coins"></i> NexBits</div>
                            </div>
                            <div class="wheel-stat">
                                <div class="wheel-stat__value wheel-stat__value--boost" id="wheelBoostBalance">{{ app.user.boostTokenBalance }}</div>
                                <div class="wheel-stat__label"><i class="fas fa-bolt"></i> NexBoost</div>
                            </div>
                            <div class="wheel-stat wheel-stat--free">
                                <div class="wheel-stat__value" id="wheelFreeSpins">{{ wheel_free_spins }}</div>
                                <div class="wheel-stat__label"><i class="fas fa-gift"></i> Tours gratuits</div>
                            </div>
                            <div class="wheel-stat">
                                <div class="wheel-stat__value" style="color:#c9d1d9;">{{ wheel_spin_cost }}</div>
                                <div class="wheel-stat__label"><i class="fas fa-tag"></i> Cout / tour</div>
                            </div>
                        </div>

                        <div class="wheel-stage" id="wheelStage">
                            <div class="wheel-pointer-wrap">
                                <svg width="28" height="34" viewBox="0 0 28 34">
                                    <defs>
                                        <linearGradient id="ptrGrad" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#45f882"/>
                                            <stop offset="100%" stop-color="#2dd66b"/>
                                        </linearGradient>
                                        <filter id="ptrGlow">
                                            <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#45f882" flood-opacity="0.6"/>
                                        </filter>
                                    </defs>
                                    <polygon points="14,34 0,0 28,0" fill="url(#ptrGrad)" filter="url(#ptrGlow)"/>
                                    <polygon points="14,28 4,2 24,2" fill="rgba(255,255,255,0.15)"/>
                                </svg>
                            </div>
                            <canvas id="wheelCanvas" width="640" height="640"></canvas>
                        </div>

                        <div class="wheel-info-bar">
                            {% if wheel_free_spins > 0 %}
                                <span class="free-badge"><i class="fas fa-gift"></i> Tour gratuit disponible</span>
                            {% else %}
                                <span>Cout : <strong>{{ wheel_spin_cost }} NexBits</strong></span>
                            {% endif %}
                        </div>

                        <button type="button" class="wheel-spin-btn" id="wheelSpinBtn">
                            <i class="fas fa-dharmachakra" style="margin-right:6px;"></i>
                            {% if wheel_free_spins > 0 %}
                                Tourner gratuitement
                            {% else %}
                                Tourner — {{ wheel_spin_cost }} NexBits
                            {% endif %}
                        </button>

                        <div class="wheel-result-overlay" id="wheelResult">
                            <div class="result-icon" id="wheelResultIcon"></div>
                            <div class="result-label" id="wheelResultLabel"></div>
                            <div class="result-detail" id="wheelResultDetail"></div>
                            <button type="button" class="result-close" id="wheelResultClose">Continuer</button>
                        </div>
                    </div>

                </div>
                {% endif %}

            </div>

            {# ══════════ SIDEBAR ══════════ #}
            <div class="col-lg-4">

                {# ── Comptes liés ── #}
                <div class="settings-sidebar-card">
                    <div class="settings-sidebar-card__title">
                        <i class="fas fa-link"></i> Comptes lies
                    </div>

                    {% set providers = [
                        {key: 'discord', label: 'Discord', icon: 'fab fa-discord', color: '#5865f2', id: app.user.discordId},
                        {key: 'google',  label: 'Google',  icon: 'fab fa-google',  color: '#ea4335', id: app.user.googleId},
                        {key: 'twitch',  label: 'Twitch',  icon: 'fab fa-twitch',  color: '#9146ff', id: app.user.twitchId},
                        {key: 'steam',   label: 'Steam',   icon: 'fab fa-steam',   color: '#c2a952', id: app.user.steamId},
                    ] %}

                    {% for p in providers %}
                        <div class="oauth-row">
                            <div class="oauth-icon" style="background:{{ p.color }};opacity:{{ p.id ? '1' : '0.35' }};">
                                <i class="{{ p.icon }}"></i>
                            </div>
                            <div class="oauth-info">
                                <div class="oauth-info__name">{{ p.label }}</div>
                                {% if p.id %}
                                    <div class="oauth-info__status oauth-info__status--connected">
                                        <i class="fas fa-check-circle"></i> Connecte
                                    </div>
                                {% else %}
                                    <div class="oauth-info__status oauth-info__status--disconnected">
                                        <i class="fas fa-times-circle"></i> Non connecte
                                    </div>
                                {% endif %}
                            </div>
                            {% if p.id %}
                                <form method="post" action="{{ path('user_settings_oauth_disconnect', {provider: p.key}) }}"
                                      onsubmit="return confirm('Deconnecter {{ p.label }} de votre compte ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('oauth_disconnect_' ~ p.key) }}">
                                    <button type="submit" class="oauth-disconnect-btn">
                                        <i class="fas fa-unlink"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    {% endfor %}

                </div>

                {# ── Infos du compte ── #}
                <div class="settings-sidebar-card">
                    <div class="settings-sidebar-card__title">
                        <i class="fas fa-info-circle"></i> Mon compte
                    </div>

                    <div class="account-info-item">
                        <i class="fas fa-user"></i>
                        <span class="account-info-item__label">Pseudo</span>
                        <span class="account-info-item__value">{{ app.user.username }}</span>
                    </div>
                    <div class="account-info-item">
                        <i class="fas fa-envelope"></i>
                        <span class="account-info-item__label">Email</span>
                        <span class="account-info-item__value" style="font-size:11px;">{{ app.user.email }}</span>
                    </div>
                    <div class="account-info-item">
                        <i class="fas fa-shield-alt"></i>
                        <span class="account-info-item__label">2FA</span>
                        <span class="account-info-item__value">
                            {% if app.user.isTwoFactorEnabled %}
                                <span style="color:#45f882;font-size:12px;"><i class="fas fa-check-circle"></i> Actif</span>
                            {% else %}
                                <span style="color:#8b949e;font-size:12px;"><i class="fas fa-times-circle"></i> Inactif</span>
                            {% endif %}
                        </span>
                    </div>
                    <div class="account-info-item">
                        <i class="fas fa-key"></i>
                        <span class="account-info-item__label">Mot de passe</span>
                        <span class="account-info-item__value">
                            {% if app.user.password %}
                                <span style="color:#45f882;font-size:12px;"><i class="fas fa-check-circle"></i> Defini</span>
                            {% else %}
                                <span style="color:#f6c23e;font-size:12px;"><i class="fas fa-exclamation-circle"></i> Non defini</span>
                            {% endif %}
                        </span>
                    </div>

                </div>

                {# ── Navigation rapide ── #}
                <div class="settings-sidebar-card">
                    <div class="settings-sidebar-card__title">
                        <i class="fas fa-bolt"></i> Raccourcis
                    </div>
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        <a href="{{ path('user_servers_list') }}" class="btn-action btn-action--outline" style="justify-content:flex-start;">
                            <i class="fas fa-server"></i> Mes serveurs
                        </a>
                        <a href="{{ path('user_servers_new') }}" class="btn-action btn-action--outline" style="justify-content:flex-start;">
                            <i class="fas fa-plus-circle"></i> Ajouter un serveur
                        </a>
                        <a href="{{ path('user_recruitment_list') }}" class="btn-action btn-action--outline" style="justify-content:flex-start;">
                            <i class="fas fa-users"></i> Mes recrutements
                        </a>
                        <a href="{{ path('profile_show', {username: app.user.username}) }}" class="btn-action btn-action--outline" style="justify-content:flex-start;">
                            <i class="fas fa-user"></i> Mon profil public
                        </a>
                    </div>
                </div>

            </div>{# /col-lg-4 #}

        </div>{# /row #}

    </div>
</section>
{% endblock %}

{% block javascripts %}
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function () {

    // ── Tab switching ──
    function switchSettingsTab(tab) {
        document.querySelectorAll('.settings-panel').forEach(function(p) { p.classList.remove('active'); });
        document.querySelectorAll('.settings-tabs__btn').forEach(function(b) { b.classList.remove('active'); });
        document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
        document.querySelector('[data-tab="' + tab + '"]').classList.add('active');
        history.replaceState(null, '', '#' + tab);
    }
    window.switchSettingsTab = switchSettingsTab;

    // Restore tab from URL hash
    var hash = location.hash.replace('#', '');
    if (['profil','securite','twofa','roue'].includes(hash)) {
        switchSettingsTab(hash);
    }

    // ── 2FA Enable ──
    var btn2faEnable    = document.getElementById('btn2faEnable');
    var twofaSetup      = document.getElementById('twofaSetup');
    var twofaQr         = document.getElementById('twofaQr');
    var twofaSecret     = document.getElementById('twofaSecret');
    var twofaMsg        = document.getElementById('twofaMsg');
    var twofaConfirmMsg = document.getElementById('twofaConfirmMsg');
    var btn2faConfirm   = document.getElementById('btn2faConfirm');
    var twofaCode       = document.getElementById('twofaCode');
    var csrfToken       = '{{ csrf_token('profile_2fa') }}';

    if (btn2faEnable) {
        btn2faEnable.addEventListener('click', function () {
            btn2faEnable.disabled = true;
            btn2faEnable.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Chargement...';
            twofaMsg.className = 'twofa-msg';
            twofaMsg.textContent = '';

            var fd = new FormData();
            fd.append('_token', csrfToken);

            fetch('{{ path('user_settings_2fa_enable') }}', { method: 'POST', body: fd })
                .then(function (r) {
                    if (!r.ok) return r.json().then(function (j) { throw new Error(j.error || 'Erreur ' + r.status); });
                    return r.json();
                })
                .then(function (data) {
                    if (data.error) {
                        twofaMsg.className = 'twofa-msg twofa-msg--error';
                        twofaMsg.textContent = data.error;
                        btn2faEnable.disabled = false;
                        btn2faEnable.innerHTML = '<i class="fas fa-qrcode"></i> Activer le 2FA';
                        return;
                    }
                    twofaQr.innerHTML = '<img src="' + data.qr + '" alt="QR Code">';
                    twofaSecret.innerHTML = '<code>' + data.secret + '</code><small>Cle secrete manuelle si le QR ne fonctionne pas</small>';
                    twofaSetup.classList.add('active');
                    btn2faEnable.style.display = 'none';
                    twofaCode.focus();
                })
                .catch(function (err) {
                    twofaMsg.className = 'twofa-msg twofa-msg--error';
                    twofaMsg.textContent = err.message || 'Une erreur est survenue.';
                    btn2faEnable.disabled = false;
                    btn2faEnable.innerHTML = '<i class="fas fa-qrcode"></i> Activer le 2FA';
                });
        });
    }

    if (btn2faConfirm) {
        btn2faConfirm.addEventListener('click', function () {
            var code = twofaCode.value.trim();
            if (code.length !== 6) {
                twofaConfirmMsg.className = 'twofa-msg twofa-msg--error';
                twofaConfirmMsg.textContent = 'Entrez un code a 6 chiffres.';
                return;
            }
            btn2faConfirm.disabled = true;
            var fd = new FormData();
            fd.append('_token', csrfToken);
            fd.append('code', code);

            fetch('{{ path('user_settings_2fa_confirm') }}', { method: 'POST', body: fd })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.error) {
                        twofaConfirmMsg.className = 'twofa-msg twofa-msg--error';
                        twofaConfirmMsg.textContent = data.error;
                        btn2faConfirm.disabled = false;
                        return;
                    }
                    twofaConfirmMsg.className = 'twofa-msg twofa-msg--success';
                    twofaConfirmMsg.textContent = data.message;
                    setTimeout(function () { location.reload(); }, 1500);
                })
                .catch(function () {
                    twofaConfirmMsg.className = 'twofa-msg twofa-msg--error';
                    twofaConfirmMsg.textContent = 'Une erreur est survenue.';
                    btn2faConfirm.disabled = false;
                });
        });

        if (twofaCode) {
            twofaCode.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); btn2faConfirm.click(); }
            });
        }
    }

    // ── Wheel ──
    {% if wheel_enabled %}
    (function() {
        var canvas = document.getElementById('wheelCanvas');
        if (!canvas) return;
        var ctx = canvas.getContext('2d');
        var prizes = {{ wheel_prizes|json_encode|raw }};
        var N = prizes.length;
        var arc = (2 * Math.PI) / N;
        var CX = 320, CY = 320;
        var R = 290;
        var currentAngle = 0;
        var spinning = false;
        var ledPhase = 0;
        var ledTimer = null;

        // Color helpers
        function hexToRgb(hex) {
            var r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
            return [r,g,b];
        }
        function lighten(hex, pct) {
            var c = hexToRgb(hex);
            return 'rgb(' + Math.min(255, c[0]+pct) + ',' + Math.min(255, c[1]+pct) + ',' + Math.min(255, c[2]+pct) + ')';
        }
        function darken(hex, pct) {
            var c = hexToRgb(hex);
            return 'rgb(' + Math.max(0, c[0]-pct) + ',' + Math.max(0, c[1]-pct) + ',' + Math.max(0, c[2]-pct) + ')';
        }

        function drawWheel(angle) {
            ctx.clearRect(0, 0, 640, 640);

            // Outer dark ring background
            ctx.beginPath();
            ctx.arc(CX, CY, R + 22, 0, 2 * Math.PI);
            ctx.fillStyle = '#0a0f18';
            ctx.fill();

            // Outer ring border
            ctx.beginPath();
            ctx.arc(CX, CY, R + 22, 0, 2 * Math.PI);
            ctx.strokeStyle = 'rgba(69,248,130,0.15)';
            ctx.lineWidth = 2;
            ctx.stroke();

            // LED dots on outer ring
            var ledCount = N * 3;
            for (var li = 0; li < ledCount; li++) {
                var la = (li / ledCount) * 2 * Math.PI - Math.PI / 2;
                var lr = R + 12;
                var lx = CX + Math.cos(la) * lr;
                var ly = CY + Math.sin(la) * lr;
                var isLit = ((li + ledPhase) % 3 === 0);
                ctx.beginPath();
                ctx.arc(lx, ly, 2.5, 0, 2 * Math.PI);
                ctx.fillStyle = isLit ? '#45f882' : 'rgba(69,248,130,0.12)';
                ctx.fill();
                if (isLit) {
                    ctx.shadowColor = '#45f882';
                    ctx.shadowBlur = 6;
                    ctx.fill();
                    ctx.shadowBlur = 0;
                }
            }

            // Inner ring border
            ctx.beginPath();
            ctx.arc(CX, CY, R + 1, 0, 2 * Math.PI);
            ctx.strokeStyle = 'rgba(0,0,0,0.5)';
            ctx.lineWidth = 2;
            ctx.stroke();

            ctx.save();
            ctx.translate(CX, CY);
            ctx.rotate(angle);

            // Draw sections
            for (var i = 0; i < N; i++) {
                var sa = i * arc - Math.PI / 2;
                var ea = sa + arc;
                var col = prizes[i].color || '#2d8a4e';
                var isJP = prizes[i].isJackpot;

                // Section fill with gradient
                ctx.beginPath();
                ctx.moveTo(0, 0);
                ctx.arc(0, 0, R, sa, ea);
                ctx.closePath();
                var grad = ctx.createRadialGradient(0, 0, 30, 0, 0, R);
                grad.addColorStop(0, lighten(col, 30));
                grad.addColorStop(0.7, col);
                grad.addColorStop(1, darken(col, 25));
                ctx.fillStyle = grad;
                ctx.fill();

                // Section divider
                ctx.beginPath();
                ctx.moveTo(0, 0);
                var ex = Math.cos(sa) * R, ey = Math.sin(sa) * R;
                ctx.lineTo(ex, ey);
                ctx.strokeStyle = 'rgba(0,0,0,0.4)';
                ctx.lineWidth = 1.5;
                ctx.stroke();

                // Inner highlight line
                ctx.beginPath();
                ctx.moveTo(0, 0);
                ctx.lineTo(ex, ey);
                ctx.strokeStyle = 'rgba(255,255,255,0.06)';
                ctx.lineWidth = 0.5;
                ctx.stroke();

                // Label
                ctx.save();
                ctx.rotate(sa + arc / 2);
                ctx.textAlign = 'right';
                ctx.textBaseline = 'middle';
                if (isJP) {
                    ctx.font = '900 16px "Segoe UI", system-ui, sans-serif';
                    ctx.fillStyle = '#0a1018';
                    ctx.shadowColor = 'rgba(0,0,0,0.5)';
                    ctx.shadowBlur = 4;
                    ctx.fillText(prizes[i].label, R - 18, 0);
                    ctx.shadowBlur = 0;
                    ctx.fillStyle = 'rgba(255,215,0,0.9)';
                    ctx.fillText(prizes[i].label, R - 18, 0);
                } else {
                    var isLoss = prizes[i].nexbits === 0 && prizes[i].nexboost === 0;
                    ctx.font = (isLoss ? '700 13px' : '700 13px') + ' "Segoe UI", system-ui, sans-serif';
                    ctx.fillStyle = 'rgba(0,0,0,0.4)';
                    ctx.fillText(prizes[i].label, R - 17, 1);
                    ctx.fillStyle = isLoss ? 'rgba(255,255,255,0.7)' : '#fff';
                    ctx.fillText(prizes[i].label, R - 18, 0);
                }
                ctx.restore();

                // Small icon for jackpot
                if (isJP) {
                    ctx.save();
                    ctx.rotate(sa + arc / 2);
                    ctx.font = '14px "Font Awesome 6 Free"';
                    ctx.fillStyle = 'rgba(255,215,0,0.8)';
                    ctx.textAlign = 'center';
                    ctx.fillText('\uf521', 60, 0);
                    ctx.restore();
                }
            }

            // Center hub - outer ring
            ctx.beginPath();
            ctx.arc(0, 0, 42, 0, 2 * Math.PI);
            var hubGrad = ctx.createRadialGradient(0, 0, 0, 0, 0, 42);
            hubGrad.addColorStop(0, '#1a2a3a');
            hubGrad.addColorStop(1, '#0a1018');
            ctx.fillStyle = hubGrad;
            ctx.fill();
            ctx.strokeStyle = '#45f882';
            ctx.lineWidth = 3;
            ctx.stroke();

            // Center hub - inner glow
            ctx.beginPath();
            ctx.arc(0, 0, 36, 0, 2 * Math.PI);
            ctx.strokeStyle = 'rgba(69,248,130,0.2)';
            ctx.lineWidth = 1;
            ctx.stroke();

            // Center text
            ctx.font = '900 11px "Segoe UI", system-ui, sans-serif';
            ctx.fillStyle = '#45f882';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.shadowColor = 'rgba(69,248,130,0.5)';
            ctx.shadowBlur = 8;
            ctx.fillText('SPIN', 0, 0);
            ctx.shadowBlur = 0;

            ctx.restore();

            // Outer glow ring
            ctx.beginPath();
            ctx.arc(CX, CY, R + 23, 0, 2 * Math.PI);
            ctx.strokeStyle = 'rgba(69,248,130,0.08)';
            ctx.lineWidth = 1;
            ctx.stroke();
        }

        // Animate LEDs
        function animateLeds() {
            ledPhase = (ledPhase + 1) % 3;
            drawWheel(currentAngle);
        }
        ledTimer = setInterval(animateLeds, 400);

        drawWheel(0);

        var spinBtn = document.getElementById('wheelSpinBtn');
        var resultOverlay = document.getElementById('wheelResult');
        var resultIcon = document.getElementById('wheelResultIcon');
        var resultLabel = document.getElementById('wheelResultLabel');
        var resultDetail = document.getElementById('wheelResultDetail');
        var resultClose = document.getElementById('wheelResultClose');
        var freeSpinsEl = document.getElementById('wheelFreeSpins');
        var balanceEl = document.getElementById('wheelBalance');
        var boostBalanceEl = document.getElementById('wheelBoostBalance');
        var wheelCsrfToken = '{{ csrf_token("wheel_spin") }}';

        function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }

        spinBtn.addEventListener('click', function() {
            if (spinning) return;
            spinning = true;
            spinBtn.disabled = true;
            spinBtn.classList.add('spinning');
            spinBtn.innerHTML = '<i class="fas fa-spinner fa-spin" style="margin-right:6px;"></i> En cours...';

            // Speed up LEDs while spinning
            clearInterval(ledTimer);
            ledTimer = setInterval(animateLeds, 100);

            var formData = new FormData();
            formData.append('_token', wheelCsrfToken);

            fetch('{{ path("wheel_spin") }}', { method: 'POST', body: formData })
                .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
                .then(function(res) {
                    if (!res.ok) {
                        spinning = false;
                        spinBtn.disabled = false;
                        spinBtn.classList.remove('spinning');
                        clearInterval(ledTimer);
                        ledTimer = setInterval(animateLeds, 400);
                        updateBtnLabel(parseInt(freeSpinsEl.textContent));
                        alert(res.data.error || 'Erreur');
                        return;
                    }

                    var d = res.data;
                    var targetIndex = d.sectionIndex;

                    // Target angle: the pointer is at top (12 o'clock = -PI/2).
                    // Section i occupies [i*arc - PI/2, (i+1)*arc - PI/2].
                    // To land in the middle of section targetIndex, the wheel
                    // needs to rotate so that angle + targetIndex*arc + arc/2 = 0 (mod 2PI)
                    // → desiredAngle = 2PI - (targetIndex*arc + arc/2)
                    var desiredAngle = 2 * Math.PI - (targetIndex * arc + arc / 2);

                    // Compensate for current wheel position
                    var startMod = currentAngle % (2 * Math.PI);
                    if (startMod < 0) startMod += 2 * Math.PI;
                    var delta = desiredAngle - startMod;
                    if (delta < 0) delta += 2 * Math.PI;

                    // Add full rotations for dramatic effect
                    var fullSpins = 5 + Math.floor(Math.random() * 3);
                    var totalDelta = fullSpins * 2 * Math.PI + delta;

                    var animStart = currentAngle;
                    var duration = 5000;
                    var startTime = null;

                    function animate(ts) {
                        if (!startTime) startTime = ts;
                        var elapsed = ts - startTime;
                        var t = Math.min(elapsed / duration, 1);
                        var eased = easeOutQuart(t);

                        currentAngle = animStart + eased * totalDelta;
                        drawWheel(currentAngle);

                        if (t < 1) {
                            requestAnimationFrame(animate);
                        } else {
                            spinning = false;
                            spinBtn.classList.remove('spinning');

                            // Slow LEDs back down
                            clearInterval(ledTimer);
                            ledTimer = setInterval(animateLeds, 400);

                            // Update UI values
                            freeSpinsEl.textContent = d.remainingFreeSpins;
                            balanceEl.textContent = d.newBalance.nexbits;
                            boostBalanceEl.textContent = d.newBalance.nexboost;

                            // Update free badge in info bar
                            var infoBar = document.querySelector('.wheel-info-bar');
                            if (d.remainingFreeSpins > 0) {
                                infoBar.innerHTML = '<span class="free-badge"><i class="fas fa-gift"></i> Tour gratuit disponible</span>';
                            } else {
                                infoBar.innerHTML = '<span>Cout : <strong>{{ wheel_spin_cost }} NexBits</strong></span>';
                            }

                            updateBtnLabel(d.remainingFreeSpins);
                            spinBtn.disabled = false;

                            // Show result
                            var isJackpot = d.isJackpot;
                            var isLoss = d.prize.nexbits === 0 && d.prize.nexboost === 0;

                            if (isJackpot) {
                                resultOverlay.className = 'wheel-result-overlay active jackpot';
                                resultIcon.innerHTML = '<i class="fas fa-crown"></i>';
                                resultLabel.textContent = 'JACKPOT !';
                                resultDetail.innerHTML = '<strong style="color:#ffd700;">' + d.prize.nexbits + ' NexBits + ' + d.prize.nexboost + ' NexBoost</strong>';
                            } else if (isLoss) {
                                resultOverlay.className = 'wheel-result-overlay active loss';
                                resultIcon.innerHTML = '<i class="fas fa-times-circle"></i>';
                                resultLabel.textContent = 'Perdu !';
                                resultDetail.textContent = 'Pas de chance, retentez votre chance !';
                            } else {
                                resultOverlay.className = 'wheel-result-overlay active';
                                resultIcon.innerHTML = '<i class="fas fa-coins" style="color:#45f882;"></i>';
                                resultLabel.textContent = d.prize.label;
                                var parts = [];
                                if (d.prize.nexbits > 0) parts.push('+' + d.prize.nexbits + ' NexBits');
                                if (d.prize.nexboost > 0) parts.push('+' + d.prize.nexboost + ' NexBoost');
                                resultDetail.innerHTML = '<strong style="color:#45f882;">' + parts.join(' & ') + '</strong>';
                            }
                        }
                    }
                    requestAnimationFrame(animate);
                })
                .catch(function() {
                    spinning = false;
                    spinBtn.disabled = false;
                    spinBtn.classList.remove('spinning');
                    clearInterval(ledTimer);
                    ledTimer = setInterval(animateLeds, 400);
                    updateBtnLabel(parseInt(freeSpinsEl.textContent));
                    alert('Erreur reseau.');
                });
        });

        resultClose.addEventListener('click', function() {
            resultOverlay.className = 'wheel-result-overlay';
        });

        function updateBtnLabel(freeSpins) {
            if (freeSpins > 0) {
                spinBtn.innerHTML = '<i class="fas fa-dharmachakra" style="margin-right:6px;"></i> Tourner gratuitement';
            } else {
                spinBtn.innerHTML = '<i class="fas fa-dharmachakra" style="margin-right:6px;"></i> Tourner — {{ wheel_spin_cost }} NexBits';
            }
        }
    })();
    {% endif %}

});
</script>
{% endblock %}
