{% extends 'base.html.twig' %}

{% block title %}Parametres - {{ setting('site_name', 'Nexarena') }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('assets/css/pages/profile.css') }}">
<style>
/* ───── Wheel ───── */
.wheel-card {
    background: linear-gradient(135deg, #0f1c2d 0%, #162231 100%);
    border: 1px solid rgba(69,248,130,0.15);
    border-radius: 12px;
    padding: 18px;
    position: relative;
    overflow: hidden;
}
.wheel-card::before {
    content: '';
    position: absolute; inset: -1px;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(69,248,130,0.2), rgba(0,198,255,0.1), rgba(69,248,130,0.2));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
}
.wheel-card__title {
    font-size: 12px; font-weight: 700;
    color: #45f882;
    text-transform: uppercase; letter-spacing: 0.6px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(69,248,130,0.1);
    display: flex; align-items: center; gap: 7px;
}
.wheel-canvas-wrap {
    position: relative;
    width: 280px; height: 280px;
    margin: 0 auto 16px;
}
.wheel-canvas-wrap canvas {
    width: 100%; height: 100%;
    border-radius: 50%;
    box-shadow: 0 0 30px rgba(69,248,130,0.08), inset 0 0 20px rgba(0,0,0,0.3);
}
.wheel-pointer {
    position: absolute;
    top: -8px; left: 50%;
    transform: translateX(-50%);
    width: 0; height: 0;
    border-left: 12px solid transparent;
    border-right: 12px solid transparent;
    border-top: 22px solid #45f882;
    filter: drop-shadow(0 2px 6px rgba(69,248,130,0.5));
    z-index: 2;
}
.wheel-info {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 12px; font-size: 12px; color: #8b949e;
}
.wheel-info strong { color: #e6edf3; }
.wheel-info .free-badge {
    padding: 2px 8px; border-radius: 4px;
    background: rgba(69,248,130,0.1); color: #45f882;
    font-weight: 700; font-size: 11px;
    border: 1px solid rgba(69,248,130,0.2);
}
.wheel-spin-btn {
    width: 100%; padding: 11px;
    border-radius: 8px; border: none;
    background: linear-gradient(135deg, #45f882, #2dd66b);
    color: #0a1018; font-size: 14px; font-weight: 800;
    cursor: pointer; transition: all .3s;
    text-transform: uppercase; letter-spacing: 0.5px;
}
.wheel-spin-btn:hover:not(:disabled) {
    box-shadow: 0 0 20px rgba(69,248,130,0.4);
    transform: translateY(-1px);
}
.wheel-spin-btn:disabled {
    opacity: 0.4; cursor: not-allowed;
    background: rgba(69,248,130,0.15); color: rgba(69,248,130,0.4);
}
.wheel-spin-btn.spinning {
    animation: pulse-spin 0.6s ease infinite;
}
@keyframes pulse-spin {
    0%, 100% { box-shadow: 0 0 10px rgba(69,248,130,0.2); }
    50% { box-shadow: 0 0 25px rgba(69,248,130,0.5); }
}
.wheel-result-overlay {
    position: absolute; inset: 0;
    background: rgba(10,16,24,0.92);
    border-radius: 12px;
    display: none; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 10; text-align: center; padding: 20px;
}
.wheel-result-overlay.active { display: flex; }
.wheel-result-overlay .result-icon {
    font-size: 40px; margin-bottom: 10px;
}
.wheel-result-overlay .result-label {
    font-size: 20px; font-weight: 800; color: #e6edf3;
    margin-bottom: 6px;
}
.wheel-result-overlay .result-detail {
    font-size: 13px; color: #8b949e; margin-bottom: 16px;
}
.wheel-result-overlay .result-close {
    padding: 7px 20px; border-radius: 6px;
    background: rgba(69,248,130,0.1); border: 1px solid rgba(69,248,130,0.2);
    color: #45f882; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: all .2s;
}
.wheel-result-overlay .result-close:hover { background: rgba(69,248,130,0.18); }
.wheel-result-overlay.jackpot {
    background: radial-gradient(ellipse at center, rgba(255,215,0,0.15) 0%, rgba(10,16,24,0.95) 70%);
}
.wheel-result-overlay.jackpot .result-icon { color: #ffd700; animation: jackpot-glow 1s ease infinite alternate; }
.wheel-result-overlay.jackpot .result-label { color: #ffd700; }
@keyframes jackpot-glow {
    0% { text-shadow: 0 0 10px rgba(255,215,0,0.3); }
    100% { text-shadow: 0 0 30px rgba(255,215,0,0.8), 0 0 60px rgba(255,215,0,0.3); }
}
</style>
{% endblock %}

{% block body %}
<section class="settings-page">
    <div class="container">

        {# ── Flash messages ── #}
        {% for message in app.flashes('success') %}
            <div class="profile-flash profile-flash--success"><i class="fas fa-check-circle"></i> {{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="profile-flash profile-flash--error"><i class="fas fa-exclamation-circle"></i> {{ message }}</div>
        {% endfor %}

        {# ── Header ── #}
        <div class="settings-header">
            <div class="settings-header__avatar">
                {% if app.user.avatar starts with 'http' %}
                    <img src="{{ app.user.avatar }}" alt="Avatar">
                {% elseif app.user.avatar %}
                    <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="Avatar">
                {% else %}
                    <i class="fas fa-user"></i>
                {% endif %}
            </div>
            <div class="settings-header__info">
                <div class="settings-header__name">{{ app.user.username }}</div>
                <div class="settings-header__meta">
                    <span class="settings-header__meta-item"><i class="fas fa-envelope"></i> {{ app.user.email }}</span>
                    {% if app.user.isTwoFactorEnabled %}
                        <span class="settings-header__meta-item" style="color:#45f882;"><i class="fas fa-shield-alt"></i> 2FA actif</span>
                    {% else %}
                        <span class="settings-header__meta-item" style="color:#8b949e;"><i class="fas fa-shield-alt"></i> 2FA inactif</span>
                    {% endif %}
                </div>
            </div>
            <div class="settings-header__actions">
                <a href="{{ path('user_profile_edit') }}" class="btn-action btn-action--outline">
                    <i class="fas fa-pen"></i> Modifier le profil
                </a>
                <a href="{{ path('profile_show', {username: app.user.username}) }}" class="btn-action btn-action--outline">
                    <i class="fas fa-user"></i> Mon profil
                </a>
            </div>
        </div>

        {# ── Tab navigation ── #}
        <div class="settings-tabs">
            <button type="button" class="settings-tabs__btn active" data-tab="profil" onclick="switchSettingsTab('profil')">
                <i class="fas fa-user-circle"></i> Profil
            </button>
            <button type="button" class="settings-tabs__btn" data-tab="securite" onclick="switchSettingsTab('securite')">
                <i class="fas fa-lock"></i> Securite
            </button>
            <button type="button" class="settings-tabs__btn" data-tab="twofa" onclick="switchSettingsTab('twofa')">
                <i class="fas fa-shield-alt"></i> Authentification 2FA
            </button>
            {% if wheel_enabled %}
            <button type="button" class="settings-tabs__btn" data-tab="roue" onclick="switchSettingsTab('roue')">
                <i class="fas fa-dharmachakra"></i> Roue
            </button>
            {% endif %}
        </div>

        <div class="row g-4">

            {# ══════════ MAIN COL ══════════ #}
            <div class="col-lg-8">

                {# ── PANEL: Profil ── #}
                <div id="tabProfil" class="settings-panel active">

                    {# Email #}
                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-envelope"></i> Adresse email</h3>
                        <form action="{{ path('user_settings_email') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('profile_email') }}">
                            <div class="form-group">
                                <label for="email">Email</label>
                                <input type="email" id="email" name="email" class="form-input" value="{{ app.user.email }}" required>
                            </div>
                            <button type="submit" class="btn-action btn-action--primary"><i class="fas fa-save"></i> Enregistrer</button>
                        </form>
                    </div>

                </div>

                {# ── PANEL: Securite ── #}
                <div id="tabSecurite" class="settings-panel">

                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-key"></i> Modifier le mot de passe</h3>
                        <form action="{{ path('user_settings_password') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('profile_password') }}">
                            {% if app.user.password %}
                                <div class="form-group">
                                    <label for="currentPassword">Mot de passe actuel</label>
                                    <input type="password" id="currentPassword" name="current_password" class="form-input" required placeholder="••••••••••">
                                </div>
                            {% endif %}
                            <div class="form-group">
                                <label for="newPassword">Nouveau mot de passe</label>
                                <input type="password" id="newPassword" name="new_password" class="form-input" required minlength="10" placeholder="••••••••••">
                                <div class="form-hint">Minimum 10 caracteres</div>
                            </div>
                            <div class="form-group">
                                <label for="confirmPassword">Confirmer le mot de passe</label>
                                <input type="password" id="confirmPassword" name="confirm_password" class="form-input" required minlength="10" placeholder="••••••••••">
                            </div>
                            <button type="submit" class="btn-action btn-action--primary"><i class="fas fa-save"></i> Modifier le mot de passe</button>
                        </form>
                    </div>

                </div>

                {# ── PANEL: 2FA ── #}
                <div id="tabTwofa" class="settings-panel">

                    <div class="form-card">
                        <h3 class="form-card__title"><i class="fas fa-shield-alt"></i> Authentification a deux facteurs</h3>

                        {% if app.user.isTwoFactorEnabled %}
                            <div class="twofa-status twofa-status--active">
                                <i class="fas fa-check-circle"></i> 2FA active
                            </div>
                            <p style="color:#8b949e;font-size:13px;margin-bottom:20px;line-height:1.6;">
                                Votre compte est protege par l'authentification a deux facteurs via une application TOTP (Google Authenticator, Authy, etc.).
                            </p>
                            <form action="{{ path('user_settings_2fa_disable') }}" method="post" onsubmit="return confirm('Etes-vous sur de vouloir desactiver le 2FA ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('profile_2fa') }}">
                                {% if app.user.password %}
                                <div class="form-group">
                                    <label>Confirmez avec votre mot de passe</label>
                                    <input type="password" name="password" required class="form-input" placeholder="Mot de passe actuel" style="max-width:320px;">
                                </div>
                                {% endif %}
                                <button type="submit" class="btn-action btn-action--danger"><i class="fas fa-times"></i> Desactiver le 2FA</button>
                            </form>

                        {% else %}
                            <div class="twofa-status twofa-status--inactive">
                                <i class="fas fa-times-circle"></i> 2FA desactive
                            </div>
                            <p style="color:#8b949e;font-size:13px;margin-bottom:20px;line-height:1.6;">
                                Protegez votre compte avec une couche de securite supplementaire. Une application comme <strong style="color:#e6edf3;">Google Authenticator</strong> ou <strong style="color:#e6edf3;">Authy</strong> sera necessaire.
                            </p>
                            <button type="button" class="btn-action btn-action--primary" id="btn2faEnable">
                                <i class="fas fa-qrcode"></i> Activer le 2FA
                            </button>
                            <div class="twofa-msg" id="twofaMsg"></div>

                            <div class="twofa-setup" id="twofaSetup">
                                <div class="twofa-qr" id="twofaQr"></div>
                                <div class="twofa-secret" id="twofaSecret"></div>
                                <p style="color:#8b949e;font-size:13px;text-align:center;margin-bottom:16px;">
                                    Scannez le QR code avec votre application, puis entrez le code a 6 chiffres pour confirmer.
                                </p>
                                <div class="twofa-confirm">
                                    <input type="text" id="twofaCode" class="form-input" placeholder="000000" maxlength="6" pattern="[0-9]{6}" inputmode="numeric">
                                    <button type="button" class="btn-action btn-action--primary" id="btn2faConfirm"><i class="fas fa-check"></i></button>
                                </div>
                                <div class="twofa-msg twofa-msg--confirm" id="twofaConfirmMsg"></div>
                            </div>
                        {% endif %}

                    </div>

                </div>

                {# ── PANEL: Roue communautaire ── #}
                {% if wheel_enabled %}
                <div id="tabRoue" class="settings-panel">

                    <div class="wheel-card" id="wheelCard">
                        <div class="wheel-card__title">
                            <i class="fas fa-dharmachakra"></i> Roue communautaire
                        </div>

                        <div class="wheel-canvas-wrap">
                            <div class="wheel-pointer"></div>
                            <canvas id="wheelCanvas" width="560" height="560"></canvas>
                        </div>

                        <div class="wheel-info">
                            <div>
                                Tours gratuits : <strong id="wheelFreeSpins">{{ wheel_free_spins }}</strong>
                                {% if wheel_free_spins > 0 %}
                                    <span class="free-badge">GRATUIT</span>
                                {% endif %}
                            </div>
                            <div>Cout : <strong>{{ wheel_spin_cost }} NexBits</strong></div>
                        </div>

                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;font-size:12px;color:#8b949e;">
                            <div><i class="fas fa-wallet" style="color:#45f882;margin-right:4px;"></i> Solde : <strong id="wheelBalance" style="color:#45f882;">{{ app.user.tokenBalance }}</strong> NexBits</div>
                            <div><strong id="wheelBoostBalance" style="color:#00c6ff;">{{ app.user.boostTokenBalance }}</strong> NexBoost</div>
                        </div>

                        <button type="button" class="wheel-spin-btn" id="wheelSpinBtn">
                            <i class="fas fa-dharmachakra"></i>
                            {% if wheel_free_spins > 0 %}
                                Tourner (gratuit)
                            {% else %}
                                Tourner ({{ wheel_spin_cost }} NexBits)
                            {% endif %}
                        </button>

                        <div class="wheel-result-overlay" id="wheelResult">
                            <div class="result-icon" id="wheelResultIcon"></div>
                            <div class="result-label" id="wheelResultLabel"></div>
                            <div class="result-detail" id="wheelResultDetail"></div>
                            <button type="button" class="result-close" id="wheelResultClose">Fermer</button>
                        </div>
                    </div>

                </div>
                {% endif %}

            </div>

            {# ══════════ SIDEBAR ══════════ #}
            <div class="col-lg-4">

                {# ── Comptes liés ── #}
                <div class="settings-sidebar-card">
                    <div class="settings-sidebar-card__title">
                        <i class="fas fa-link"></i> Comptes lies
                    </div>

                    {% set providers = [
                        {key: 'discord', label: 'Discord', icon: 'fab fa-discord', color: '#5865f2', id: app.user.discordId},
                        {key: 'google',  label: 'Google',  icon: 'fab fa-google',  color: '#ea4335', id: app.user.googleId},
                        {key: 'twitch',  label: 'Twitch',  icon: 'fab fa-twitch',  color: '#9146ff', id: app.user.twitchId},
                        {key: 'steam',   label: 'Steam',   icon: 'fab fa-steam',   color: '#c2a952', id: app.user.steamId},
                    ] %}

                    {% for p in providers %}
                        <div class="oauth-row">
                            <div class="oauth-icon" style="background:{{ p.color }};opacity:{{ p.id ? '1' : '0.35' }};">
                                <i class="{{ p.icon }}"></i>
                            </div>
                            <div class="oauth-info">
                                <div class="oauth-info__name">{{ p.label }}</div>
                                {% if p.id %}
                                    <div class="oauth-info__status oauth-info__status--connected">
                                        <i class="fas fa-check-circle"></i> Connecte
                                    </div>
                                {% else %}
                                    <div class="oauth-info__status oauth-info__status--disconnected">
                                        <i class="fas fa-times-circle"></i> Non connecte
                                    </div>
                                {% endif %}
                            </div>
                            {% if p.id %}
                                <form method="post" action="{{ path('user_settings_oauth_disconnect', {provider: p.key}) }}"
                                      onsubmit="return confirm('Deconnecter {{ p.label }} de votre compte ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('oauth_disconnect_' ~ p.key) }}">
                                    <button type="submit" class="oauth-disconnect-btn">
                                        <i class="fas fa-unlink"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    {% endfor %}

                </div>

                {# ── Infos du compte ── #}
                <div class="settings-sidebar-card">
                    <div class="settings-sidebar-card__title">
                        <i class="fas fa-info-circle"></i> Mon compte
                    </div>

                    <div class="account-info-item">
                        <i class="fas fa-user"></i>
                        <span class="account-info-item__label">Pseudo</span>
                        <span class="account-info-item__value">{{ app.user.username }}</span>
                    </div>
                    <div class="account-info-item">
                        <i class="fas fa-envelope"></i>
                        <span class="account-info-item__label">Email</span>
                        <span class="account-info-item__value" style="font-size:11px;">{{ app.user.email }}</span>
                    </div>
                    <div class="account-info-item">
                        <i class="fas fa-shield-alt"></i>
                        <span class="account-info-item__label">2FA</span>
                        <span class="account-info-item__value">
                            {% if app.user.isTwoFactorEnabled %}
                                <span style="color:#45f882;font-size:12px;"><i class="fas fa-check-circle"></i> Actif</span>
                            {% else %}
                                <span style="color:#8b949e;font-size:12px;"><i class="fas fa-times-circle"></i> Inactif</span>
                            {% endif %}
                        </span>
                    </div>
                    <div class="account-info-item">
                        <i class="fas fa-key"></i>
                        <span class="account-info-item__label">Mot de passe</span>
                        <span class="account-info-item__value">
                            {% if app.user.password %}
                                <span style="color:#45f882;font-size:12px;"><i class="fas fa-check-circle"></i> Defini</span>
                            {% else %}
                                <span style="color:#f6c23e;font-size:12px;"><i class="fas fa-exclamation-circle"></i> Non defini</span>
                            {% endif %}
                        </span>
                    </div>

                </div>

                {# ── Navigation rapide ── #}
                <div class="settings-sidebar-card">
                    <div class="settings-sidebar-card__title">
                        <i class="fas fa-bolt"></i> Raccourcis
                    </div>
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        <a href="{{ path('user_servers_list') }}" class="btn-action btn-action--outline" style="justify-content:flex-start;">
                            <i class="fas fa-server"></i> Mes serveurs
                        </a>
                        <a href="{{ path('user_servers_new') }}" class="btn-action btn-action--outline" style="justify-content:flex-start;">
                            <i class="fas fa-plus-circle"></i> Ajouter un serveur
                        </a>
                        <a href="{{ path('user_recruitment_list') }}" class="btn-action btn-action--outline" style="justify-content:flex-start;">
                            <i class="fas fa-users"></i> Mes recrutements
                        </a>
                        <a href="{{ path('profile_show', {username: app.user.username}) }}" class="btn-action btn-action--outline" style="justify-content:flex-start;">
                            <i class="fas fa-user"></i> Mon profil public
                        </a>
                    </div>
                </div>

            </div>{# /col-lg-4 #}

        </div>{# /row #}

    </div>
</section>
{% endblock %}

{% block javascripts %}
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function () {

    // ── Tab switching ──
    function switchSettingsTab(tab) {
        document.querySelectorAll('.settings-panel').forEach(function(p) { p.classList.remove('active'); });
        document.querySelectorAll('.settings-tabs__btn').forEach(function(b) { b.classList.remove('active'); });
        document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
        document.querySelector('[data-tab="' + tab + '"]').classList.add('active');
        history.replaceState(null, '', '#' + tab);
    }
    window.switchSettingsTab = switchSettingsTab;

    // Restore tab from URL hash
    var hash = location.hash.replace('#', '');
    if (['profil','securite','twofa','roue'].includes(hash)) {
        switchSettingsTab(hash);
    }

    // ── 2FA Enable ──
    var btn2faEnable    = document.getElementById('btn2faEnable');
    var twofaSetup      = document.getElementById('twofaSetup');
    var twofaQr         = document.getElementById('twofaQr');
    var twofaSecret     = document.getElementById('twofaSecret');
    var twofaMsg        = document.getElementById('twofaMsg');
    var twofaConfirmMsg = document.getElementById('twofaConfirmMsg');
    var btn2faConfirm   = document.getElementById('btn2faConfirm');
    var twofaCode       = document.getElementById('twofaCode');
    var csrfToken       = '{{ csrf_token('profile_2fa') }}';

    if (btn2faEnable) {
        btn2faEnable.addEventListener('click', function () {
            btn2faEnable.disabled = true;
            btn2faEnable.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Chargement...';
            twofaMsg.className = 'twofa-msg';
            twofaMsg.textContent = '';

            var fd = new FormData();
            fd.append('_token', csrfToken);

            fetch('{{ path('user_settings_2fa_enable') }}', { method: 'POST', body: fd })
                .then(function (r) {
                    if (!r.ok) return r.json().then(function (j) { throw new Error(j.error || 'Erreur ' + r.status); });
                    return r.json();
                })
                .then(function (data) {
                    if (data.error) {
                        twofaMsg.className = 'twofa-msg twofa-msg--error';
                        twofaMsg.textContent = data.error;
                        btn2faEnable.disabled = false;
                        btn2faEnable.innerHTML = '<i class="fas fa-qrcode"></i> Activer le 2FA';
                        return;
                    }
                    twofaQr.innerHTML = '<img src="' + data.qr + '" alt="QR Code">';
                    twofaSecret.innerHTML = '<code>' + data.secret + '</code><small>Cle secrete manuelle si le QR ne fonctionne pas</small>';
                    twofaSetup.classList.add('active');
                    btn2faEnable.style.display = 'none';
                    twofaCode.focus();
                })
                .catch(function (err) {
                    twofaMsg.className = 'twofa-msg twofa-msg--error';
                    twofaMsg.textContent = err.message || 'Une erreur est survenue.';
                    btn2faEnable.disabled = false;
                    btn2faEnable.innerHTML = '<i class="fas fa-qrcode"></i> Activer le 2FA';
                });
        });
    }

    if (btn2faConfirm) {
        btn2faConfirm.addEventListener('click', function () {
            var code = twofaCode.value.trim();
            if (code.length !== 6) {
                twofaConfirmMsg.className = 'twofa-msg twofa-msg--error';
                twofaConfirmMsg.textContent = 'Entrez un code a 6 chiffres.';
                return;
            }
            btn2faConfirm.disabled = true;
            var fd = new FormData();
            fd.append('_token', csrfToken);
            fd.append('code', code);

            fetch('{{ path('user_settings_2fa_confirm') }}', { method: 'POST', body: fd })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.error) {
                        twofaConfirmMsg.className = 'twofa-msg twofa-msg--error';
                        twofaConfirmMsg.textContent = data.error;
                        btn2faConfirm.disabled = false;
                        return;
                    }
                    twofaConfirmMsg.className = 'twofa-msg twofa-msg--success';
                    twofaConfirmMsg.textContent = data.message;
                    setTimeout(function () { location.reload(); }, 1500);
                })
                .catch(function () {
                    twofaConfirmMsg.className = 'twofa-msg twofa-msg--error';
                    twofaConfirmMsg.textContent = 'Une erreur est survenue.';
                    btn2faConfirm.disabled = false;
                });
        });

        if (twofaCode) {
            twofaCode.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); btn2faConfirm.click(); }
            });
        }
    }

    // ── Wheel ──
    {% if wheel_enabled %}
    (function() {
        var canvas = document.getElementById('wheelCanvas');
        if (!canvas) return;
        var ctx = canvas.getContext('2d');
        var prizes = {{ wheel_prizes|json_encode|raw }};
        var numSections = prizes.length;
        var arc = (2 * Math.PI) / numSections;
        var currentAngle = 0;
        var spinning = false;

        function drawWheel(angle) {
            ctx.clearRect(0, 0, 560, 560);
            ctx.save();
            ctx.translate(280, 280);
            ctx.rotate(angle);

            for (var i = 0; i < numSections; i++) {
                var startAngle = i * arc - Math.PI / 2;
                var endAngle = startAngle + arc;

                ctx.beginPath();
                ctx.moveTo(0, 0);
                ctx.arc(0, 0, 270, startAngle, endAngle);
                ctx.closePath();
                ctx.fillStyle = prizes[i].color || '#2d8a4e';
                ctx.fill();

                ctx.strokeStyle = 'rgba(0,0,0,0.3)';
                ctx.lineWidth = 1.5;
                ctx.stroke();

                ctx.save();
                ctx.rotate(startAngle + arc / 2);
                ctx.textAlign = 'right';
                ctx.fillStyle = prizes[i].isJackpot ? '#0a1018' : '#fff';
                ctx.font = (prizes[i].isJackpot ? 'bold 15px' : '13px') + ' system-ui, -apple-system, sans-serif';
                ctx.fillText(prizes[i].label, 255, 5);
                ctx.restore();
            }

            ctx.beginPath();
            ctx.arc(0, 0, 35, 0, 2 * Math.PI);
            ctx.fillStyle = '#0a1018';
            ctx.fill();
            ctx.strokeStyle = '#45f882';
            ctx.lineWidth = 3;
            ctx.stroke();

            ctx.font = 'bold 10px system-ui, sans-serif';
            ctx.fillStyle = '#45f882';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('SPIN', 0, 0);

            ctx.restore();

            ctx.beginPath();
            ctx.arc(280, 280, 272, 0, 2 * Math.PI);
            ctx.strokeStyle = 'rgba(69,248,130,0.2)';
            ctx.lineWidth = 4;
            ctx.stroke();
        }

        drawWheel(0);

        var spinBtn = document.getElementById('wheelSpinBtn');
        var resultOverlay = document.getElementById('wheelResult');
        var resultIcon = document.getElementById('wheelResultIcon');
        var resultLabel = document.getElementById('wheelResultLabel');
        var resultDetail = document.getElementById('wheelResultDetail');
        var resultClose = document.getElementById('wheelResultClose');
        var freeSpinsEl = document.getElementById('wheelFreeSpins');
        var balanceEl = document.getElementById('wheelBalance');
        var boostBalanceEl = document.getElementById('wheelBoostBalance');
        var wheelCsrfToken = '{{ csrf_token("wheel_spin") }}';

        function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }

        spinBtn.addEventListener('click', function() {
            if (spinning) return;
            spinning = true;
            spinBtn.disabled = true;
            spinBtn.classList.add('spinning');
            spinBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> En cours...';

            var formData = new FormData();
            formData.append('_token', wheelCsrfToken);

            fetch('{{ path("wheel_spin") }}', { method: 'POST', body: formData })
                .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
                .then(function(res) {
                    if (!res.ok) {
                        spinning = false;
                        spinBtn.disabled = false;
                        spinBtn.classList.remove('spinning');
                        updateWheelBtnLabel(parseInt(freeSpinsEl.textContent));
                        alert(res.data.error || 'Erreur');
                        return;
                    }

                    var d = res.data;
                    var targetIndex = d.sectionIndex;

                    var sectionAngle = targetIndex * arc + arc / 2;
                    var targetAngle = (2 * Math.PI - sectionAngle);
                    var fullSpins = 5 + Math.floor(Math.random() * 3);
                    var totalAngle = fullSpins * 2 * Math.PI + targetAngle;

                    var startAngle = currentAngle % (2 * Math.PI);
                    var duration = 4000;
                    var startTime = null;

                    function animate(ts) {
                        if (!startTime) startTime = ts;
                        var elapsed = ts - startTime;
                        var t = Math.min(elapsed / duration, 1);
                        var eased = easeOutCubic(t);

                        currentAngle = startAngle + eased * totalAngle;
                        drawWheel(currentAngle);

                        if (t < 1) {
                            requestAnimationFrame(animate);
                        } else {
                            spinning = false;
                            spinBtn.classList.remove('spinning');

                            freeSpinsEl.textContent = d.remainingFreeSpins;
                            balanceEl.textContent = d.newBalance.nexbits;
                            boostBalanceEl.textContent = d.newBalance.nexboost;

                            var freeParent = freeSpinsEl.parentElement;
                            var existingBadge = freeParent.querySelector('.free-badge');
                            if (d.remainingFreeSpins > 0) {
                                if (!existingBadge) {
                                    var badge = document.createElement('span');
                                    badge.className = 'free-badge';
                                    badge.textContent = 'GRATUIT';
                                    freeParent.appendChild(badge);
                                }
                            } else if (existingBadge) {
                                existingBadge.remove();
                            }

                            updateWheelBtnLabel(d.remainingFreeSpins);
                            spinBtn.disabled = false;

                            var isJackpot = d.isJackpot;
                            var isLoss = d.prize.nexbits === 0 && d.prize.nexboost === 0;

                            resultOverlay.className = 'wheel-result-overlay active' + (isJackpot ? ' jackpot' : '');

                            if (isJackpot) {
                                resultIcon.innerHTML = '<i class="fas fa-crown"></i>';
                                resultLabel.textContent = 'JACKPOT !';
                                resultDetail.innerHTML = '<strong style="color:#ffd700;">' + d.prize.nexbits + ' NexBits + ' + d.prize.nexboost + ' NexBoost</strong>';
                            } else if (isLoss) {
                                resultIcon.innerHTML = '<i class="fas fa-times-circle" style="color:#c9314a;"></i>';
                                resultLabel.textContent = 'Perdu !';
                                resultDetail.textContent = 'Pas de chance, retentez votre chance !';
                            } else {
                                resultIcon.innerHTML = '<i class="fas fa-coins" style="color:#45f882;"></i>';
                                resultLabel.textContent = d.prize.label;
                                var detailParts = [];
                                if (d.prize.nexbits > 0) detailParts.push('+' + d.prize.nexbits + ' NexBits');
                                if (d.prize.nexboost > 0) detailParts.push('+' + d.prize.nexboost + ' NexBoost');
                                resultDetail.innerHTML = '<strong style="color:#45f882;">' + detailParts.join(' & ') + '</strong>';
                            }
                        }
                    }
                    requestAnimationFrame(animate);
                })
                .catch(function(err) {
                    spinning = false;
                    spinBtn.disabled = false;
                    spinBtn.classList.remove('spinning');
                    updateWheelBtnLabel(parseInt(freeSpinsEl.textContent));
                    alert('Erreur reseau.');
                });
        });

        resultClose.addEventListener('click', function() {
            resultOverlay.classList.remove('active');
        });

        function updateWheelBtnLabel(freeSpins) {
            if (freeSpins > 0) {
                spinBtn.innerHTML = '<i class="fas fa-dharmachakra"></i> Tourner (gratuit)';
            } else {
                spinBtn.innerHTML = '<i class="fas fa-dharmachakra"></i> Tourner ({{ wheel_spin_cost }} NexBits)';
            }
        }
    })();
    {% endif %}

});
</script>
{% endblock %}
