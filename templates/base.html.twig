<!doctype html>
<html class="no-js" lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {# ── Titles & descriptions ─────────────────────────────── #}
    {% set _title       = block('title') %}
    {% set _description = block('meta_description') %}
    {% set _site_name   = setting('site_name', 'Nexarena') %}
    {% set _site_url    = setting('seo_site_url', app.request.schemeAndHttpHost) %}
    {% set _canonical   = block('canonical_url') ?: (_site_url ~ app.request.pathInfo) %}
    {% set _og_image    = block('og_image') ?: (setting('seo_og_image') ? (asset(setting('seo_og_image'))) : null) %}
    {% set _og_type     = block('og_type') ?: 'website' %}

    <title>{% block title %}{{ setting('seo_title', 'Nexarena - Classement de Serveurs de Jeux') }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ setting('seo_description', 'Nexarena - Classement et listing de serveurs prives de jeux videos') }}{% endblock %}">
    {% if setting('seo_keywords') %}<meta name="keywords" content="{{ setting('seo_keywords') }}">{% endif %}
    {% block robots %}<meta name="robots" content="index, follow">{% endblock %}

    {# ── Canonical ─────────────────────────────────────────── #}
    <link rel="canonical" href="{{ _canonical }}">
    {% block canonical_url %}{% endblock %}

    {# ── Open Graph (Discord, Facebook, LinkedIn…) ─────────── #}
    <meta property="og:site_name"   content="{{ _site_name }}">
    <meta property="og:locale"      content="fr_FR">
    <meta property="og:type"        content="{{ _og_type }}">
    {% block og_type %}{% endblock %}
    <meta property="og:title"       content="{{ _title }}">
    <meta property="og:description" content="{{ _description }}">
    <meta property="og:url"         content="{{ _canonical }}">
    {% if _og_image %}
    <meta property="og:image"       content="{{ _og_image }}">
    <meta property="og:image:width"  content="1200">
    <meta property="og:image:height" content="630">
    {% endif %}
    {% block og_image %}{% endblock %}

    {# ── Twitter / X Card ──────────────────────────────────── #}
    <meta name="twitter:card"        content="{{ _og_image ? 'summary_large_image' : 'summary' }}">
    <meta name="twitter:title"       content="{{ _title }}">
    <meta name="twitter:description" content="{{ _description }}">
    {% if _og_image %}
    <meta name="twitter:image"       content="{{ _og_image }}">
    {% endif %}

    {# ── Google verification (Search Console) ─────────────── #}
    {% if setting('google_verification') %}
    <meta name="google-site-verification" content="{{ setting('google_verification') }}">
    {% endif %}

    {# ── Favicon ───────────────────────────────────────────── #}
    <link rel="icon" type="image/png" href="{{ asset('assets/img/logo/new_logo_hd.png') }}">
    <link rel="apple-touch-icon" href="{{ asset('assets/img/logo/new_logo_hd.png') }}">

    {# ── JSON-LD structured data ────────────────────────────── #}
    {% block json_ld %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ _site_name|json_encode|raw }},
      "url": {{ _site_url|json_encode|raw }},
      "description": {{ setting('seo_description', '')|json_encode|raw }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {{ (_site_url ~ '/classement?q={search_term_string}')|json_encode|raw }}
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    {% endblock %}

    {# CSS #}
    <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/magnific-popup.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/fontawesome-all.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/swiper-bundle.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/tg-cursor.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/jquery-ui.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/odometer.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/slick.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/flaticon.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/spacing.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/main.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/components/header.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/components/footer.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/components/notifications.css') }}">

    {% block stylesheets %}{% endblock %}

    {# ── Google Analytics ─────────────────────────────────── #}
    {% if setting('google_analytics_id') %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ setting('google_analytics_id') }}"></script>
    <script nonce="{{ csp_nonce() }}">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ setting('google_analytics_id') }}');
    </script>
    {% endif %}

    {# Page-Revealer #}
    <script src="{{ asset('assets/js/tg-page-head.js') }}"></script>
</head>

<body class="bg-black2">

    {# Scroll to top #}
    <button class="scroll__top scroll-to-target" data-target="html">
        <i class="flaticon-right-arrow"></i>
    </button>

    {# Header #}
    {% block header %}
        {% include 'includes/_header.html.twig' %}
    {% endblock %}

    {# Main Content #}
    <main class="main--area">
        {% block body %}{% endblock %}
    </main>

    {# Footer #}
    {% include 'includes/_footer.html.twig' %}

    {# JS #}
    <script src="{{ asset('assets/js/vendor/jquery-3.6.0.min.js') }}"></script>
    <script src="{{ asset('assets/js/bootstrap.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.magnific-popup.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.countdown.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.waypoints.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.odometer.min.js') }}"></script>
    <script src="{{ asset('assets/js/simpleParallax.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery-ui.min.js') }}"></script>
    <script src="{{ asset('assets/js/gsap.min.js') }}"></script>
    <script src="{{ asset('assets/js/scrollTrigger.min.js') }}"></script>
    <script src="{{ asset('assets/js/splitText.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.appear.js') }}"></script>
    <script src="{{ asset('assets/js/tg-cursor.min.js') }}"></script>
    <script src="{{ asset('assets/js/swiper-bundle.js') }}"></script>
    <script src="{{ asset('assets/js/jarallax.min.js') }}"></script>
    <script src="{{ asset('assets/js/parallax.min.js') }}"></script>
    <script src="{{ asset('assets/js/slick.min.js') }}"></script>
    <script src="{{ asset('assets/js/ajax-form.js') }}"></script>
    <script src="{{ asset('assets/js/vivus.min.js') }}"></script>
    <script src="{{ asset('assets/js/main.js') }}"></script>

    {% block javascripts %}{% endblock %}

    {# ===== DEV LOGIN TOOLBAR (dev only) ===== #}
    {% if _dev_users is defined and _dev_users is not empty %}
    <div id="devToolbar" class="dev-toolbar">
        <button type="button" class="dev-toolbar__toggle" id="devToolbarToggle" title="Dev Login">
            <i class="fas fa-bug"></i>
        </button>
        <div class="dev-toolbar__panel" id="devToolbarPanel">
            <div class="dev-toolbar__header">
                <span><i class="fas fa-bug"></i> Dev Login</span>
                <button type="button" class="dev-toolbar__close" id="devToolbarClose">&times;</button>
            </div>
            <div class="dev-toolbar__list">
                {% for u in _dev_users %}
                    <form method="post" action="{{ path('dev_login', {id: u.id}) }}" class="dev-toolbar__item {{ app.user and app.user.id == u.id ? 'dev-toolbar__item--active' : '' }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('dev_login') }}">
                        <button type="submit" class="dev-toolbar__btn">
                            <span class="dev-toolbar__name">{{ u.username }}</span>
                            <span class="dev-toolbar__role dev-toolbar__role--{{ u.roles|first|lower|replace({'role_': ''}) }}">
                                {{ u.roles|first|replace({'ROLE_': ''}) }}
                            </span>
                        </button>
                    </form>
                {% endfor %}
            </div>
            {% if app.user %}
                <div class="dev-toolbar__footer">
                    <a href="{{ path('app_logout') }}" class="dev-toolbar__logout">
                        <i class="fas fa-sign-out-alt"></i> Deconnecter
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
    <style>
        .dev-toolbar { position: fixed; bottom: 36px; left: 12px; z-index: 99999; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
        .dev-toolbar__toggle {
            width: 42px; height: 42px; border-radius: 50%; border: 2px solid #45f882;
            background: #1a1a2e; color: #45f882; font-size: 18px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 2px 12px rgba(69,248,130,0.3); transition: all 0.2s;
        }
        .dev-toolbar__toggle:hover { background: #45f882; color: #1a1a2e; transform: scale(1.1); }
        .dev-toolbar__panel {
            display: none; position: absolute; bottom: 52px; left: 0;
            width: 280px; background: #12121a; border: 1px solid #2a2a3e;
            border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.6);
            overflow: hidden; animation: devSlideUp 0.2s ease-out;
        }
        .dev-toolbar__panel.open { display: block; }
        @keyframes devSlideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .dev-toolbar__header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 12px 16px; background: #1a1a2e; border-bottom: 1px solid #2a2a3e;
            color: #45f882; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
        }
        .dev-toolbar__close { background: none; border: none; color: #666; font-size: 20px; cursor: pointer; line-height: 1; }
        .dev-toolbar__close:hover { color: #ff4757; }
        .dev-toolbar__list { max-height: 320px; overflow-y: auto; padding: 6px; }
        .dev-toolbar__list::-webkit-scrollbar { width: 4px; }
        .dev-toolbar__list::-webkit-scrollbar-thumb { background: #2a2a3e; border-radius: 2px; }
        .dev-toolbar__item { margin: 0; }
        .dev-toolbar__item--active .dev-toolbar__btn { background: rgba(69,248,130,0.1); border-color: #45f882; }
        .dev-toolbar__btn {
            display: flex; align-items: center; justify-content: space-between; width: 100%;
            padding: 8px 12px; background: transparent; border: 1px solid transparent;
            border-radius: 8px; cursor: pointer; transition: all 0.15s; color: #e0e0e0; font-size: 13px;
        }
        .dev-toolbar__btn:hover { background: rgba(255,255,255,0.05); border-color: #2a2a3e; }
        .dev-toolbar__name { font-weight: 600; }
        .dev-toolbar__role {
            font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
            padding: 2px 8px; border-radius: 4px; color: #fff;
        }
        .dev-toolbar__role--fondateur { background: #e74c3c; }
        .dev-toolbar__role--developpeur { background: #9b59b6; }
        .dev-toolbar__role--responsable { background: #e67e22; }
        .dev-toolbar__role--manager { background: #3498db; }
        .dev-toolbar__role--editeur { background: #1abc9c; }
        .dev-toolbar__role--user { background: #636e72; }
        .dev-toolbar__footer {
            padding: 10px 16px; border-top: 1px solid #2a2a3e; text-align: center;
        }
        .dev-toolbar__logout {
            color: #ff4757; font-size: 12px; font-weight: 600; text-decoration: none;
            transition: opacity 0.15s;
        }
        .dev-toolbar__logout:hover { opacity: 0.8; color: #ff4757; }
    </style>
    <script nonce="{{ csp_nonce() }}">
    (function(){
        var toggle = document.getElementById('devToolbarToggle');
        var panel = document.getElementById('devToolbarPanel');
        var close = document.getElementById('devToolbarClose');
        toggle.addEventListener('click', function(){ panel.classList.toggle('open'); });
        close.addEventListener('click', function(){ panel.classList.remove('open'); });
        document.addEventListener('click', function(e){
            if (!e.target.closest('#devToolbar')) panel.classList.remove('open');
        });
    })();
    </script>
    {% endif %}

    {# ════════════════════════════════════════════
       GLOBAL CHAT BAR — Facebook-style bottom chat
       Only for logged-in users with active chats
    ════════════════════════════════════════════ #}
    {% if app.user %}
    <link rel="stylesheet" href="{{ asset('assets/css/chat-bar.css') }}">

    {# Chat bar — contacts on the LEFT, "Messages" button anchored to the RIGHT #}
    <div id="nxc-bar" style="display:none;">
        <div id="nxc-contacts"></div>
        <div id="nxc-header" onclick="NxChat.mobOpen()" role="button" tabindex="0" aria-label="Ouvrir les messages">
            <i class="fas fa-comments"></i>
            <span>Messages</span>
            <span id="nxc-total-badge" class="nxc-badge" style="display:none;"></span>
        </div>
    </div>

    {# Mobile conversation list panel #}
    <div id="nxc-mob-panel">
        <div class="nxc-mob-panel-hdr">
            <i class="fas fa-comments" style="color:#45f882;font-size:17px;"></i>
            <span>Messages</span>
            <button class="nxc-mob-close" onclick="NxChat.mobClose()" aria-label="Fermer"><i class="fas fa-times"></i></button>
        </div>
        <div id="nxc-mob-list" class="nxc-mob-list"></div>
    </div>

    {# Mobile full-screen chat view #}
    <div id="nxc-mob-chat">
        <div class="nxc-mob-chat-hdr">
            <button class="nxc-mob-back" onclick="NxChat.mobChatBack()" aria-label="Retour"><i class="fas fa-arrow-left"></i></button>
            <span id="nxc-mob-chat-name" class="nxc-mob-chat-name"></span>
        </div>
        <div id="nxc-mob-chat-msgs" class="nxc-mob-chat-msgs"></div>
        <div class="nxc-mob-chat-input">
            <input type="text" id="nxc-mob-input" placeholder="Message..." maxlength="2000" autocomplete="off">
            <button id="nxc-mob-send" class="nxc-mob-chat-send" onclick="NxChat.mobSend()" aria-label="Envoyer">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>

    <script nonce="{{ csp_nonce() }}">
    (function () {
        'use strict';

        var NxChat = {
            uid:      {{ app.user.id }},
            convUrl:  '{{ path('api_chat_conversations') }}',
            convs:    {},   // appId → state object
            wins:     [],   // open desktop window appIds (ordered)
            maxWins:  3,
            mobId:    null, // currently open mobile chat appId

            /* ── Bootstrap ─────────────────────────────── */
            init: function () {
                this._loadConvs();
                setInterval(function () { NxChat._loadConvs(); }, 15000);
                setInterval(function () { NxChat._poll(); }, 4000);
                var mi = document.getElementById('nxc-mob-input');
                if (mi) mi.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter') { e.preventDefault(); NxChat.mobSend(); }
                });
            },

            /* ── Load / refresh conversation list ──────── */
            _loadConvs: function () {
                fetch(NxChat.convUrl, { credentials: 'same-origin' })
                    .then(function (r) { if (!r.ok) throw 0; return r.json(); })
                    .then(function (list) {
                        list.forEach(function (c) {
                            if (NxChat.convs[c.appId]) return;
                            NxChat.convs[c.appId] = {
                                appId: c.appId, role: c.role,
                                name: c.contactName, avatar: c.contactAvatar,
                                title: c.listingTitle, server: c.serverName,
                                mUrl: c.messagesUrl, sUrl: c.sendUrl,
                                lastId: 0, unread: 0,
                                open: false, min: false, msgs: []
                            };
                            NxChat._addBubble(c.appId);
                            NxChat._addMobItem(c.appId);
                        });
                        if (list.length > 0) {
                            var bar = document.getElementById('nxc-bar');
                            if (bar) bar.style.display = 'flex';
                        }
                    }).catch(function () {});
            },

            /* ── Poll all known conversations for new msgs ─ */
            _poll: function () {
                Object.keys(NxChat.convs).forEach(function (id) {
                    var c   = NxChat.convs[id];
                    var aid = parseInt(id);
                    fetch(c.mUrl + '?after=' + c.lastId, { credentials: 'same-origin' })
                        .then(function (r) { if (!r.ok) return null; return r.json(); })
                        .then(function (msgs) {
                            if (!Array.isArray(msgs) || !msgs.length) return;
                            var notify = false;
                            msgs.forEach(function (m) {
                                c.lastId = m.id;
                                c.msgs.push(m);
                                var fromOther = m.senderId !== NxChat.uid;
                                // Desktop window
                                if (c.open && !c.min) {
                                    NxChat._appendMsg('nxc-msgs-' + aid, m);
                                } else if (fromOther) {
                                    c.unread++;
                                }
                                // Mobile chat
                                if (NxChat.mobId === aid) {
                                    NxChat._appendMsg('nxc-mob-chat-msgs', m);
                                }
                                if (fromOther) notify = true;
                            });
                            NxChat._updBubBadge(aid);
                            NxChat._updTotalBadge();
                            NxChat._updMobBadge(aid);
                            if (notify) NxChat._beep();
                        }).catch(function () {});
                });
            },

            /* ── Desktop bubbles ──────────────────────────── */
            _addBubble: function (id) {
                var c  = NxChat.convs[id];
                var el = document.createElement('div');
                el.className = 'nxc-bubble';
                el.id    = 'nxc-bub-' + id;
                el.title = c.name + '\n' + c.title + ' · ' + c.server;
                el.innerHTML = NxChat._avImg(c.avatar, c.name, 'nxc-bubble-initial') +
                    '<span class="nxc-bubble-badge" id="nxc-bubbadge-' + id + '" style="display:none;"></span>';
                el.addEventListener('click', function () { NxChat.openWin(id); });
                var ct = document.getElementById('nxc-contacts');
                if (ct) ct.appendChild(el);
            },

            _updBubBadge: function (id) {
                var c = NxChat.convs[id];
                var b = document.getElementById('nxc-bubbadge-' + id);
                if (!b) return;
                if (c.unread > 0) { b.textContent = c.unread > 9 ? '9+' : c.unread; b.style.display = 'flex'; }
                else { b.style.display = 'none'; }
            },

            _updTotalBadge: function () {
                var total = 0;
                Object.keys(NxChat.convs).forEach(function (id) { total += NxChat.convs[id].unread; });
                var b = document.getElementById('nxc-total-badge');
                if (!b) return;
                if (total > 0) { b.textContent = total > 99 ? '99+' : total; b.style.display = 'inline-flex'; }
                else b.style.display = 'none';
            },

            /* ── Desktop windows ──────────────────────────── */
            openWin: function (rawId) {
                var id = parseInt(rawId);
                var c  = NxChat.convs[id];
                if (!c) return;

                // Already open → unminimize / focus
                if (c.open) {
                    if (c.min) {
                        var w = document.getElementById('nxc-win-' + id);
                        if (w) w.classList.remove('nxc-win--minimized');
                        c.min = false;
                    }
                    c.unread = 0;
                    NxChat._updBubBadge(id);
                    NxChat._updTotalBadge();
                    var msgs = document.getElementById('nxc-msgs-' + id);
                    if (msgs) msgs.scrollTop = msgs.scrollHeight;
                    return;
                }

                // Evict oldest if at max
                if (NxChat.wins.length >= NxChat.maxWins) NxChat.closeWin(NxChat.wins[0]);

                c.open = true; c.min = false; c.unread = 0;
                NxChat.wins.push(id);
                NxChat._buildWin(id);
                NxChat._reposition();
                NxChat._updBubBadge(id);
                NxChat._updTotalBadge();
                NxChat._loadWinMsgs(id);
            },

            closeWin: function (rawId) {
                var id = parseInt(rawId);
                var c  = NxChat.convs[id];
                if (!c) return;
                c.open = false; c.min = false;
                var w = document.getElementById('nxc-win-' + id);
                if (w) w.remove();
                NxChat.wins = NxChat.wins.filter(function (x) { return x !== id; });
                NxChat._reposition();
            },

            toggleMin: function (rawId) {
                var id = parseInt(rawId);
                var c  = NxChat.convs[id];
                if (!c) return;
                var w = document.getElementById('nxc-win-' + id);
                if (!w) return;
                c.min = !c.min;
                w.classList.toggle('nxc-win--minimized', c.min);
                if (!c.min) {
                    var msgs = document.getElementById('nxc-msgs-' + id);
                    if (msgs) msgs.scrollTop = msgs.scrollHeight;
                    c.unread = 0;
                    NxChat._updBubBadge(id);
                    NxChat._updTotalBadge();
                }
            },

            _buildWin: function (id) {
                var c = NxChat.convs[id];
                var av = NxChat._avWinHdr(c.avatar, c.name);
                var w  = document.createElement('div');
                w.className = 'nxc-win'; w.id = 'nxc-win-' + id;
                w.innerHTML =
                    '<div class="nxc-win-hdr" onclick="NxChat.toggleMin(' + id + ')">' +
                        av +
                        '<div class="nxc-win-hdr-info">' +
                            '<span class="nxc-win-name">' + NxChat._e(c.name) + '</span>' +
                            '<span class="nxc-win-sub">' + NxChat._e(c.title) + ' · ' + NxChat._e(c.server) + '</span>' +
                        '</div>' +
                        '<div class="nxc-win-hdr-btns">' +
                            '<button class="nxc-win-btn" onclick="event.stopPropagation();NxChat.closeWin(' + id + ');" title="Fermer"><i class="fas fa-times"></i></button>' +
                        '</div>' +
                    '</div>' +
                    '<div class="nxc-win-body">' +
                        '<div class="nxc-win-msgs" id="nxc-msgs-' + id + '">' +
                            '<div class="nxc-empty" id="nxc-empty-' + id + '"><i class="fas fa-comment-dots"></i><span>Aucun message pour l\'instant</span></div>' +
                        '</div>' +
                        '<div class="nxc-win-input">' +
                            '<input type="text" id="nxc-inp-' + id + '" placeholder="Message..." maxlength="2000" autocomplete="off" ' +
                                'onkeypress="if(event.key===\'Enter\'){event.preventDefault();NxChat.send(' + id + ');}">' +
                            '<button class="nxc-win-send" id="nxc-sbtn-' + id + '" onclick="NxChat.send(' + id + ');" title="Envoyer"><i class="fas fa-paper-plane"></i></button>' +
                        '</div>' +
                    '</div>';
                document.body.appendChild(w);
            },

            _reposition: function () {
                var W = 298, G = 8, base = 8;
                NxChat.wins.forEach(function (id, i) {
                    var w = document.getElementById('nxc-win-' + id);
                    if (w) w.style.right = (base + i * (W + G)) + 'px';
                });
            },

            _loadWinMsgs: function (id) {
                var c = NxChat.convs[id];
                var box = document.getElementById('nxc-msgs-' + id);

                // Use cached messages if we already loaded them
                if (c.msgs.length > 0) {
                    var emp = document.getElementById('nxc-empty-' + id);
                    if (emp) emp.remove();
                    c.msgs.forEach(function (m) { NxChat._appendMsg('nxc-msgs-' + id, m, true); });
                    if (box) box.scrollTop = box.scrollHeight;
                    return;
                }

                fetch(c.mUrl, { credentials: 'same-origin' })
                    .then(function (r) { if (!r.ok) return []; return r.json(); })
                    .then(function (msgs) {
                        if (!Array.isArray(msgs)) return;
                        var emp = document.getElementById('nxc-empty-' + id);
                        if (msgs.length && emp) emp.remove();
                        msgs.forEach(function (m) {
                            c.msgs.push(m); c.lastId = m.id;
                            NxChat._appendMsg('nxc-msgs-' + id, m, true);
                        });
                        if (box) box.scrollTop = box.scrollHeight;
                    }).catch(function () {});
            },

            send: function (rawId) {
                var id  = parseInt(rawId);
                var c   = NxChat.convs[id];
                if (!c) return;
                var inp = document.getElementById('nxc-inp-' + id);
                var btn = document.getElementById('nxc-sbtn-' + id);
                if (!inp) return;
                var txt = inp.value.trim();
                if (!txt) return;
                btn.disabled = true;
                fetch(c.sUrl, {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: txt })
                }).then(function (r) { if (!r.ok) throw 0; return r.json(); })
                .then(function (m) {
                    if (m.id) {
                        inp.value = '';
                        c.lastId = m.id; c.msgs.push(m);
                        var emp = document.getElementById('nxc-empty-' + id);
                        if (emp) emp.remove();
                        NxChat._appendMsg('nxc-msgs-' + id, m);
                    }
                    btn.disabled = false;
                    inp.focus();
                }).catch(function () { btn.disabled = false; });
            },

            /* ── Shared message rendering ─────────────────── */
            _appendMsg: function (boxId, msg, skipScroll) {
                var box = document.getElementById(boxId);
                if (!box) return;
                var nearBottom = box.scrollTop + box.clientHeight >= box.scrollHeight - 40;
                var isMine = msg.senderId === NxChat.uid;
                var el = document.createElement('div');
                el.className = 'nxc-msg ' + (isMine ? 'nxc-msg--mine' : 'nxc-msg--other');
                var txt = document.createElement('div');
                txt.textContent = msg.content;
                el.appendChild(txt);
                var meta = document.createElement('div');
                meta.className = 'nxc-msg-meta';
                meta.textContent = (isMine ? 'Vous' : msg.senderName) + ' · ' + msg.createdAt;
                el.appendChild(meta);
                box.appendChild(el);
                if (!skipScroll || nearBottom) box.scrollTop = box.scrollHeight;
            },

            /* ── Mobile ───────────────────────────────────── */
            _addMobItem: function (id) {
                var c  = NxChat.convs[id];
                var li = document.createElement('div');
                li.className = 'nxc-mob-item';
                li.id = 'nxc-mobitem-' + id;
                li.innerHTML =
                    '<div class="nxc-mob-av">' + NxChat._avImg(c.avatar, c.name, '') + '</div>' +
                    '<div class="nxc-mob-info">' +
                        '<div class="nxc-mob-name">' + NxChat._e(c.name) + '</div>' +
                        '<div class="nxc-mob-sub">' + NxChat._e(c.title) + ' — ' + NxChat._e(c.server) + '</div>' +
                    '</div>' +
                    '<span class="nxc-mob-badge" id="nxc-mobbadge-' + id + '"></span>';
                li.addEventListener('click', function () { NxChat.mobOpenChat(parseInt(id)); });
                var list = document.getElementById('nxc-mob-list');
                if (list) list.appendChild(li);
            },

            _updMobBadge: function (id) {
                var c = NxChat.convs[id];
                var b = document.getElementById('nxc-mobbadge-' + id);
                if (!b) return;
                if (c.unread > 0) { b.textContent = c.unread > 9 ? '9+' : c.unread; b.style.display = 'flex'; }
                else b.style.display = 'none';
            },

            mobOpen: function () {
                var p = document.getElementById('nxc-mob-panel');
                if (p) p.classList.add('open');
            },

            mobClose: function () {
                var p = document.getElementById('nxc-mob-panel');
                if (p) p.classList.remove('open');
            },

            mobOpenChat: function (id) {
                var c = NxChat.convs[id];
                if (!c) return;
                NxChat.mobId = id;
                c.unread = 0;
                NxChat._updMobBadge(id);
                NxChat._updTotalBadge();
                // Header
                var nameEl = document.getElementById('nxc-mob-chat-name');
                if (nameEl) nameEl.textContent = c.name + ' — ' + c.title;
                // Clear box
                var box = document.getElementById('nxc-mob-chat-msgs');
                if (box) box.innerHTML = '';
                // Input reset
                var inp = document.getElementById('nxc-mob-input');
                if (inp) inp.value = '';
                // Close panel, open chat
                NxChat.mobClose();
                var chat = document.getElementById('nxc-mob-chat');
                if (chat) chat.classList.add('open');
                // Load messages
                if (c.msgs.length > 0) {
                    c.msgs.forEach(function (m) { NxChat._appendMsg('nxc-mob-chat-msgs', m, true); });
                    if (box) box.scrollTop = box.scrollHeight;
                } else {
                    fetch(c.mUrl, { credentials: 'same-origin' })
                        .then(function (r) { if (!r.ok) return []; return r.json(); })
                        .then(function (msgs) {
                            if (!Array.isArray(msgs)) return;
                            msgs.forEach(function (m) { c.msgs.push(m); c.lastId = m.id; NxChat._appendMsg('nxc-mob-chat-msgs', m, true); });
                            var b2 = document.getElementById('nxc-mob-chat-msgs');
                            if (b2) b2.scrollTop = b2.scrollHeight;
                        }).catch(function () {});
                }
            },

            mobChatBack: function () {
                NxChat.mobId = null;
                var chat = document.getElementById('nxc-mob-chat');
                if (chat) chat.classList.remove('open');
                NxChat.mobOpen();
            },

            mobSend: function () {
                var id = NxChat.mobId;
                if (!id) return;
                var c  = NxChat.convs[id];
                if (!c) return;
                var inp = document.getElementById('nxc-mob-input');
                var btn = document.getElementById('nxc-mob-send');
                if (!inp) return;
                var txt = inp.value.trim();
                if (!txt) return;
                btn.disabled = true;
                fetch(c.sUrl, {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: txt })
                }).then(function (r) { if (!r.ok) throw 0; return r.json(); })
                .then(function (m) {
                    if (m.id) { inp.value = ''; c.lastId = m.id; c.msgs.push(m); NxChat._appendMsg('nxc-mob-chat-msgs', m); }
                    btn.disabled = false;
                    inp.focus();
                }).catch(function () { btn.disabled = false; });
            },

            /* ── Avatar helpers ───────────────────────────── */
            _avImg: function (avatar, name, cls) {
                var init = name ? name.charAt(0).toUpperCase() : '?';
                if (avatar) {
                    var src = avatar.indexOf('http') === 0 ? avatar : '/uploads/avatars/' + avatar;
                    return '<img src="' + NxChat._e(src) + '" alt="" style="width:100%;height:100%;object-fit:cover;">';
                }
                return cls ? '<span class="' + cls + '">' + NxChat._e(init) + '</span>' : NxChat._e(init);
            },

            _avWinHdr: function (avatar, name) {
                var init = name ? name.charAt(0).toUpperCase() : '?';
                var s    = 'width:28px;height:28px;border-radius:50%;background:#0d1b2d;border:1px solid #1e3048;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;';
                if (avatar) {
                    var src = avatar.indexOf('http') === 0 ? avatar : '/uploads/avatars/' + avatar;
                    return '<div style="' + s + '"><img src="' + NxChat._e(src) + '" style="width:100%;height:100%;object-fit:cover;"></div>';
                }
                return '<div style="' + s + 'font-size:12px;font-weight:800;color:#e6edf3;text-transform:uppercase;">' + NxChat._e(init) + '</div>';
            },

            /* ── Notification beep ────────────────────────── */
            _beep: function () {
                try {
                    var ctx = new (window.AudioContext || window.webkitAudioContext)();
                    var o = ctx.createOscillator(), g = ctx.createGain();
                    o.connect(g); g.connect(ctx.destination);
                    o.frequency.value = 880; o.type = 'sine';
                    g.gain.setValueAtTime(0.1, ctx.currentTime);
                    g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.18);
                    o.start(ctx.currentTime); o.stop(ctx.currentTime + 0.18);
                } catch (e) {}
            },

            /* ── HTML escape ──────────────────────────────── */
            _e: function (s) {
                if (s === null || s === undefined) return '';
                var d = document.createElement('div');
                d.textContent = String(s);
                return d.innerHTML;
            }
        };

        document.addEventListener('DOMContentLoaded', function () { NxChat.init(); });
        window.NxChat = NxChat;
    })();
    </script>
    {% endif %}
</body>
</html>
