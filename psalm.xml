<?xml version="1.0"?>
<psalm
    errorLevel="3"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    findUnusedVariablesAndParams="false"
>
    <projectFiles>
        <directory name="src" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>

    <plugins>
        <pluginClass class="Psalm\SymfonyPsalmPlugin\Plugin">
            <!-- Container XML gives Psalm accurate service return types -->
            <containerXml>var/cache/dev/App_KernelDevDebugContainer.xml</containerXml>
        </pluginClass>
    </plugins>

    <!-- Auto-generated Symfony config classes (PHP-based config, Symfony 5.3+) -->
    <extraFiles>
        <directory name="var/cache/dev/Symfony/Config" />
    </extraFiles>

    <issueHandlers>
        <!-- Suppress noisy baseline issues that are not security/logic bugs -->
        <MissingReturnType errorLevel="info" />
        <MissingParamType errorLevel="info" />
        <PropertyNotSetInConstructor errorLevel="info" />
        <MixedAssignment errorLevel="info" />
        <MixedArgumentTypeCoercion errorLevel="info" />
        <MixedReturnTypeCoercion errorLevel="info" />
        <MixedMethodCall errorLevel="info" />

        <!-- Symfony false positives: classes/methods are wired via DI/autoconfiguration -->
        <UnusedClass errorLevel="info" />
        <PossiblyUnusedMethod errorLevel="info" />

        <!-- PHP 8.3 #[Override] attribute — optional, not a logic bug -->
        <MissingOverrideAttribute errorLevel="info" />

        <!-- Common in closures/callbacks registered in arrays -->
        <UnusedVariable errorLevel="info" />

        <!-- Return value intentionally ignored by some callers -->
        <PossiblyUnusedReturnValue errorLevel="info" />
        <UnusedReturnValue errorLevel="info" />
        <PossiblyUnusedParam errorLevel="info" />

        <!-- Psalm can't infer that final is not required in Symfony services -->
        <ClassMustBeFinal errorLevel="info" />

        <!-- Symfony: getUser() returns UserInterface, not App\Entity\User; request->get() returns scalar -->
        <ArgumentTypeCoercion errorLevel="info" />
        <UndefinedInterfaceMethod errorLevel="info" />

        <!-- Symfony: InputBag::get() integer defaults, PasswordHasher with UserInterface -->
        <InvalidArgument errorLevel="info" />

        <!-- Entity getId() returns ?int; concatenation with nullable; float/int arithmetic -->
        <InvalidOperand errorLevel="info" />

        <!-- Nullable entity chain calls (getOwner()->getUsername(), etc.); all guarded at runtime -->
        <PossiblyNullArgument errorLevel="info" />
        <PossiblyNullReference errorLevel="info" />
        <PossiblyNullArrayOffset errorLevel="info" />

        <!-- file_get_contents() / preg_replace() return false on failure; handled at runtime -->
        <PossiblyFalseArgument errorLevel="info" />

        <!-- AbstractType generic params — Symfony form false positives -->
        <MissingTemplateParam errorLevel="info" />

        <!-- Return-type specificity & redundant analysis -->
        <MoreSpecificReturnType errorLevel="info" />
        <LessSpecificReturnStatement errorLevel="info" />
        <RedundantCast errorLevel="info" />
        <TypeDoesNotContainType errorLevel="info" />
        <RedundantCondition errorLevel="info" />
        <RedundantFunctionCall errorLevel="info" />
        <NoValue errorLevel="info" />

        <!-- Doctrine performance hint — not a bug -->
        <QueryBuilderSetParameter errorLevel="info" />
    </issueHandlers>
</psalm>
